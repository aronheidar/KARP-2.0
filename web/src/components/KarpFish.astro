---
// ─────────────────────────────────────────────────────────────
// 🐟 KARP-FISKURINN (LOTA 19) — upprunalegt SVG-merki Karp: gylltur vatnakarpi
// (með veiðihárin sín tvö!) í Stellaris-stílnum. Notaður í nav, sem fljótandi
// „Spyrðu Karp"-hnappur á öllum síðum og sem hero á /spyrdu/.
// Hreyfingar (synd, blikk, bólur) stýrast af foreldra-CSS gegnum klasana
// .kf-body / .kf-eye / .kf-bubble — statískur án þeirra.
// ─────────────────────────────────────────────────────────────
const { size = 40 } = Astro.props;
---
<svg class="karpfish" width={size} height={size} viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g class="kf-body">
    <!-- sporður -->
    <path d="M78 50 L96 34 Q91 50 96 66 Z" fill="#c98a26"/>
    <!-- bakuggi -->
    <path d="M38 32 Q52 14 68 30 L60 38 Q48 30 42 36 Z" fill="#c98a26"/>
    <!-- kviðuggi -->
    <path d="M46 68 Q52 82 62 78 L56 66 Z" fill="#c98a26"/>
    <!-- búkur -->
    <ellipse cx="48" cy="50" rx="34" ry="21" fill="#f6b13b"/>
    <!-- hreistur (þrjár raðir af bogum) -->
    <g fill="none" stroke="#c98a26" stroke-width="1.6" opacity=".45">
      <path d="M36 40 q5 5 0 10 M48 38 q5 6 0 12 M60 40 q5 5 0 10"/>
      <path d="M42 52 q5 5 0 10 M54 52 q5 5 0 10 M66 50 q4 5 0 10"/>
    </g>
    <!-- haus-lína + tálkn -->
    <path d="M30 33 Q20 50 30 67" fill="none" stroke="#c98a26" stroke-width="2" opacity=".6"/>
    <!-- auga -->
    <g class="kf-eye">
      <circle cx="24" cy="45" r="5.2" fill="#0b1220"/>
      <circle cx="22.4" cy="43.4" r="1.7" fill="#eaf1fb"/>
    </g>
    <!-- munnur + veiðihár karpans -->
    <path d="M14.5 52 q3 2.4 6 1.6" fill="none" stroke="#0b1220" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M15 56 q-3 5 -7 5.5 M19 58 q-1 5 -4.5 7" fill="none" stroke="#c98a26" stroke-width="1.7" stroke-linecap="round"/>
  </g>
  <!-- bólur -->
  <g class="kf-bubbles" fill="none" stroke="#7fd0ff" stroke-width="1.4" opacity=".7">
    <circle class="kf-bubble b1" cx="12" cy="34" r="2.6"/>
    <circle class="kf-bubble b2" cx="7" cy="26" r="1.8"/>
    <circle class="kf-bubble b3" cx="15" cy="22" r="1.3"/>
  </g>
</svg>
