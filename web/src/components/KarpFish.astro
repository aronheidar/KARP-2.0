---
// ─────────────────────────────────────────────────────────────
// 🐟 KARP-FISKURINN (LOTA 19; endursmíðaður LOTA 50) — gylltur vatnakarpi með
// veiðihárin sín tvö, Stellaris-stíll. Horfir til VINSTRI (ákvörðun Arons 4.7.2026)
// — teikningin er náttúrulega vinstri-horfandi, engin speglun lengur.
//
// EITT HEIMILI ANIMATION-SAFNSINS: allar @keyframes og klasar búa HÉR (is:global)
// svo hver síða þurfi aldrei að skilgreina neitt sjálf. Notkun:
//   <KarpFish size={68} />                       → statískur fiskur
//   <div class="kf-anim"><KarpFish /></div>      → lifandi: synd + sporðaköst +
//                                                  uggaflökt + blikk + augnaráf +
//                                                  gúlp + bólur
//   <a class="kf-anim-hover"><KarpFish /></a>    → kviknar á sundi við hover (nav)
//   wrapper.classList.add('kf-roll')             → heljarstökk einu sinni (~1s,
//                                                  fjarlægja klasann eftir á)
//   .kf-anim--fast á wrapper                     → allt á tvöföldum hraða (hover-FAB)
// Öll hreyfing slokknar sjálfkrafa við prefers-reduced-motion.
// ─────────────────────────────────────────────────────────────
const { size = 40 } = Astro.props;
---
<svg class="karpfish" width={size} height={size} viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g class="kf-body">
    <!-- sporður -->
    <path class="kf-tail" d="M78 50 L96 34 Q91 50 96 66 Z" fill="#c98a26"/>
    <!-- bakuggi -->
    <path class="kf-fin-d" d="M38 32 Q52 14 68 30 L60 38 Q48 30 42 36 Z" fill="#c98a26"/>
    <!-- kviðuggi -->
    <path class="kf-fin-k" d="M46 68 Q52 82 62 78 L56 66 Z" fill="#c98a26"/>
    <!-- búkur -->
    <ellipse cx="48" cy="50" rx="34" ry="21" fill="#f6b13b"/>
    <!-- hreistur (þrjár raðir af bogum) -->
    <g fill="none" stroke="#c98a26" stroke-width="1.6" opacity=".45">
      <path d="M36 40 q5 5 0 10 M48 38 q5 6 0 12 M60 40 q5 5 0 10"/>
      <path d="M42 52 q5 5 0 10 M54 52 q5 5 0 10 M66 50 q4 5 0 10"/>
    </g>
    <!-- haus-lína + tálkn -->
    <path d="M30 33 Q20 50 30 67" fill="none" stroke="#c98a26" stroke-width="2" opacity=".6"/>
    <!-- auga (blikk skalar hópinn; ráfið færir sjáaldrið) -->
    <g class="kf-eye">
      <g class="kf-pupil">
        <circle cx="24" cy="45" r="5.2" fill="#0b1220"/>
        <circle cx="22.4" cy="43.4" r="1.7" fill="#eaf1fb"/>
      </g>
    </g>
    <!-- munnur + veiðihár karpans -->
    <path class="kf-mouth" d="M14.5 52 q3 2.4 6 1.6" fill="none" stroke="#0b1220" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M15 56 q-3 5 -7 5.5 M19 58 q-1 5 -4.5 7" fill="none" stroke="#c98a26" stroke-width="1.7" stroke-linecap="round"/>
  </g>
  <!-- bólur (fyrir framan trýnið — fiskurinn horfir til vinstri) -->
  <g class="kf-bubbles" fill="none" stroke="#7fd0ff" stroke-width="1.4" opacity=".7">
    <circle class="kf-bubble b1" cx="12" cy="34" r="2.6"/>
    <circle class="kf-bubble b2" cx="7" cy="26" r="1.8"/>
    <circle class="kf-bubble b3" cx="15" cy="22" r="1.3"/>
  </g>
</svg>

<style is:global>
  /* ── 🐟 Animation-safn karpans — EINA skilgreiningin í öllu appinu (LOTA 50) ──
     Allir hlutar nota transform-box/origin miðað við ÓSPEGLAÐA teikningu. */
  .karpfish .kf-eye, .karpfish .kf-pupil { transform-origin: 24px 45px; transform-box: view-box; }
  .karpfish .kf-tail { transform-origin: 79px 50px; transform-box: view-box; }
  .karpfish .kf-fin-d { transform-origin: 50px 34px; transform-box: view-box; }
  .karpfish .kf-fin-k { transform-origin: 50px 68px; transform-box: view-box; }
  .karpfish .kf-mouth { transform-origin: 17px 52px; transform-box: view-box; }
  .karpfish { transform-origin: 50px 50px; transform-box: view-box; }

  @keyframes kf-swim { 0%,100% { transform: translateY(0) rotate(0deg); } 30% { transform: translateY(-5px) rotate(-4deg); } 65% { transform: translateY(2px) rotate(3deg); } }
  @keyframes kf-blink { 0%, 91%, 100% { transform: scaleY(1); } 94%, 96% { transform: scaleY(.08); } }
  @keyframes kf-float { 0% { opacity: 0; transform: translateY(4px); } 25% { opacity: .8; } 100% { opacity: 0; transform: translateY(-14px); } }
  @keyframes kf-tailwag { 0%,100% { transform: rotate(0deg); } 25% { transform: rotate(9deg); } 75% { transform: rotate(-8deg); } }
  @keyframes kf-finflut { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(-7deg); } }
  @keyframes kf-glance { 0%, 54%, 100% { transform: translate(0,0); } 60%, 72% { transform: translate(-1.6px,.4px); } 78%, 90% { transform: translate(.9px,-.5px); } }
  @keyframes kf-gulp { 0%, 87%, 100% { transform: scale(1); } 92% { transform: scale(1.25) translateX(-.6px); } }
  @keyframes kf-roll { 0% { transform: rotate(0deg) scale(1); } 55% { transform: rotate(-330deg) scale(1.12); } 100% { transform: rotate(-360deg) scale(1); } }
  @keyframes kf-dart { 0% { transform: translateX(0) scaleX(1); } 35% { transform: translateX(-7px) scaleX(1.07); } 100% { transform: translateX(0) scaleX(1); } }

  /* Full-lifandi fiskurinn: <wrapper class="kf-anim"> */
  .kf-anim .karpfish { animation: kf-swim 3.8s ease-in-out infinite; }
  .kf-anim .kf-tail { animation: kf-tailwag 1.9s ease-in-out infinite; }
  .kf-anim .kf-fin-d { animation: kf-finflut 2.3s ease-in-out infinite; }
  .kf-anim .kf-fin-k { animation: kf-finflut 1.7s ease-in-out infinite reverse; }
  .kf-anim .kf-eye { animation: kf-blink 4.8s infinite; }
  .kf-anim .kf-pupil { animation: kf-glance 7s ease-in-out infinite; }
  .kf-anim .kf-mouth { animation: kf-gulp 5.6s ease-in-out infinite; }
  .kf-anim .kf-bubble { animation: kf-float 3.2s ease-in infinite; }
  .kf-anim .kf-bubble.b2 { animation-delay: 1.1s; }
  .kf-anim .kf-bubble.b3 { animation-delay: 2.2s; }
  /* Hraðstilling (t.d. hover á FAB): allt á ~tvöföldum hraða */
  .kf-anim--fast .karpfish { animation-duration: 1.6s; }
  .kf-anim--fast .kf-tail { animation-duration: .8s; }
  .kf-anim--fast .kf-fin-d, .kf-anim--fast .kf-fin-k { animation-duration: .9s; }
  /* Hover-kveikja (nav-merkið): kyrr þar til bent er á */
  .kf-anim-hover .karpfish { animation: none; }
  .kf-anim-hover:hover .karpfish { animation: kf-swim 1.8s ease-in-out infinite; }
  .kf-anim-hover:hover .kf-tail { animation: kf-tailwag 1s ease-in-out infinite; }
  /* Heljarstökk (einu sinni) og snögg-skot: bæta klasa á wrapper, fjarlægja eftir ~1s */
  .kf-roll .karpfish { animation: kf-roll .95s cubic-bezier(.45,.05,.35,1) 1; }
  .kf-dart .karpfish { animation: kf-dart .5s ease-out 1; }

  @media (prefers-reduced-motion: reduce) {
    .kf-anim .karpfish, .kf-anim .kf-tail, .kf-anim .kf-fin-d, .kf-anim .kf-fin-k,
    .kf-anim .kf-eye, .kf-anim .kf-pupil, .kf-anim .kf-mouth, .kf-anim .kf-bubble,
    .kf-anim-hover:hover .karpfish, .kf-anim-hover:hover .kf-tail,
    .kf-roll .karpfish, .kf-dart .karpfish { animation: none; }
  }
</style>
