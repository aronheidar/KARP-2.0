---
// AuthShell.astro — sameiginleg Karp-spjaldskel fyrir auðkenningarsíðurnar
// (/innskra/, /nyskraning/, /endurstilla/). Dökka Karp-þemað, gyllt spjaldkort.
// Síðan sjálf leggur til formið + skriftuna í sjálfgefna slot-ið; „alt"-slot-ið er
// neðsti kross-hlekkurinn undir spjaldinu.
//
// Öll CSS er is:global EN fest undir .karp-auth svo hún leki ekki á aðrar síður
// (Astro tré-hristir annars scoped-klasa sem birtast aðeins í keyrslutíma-innerHTML
// — sjá [[karp-deploy-cdn]]; hér er markup að vísu static en is:global er öruggast).
const { heading = '', sub = '', pg = 'auth' } = Astro.props;
---
<main class="karp-auth" data-pg={pg}>
  <div class="ka-logo"><a href="/">KARP</a></div>
  <div class="ka-card">
    <p class="ka-kicker">Karp · Aðgangur</p>
    <h1 class="ka-h">{heading}</h1>
    {sub && <p class="ka-sub">{sub}</p>}
    <slot />
  </div>
  <div class="ka-alt"><slot name="alt" /></div>
</main>

<style is:global>
  main.karp-auth { max-width: 470px; margin: 30px auto; padding: 0 20px 64px; }
  main.karp-auth .ka-logo { text-align: center; margin-bottom: 14px; }
  main.karp-auth .ka-logo a { font-weight: 800; letter-spacing: .24em; color: #f6b13b; text-decoration: none; font-size: 20px; }
  main.karp-auth .ka-card { background: rgba(255,255,255,.04); border: 1px solid rgba(246,177,59,.35); border-radius: 18px; padding: 30px 28px 32px; }
  main.karp-auth .ka-kicker { text-align: center; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 6px; }
  main.karp-auth .ka-h { text-align: center; font-size: 24px; color: #eaf1fb; margin: 0 0 8px; }
  main.karp-auth .ka-sub { text-align: center; color: #cdd6e6; font-size: 14px; line-height: 1.55; margin: 0 0 20px; }
  main.karp-auth .ka-sub a { color: #f6b13b; text-decoration: none; }

  /* Skilaboð (villa / árangur) — falin þar til JS sýnir þau (global [hidden] í Layout.astro). */
  main.karp-auth .ka-msg { border-radius: 11px; padding: 11px 14px; font-size: 13.5px; line-height: 1.5; margin: 0 0 16px; }
  main.karp-auth .ka-msg.err { background: rgba(244,63,94,.1); border: 1px solid rgba(244,63,94,.42); color: #fecdd3; }
  main.karp-auth .ka-msg.ok { background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.42); color: #bbf7d0; }

  /* Reitir */
  main.karp-auth .ka-field { margin-bottom: 14px; }
  main.karp-auth .ka-field label { display: block; font-size: 13px; color: #cdd6e6; font-weight: 600; margin-bottom: 6px; }
  main.karp-auth input[type=text], main.karp-auth input[type=email], main.karp-auth input[type=password] {
    width: 100%; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14);
    border-radius: 10px; padding: 11px 13px; color: #eaf1fb; font-size: 15px; }
  main.karp-auth input[type=text]:focus, main.karp-auth input[type=email]:focus, main.karp-auth input[type=password]:focus {
    outline: none; border-color: rgba(246,177,59,.55); }

  /* Röð: „muna eftir mér" + „gleymt lykilorð?" */
  main.karp-auth .ka-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 2px 0 18px; font-size: 13px; flex-wrap: wrap; }
  main.karp-auth .ka-check { display: flex; align-items: center; gap: 7px; color: #cdd6e6; cursor: pointer; }
  main.karp-auth .ka-check input { width: auto; }
  main.karp-auth a.ka-link { color: #f6b13b; text-decoration: none; }
  main.karp-auth a.ka-link:hover { text-decoration: underline; }

  /* Skilmála-gátreitur (nýskráning) */
  main.karp-auth .ka-terms { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; color: #cdd6e6; line-height: 1.45; margin: 2px 0 18px; }
  main.karp-auth .ka-terms input { width: auto; margin-top: 3px; flex: none; }
  main.karp-auth .ka-terms a { color: #f6b13b; text-decoration: none; }

  /* Aðal-hnappur */
  main.karp-auth .ka-btn { display: block; width: 100%; background: #f6b13b; color: #131a29; font-weight: 800; font-size: 15px; text-align: center; border: 0; border-radius: 11px; padding: 13px; cursor: pointer; }
  main.karp-auth .ka-btn:hover { filter: brightness(1.07); }
  main.karp-auth .ka-btn:disabled { opacity: .6; cursor: wait; }

  /* Neðanmáls-nóta + neðsti kross-hlekkur */
  main.karp-auth .ka-note { font-size: 12px; color: #7e8ca6; line-height: 1.5; margin: 14px 0 0; text-align: center; }
  main.karp-auth .ka-alt { text-align: center; margin-top: 18px; font-size: 13.5px; color: #9fb0c8; }
  main.karp-auth .ka-alt a { color: #f6b13b; text-decoration: none; font-weight: 600; }

  /* „Þú ert þegar innskráð(ur)" staða */
  main.karp-auth .ka-in { text-align: center; }
  main.karp-auth .ka-in p { color: #cdd6e6; font-size: 14.5px; margin: 0 0 16px; }
  main.karp-auth .ka-in .ka-btn { display: inline-block; width: auto; padding: 11px 22px; text-decoration: none; }
</style>
