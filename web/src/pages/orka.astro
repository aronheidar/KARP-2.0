---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Orka: raforkuframleiðsla Íslands 1969–2024 (orka.json),
// heildarferill + uppruna-sundurliðun (frá 1992). Í app-skelinni (Layout). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import ORKA from '@gogn/orka.json';

const rows = ORKA.rows || [];
const latest = rows[rows.length - 1] || {};
const renew = latest.total ? ((latest.hydro || 0) + (latest.geo || 0) + (latest.wind || 0) + (latest.solar || 0)) / latest.total * 100 : 0;
const POP = 395000; // ~íbúafjöldi (nálgun fyrir MWh/íbúa)
const perCapita = latest.total ? (latest.total * 1000) / POP : 0; // GWh→MWh / íbúar

const totalSeries = rows.map((r) => r.total);
const years = rows.map((r) => r.y);
const srcRows = rows.filter((r) => r.hydro != null);
const srcYears = srcRows.map((r) => r.y);
const srcData = {
  hydro: srcRows.map((r) => r.hydro),
  geo: srcRows.map((r) => r.geo),
  fuel: srcRows.map((r) => r.fuel),
  wind: srcRows.map((r) => r.wind),
  solar: srcRows.map((r) => r.solar),
};

const updated = '2026-07-01';
const desc = `Raforkuframleiðsla á Íslandi — ${groupThousands(Math.round(latest.total))} GWh árið ${latest.y}, ${fmtNum(renew, 2)}% endurnýjanleg (vatnsafl + jarðvarmi). Þróun frá 1969 og sundurliðun eftir orkugjafa.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: 'Raforkuframleiðsla á Íslandi',
  description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Raforkuframleiðsla (GWh)',
};
---

<Layout title="Orka — raforkuframleiðsla | Karp" description={desc} canonical="https://app.karp.is/orka/" jsonLd={jsonLd} ogTitle="Raforka á Íslandi">
  <main data-pg="orka">
    <p class="kicker">Hagvísir Íslands · Orka</p>
    <h1>Raforka á Íslandi</h1>
    <p>Raforkuframleiðsla árið {latest.y} var <strong>{groupThousands(Math.round(latest.total))} GWh</strong> — {fmtNum(renew, 2)}% endurnýjanleg. Heimild: Orkustofnun.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Orkutölur: raforkuframleiðsla og -notkun frá Orkustofnun (opin gagnasöfn) og kerfisgögn Landsnets.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      <div class="kpi"><div class="k-l">⚡ Heildarframleiðsla</div><div class="k-v">{groupThousands(Math.round(latest.total))}</div><div class="k-s">GWh · {latest.y}</div></div>
      <div class="kpi"><div class="k-l">🌿 Endurnýjanlegt</div><div class="k-v">{fmtNum(renew, 2)}%</div><div class="k-s">vatnsafl + jarðvarmi</div></div>
      <div class="kpi"><div class="k-l">👤 Á íbúa</div><div class="k-v">{fmtNum(perCapita, 0)}</div><div class="k-s">MWh (heimsmet)</div></div>
    </div>

    <div id="orka-live" hidden>
      <h2>⚡ Framleiðsla núna</h2>
      <div class="live-row" id="orka-live-row"></div>
      <p class="srcnote" id="orka-live-ts"></p>
    </div>

    <div class="ppair">
      <div>
        <h2>Heildarframleiðsla 1969–{latest.y}</h2>
        <div id="chart-total"></div>
      </div>
      <div>
        <h2>Eftir orkugjafa (frá 1992)</h2>
        <div id="chart-src"></div>
      </div>
    </div>

    <p class="note">ⓘ Sundurliðun eftir orkugjafa fæst frá 1992; heildartala frá 1969. Ísland framleiðir nær alla raforku með vatnsafli (~70%) og jarðvarma (~30%); jarðefnaeldsneyti er hverfandi.</p>
    <p class="foot">Forþjónað (SSG) {updated}. Heimild: Orkustofnun (raforkuþróun). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 26px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #chart-total, #chart-src { width: 100%; height: 320px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }

    .live-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; }
    .srcnote { font-size: 12px; color: #7e8ca6; margin: 6px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: heildarferill + uppruna-stöflun, astro:page-load. #2 -->
  <script define:vars={{ years, totalSeries, srcYears, srcData }}>
    function initCharts() {
      const ct = document.getElementById('chart-total');
      if (!ct) return;
      const go = () => {
        const cs = document.getElementById('chart-src');
        if (!window.echarts.getInstanceByDom(ct)) {
          const c = window.echarts.init(ct);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 52, right: 16, top: 12, bottom: 26 },
            xAxis: { type: 'category', data: years, axisLabel: { color: '#7e8ca6' }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => Math.round(v) + ' GWh' },
            series: [{ type: 'line', data: totalSeries, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#f6b13b' }, areaStyle: { opacity: 0.14, color: '#f6b13b' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        if (cs && !window.echarts.getInstanceByDom(cs)) {
          const c = window.echarts.init(cs);
          const src = [
            { name: 'Vatnsafl', data: srcData.hydro, color: '#3a8dff' },
            { name: 'Jarðvarmi', data: srcData.geo, color: '#f6b13b' },
            { name: 'Vindur', data: srcData.wind, color: '#46e08a' },
            { name: 'Eldsneyti', data: srcData.fuel, color: '#ff6d7a' },
            { name: 'Sól', data: srcData.solar, color: '#7c5cf7' },
          ];
          c.setOption({
            backgroundColor: 'transparent', legend: { data: src.map((s) => s.name), textStyle: { color: '#9fb0c8' }, top: 0 },
            grid: { left: 52, right: 16, top: 34, bottom: 26 },
            xAxis: { type: 'category', data: srcYears, axisLabel: { color: '#7e8ca6' }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => Math.round(v) + ' GWh' },
            series: src.map((s) => ({ name: s.name, type: 'line', stack: 'orka', data: s.data, smooth: true, symbol: 'none', lineStyle: { width: 0 }, areaStyle: { color: s.color, opacity: 0.75 }, itemStyle: { color: s.color } })),
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="orka"]')) initCharts(); });
  </script>

  <!-- Eyja: lifandi framleiðsla (Landsnet gegnum karp-orka.php proxy). Felst ef ekki tiltækt (CORS/localhost). #2 -->
  <script>
    function initLive() {
      const box = document.getElementById('orka-live');
      if (!box || box.dataset.done) return;
      fetch('https://karp.is/wp-json/karp/v1/orka')
        .then((r) => (r.ok ? r.json() : Promise.reject()))
        .then((d) => {
          const mw = (v) => (v == null ? null : Math.round(v));
          const parts = [
            { l: '💧 Vatnsafl', v: mw(d.hydro) },
            { l: '🌋 Jarðvarmi', v: mw(d.geothermal) },
            { l: '🛢️ Eldsneyti', v: mw(d.oil) },
          ].filter((p) => p.v != null);
          if (!parts.length) return;
          const total = parts.reduce((s, p) => s + p.v, 0);
          const row = document.getElementById('orka-live-row');
          row.innerHTML = [{ l: '⚡ Alls', v: total }, ...parts].map((p) => `<div class="kpi"><div class="k-l">${p.l}</div><div class="k-v">${String(p.v).replace(/\B(?=(\d{3})+(?!\d))/g, '.')}</div><div class="k-s">MW núna</div></div>`).join('');
          document.getElementById('orka-live-ts').textContent = 'Rauntímagögn frá Landsnet' + (d.timestamp ? ' · ' + d.timestamp : '') + ' — birtast aðeins á app.karp.is.';
          box.hidden = false;
          box.dataset.done = '1';
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="orka"]')) initLive(); });
  </script>
</Layout>
