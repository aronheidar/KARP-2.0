---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Rafbílar & bílafloti: heildarFLOTI (árslok) eftir orkugjafa
// (SAM30120 — ökutæki eru undir Umhverfi, EKKI Atvinnuvegir!) + rafvæðingar-%.
// Gögn: daglegt snapshot úr skriptur/build_rafbilar.mjs → gogn/rafbilar.json
// (áður sótt beint á Hagstofu í frontmatter á hverri byggingu → seigla + saga). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import DATA from '@gogn/rafbilar.json';

const { CARS, updated } = DATA;
const desc = `Rafbílar og bílafloti Íslands${CARS ? ` — ${groupThousands(CARS.bev)} hreinir rafbílar, rafvæðing ${fmtNum(CARS.rafPct, 1)}% af ${groupThousands(CARS.total)} bíla flota (${CARS.lastY})` : ''}. Þróun flotans eftir orkugjafa.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Rafbílar og bílafloti Íslands', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Fjöldi ökutækja eftir orkugjafa' };
---

<Layout title="Rafbílar & bílafloti | Karp" description={desc} canonical="https://karp.is/rafbilar/" jsonLd={jsonLd} ogTitle="Rafbílar á Íslandi">
  <main data-pg="rafbilar">
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Rafbílar &amp; bílafloti</h1>
    <p>Heildarfloti fólksbíla í árslok eftir orkugjafa — bensín og dísil á móti rafmagni, tengiltvinn og tvinn. Heimild: Hagstofa Íslands (skráð ökutæki).</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Bílaflotatölur: nýskráningar og samsetning flotans úr tölum Samgöngustofu (um Hagstofu).">ⓘ</i> Um gögnin á síðunni</p>

    {CARS && (
      <div class="kpis">
        <div class="kpi"><div class="k-l">⚡ Hreinir rafbílar</div><div class="k-v">{groupThousands(CARS.bev)}</div><div class="k-s">BEV · {CARS.lastY}</div></div>
        <div class="kpi"><div class="k-l">🔌 Rafvæðing</div><div class="k-v">{fmtNum(CARS.rafPct, 1)}%</div><div class="k-s">BEV + PHEV af flota</div></div>
        <div class="kpi"><div class="k-l">🚗 Floti alls</div><div class="k-v">{groupThousands(CARS.total)}</div><div class="k-s">ökutæki · {CARS.lastY}</div></div>
      </div>
    )}

    {CARS && (
      <>
        <div class="ppair">
          <div>
            <h2>Rafvæðing flotans</h2>
            <div id="chart-raf"></div>
          </div>
          <div>
            <h2>Flotinn eftir orkugjafa</h2>
            <div id="chart-fleet"></div>
          </div>
        </div>
      </>
    )}

    <p class="note">ⓘ Tölurnar sýna <strong>heildarflota</strong> í árslok (ekki nýskráningar) — rafvæðingin birtist því hægar en í sölutölum. BEV = hreinn rafbíll, PHEV = tengiltvinn.</p>
    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Heimild: Hagstofa (SAM30120). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: var(--ink); }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .note { font-size: 13px; color: var(--muted); background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: var(--muted); }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: var(--faint); }
    #chart-raf { width: 100%; height: 250px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }

    #chart-fleet { width: 100%; height: 330px; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: rafvæðingar-% + stöfluð floti. astro:page-load. #2 -->
  <script define:vars={{ CARS }}>
    function initCharts() {
      if (!document.getElementById('chart-raf')) return;
      const go = () => {
        const cr = document.getElementById('chart-raf');
        if (cr && CARS && !window.echarts.getInstanceByDom(cr)) {
          const c = window.echarts.init(cr);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 42, right: 14, top: 14, bottom: 24 },
            xAxis: { type: 'category', data: CARS.years, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v.toFixed(1).replace('.', ',') + '%') },
            series: [{ type: 'line', data: CARS.raf, smooth: true, symbol: 'circle', symbolSize: 4, lineStyle: { width: 3, color: '#46e08a' }, itemStyle: { color: '#46e08a' }, areaStyle: { opacity: 0.14, color: '#46e08a' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cf = document.getElementById('chart-fleet');
        if (cf && CARS && !window.echarts.getInstanceByDom(cf)) {
          const c = window.echarts.init(cf);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: CARS.series.map((s) => s.name), textStyle: { color: '#9fb0c8', fontSize: 10.5 }, top: 0, type: 'scroll' },
            grid: { left: 56, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: CARS.years, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: (v) => v / 1000 + 'þ' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.')) },
            series: CARS.series.map((s) => ({ name: s.name, type: 'line', stack: 'fleet', data: s.data, smooth: true, symbol: 'none', lineStyle: { width: 0 }, areaStyle: { color: s.color, opacity: 0.8 }, itemStyle: { color: s.color } })),
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="rafbilar"]')) initCharts(); });
  </script>
</Layout>
