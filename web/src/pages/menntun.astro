---
// ─────────────────────────────────────────────────────────────
// Menntun (auðgað) — menntunarstaða 25–64 (SKO00002) + eftir kyni,
// fjöldi nemenda eftir skólastigi (SKO00000), brautskráning háskóla eftir sviði (SKO04205),
// fræðsluútgjöld % af VLF (THJ05631), kostnaður á nemanda (THJ05661), PISA Norðurlönd (OECD 2022).
// Byggingartíma-PxWeb (þolir bilun per hluta). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';

const px = async (path, query) => {
  const call = async () => (await fetch('https://px.hagstofa.is/pxis/api/v1/is/' + path, { method: 'POST', body: JSON.stringify({ query, response: { format: 'json' } }) })).json();
  try { return await call(); } catch (e) { await new Promise((r) => setTimeout(r, 1500)); return call(); }
};
const sel = (code, filter, values) => ({ code, selection: { filter, values } });
const num = (v) => { const n = parseFloat(String(v).replace(',', '.')); return isNaN(n) ? null : n; };

// 1. Menntunarstaða 25–64 (SKO00002) — þróun + eftir kyni ------------------
const ISCED = { 'ISCED 1, 2': ['Grunnmenntun', '#ff8a3d'], 'ISCED 3, 4': ['Framhaldsskólastig', '#3a8dff'], 'ISCED 5, 6, 7, 8': ['Háskólastig', '#46e08a'] };
const LVLS = Object.keys(ISCED);
let C_edu = null, C_sex = null, uniPct = null, uniY = null, uniK = null, uniM = null, sexY = null;
try {
  const [aj, sj] = await Promise.all([
    px('Samfelag/skolamal/5_menntunarstada/SKO00002.px', [sel('Kyn', 'item', ['Alls']), sel('Aldursflokkur/búseta', 'item', ['25-64']), sel('Menntun', 'item', LVLS)]),
    px('Samfelag/skolamal/5_menntunarstada/SKO00002.px', [sel('Kyn', 'item', ['1', '2']), sel('Aldursflokkur/búseta', 'item', ['25-64']), sel('Menntun', 'item', LVLS)]),
  ]);
  const byLvl = {};
  aj.data.forEach((d) => { const t = d.key.find((k) => /^\d{4}$/.test(k)); const l = d.key.find((k) => ISCED[k]); const v = num(d.values[0]); if (t && l && v != null) (byLvl[l] = byLvl[l] || {})[t] = v; });
  const years = [...new Set(Object.values(byLvl).flatMap((m) => Object.keys(m)))].sort();
  if (years.length) {
    C_edu = { x: years, u: '%', stack: true, max: 100, pct: true, series: LVLS.map((l) => ({ name: ISCED[l][0], color: ISCED[l][1], data: years.map((y) => byLvl[l]?.[y] ?? null) })) };
    uniY = years[years.length - 1];
    uniPct = byLvl['ISCED 5, 6, 7, 8']?.[uniY] ?? null;
  }
  const sx = { 1: {}, 2: {} };
  sj.data.forEach((d) => { const t = d.key.find((k) => /^\d{4}$/.test(k)); const kyn = d.key.includes('1') && !d.key.includes('2') ? '1' : d.key.includes('2') ? '2' : null; const l = d.key.find((k) => ISCED[k]); const v = num(d.values[0]); if (t && kyn && l && v != null) ((sx[kyn][t] = sx[kyn][t] || {})[l] = v); });
  const yrs = Object.keys(sx[1]).filter((y) => sx[2][y]).sort();
  sexY = yrs[yrs.length - 1];
  if (sexY) {
    C_sex = { kind: 'hbar', u: '%', max: 100, pct: true, showLabel: true, gridLeft: 132, x: LVLS.map((l) => ISCED[l][0]), series: [
      { name: 'Konur', color: '#c95cf7', data: LVLS.map((l) => sx[2][sexY][l] ?? null) },
      { name: 'Karlar', color: '#3a8dff', data: LVLS.map((l) => sx[1][sexY][l] ?? null) },
    ] };
    uniK = sx[2][sexY]['ISCED 5, 6, 7, 8'] ?? null; uniM = sx[1][sexY]['ISCED 5, 6, 7, 8'] ?? null;
  }
} catch (e) {}

// 2. Fjöldi nemenda eftir skólastigi (SKO00000) ----------------------------
let C_enroll = null, haskN = null, totN = null, enrollY = null;
try {
  const j = await px('Samfelag/skolamal/0_yfirlit/yfirlit/SKO00000.px', [sel('Skólastig', 'item', ['1', '2', '3', '4', '5', '6']), sel('Kyn', 'item', ['Alls']), sel('Ár', 'all', ['*'])]);
  const FOLD = { 1: 0, 2: 1, 3: 2, 4: 2, 5: 3, 6: 3 };
  const GROUPS = ['Leikskóli', 'Grunnskóli', 'Framhalds- & viðbótarstig', 'Háskóla- & doktorsstig'];
  const GCOL = ['#46e08a', '#3a8dff', '#f6b13b', '#c95cf7'];
  const by = {};
  j.data.forEach((d) => { const y = d.key.find((k) => /^\d{4}$/.test(k)); const st = d.key.find((k) => k.length === 1 && FOLD[k] != null); const v = num(d.values[0]); if (y && st && v != null) { const gi = FOLD[st]; (by[gi] = by[gi] || {})[y] = (by[gi][y] || 0) + v; } });
  const years = [...new Set(Object.values(by).flatMap((o) => Object.keys(o)))].sort();
  while (years.length && [0, 1, 2, 3].some((i) => by[i]?.[years[years.length - 1]] == null)) years.pop(); // sleppa ófullgerðu nýjasta ári (t.d. leikskólatölur ekki komnar)
  if (years.length) {
    C_enroll = { x: years, u: 'nemendur', stack: true, series: GROUPS.map((g, i) => ({ name: g, color: GCOL[i], data: years.map((y) => by[i]?.[y] ?? null) })) };
    enrollY = years[years.length - 1];
    haskN = by[3]?.[enrollY] ?? null;
    totN = [0, 1, 2, 3].reduce((s, i) => s + (by[i]?.[enrollY] || 0), 0);
  }
} catch (e) {}

// 3. Brautskráning á háskólastigi eftir sviði (SKO04205) --------------------
const SVID = { 1: 'Menntun', 2: 'Hugvísindi og listir', 3: 'Félagsvís., viðskipti, lögfr.', 4: 'Raunvís., stærðfr., tölvun.', 5: 'Verkfræði & mannvirki', 6: 'Landbúnaður & dýralækn.', 7: 'Heilbrigði & velferð', 8: 'Þjónusta' };
let C_field = null, fieldY = null, gradTot = null;
try {
  const j = await px('Samfelag/skolamal/4_haskolastig/1_hsProf/SKO04205.px', [sel('Svið', 'item', Object.keys(SVID)), sel('Prófgráða', 'item', ['Alls']), sel('Kyn', 'item', ['Alls']), sel('Ár', 'top', ['1'])]);
  const by = {};
  j.data.forEach((d) => { const sv = d.key.find((k) => SVID[k]); const v = num(d.values[0]); if (sv && v != null) by[sv] = v; if (!fieldY) { const yr = d.key.find((k) => /^\d{4}-\d{4}$/.test(k)); if (yr) fieldY = yr; } });
  const rows = Object.keys(SVID).filter((k) => by[k] != null).map((k) => [SVID[k], by[k]]).sort((a, b) => b[1] - a[1]);
  if (rows.length) {
    C_field = { kind: 'hbar', u: 'brautskráðir', gridLeft: 168, showLabel: true, x: rows.map((r) => r[0]), series: [{ name: 'Brautskráðir ' + (fieldY || ''), color: '#46e08a', data: rows.map((r) => r[1]) }] };
    gradTot = rows.reduce((s, r) => s + r[1], 0);
  }
} catch (e) {}

// 4. Fræðsluútgjöld % af VLF (THJ05631) ------------------------------------
let C_spend = null, spendPct = null, spendY = null;
try {
  const j = await px('Efnahagur/fjaropinber/fjarmal_fraedsla/1_utgjold_fraedsla/THJ05631.px', [sel('Skipting', 'item', ['5', '7']), sel('Ár', 'all', ['*'])]);
  const b5 = {}, b7 = {};
  j.data.forEach((d) => { const y = d.key.find((k) => /^\d{4}$/.test(k)); const s = d.key.find((k) => k === '5' || k === '7'); const v = num(d.values[0]); if (y && s && v != null) (s === '5' ? b5 : b7)[y] = v; });
  const years = [...new Set([...Object.keys(b5), ...Object.keys(b7)])].sort();
  if (years.length) {
    C_spend = { x: years, u: '% af VLF', pct: true, series: [
      { name: 'Hið opinbera', color: '#3a8dff', data: years.map((y) => b5[y] ?? null) },
      { name: 'Alls (m. heimilum)', color: '#f6b13b', data: years.map((y) => b7[y] ?? null) },
    ] };
    spendY = years[years.length - 1]; spendPct = b5[spendY] ?? null;
  }
} catch (e) {}

// 5. Kostnaður á nemanda eftir skólastigi (THJ05661, þús.kr) ---------------
let C_cost = null, costHask = null, costY = null;
try {
  const j = await px('Efnahagur/fjaropinber/fjarmal_fraedsla/1_utgjold_fraedsla/THJ05661.px', [sel('Skipting', 'all', ['*']), sel('Ár', 'top', ['1'])]);
  const map = [['11 Pre-primary', 'Leikskóli', '#46e08a'], ['12 Primary', 'Barnaskóli', '#3a8dff'], ['22 Upper-secondary', 'Framhaldsskóli', '#f6b13b'], ['University', 'Háskóli', '#c95cf7']];
  const got = {};
  j.data.forEach((d) => { const y = d.key.find((k) => /^\d{4}$/.test(k)); const sk = d.key.find((k) => k !== y); const v = num(d.values[0]); if (!costY && y) costY = y; if (sk && v != null) map.forEach(([m], i) => { if (sk.includes(m)) got[i] = v; }); });
  if (Object.keys(got).length) {
    C_cost = { kind: 'bar', u: 'þús.kr', showLabel: true, x: map.map((m) => m[1]), series: [{ name: 'Kostnaður á nemanda ' + (costY || ''), color: '#f6b13b', data: map.map((m, i) => got[i] ?? null) }] };
    costHask = got[3] ?? null;
  }
} catch (e) {}

// 6. PISA Norðurlönd (OECD PISA 2022) — birt heimild ------------------------
const C_pisa = { kind: 'bar', u: 'stig', min: 400, x: ['Lesskilningur', 'Stærðfræði', 'Náttúrufræði'], series: [
  { name: 'Ísland', color: '#f6b13b', data: [436, 459, 447] },
  { name: 'Danmörk', color: '#e8436f', data: [489, 489, 494] },
  { name: 'Noregur', color: '#3a8dff', data: [477, 468, 478] },
  { name: 'Svíþjóð', color: '#46e08a', data: [487, 482, 485] },
  { name: 'Finnland', color: '#c95cf7', data: [490, 484, 511] },
] };

const updated = '2026-07-10';
const desc = `Menntun á Íslandi${uniPct != null ? ' — ' + fmtNum(uniPct, 0) + '% með háskólamenntun (25–64 ára)' : ''}${haskN ? ', ' + groupThousands(haskN) + ' háskólanemar' : ''}. Menntunarstaða, nemendafjöldi, brautskráningar eftir sviði, fræðsluútgjöld, kostnaður á nemanda og PISA-samanburður Norðurlanda.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Menntun á Íslandi', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Menntunarstaða, nemendafjöldi, brautskráningar, fræðsluútgjöld' };
---
<Layout title="Menntun — menntunarstaða, nemendur & PISA | Karp" description={desc} canonical="https://karp.is/menntun/" jsonLd={jsonLd} ogTitle="Menntun á Íslandi">
  <main data-pg="menntun">
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Menntun 🎓</h1>
    <p>Frá menntunarstöðu þjóðar til nemendafjölda, brautskráninga eftir fræðasviði, opinberra fræðsluútgjalda og PISA-samanburðar við hin Norðurlöndin. Heimildir: Hagstofa Íslands og OECD.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Menntunartölur: menntunarstaða, skólahald og brautskráningar Hagstofunnar (SKO), fræðsluútgjöld hins opinbera (THJ056xx) og PISA-niðurstöður OECD 2022.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      {uniPct != null && <div class="kpi"><div class="k-l">🎓 Háskólamenntun</div><div class="k-v">{fmtNum(uniPct, 0)}%</div><div class="k-s">25–64 ára · {uniY}</div></div>}
      {haskN && <div class="kpi"><div class="k-l">👩‍🎓 Háskólanemar</div><div class="k-v">{groupThousands(haskN)}</div><div class="k-s">skráðir · {enrollY}</div></div>}
      {gradTot && <div class="kpi"><div class="k-l">📜 Brautskráðir háskóla</div><div class="k-v">{groupThousands(gradTot)}</div><div class="k-s">{fieldY}</div></div>}
      {spendPct != null && <div class="kpi"><div class="k-l">💸 Fræðsluútgjöld</div><div class="k-v">{fmtNum(spendPct, 1)}%</div><div class="k-s">hins opinbera, af VLF · {spendY}</div></div>}
      {costHask != null && <div class="kpi"><div class="k-l">💰 Kostn./háskólanema</div><div class="k-v">{fmtNum(costHask / 1000, 1)}</div><div class="k-s">m.kr á ári · {costY}</div></div>}
    </div>

    <div class="ppair">
      {C_edu && <div><h2>Þróun menntunarstöðu (25–64 ára)</h2><div id="cEdu"></div></div>}
      {C_sex && <div><h2>Menntunarstaða eftir kyni ({sexY})</h2><div id="cSex"></div></div>}
    </div>
    <div class="ppair">
      {C_enroll && <div><h2>Fjöldi nemenda eftir skólastigi</h2><div id="cEnroll"></div></div>}
      {C_field && <div><h2>Brautskráningar háskóla eftir fræðasviði ({fieldY})</h2><div id="cField"></div></div>}
    </div>
    <div class="ppair">
      {C_spend && <div><h2>Fræðsluútgjöld sem hlutfall af VLF</h2><div id="cSpend"></div></div>}
      {C_cost && <div><h2>Kostnaður á hvern nemanda eftir skólastigi ({costY})</h2><div id="cCost"></div></div>}
    </div>

    <h2>PISA — Ísland vs. Norðurlöndin (OECD 2022)</h2>
    <p class="pisanote">Meðaltal 15 ára nemenda í könnun OECD. Til viðmiðunar var meðaltal OECD-ríkja 476 (lesskilningur), 472 (stærðfræði) og 485 (náttúrufræði). Ísland mælist undir hinum Norðurlöndunum í öllum þremur greinum.</p>
    <div id="cPisa"></div>

    <p class="foot">Forþjónað (SSG) {updated}. Heimildir: Hagstofa (SKO00002 menntunarstaða, SKO00000 nemendafjöldi, SKO04205 brautskráningar, THJ05631 fræðsluútgjöld, THJ05661 kostnaður á nemanda) og OECD (PISA 2022). ISCED 1–2 = grunnmenntun · 3–4 = framhaldsskólastig · 5–8 = háskólastig. #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; } p a { color: #f6b13b; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    #cEdu, #cSex, #cEnroll, #cField, #cSpend, #cCost { width: 100%; height: 300px; }
    #cPisa { width: 100%; height: 340px; }
    .pisanote { font-size: 13px; color: #9fb0c8; margin: 0 0 8px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <script define:vars={{ charts: { cEdu: C_edu, cSex: C_sex, cEnroll: C_enroll, cField: C_field, cSpend: C_spend, cCost: C_cost, cPisa: C_pisa } }}>
    function initM() {
      const ids = Object.keys(charts);
      if (!ids.some((id) => document.getElementById(id))) return;
      const go = () => {
        ids.forEach((id) => {
          const el = document.getElementById(id); const C = charts[id];
          if (!el || !C || window.echarts.getInstanceByDom(el)) return;
          const horiz = C.kind === 'hbar'; const isBar = horiz || C.kind === 'bar';
          const catAxis = { type: 'category', data: C.x, inverse: horiz, axisLabel: { color: '#9fb0c8', fontSize: horiz ? 11 : 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } }, axisTick: { show: !horiz } };
          const valAxis = { type: 'value', max: C.max, min: C.min, axisLabel: { color: '#7e8ca6', formatter: C.pct ? '{value}%' : undefined }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } };
          const c = window.echarts.init(el);
          c.setOption({
            backgroundColor: 'transparent',
            legend: C.series.length > 1 ? { data: C.series.map((s) => s.name), textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0, type: 'scroll' } : undefined,
            grid: { left: horiz ? (C.gridLeft || 130) : 48, right: horiz ? 52 : 14, top: C.series.length > 1 ? 32 : 12, bottom: 24 },
            xAxis: horiz ? valAxis : catAxis,
            yAxis: horiz ? catAxis : valAxis,
            tooltip: { trigger: 'axis', axisPointer: { type: isBar ? 'shadow' : 'line' }, valueFormatter: (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ',') + ' ' + C.u) },
            series: C.series.map((s) => ({
              name: s.name, type: isBar ? 'bar' : 'line', stack: C.stack ? 'st' : undefined, data: s.data, smooth: isBar ? false : true, symbol: 'none', barMaxWidth: horiz ? 13 : 24,
              label: C.showLabel ? { show: true, position: horiz ? 'right' : 'top', color: '#9fb0c8', fontSize: 10, formatter: (p) => (p.value == null ? '' : String(Math.round(p.value)).replace(/\B(?=(\d{3})+(?!\d))/g, '.')) } : undefined,
              lineStyle: { width: C.stack || isBar ? 0 : 2.5, color: s.color },
              itemStyle: { color: s.color, borderRadius: isBar ? (horiz ? [0, 3, 3, 0] : [3, 3, 0, 0]) : 0 },
              areaStyle: (C.area || C.stack) && !isBar ? { color: s.color, opacity: C.stack ? 0.8 : 0.14 } : undefined,
            })),
          });
          window.addEventListener('resize', () => c.resize());
        });
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="menntun"]')) initM(); });
  </script>
</Layout>
