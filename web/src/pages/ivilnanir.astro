---
// ─────────────────────────────────────────────────────────────
// Ívilnanir & styrkir (#2 LOTA 7) — 53 ívilnana-/styrkjaleiðir ríkisins
// (ivilnanir.json), flokkaðar og með stöðu. Eins og gamli Alþingis-flipinn.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import ThingTabs from '../components/ThingTabs.astro';
import IVILNANIR from '@gogn/ivilnanir.json';

const FLOKKAR = { atvinnulif: ['🏭', 'Atvinnulíf'], nyskopun: ['🔬', 'Nýsköpun & rannsóknir'], orkuskipti: ['⚡', 'Orkuskipti & umhverfi'], husnaedi: ['🏠', 'Húsnæði'], heimili: ['👨‍👩‍👧', 'Heimili & einstaklingar'], menning: ['🎭', 'Menning & listir'], byggd: ['🌄', 'Byggðamál'], annad: ['📦', 'Annað'] };
const groups = {};
(Array.isArray(IVILNANIR) ? IVILNANIR : []).forEach((x) => {
  const f = FLOKKAR[x.flokkur] ? x.flokkur : 'annad';
  (groups[f] = groups[f] || []).push(x);
});
const order = Object.keys(FLOKKAR).filter((f) => groups[f]?.length);
const total = (Array.isArray(IVILNANIR) ? IVILNANIR : []).length;
const active = (Array.isArray(IVILNANIR) ? IVILNANIR : []).filter((x) => x.stada === 'virk').length;
const updated = '2026-07-02';
const desc = `Ívilnanir og styrkir ríkisins — ${total} leiðir (${active} virkar): endurgreiðslur, skattaívilnanir og stuðningskerfi eftir málaflokkum.`;
---

<Layout title="Ívilnanir & styrkir | Karp" description={desc} canonical="https://app.karp.is/ivilnanir/" ogTitle="Ívilnanir & styrkir">
  <main>
    <p class="kicker">Hagvísir Íslands · Alþingi</p>
    <ThingTabs active="ivilnanir" />
    <h1>Ívilnanir &amp; styrkir</h1>
    <p>Stuðningskerfi ríkisins á einum stað — <strong>{total} leiðir</strong>, þar af {active} virkar. Smelltu á færslu fyrir lýsingu.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Ívilnanir: opinberar skrár um ívilnanasamninga og byggðaaðstoð stjórnvalda.">ⓘ</i> Um gögnin á síðunni</p>

    {order.map((f) => (
      <>
        <h2>{FLOKKAR[f][0]} {FLOKKAR[f][1]} ({groups[f].length})</h2>
        <div class="grid">
          {groups[f].map((x) => (
            <details class="iv">
              <summary>
                <span class="iv-n">{x.nafn}</span>
                <span class={`iv-st ${x.stada === 'virk' ? 'on' : 'off'}`}>{x.stada === 'virk' ? 'Virk' : 'Lokið'}</span>
                <span class="iv-y">{x.fra}{x.til ? `–${x.til}` : '–'}</span>
              </summary>
              <div class="iv-b">{x.lysing}</div>
            </details>
          ))}
        </div>
      </>
    ))}

    <p class="foot">Forþjónað (SSG) {updated}. Samantekt Karp úr lögum, reglugerðum og fjárlögum — ekki tæmandi réttindalýsing; kannaðu skilyrði hjá viðkomandi stofnun. #2.</p>
  </main>

  <style>
    main { max-width: 820px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 26px 0 8px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 8px; }
    .iv { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; }
    .iv[open] { border-color: rgba(246,177,59,.5); }
    .iv summary { list-style: none; cursor: pointer; padding: 10px 12px; position: relative; }
    .iv summary::-webkit-details-marker { display: none; }
    .iv-n { display: block; font-weight: 600; font-size: 13.5px; color: #eaf1fb; padding-right: 52px; }
    .iv-st { position: absolute; top: 10px; right: 12px; font-size: 10px; font-weight: 700; border-radius: 5px; padding: 1px 7px; }
    .iv-st.on { color: #06121a; background: #46e08a; }
    .iv-st.off { color: #9fb0c8; background: rgba(255,255,255,.1); }
    .iv-y { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .iv-b { font-size: 12.5px; color: #cdd6e6; line-height: 1.55; padding: 0 12px 10px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
</Layout>
