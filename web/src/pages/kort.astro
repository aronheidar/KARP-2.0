---
// ─────────────────────────────────────────────────────────────
// ÍSLANDSKORTIÐ (#2) — gagnvirkt kort eins og Yfirlit gamla mælaborðsins:
// landshluta-fjölhyrningar (landshlutar.json, BAKAÐ inline) + sveitarfélög sem
// punktar (SVCOORDS) litaðir eftir völdum kortaham (14 hamir). Smelltu á
// sveitarfélag → síðan þess; á landshluta → þysjun. Öll gildi reiknuð á
// BYGGINGARTÍMA úr sameiginlega @lib (muniIndex/muniStats/geo). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { computeMuniIndex } from '@lib/muniIndex.mjs';
import { makeMuniStats } from '@lib/muniStats.mjs';
import { makeRegionOf, makeLifsQ } from '@lib/geo.mjs';
import { slugify } from '@lib/format.mjs';

import SVFIN from '@gogn/sveitarfelog_fin.json';
import SVMETA from '@gogn/sveitarfelog_meta.json';
import SVPOP from '@gogn/sveitarfelog_pop.json';
import ATVINNULEYSI from '@gogn/atvinnuleysi.json';
import GLAEPIR from '@gogn/glaepir.json';
import FASTEIGNIR from '@gogn/fasteignir.json';
import SVCOORDS from '@gogn/sveitarfelog_coords.json';
import REGIONGEO from '@gogn/landshlutar.json';
import SVREV from '@gogn/sveitarfelog_rev.json';
import JOFNUN from '@gogn/jofnun.json';

const idxMap = computeMuniIndex({ SVFIN, SVMETA, SVPOP, ATVINNULEYSI });
const regionOf = makeRegionOf({ SVCOORDS, REGIONGEO });
const stats = makeMuniStats({ ATVINNULEYSI, GLAEPIR, FASTEIGNIR });
const lifsQ = makeLifsQ({ SVMETA, regionOf, svUnemp: stats.svUnemp, svCrime: stats.svCrime });
const r0 = (v) => (v == null ? null : Math.round(v));
const r1 = (v) => (v == null ? null : Math.round(v * 10) / 10);

// Punktar: öll 61 sveitarfélög með ÖLL kortahams-gildi bökuð.
const MUNIS = Object.keys(SVCOORDS).map((name) => {
  const [lat, lng] = SVCOORDS[name]; // ATH: coords eru [lat,lng] — ECharts vill [lng,lat]
  const reg = regionOf(name);
  const fin = SVFIN[name] || {}, meta = SVMETA[name] || {};
  const pop = SVPOP[name] || null;
  const house = stats.svHouse(name, reg);
  const crime = stats.svCrime(reg);
  const ix = idxMap[name];
  return {
    n: name, s: slugify(name), lng, lat, reg, pop,
    v: {
      visitala: ix && ix.idx != null ? r0(ix.idx) : null,
      ibuar: pop,
      breyting: meta.breyting_pct ?? null,
      aldur: meta.pct67 ?? null,
      lifs: lifsQ(name),
      atv: r1(stats.svUnemp(name, reg)),
      afbrot: crime ? r0(crime.hegn) : null,
      hus: house ? r0(house.v) : null,
      utsvar: fin.utsvar ?? null,
      tekjur: fin.tekjur && pop ? r0(fin.tekjur / pop) : null,
      fasteign: fin.fasteign_ibui && pop ? r0(fin.fasteign_ibui / pop) : null,
      skuldir: fin.skuldir_ibui ?? null,
      skhlutf: fin.skuldir && fin.tekjur ? r0((fin.skuldir / fin.tekjur) * 100) : null,
      afkoma: fin.afkoma_ibui ?? null,
      kjor: meta.kjordaemi || null,
      // Ríkisflæði: staðgreiðsla til ríkisins (nýjasta ár, ma.kr) + jöfnunarframlög á íbúa (þús.kr)
      stadgr: (() => { const s = SVREV[name]; const v = Array.isArray(s) ? s[s.length - 1] : null; return v != null ? Math.round((v / 1000) * 10) / 10 : null; })(),
      jofnun: (() => { const j = (JOFNUN.m || {})[name]; return j && j.t && pop ? Math.round(j.t / pop / 1000) : null; })(),
    },
  };
});

// Landshluta-rammar (fyrir þysjun) + heildar-miðja.
function bboxOf(geom) {
  let mnx = 999, mxx = -999, mny = 999, mxy = -999;
  const walk = (c) => { if (typeof c[0] === 'number') { mnx = Math.min(mnx, c[0]); mxx = Math.max(mxx, c[0]); mny = Math.min(mny, c[1]); mxy = Math.max(mxy, c[1]); } else c.forEach(walk); };
  walk(geom.coordinates);
  return [mnx, mxx, mny, mxy];
}
let FX = [999, -999, 999, -999];
const REGBOX = {};
(REGIONGEO.features || []).forEach((f) => {
  const b = bboxOf(f.geometry);
  FX = [Math.min(FX[0], b[0]), Math.max(FX[1], b[1]), Math.min(FX[2], b[2]), Math.max(FX[3], b[3])];
  REGBOX[f.properties.name] = b;
});
const REGZOOM = {};
Object.keys(REGBOX).forEach((n) => {
  const b = REGBOX[n];
  const z = 0.85 * Math.min((FX[1] - FX[0]) / Math.max(0.5, b[1] - b[0]), (FX[3] - FX[2]) / Math.max(0.2, b[3] - b[2]));
  REGZOOM[n] = { c: [(b[0] + b[1]) / 2, (b[2] + b[3]) / 2], z: Math.max(1.6, Math.min(4.5, z)) };
});

// Kökurit Ríkisflæðis (LOTA 12): jöfnunar-flokkarnir (heild) bakaðir.
const JOFNCATS = (JOFNUN.catLabels || [])
  .map((l, i) => ({ l, v: Math.round(((JOFNUN.cats || [])[i] || 0) / 1e6) }))
  .filter((x) => x.v > 0)
  .sort((a, b) => b.v - a.v);
const JOFNYEAR = JOFNUN.ar || '';

const updated = '2026-07-01';
const desc = 'Gagnvirkt Íslandskort — öll 61 sveitarfélög lituð eftir vísitölu, lífsgæðum, atvinnuleysi, húsnæðisverði, fjármálum og fleiru. Smelltu á sveitarfélag fyrir nánari síðu.';
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Íslandskort — hagvísar sveitarfélaga', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland' };

const MODEGROUPS = [
  ['Samfélag', [['visitala', 'Vísitala'], ['lifs', 'Lífsgæði'], ['ibuar', 'Íbúafjöldi'], ['breyting', 'Fólksfjölgun'], ['aldur', '67 ára+'], ['atv', 'Atvinnuleysi'], ['afbrot', 'Afbrot'], ['hus', 'Húsnæðisverð']]],
  ['Fjármál sveitarf.', [['utsvar', 'Útsvar'], ['tekjur', 'Tekjur/íbúi'], ['fasteign', 'Fasteignask./íbúi'], ['skuldir', 'Skuldir/íbúi'], ['skhlutf', 'Skuldahlutfall'], ['afkoma', 'Afkoma/íbúi']]],
  ['Ríkisflæði', [['stadgr', 'Staðgreiðsla'], ['jofnun', 'Jöfnunarsjóður']]],
  ['Stjórnsýsla', [['kjor', 'Kjördæmi']]],
];
---

<Layout title="Íslandskortið — hagvísar sveitarfélaga | Karp" description={desc} canonical="https://app.karp.is/kort/" jsonLd={jsonLd} ogTitle="Íslandskortið">
  <main data-pg="kort">
    <p class="kicker">Hagvísir Íslands · Kort</p>
    <h1>Íslandskortið</h1>
    <p>Veldu hvaða upplýsingar lita kortið — smelltu á <strong>sveitarfélag</strong> fyrir nánari síðu, eða á <strong>landshluta</strong> til að þysja inn.</p>

    <div class="modes">
      {MODEGROUPS.map(([grp, modes]) => (
        <div class="mg">
          <span class="mg-l">{grp}</span>
          {modes.map(([key, label]) => <button class={`mb${key === 'visitala' ? ' on' : ''}`} data-m={key}>{label}</button>)}
        </div>
      ))}
    </div>

    <div class="map-wrap">
      <button id="map-reset" hidden>↩ Allt landið</button>
      <div id="map"></div>
      <div id="map-info" class="minfo"></div>
      <div id="map-scale" class="scale"></div>
    </div>

    <!-- Topp/botn undir kortinu (LOTA 14): graf + tafla í stað yfirlagnar-texta -->
    <div id="mode-wrap" hidden>
      <div class="ppair">
        <div><h2 id="mode-title"></h2><div id="mode-chart"></div></div>
        <div><h2>Hæst og lægst</h2><div class="tw"><table id="mode-tbl"><thead><tr><th class="l">#</th><th class="l">Sveitarfélag</th><th id="mode-vh">Gildi</th></tr></thead><tbody></tbody></table></div></div>
      </div>
    </div>

    <!-- Ríkisflæðis-kökuritið (LOTA 12): birtist í stadgr/jofnun-ham -->
    <div id="flow-wrap" hidden>
      <h2 id="flow-title"></h2>
      <div id="flow-pie"></div>
      <p class="src" id="flow-src"></p>
    </div>

    <p class="note">ⓘ Punktastærð fylgir íbúafjölda. Afbrot eru eftir landshluta (lögregluumdæmi) — öll sveitarfélög innan landshluta fá sama gildi. Reiknað á byggingartíma úr opinberum gögnum (Hagstofa, Samband ísl. sveitarfélaga, VMST, Ríkislögreglustjóri, HMS).</p>
    <p class="foot">Forþjónað (SSG) {updated}. Landshlutamörk + hnit bökuð; sama reiknilíkan og <a href="/sveitarfelog/">Sveitarfélaga-vísitalan</a>. #2.</p>
  </main>

  <!-- Bökuð gögn (ekki keyrð): landshlutar + punktar + þysjunarrammar -->
  <script type="application/json" id="d-reg" set:html={JSON.stringify(REGIONGEO)}></script>
  <script type="application/json" id="d-munis" set:html={JSON.stringify(MUNIS)}></script>
  <script type="application/json" id="d-zoom" set:html={JSON.stringify(REGZOOM)}></script>
  <script type="application/json" id="d-jofncats" set:html={JSON.stringify({ ar: JOFNYEAR, cats: JOFNCATS })}></script>

  <style>
    main { max-width: 980px; margin: 0 auto; padding: 40px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 8px; }
    p { color: #cdd6e6; }
    .modes { display: flex; flex-direction: column; gap: 6px; margin: 14px 0 10px; }
    .mg { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
    .mg-l { font-size: 10px; text-transform: uppercase; letter-spacing: .08em; color: #5a6678; font-weight: 700; width: 108px; flex: none; }
    .mb { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); color: #9fb0c8; border-radius: 7px; padding: 5px 10px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .mb:hover { color: #eaf1fb; border-color: rgba(255,255,255,.25); }
    .mb.on { background: rgba(246,177,59,.15); border-color: #f6b13b; color: #f6b13b; }
    .map-wrap { position: relative; background: radial-gradient(ellipse 65% 55% at 52% 46%, rgba(58,141,255,.09), rgba(25,211,197,.03) 55%, transparent 75%), rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 14px; }
    #map { width: 100%; height: 560px; }
    #map-reset { position: absolute; top: 10px; right: 10px; z-index: 4; background: rgba(9,14,26,.9); border: 1px solid rgba(255,255,255,.2); color: #eaf1fb; border-radius: 8px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .scale { position: absolute; left: 12px; bottom: 10px; font-size: 11px; color: #9fb0c8; background: rgba(9,14,26,.75); border-radius: 7px; padding: 5px 10px; }
    /* Skýringar-yfirlögn á kortinu (LOTA 13) */
    .minfo { position: absolute; top: 10px; left: 12px; z-index: 3; max-width: 250px; background: rgba(9,14,26,.86); border: 1px solid rgba(255,255,255,.12); border-radius: 10px; padding: 10px 12px; pointer-events: none; backdrop-filter: blur(2px); }
    .minfo .mi-t { font-size: 13px; font-weight: 800; color: #f6b13b; }
    .minfo .mi-d { font-size: 11px; color: #b9c6da; line-height: 1.45; margin-top: 3px; }
    .minfo .mi-x { font-size: 11px; margin-top: 7px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,.09); }
    .minfo .mi-x b { font-variant-numeric: tabular-nums; margin-left: auto; }
    .minfo .mi-row { display: flex; gap: 5px; align-items: baseline; padding: 1px 0; }
    .minfo .mi-n { min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #cdd6e6; }
    .minfo .mi-sep { height: 1px; background: rgba(255,255,255,.08); margin: 4px 0; }
    .minfo .mi-hint { font-size: 10px; color: #7e8ca6; margin-top: 7px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,.09); }
    .minfo .mi-hi { color: #46e08a; } .minfo .mi-lo { color: #ff6d7a; }
    @media (max-width: 640px) { .minfo { position: static; max-width: none; margin: 8px; pointer-events: auto; } }
    .note { font-size: 12.5px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0 0; }
    #flow-wrap h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 26px 0 8px; }
    #flow-pie { width: 100%; height: 380px; }
    .ppair { display: grid; grid-template-columns: 1.2fr 1fr; gap: 14px; align-items: start; margin-top: 8px; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    #mode-chart { width: 100%; height: 320px; }
    .tw { overflow-x: auto; }
    #mode-tbl { width: 100%; border-collapse: collapse; font-size: 12.5px; }
    #mode-tbl th, #mode-tbl td { text-align: right; padding: 5px 8px; border-bottom: 1px solid rgba(255,255,255,.07); white-space: nowrap; }
    #mode-tbl th { color: #7e8ca6; font-size: 10.5px; text-transform: uppercase; }
    #mode-tbl td.l, #mode-tbl th.l { text-align: left; }
    #mode-tbl tr.sep td { border-bottom: 2px solid rgba(255,255,255,.14); padding: 2px; }
    .src { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 22px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .foot a { color: #9fb0c8; }
    @media (max-width: 640px) { #map { height: 420px; } .mg-l { width: 100%; } }
  </style>

  <!-- Eyja: kortið (ECharts geo + scatter). Keyrir á astro:page-load (VT). #2 -->
  <script>
    const MODES = {
      visitala: { l: 'Vísitala', u: '', dir: 1, d: 0 },
      lifs: { l: 'Lífsgæði', u: '', dir: 1, d: 0 },
      ibuar: { l: 'Íbúar', u: '', dir: 0, d: 0, th: true },
      breyting: { l: 'Fólksfjölgun', u: '%', dir: 1, d: 1 },
      aldur: { l: '67 ára+', u: '%', dir: 0, d: 1 },
      atv: { l: 'Atvinnuleysi', u: '%', dir: -1, d: 1 },
      afbrot: { l: 'Afbrot', u: ' /10þ', dir: -1, d: 0 },
      hus: { l: 'Húsnæðisverð', u: ' þús/m²', dir: 0, d: 0, th: true },
      utsvar: { l: 'Útsvar', u: '%', dir: -1, d: 2 },
      tekjur: { l: 'Tekjur/íbúa', u: ' þús', dir: 0, d: 0, th: true },
      fasteign: { l: 'Fasteignask./íbúa', u: ' þús', dir: 0, d: 0, th: true },
      skuldir: { l: 'Skuldir/íbúa', u: ' þús', dir: -1, d: 0, th: true },
      skhlutf: { l: 'Skuldahlutfall', u: '%', dir: -1, d: 0 },
      afkoma: { l: 'Afkoma/íbúa', u: ' þús', dir: 1, d: 0, th: true },
      stadgr: { l: 'Staðgreiðsla → ríkið', u: ' ma.kr', dir: 0, d: 1 },
      jofnun: { l: 'Jöfnunarframlög/íbúa', u: ' þús', dir: 0, d: 0, th: true },
      kjor: { l: 'Kjördæmi', cat: true },
    };
    const KJORCOL = [['Reykjav', '#e8436f'], ['Suðvest', '#3a8dff'], ['Norðaust', '#f6b13b'], ['Norðvest', '#7c5cf7'], ['Suður', '#46e08a']];
    const REGCOL = { 'Höfuðborgarsvæðið': 'rgba(58,141,255,.20)', 'Suðurnes': 'rgba(255,138,61,.18)', 'Vesturland': 'rgba(70,192,106,.16)', 'Vestfirðir': 'rgba(124,92,247,.18)', 'Norðurland vestra': 'rgba(31,182,201,.16)', 'Norðurland eystra': 'rgba(245,197,66,.15)', 'Austurland': 'rgba(232,67,111,.16)', 'Suðurland': 'rgba(90,168,74,.16)' };
    const $ = (id) => document.getElementById(id);
    const J = (id) => { try { return JSON.parse($(id).textContent); } catch (e) { return null; } };
    const th = (n) => String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');

    function initMap() {
      const el = $('map');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initMap, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const REG = J('d-reg'), MUNIS = J('d-munis'), RZ = J('d-zoom');
      if (!REG || !MUNIS) return;
      try { window.echarts.registerMap('landshlutar', REG); } catch (e) {}
      const chart = window.echarts.init(el);
      let mode = 'visitala';

      const fmtV = (m, v) => { const M = MODES[m]; if (v == null) return '—'; if (M.cat) return v; const s = M.th ? th(v) : v.toFixed(M.d).replace('.', ','); return s + (M.u || ''); };
      const kjorColor = (v) => { for (const [k, c] of KJORCOL) if (v && v.indexOf(k) >= 0) return c; return '#8892a6'; };

      function pointData() {
        const M = MODES[mode];
        let mn = Infinity, mx = -Infinity;
        if (!M.cat) MUNIS.forEach((u) => { const v = u.v[mode]; if (v != null) { mn = Math.min(mn, v); mx = Math.max(mx, v); } });
        const span = mx - mn || 1;
        return MUNIS.map((u) => {
          const v = u.v[mode];
          let col = '#4a5568';
          if (v != null) {
            if (M.cat) col = kjorColor(v);
            else if (M.dir === 0) { const t = (v - mn) / span; col = `hsl(212,72%,${28 + t * 42}%)`; }
            else { let t = (v - mn) / span; if (M.dir < 0) t = 1 - t; col = `hsl(${Math.round(t * 120)},62%,47%)`; }
          }
          return {
            name: u.n, value: [u.lng, u.lat, v == null ? '' : v], slug: u.s, reg: u.reg, vTxt: fmtV(mode, v),
            itemStyle: { color: col, borderColor: 'rgba(4,8,16,.55)', borderWidth: 1 }, symbolSize: 6 + Math.cbrt(u.pop || 300) * 0.32,
            // Nafnamerki á stærstu staðina — kortið les eins og kort (LOTA 13e)
            label: (u.pop || 0) > 9000 ? { show: true, position: 'right', distance: 3, fontSize: 9, fontWeight: 600, color: 'rgba(205,214,230,.78)', textBorderColor: 'rgba(4,8,16,.9)', textBorderWidth: 2, formatter: u.n.replace(/bær$|borg$|kaupstaður$/, '') } : undefined,
          };
        });
      }
      function scaleTxt() {
        const M = MODES[mode];
        if (M.cat) { $('map-scale').innerHTML = KJORCOL.map(([k, c]) => `<span style="color:${c}">●</span> ${k}.`).join(' '); return; }
        let mn = Infinity, mx = -Infinity;
        MUNIS.forEach((u) => { const v = u.v[mode]; if (v != null) { mn = Math.min(mn, v); mx = Math.max(mx, v); } });
        const lo = M.dir < 0 ? 'grænt' : M.dir > 0 ? 'rautt' : 'dökkblátt';
        const hi = M.dir < 0 ? 'rautt' : M.dir > 0 ? 'grænt' : 'ljósblátt';
        $('map-scale').innerHTML = `<b>${M.l}</b>: ${fmtV(mode, mn)} (${lo}) → ${fmtV(mode, mx)} (${hi})`;
      }
      // Skýringar-yfirlögnin á kortinu (LOTA 13): hvað sýnir hamurinn + hæst/lægst
      const MDESC = {
        visitala: 'Samsett vísitala Karp (0–100): fjárhagur, vöxtur og atvinna vegin saman. Reiknuð fyrir sveitarfélög með 1.000+ íbúa.',
        lifs: 'Lífsgæðavísir (0–100): aldurssamsetning, atvinna og öryggi svæðisins vegin saman.',
        ibuar: 'Íbúafjöldi — punktastærðin fylgir líka íbúafjölda í öllum hömum.',
        breyting: 'Fólksfjölgun á ári (%) — hvar landið er að vaxa og hvar það fækkar.',
        aldur: 'Hlutfall íbúa 67 ára og eldri — öldrun byggðanna.',
        atv: 'Skráð atvinnuleysi (%) skv. Vinnumálastofnun.',
        afbrot: 'Hegningarlagabrot á 10.000 íbúa — eftir lögregluumdæmum (öll sveitarfélög innan umdæmis fá sama gildi).',
        hus: 'Söluverð íbúða (þús. kr á m²) úr kaupskrá HMS.',
        utsvar: 'Útsvarshlutfall sveitarfélagsins — hámark er 14,97%.',
        tekjur: 'Tekjur sveitarsjóðs á íbúa (þús. kr á ári).',
        fasteign: 'Fasteignaskattur á íbúa (þús. kr á ári).',
        skuldir: 'Skuldir sveitarsjóðs á íbúa (þús. kr).',
        skhlutf: 'Skuldir sem hlutfall af tekjum — viðmið eftirlitsnefndar er 150%.',
        afkoma: 'Rekstrarafkoma á íbúa (þús. kr) — jákvætt er afgangur.',
        stadgr: 'Staðgreiðsla íbúa til ríkisins (ma.kr á ári). Örvarnar sýna flæðið til ríkisins og kökuritið að neðan skiptinguna.',
        jofnun: 'Framlög Jöfnunarsjóðs á íbúa (þús. kr á ári). Örvarnar sýna flæðið frá ríkinu og kökuritið framlagsflokkana.',
        kjor: 'Kjördæmin sex — litur sýnir hvaða kjördæmi hvert sveitarfélag tilheyrir.',
      };
      let modeChart = null;
      function paintBelow() {
        const wrap = $('mode-wrap');
        const M = MODES[mode];
        const flows = mode === 'stadgr' || mode === 'jofnun';
        if (!wrap) return;
        if (M.cat || flows) { wrap.hidden = true; return; }
        const vals = MUNIS.filter((u) => u.v[mode] != null).sort((a, b) => b.v[mode] - a.v[mode]);
        if (vals.length < 6) { wrap.hidden = true; return; }
        wrap.hidden = false;
        const tt = $('mode-title');
        if (tt) tt.textContent = 'Topp 10 — ' + M.l;
        const vh = $('mode-vh');
        if (vh) vh.textContent = M.l;
        const tb = document.querySelector('#mode-tbl tbody');
        if (tb) {
          const row = (u, i) => `<tr><td class="l">${i}</td><td class="l">${u.n}</td><td>${fmtV(mode, u.v[mode])}</td></tr>`;
          tb.innerHTML = vals.slice(0, 5).map((u, i) => row(u, i + 1)).join('')
            + '<tr class="sep"><td colspan="3"></td></tr>'
            + vals.slice(-5).map((u, i) => row(u, vals.length - 4 + i)).join('');
        }
        const el2 = $('mode-chart');
        if (el2 && window.echarts) {
          if (!modeChart || modeChart.getDom() !== el2) { try { if (modeChart) modeChart.dispose(); } catch (e) {} modeChart = window.echarts.init(el2); }
          const top = vals.slice(0, 10).reverse();
          modeChart.setOption({
            backgroundColor: 'transparent', grid: { left: 8, right: 44, top: 6, bottom: 6, containLabel: true },
            tooltip: { trigger: 'axis', valueFormatter: (v) => fmtV(mode, v) },
            xAxis: { type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 10 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            yAxis: { type: 'category', data: top.map((u) => u.n), axisLabel: { color: '#cdd6e6', fontSize: 11 }, axisLine: { show: false }, axisTick: { show: false } },
            series: [{ type: 'bar', barMaxWidth: 15, data: top.map((u) => u.v[mode]), itemStyle: { color: '#f6b13b', borderRadius: [0, 5, 5, 0] }, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10, formatter: (p) => fmtV(mode, p.value) } }],
          }, true);
        }
      }
      function paintInfo() {
        const el = $('map-info');
        if (!el) return;
        const M = MODES[mode];
        let x = '';
        if (!M.cat) {
          const vals = MUNIS.filter((u) => u.v[mode] != null).sort((a, b) => b.v[mode] - a.v[mode]);
          if (vals.length > 5) {
            const row = (u, i, cls, pre) => `<div class="mi-row"><span class="${cls}">${pre}${i}.</span> <span class="mi-n">${u.n}</span> <b>${fmtV(mode, u.v[mode])}</b></div>`;
            x = '<div class="mi-x">'
              + vals.slice(0, 3).map((u, i) => row(u, i + 1, 'mi-hi', '▲')).join('')
              + '<div class="mi-sep"></div>'
              + vals.slice(-3).reverse().map((u, i) => row(u, vals.length - i, 'mi-lo', '▼')).join('')
              + '</div>';
          }
        }
        el.innerHTML = `<div class="mi-t">${M.l}</div><div class="mi-d">${MDESC[mode] || ''}</div><div class="mi-hint">💡 Smelltu á landshluta til að þysja · á punkt fyrir síðu</div>`;
        paintBelow();
      }
      const geoRegions = (REG.features || []).map((f) => { const nm = f.properties.name, base = REGCOL[nm] || 'rgba(255,255,255,.05)'; return { name: nm, itemStyle: { areaColor: base }, emphasis: { itemStyle: { areaColor: base.replace(/[\d.]+\)\s*$/, '0.42)') } } }; });

      // ── Ríkisflæði (LOTA 12): örvar milli sveitarfélaga og Reykjavíkur + kökurit ──
      const RVKU = MUNIS.find((u) => u.n === 'Reykjavíkurborg');
      const RVK = RVKU ? [RVKU.lng, RVKU.lat] : [-21.9, 64.13];
      function flowData() {
        if (mode !== 'stadgr' && mode !== 'jofnun') return [];
        const toState = mode === 'stadgr';
        const col = toState ? '#f6b13b' : '#19d3c5';
        const vals = MUNIS.map((u) => u.v[mode]).filter((v) => v != null && v > 0);
        const mx = Math.max(...vals, 1);
        return MUNIS.filter((u) => u.v[mode] != null && u.v[mode] > 0 && u.n !== 'Reykjavíkurborg').map((u) => ({
          coords: toState ? [[u.lng, u.lat], RVK] : [RVK, [u.lng, u.lat]],
          nafn: u.n, vTxt: fmtV(mode, u.v[mode]),
          lineStyle: { width: 0.5 + Math.sqrt(u.v[mode] / mx) * 3.6, color: col, opacity: 0.42, curveness: 0.28 },
        }));
      }
      // Seríu-verksmiðjur: replaceMerge þarf FULLA seríulistann (tóm data[] tæmir ekki í merge-ham!)
      const muniTip = { formatter: (p) => `<b>${p.name}</b><br>${p.data.reg || ''}<br>${MODES[mode].l}: <b>${p.data.vTxt}</b><br><span style="color:#19d3c5">Smelltu fyrir síðu →</span>` };
      const munisSeries = () => ({ name: 'munis', type: 'scatter', coordinateSystem: 'geo', data: pointData(), emphasis: { scale: 1.4 }, labelLayout: { hideOverlap: true }, tooltip: muniTip, zlevel: 2 });
      // Topp-5 í völdum ham fá ripple-hring (effectScatter) — id per ham svo replaceMerge skipti rétt út
      const topSeries = () => {
        const M = MODES[mode];
        let top = [];
        if (!M.cat) {
          const pd = pointData().filter((d) => d.value[2] !== '' && d.value[2] != null);
          pd.sort((a, b) => (M.dir < 0 ? a.value[2] - b.value[2] : b.value[2] - a.value[2]));
          top = pd.slice(0, 5);
        }
        return { id: 'top-' + mode, name: 'top', type: 'effectScatter', coordinateSystem: 'geo', zlevel: 3, rippleEffect: { brushType: 'stroke', scale: 3, period: 4.5 }, labelLayout: { hideOverlap: true }, tooltip: muniTip, data: top };
      };
      // id breytist með ham → replaceMerge EYÐIR gömlu og býr til nýja (merge hunsar tóm data[])
      const flowsSeries = () => ({ id: 'flows-' + mode, name: 'flows', type: 'lines', coordinateSystem: 'geo', zlevel: 1, silent: false,
        effect: { show: mode === 'stadgr' || mode === 'jofnun', period: 5, symbol: 'arrow', symbolSize: 5.5, trailLength: 0.12 },
        tooltip: { formatter: (p) => `<b>${p.data.nafn}</b><br>${MODES[mode] ? MODES[mode].l : ''}: <b>${p.data.vTxt}</b>` },
        data: flowData() });
      let flowPie = null;
      function paintFlow() {
        const wrap = $('flow-wrap');
        const on = mode === 'stadgr' || mode === 'jofnun';
        if (wrap) wrap.hidden = !on;
        if (!on) return;
        const title = $('flow-title'), src = $('flow-src'), pieEl = $('flow-pie');
        let data, sub;
        if (mode === 'stadgr') {
          const rows = MUNIS.filter((u) => u.v.stadgr != null && u.v.stadgr > 0).sort((a, b) => b.v.stadgr - a.v.stadgr);
          const top = rows.slice(0, 8), rest = rows.slice(8).reduce((a, u) => a + u.v.stadgr, 0);
          data = top.map((u) => ({ name: u.n, value: u.v.stadgr })).concat(rest > 0 ? [{ name: 'Önnur sveitarfélög', value: Math.round(rest * 10) / 10, itemStyle: { color: '#42506a' } }] : []);
          if (title) title.textContent = '💰 Hvaðan kemur staðgreiðslan? — skipting eftir sveitarfélögum';
          sub = 'Staðgreiðsla í ríkissjóð eftir sveitarfélagi (ma.kr, nýjasta ár). Örvarnar á kortinu sýna flæðið til ríkisins.';
        } else {
          const JC = J('d-jofncats') || { cats: [] };
          data = JC.cats.slice(0, 9).map((c) => ({ name: c.l, value: c.v }));
          if (title) title.textContent = '⚖️ Hvert fer Jöfnunarsjóðurinn? — skipting eftir framlagsflokkum';
          sub = `Framlög Jöfnunarsjóðs sveitarfélaga ${JC.ar || ''} (m.kr). Örvarnar á kortinu sýna flæðið frá ríkinu út í sveitarfélögin.`;
        }
        if (src) src.textContent = sub;
        if (pieEl) {
          if (!flowPie || flowPie.getDom() !== pieEl) { try { if (flowPie) flowPie.dispose(); } catch (e) {} flowPie = window.echarts.init(pieEl); }
          flowPie.setOption({
            backgroundColor: 'transparent',
            tooltip: { trigger: 'item', backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 }, valueFormatter: (v) => th(v) + (mode === 'stadgr' ? ' ma.kr' : ' m.kr') },
            series: [{
              type: 'pie', radius: ['42%', '72%'], center: ['50%', '52%'],
              label: { color: '#cdd6e6', fontSize: 11, formatter: '{b}\n{d}%' }, labelLine: { lineStyle: { color: 'rgba(255,255,255,.2)' } },
              itemStyle: { borderColor: '#0b1220', borderWidth: 2 },
              data,
            }],
          }, true);
        }
      }

      chart.setOption({
        backgroundColor: 'transparent',
        // roam:false — EKKERT músarhjóls-zoom/drag (eins og gamla): þysjun AÐEINS með smelli á landshluta + ↩-takka.
        geo: { map: 'landshlutar', roam: false, zoom: 1.12, itemStyle: { borderColor: 'rgba(255,255,255,.25)', borderWidth: 0.8 }, label: { show: true, color: 'rgba(159,176,200,.4)', fontSize: 9.5 }, emphasis: { label: { show: true, color: '#eaf1fb', fontSize: 11 } }, regions: geoRegions, select: { disabled: true } },
        tooltip: { backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12.5 } },
        series: [munisSeries(), flowsSeries(), topSeries()],
      });
      scaleTxt();
      paintInfo();

      chart.on('click', (p) => {
        if (p.seriesType === 'scatter' && p.data && p.data.slug) { window.location.href = '/sveitarfelog/' + p.data.slug + '/'; return; }
        if (p.componentType === 'geo' && RZ && RZ[p.name]) { chart.setOption({ geo: { center: RZ[p.name].c, zoom: RZ[p.name].z } }); $('map-reset').hidden = false; }
      });
      $('map-reset').onclick = () => { chart.setOption({ geo: { center: null, zoom: 1.12 } }); $('map-reset').hidden = true; };

      document.querySelectorAll('.mb').forEach((b) => {
        b.onclick = () => {
          document.querySelectorAll('.mb').forEach((x) => x.classList.toggle('on', x === b));
          mode = b.dataset.m;
          chart.setOption({ series: [munisSeries(), flowsSeries(), topSeries()] }, { replaceMerge: ['series'] });
          scaleTxt();
          paintInfo();
          paintFlow();
        };
      });
      window.addEventListener('resize', () => chart.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="kort"]')) initMap(); });
  </script>
</Layout>
