---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Atvinnuleysi: skráð atvinnuleysi (VMST) — mánaðarþróun +
// eftir landshlutum + kyn + ríkisfang (bakað gogn/atvinnuleysi.json).
// Laun vs verðbólga (kaupmáttur) úr daglegu snapshoti gogn/vinnumarkadur.json
// (build_vinnumarkadur.mjs; áður sótt beint á Hagstofu í frontmatter). Í Layout. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, monthLabel } from '@lib/format.mjs';
import ATV from '@gogn/atvinnuleysi.json';
import DATA from '@gogn/vinnumarkadur.json';

const latest = ATV.latest;
const monthly = ATV.monthly || [];
const recent = monthly.slice(-72);
const chartMonths = recent.map((m) => monthLabel(m.t));
const trendVals = recent.map((m) => m.v);
const regionBars = (ATV.byRegion || []).slice().sort((a, b) => b.v - a.v);
const sex = ATV.bySex || {};
const cit = ATV.byCitizenship || {};
const updated = ATV.updated || '2026M05';
const updLabel = monthLabel(updated);

const hi = regionBars[0], lo = regionBars[regionBars.length - 1];

// Choropleth-kort: atvinnuleysi per landshluta (ATV.byRegion). Samræma nafn +
// sleppa "Landsbyggð" (landsaggregat, ekki fjölhyrningur).
const REGION_ALIAS = { 'Höfuðborgarsvæði': 'Höfuðborgarsvæðið' };
const mapValues = {};
(ATV.byRegion || []).forEach((r) => { if (r.name !== 'Landsbyggð') mapValues[REGION_ALIAS[r.name] || r.name] = r.v; });

// Laun vs verðbólga (kaupmáttur) — úr daglegu snapshoti (skriptur/build_vinnumarkadur.mjs):
// LAU04001 ársbreyting launavísitölu + VIS01000 ársbreyting neysluverðs. Áður sótt hér í frontmatter.
const { WAGE } = DATA;

// Atvinnugreinar (top 10) + ríkisfangs-þróun úr bökuðu gögnunum.
const INDBARS = (ATV.industries || []).slice(0, 10).map((x) => ({ label: x.name, v: x.n }));
const CITS = ATV.citSeries || null;
const citMonths = CITS ? (CITS.islenskt || []).slice(-72).map((x) => monthLabel(x.t)) : [];
const citIsl = CITS ? (CITS.islenskt || []).slice(-72).map((x) => x.v) : [];
const citErl = CITS ? (CITS.erlent || []).slice(-72).map((x) => x.v) : [];
const desc = `Skráð atvinnuleysi á Íslandi mælist ${fmtNum(latest, 1)}% (${updLabel}). Þróun, landshlutar, kyn og ríkisfang — gögn frá Vinnumálastofnun.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: 'Skráð atvinnuleysi á Íslandi',
  description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Skráð atvinnuleysi (%)',
};
---

<Layout  title={`Vinnumarkaður — atvinnuleysi ${fmtNum(latest, 1)}% | Karp`} description={desc} canonical="https://karp.is/vinnumarkadur/" jsonLd={jsonLd} ogTitle="Atvinnuleysi á Íslandi">
  <main data-pg="vinnumarkadur">
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Vinnumarkaður</h1>
    <div class="big">{fmtNum(latest, 1)}%<span>skráð atvinnuleysi · {updLabel}</span></div>
    <p>Skráð atvinnuleysi hjá Vinnumálastofnun. Hæst á {hi?.name} ({fmtNum(hi?.v, 1)}%), lægst á {lo?.name} ({fmtNum(lo?.v, 1)}%).</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Vinnumarkaðstölur: launavísitala og vinnumarkaðsrannsókn Hagstofunnar; kaupmátt reiknar Karp sem launavísitölu deilt með verðvísitölu.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      <div class="kpi"><div class="k-l">👨 Karlar</div><div class="k-v">{fmtNum(sex.karlar, 1)}%</div></div>
      <div class="kpi"><div class="k-l">👩 Konur</div><div class="k-v">{fmtNum(sex.konur, 1)}%</div></div>
      <div class="kpi"><div class="k-l">🇮🇸 Íslenskt ríkisfang</div><div class="k-v">{fmtNum(cit.islenskt, 1)}%</div></div>
      <div class="kpi"><div class="k-l">🌍 Erlent ríkisfang</div><div class="k-v hl">{fmtNum(cit.erlent, 1)}%</div></div>
    </div>

    <div class="ppair">
      <div>
        <h2>Mánaðarþróun (6 ár)</h2>
        <div id="chart-trend"></div>
      </div>
      {WAGE && (
        <div>
          <h2>Laun vs verðbólga</h2>
          <div id="chart-wage"></div>
        </div>
      )}
    </div>

    <h2>Eftir landshlutum</h2>
    <div id="chart-region"></div>

    <h2>Kort — atvinnuleysi eftir landshlutum</h2>
    <div id="atv-map" class="chl-mapbox"></div>
    <p class="srcnote">Skráð atvinnuleysi (%) eftir landshluta. Smelltu á svæði fyrir samanburð við landsmeðaltal.</p>

    {WAGE && (
      <>
        <p class="srcnote">Ársbreyting launavísitölu vs vísitölu neysluverðs. Bilið á milli = kaupmáttarbreyting (nú {WAGE.kaupm > 0 ? '+' : ''}{fmtNum(WAGE.kaupm, 1)} pp). Heimild: Hagstofa (LAU04001/VIS01000).</p>
      </>
    )}

    <div class="ppair">
      {citMonths.length > 0 && (
        <div>
          <h2>Eftir ríkisfangi — þróun</h2>
          <div id="chart-cit"></div>
        </div>
      )}
      {INDBARS.length > 0 && (
        <div>
          <h2>Atvinnulausir eftir atvinnugreinum</h2>
          <div id="chart-ind"></div>
        </div>
      )}
    </div>
    {INDBARS.length > 0 && (
      <>
        <p class="srcnote">Fjöldi á atvinnuleysisskrá eftir atvinnugrein (VMST, nýjasti mánuður).</p>
      </>
    )}

    <p class="note">ⓘ Skráð atvinnuleysi (hlutfall á atvinnuleysisskrá VMST) — ekki það sama og atvinnuleysi skv. vinnumarkaðsrannsókn Hagstofu. Erlent ríkisfang mælist umtalsvert hærra en íslenskt.</p>
    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot). Heimild: Vinnumálastofnun ({updLabel}). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 6px; }
    .big { font-size: 48px; font-weight: 800; color: #f6b13b; line-height: 1; margin: 4px 0 2px; font-variant-numeric: tabular-nums; }
    .big span { font-size: 14px; font-weight: 500; color: var(--muted); margin-left: 8px; }
    p { color: var(--ink); }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .note { font-size: 13px; color: var(--muted); background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; margin: 20px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 11px 13px; }
    .k-l { font-size: 12px; color: var(--muted); }
    .k-v { font-size: 22px; font-weight: 800; color: var(--ink); margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-v.hl { color: #ff8e98; }
    #chart-trend { width: 100%; height: 300px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 720px) { .ppair { grid-template-columns: 1fr; } }
    #chart-region { width: 100%; }
    #chart-wage { width: 100%; height: 290px; }
    #chart-cit { width: 100%; height: 280px; }
    #chart-ind { width: 100%; }
    .srcnote { font-size: 12px; color: var(--faint); margin: 2px 0 0; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: mánaðarþróun + landshlutar + laun/verðbólga + ríkisfang + greinar. #2 -->
  <script define:vars={{ chartMonths, trendVals, regionBars, WAGE, citMonths, citIsl, citErl, INDBARS }}>
    function initCharts() {
      const ct = document.getElementById('chart-trend');
      if (!ct) return;
      const go = () => {
        if (!window.echarts.getInstanceByDom(ct)) {
          const c = window.echarts.init(ct);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 40, right: 16, top: 12, bottom: 26 },
            xAxis: { type: 'category', data: chartMonths, axisLabel: { color: '#7e8ca6', interval: 11 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v + '%') },
            series: [{ type: 'line', data: trendVals, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#f6b13b' }, areaStyle: { opacity: 0.12, color: '#f6b13b' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cr = document.getElementById('chart-region');
        if (cr && !window.echarts.getInstanceByDom(cr)) {
          cr.style.height = (regionBars.length * 28 + 26) + 'px';
          const c = window.echarts.init(cr);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 120, right: 44, top: 6, bottom: 20 },
            xAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            yAxis: { type: 'category', inverse: true, data: regionBars.map((d) => d.name), axisLabel: { color: '#cdd6e6', fontSize: 11 }, axisLine: { show: false }, axisTick: { show: false } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => v + '%' },
            series: [{ type: 'bar', barWidth: 14, data: regionBars.map((d) => d.v), itemStyle: { color: '#3a8dff' }, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10, formatter: (p) => p.value.toFixed(1).replace('.', ',') + '%' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cw = document.getElementById('chart-wage');
        if (cw && WAGE && !window.echarts.getInstanceByDom(cw)) {
          const c = window.echarts.init(cw);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: ['Laun (ársbreyting)', 'Verðbólga'], textStyle: { color: '#9fb0c8' }, top: 0 },
            grid: { left: 40, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: WAGE.months, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: 5 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v.toFixed(1).replace('.', ',') + '%') },
            series: [
              { name: 'Laun (ársbreyting)', type: 'line', data: WAGE.laun, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#46e08a' }, itemStyle: { color: '#46e08a' } },
              { name: 'Verðbólga', type: 'line', data: WAGE.verd, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#ff6d7a' }, itemStyle: { color: '#ff6d7a' } },
            ],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cc = document.getElementById('chart-cit');
        if (cc && citMonths.length && !window.echarts.getInstanceByDom(cc)) {
          const c = window.echarts.init(cc);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: ['Íslenskt ríkisfang', 'Erlent ríkisfang'], textStyle: { color: '#9fb0c8' }, top: 0 },
            grid: { left: 40, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: citMonths, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: 11 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v.toFixed(1).replace('.', ',') + '%') },
            series: [
              { name: 'Íslenskt ríkisfang', type: 'line', data: citIsl, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#3a8dff' }, itemStyle: { color: '#3a8dff' } },
              { name: 'Erlent ríkisfang', type: 'line', data: citErl, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#ff8a3d' }, itemStyle: { color: '#ff8a3d' } },
            ],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const ci = document.getElementById('chart-ind');
        if (ci && INDBARS.length && !window.echarts.getInstanceByDom(ci)) {
          ci.style.height = (INDBARS.length * 30 + 26) + 'px';
          const c = window.echarts.init(ci);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 210, right: 48, top: 6, bottom: 20 },
            xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            yAxis: { type: 'category', inverse: true, data: INDBARS.map((d) => d.label), axisLabel: { color: '#cdd6e6', fontSize: 11, width: 200, overflow: 'truncate' }, axisLine: { show: false }, axisTick: { show: false } },
            tooltip: { trigger: 'axis' },
            series: [{ type: 'bar', barWidth: 15, data: INDBARS.map((d) => d.v), itemStyle: { color: '#7c5cf7' }, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10 } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vinnumarkadur"]')) initCharts(); });
  </script>

  <!-- Choropleth-kort (Leaflet) — sér eyja sem importar sameiginlega hjálparann. #2 -->
  <script type="application/json" id="atv-mapcfg" set:html={JSON.stringify({ values: mapValues, national: latest })}></script>
  <script>
    import { renderChoropleth } from '../lib/choropleth.mjs';
    function initAtvMap() {
      const el = document.getElementById('atv-map');
      if (!el || !document.querySelector('main[data-pg="vinnumarkadur"]')) return;
      let cfg; try { cfg = JSON.parse(document.getElementById('atv-mapcfg').textContent); } catch (e) { return; }
      const fmt = (v) => (v == null ? '—' : v.toFixed(1).replace('.', ',') + '%');
      renderChoropleth(el, {
        geojsonUrl: '/gogn/landshlutar.json',
        values: cfg.values,
        ramp: 'redgreen', bins: 5, format: fmt,
        label: 'Atvinnuleysi', legendTitle: 'Atvinnuleysi (%)',
        popupHtml: (name, v) => `<b>${name}</b><br>Atvinnuleysi: <b>${fmt(v)}</b>`
          + `<br><span style="color:#9fb0c8;font-size:12px">Landsmeðaltal: ${fmt(cfg.national)}</span>`,
        attribution: 'Mörk: geoBoundaries · Gögn: Vinnumálastofnun',
      });
    }
    document.addEventListener('astro:page-load', initAtvMap);
  </script>
</Layout>
