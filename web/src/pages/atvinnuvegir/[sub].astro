---
// Atvinnuvega-stubbar (LOTA 8 byggir raun-síðurnar úr skjalfestum PxWeb-töflum:
// SJA01101 afli, SJA07001 fiskeldi, SAM02001+SAM01601 ferðaþj., LAN10201/10102
// landbúnaður, UTA06105+IDN02103 stóriðja). Nav-parity á meðan. #2 LOTA 7.
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const S = {
    sjavarutvegur: { t: 'Sjávarútvegur', e: '🐟', d: 'Afli eftir mánuðum, fiskeldi og útflutningsverðmæti sjávarafurða — lifandi frá Hagstofu.' },
    ferdathjonusta: { t: 'Ferðaþjónusta', e: '🧳', d: 'Komur ferðamanna um Keflavík, gistinætur og lykiltölur greinarinnar.' },
    landbunadur: { t: 'Landbúnaður', e: '🌾', d: 'Kjötframleiðsla, búfé og framleiðsla landbúnaðarins.' },
    storidja: { t: 'Stóriðja & orka', e: '🏗️', d: 'Útflutningsverðmæti áls og kísiljárns og raforkunotkun stóriðjunnar.' },
    hugverk: { t: 'Hugverk & tækni', e: '💡', d: 'Hugverkaiðnaðurinn — fjórða stoðin: lyf, líftækni, hugbúnaður og tækniútflutningur.' },
  };
  return Object.keys(S).map((sub) => ({ params: { sub }, props: S[sub] }));
}
const { t, e, d } = Astro.props;
---

<Layout title={`${t} | Karp`} description={d} noindex={true}>
  <main>
    <div class="e">{e}</div>
    <h1>{t}</h1>
    <p>{d}</p>
    <p class="soon">🚧 Í smíðum í nýja appinu — kemur í næstu uppfærslu. Á meðan: <a href="https://www.karp.is">gamla mælaborðið á karp.is</a> og <a href="/orka/">Raforku-síðan</a>.</p>
  </main>
  <style>
    main { max-width: 620px; margin: 0 auto; padding: 70px 20px 64px; text-align: center; }
    .e { font-size: 52px; }
    h1 { font-size: 30px; margin: 10px 0; }
    p { color: #cdd6e6; }
    .soon { font-size: 13.5px; color: #9fb0c8; background: rgba(255,255,255,.04); border: 1px solid rgba(246,177,59,.35); border-radius: 12px; padding: 14px 16px; margin-top: 22px; }
    .soon a { color: #f6b13b; }
  </style>
</Layout>
