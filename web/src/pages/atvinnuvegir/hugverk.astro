---
// Hugverk & tækni: R&Þ-útgjöld % af VLF eftir framkvæmdaaðila (FYR05101) — byggingartíma-PxWeb (þolir bilun per hluta). #2 LOTA 10.
import Layout from '../../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
const px = async (path, query) => {
  const call = async () => (await fetch('https://px.hagstofa.is/pxis/api/v1/is/' + path, { method: 'POST', body: JSON.stringify({ query, response: { format: 'json' } }) })).json();
  try { return await call(); } catch (e) { await new Promise((r) => setTimeout(r, 1500)); return call(); }
};
const sel = (code, filter, values) => ({ code, selection: { filter, values } });
const num = (v) => { const n = parseFloat(String(v).replace(',', '.')); return isNaN(n) ? null : n; };
const curYear = 2026;

const ADILAR = { 1: ['Fyrirtæki', '#19d3c5'], 2: ['Háskólar', '#3a8dff'], 3: ['Opinberar stofnanir', '#c95cf7'] };
let C1 = null, C2 = null, rdL = null;
try {
  const j = await px('Atvinnuvegir/visinditaekni/rannsoknthroun/FYR05101.px', [sel('Eining', 'item', Object.keys(ADILAR)), sel('Niðurstöður', 'item', ['2']), sel('Ár', 'all', ['*'])]);
  const by = {};
  j.data.forEach((d) => { const y = d.key.find((k) => /^\d{4}$/.test(k)); const a = d.key.find((k) => ADILAR[k] && k.length === 1); const v = num(d.values[0]); if (y && a && v != null) ((by[a] = by[a] || {})[y] = v); });
  const ys = [...new Set(Object.values(by).flatMap((o) => Object.keys(o)))].sort();
  if (ys.length) {
    C1 = { x: ys, u: '% af VLF', series: Object.keys(ADILAR).filter((k) => by[k]).map((k) => ({ name: ADILAR[k][0], color: ADILAR[k][1], data: ys.map((y) => by[k][y] ?? null) })), stack: true };
    const l = ys[ys.length - 1];
    rdL = { y: l, v: Math.round(Object.keys(by).reduce((s, k) => s + (by[k][l] || 0), 0) * 100) / 100 };
  }
} catch (e) {}
const updated = '2026-07-02';

// 🆕 Nýskráð vörumerki (Hugverkastofan, api.hugverk.is — opið leitar-API) — vakt-feed, byggingartíma.
// registrationDateFrom = sl. 45 dagar → nýskráð vörumerki, nýjust fyrst. Sjá memory/iceland-hugverkastofa-api.md
const dIS = (iso) => { const [y, m, d] = String(iso || '').split('-'); return d ? +d + '.' + +m + '.' + y : ''; };
let VM = null, vmTotal = 0, vmFra = '';
try {
  const df = new Date(); df.setDate(df.getDate() - 45);
  vmFra = df.toISOString().slice(0, 10);
  const r = await fetch('https://api.hugverk.is/umbraco/api/search/searchtrademarks', {
    method: 'POST', headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ textfield: '', owner: [], agent: [], type: [], status: [], category: [], registrationDateFrom: vmFra, page: 1 }),
  });
  if (r.ok) {
    const j = await r.json();
    vmTotal = j.totalCount || 0;
    VM = (j.results || []).map((it) => it.document || {}).filter((x) => x.identifier).slice(0, 30).map((x) => ({
      id: x.identifier, titill: x.titleUnchanged || x.title || '', tegund: x.type || '',
      eigandi: (x.owner || []).map((o) => o.ownerName).filter(Boolean).join(', '),
      kt: String(((x.owner || [])[0] || {}).ownerSsn || '').replace(/\D/g, ''),
      flokkar: (x.category || []).slice(0, 6), skrad: dIS((x.registrationDate || '').slice(0, 10)),
      mynd: x.imagePath || '', url: 'https://www.hugverk.is/leit/trademark/' + x.identifier,
    }));
    if (!VM.length) VM = null;
  }
} catch (e) { VM = null; }

const desc = `Hugverkaiðnaðurinn — „fjórða stoðin": lyf, hugbúnaður, tölvuleikir og stoðtæki. Undirstaðan er rannsóknir og þróun${rdL ? ' — Ísland ver ' + String(rdL.v).replace('.', ',') + '% af VLF í R&Þ (' + rdL.y + ')' : ''}.${VM ? ' ' + vmTotal + ' ný vörumerki skráð sl. 45 daga.' : ''}`;
---
<Layout title="Hugverk & tækni | Karp" description={desc} canonical="https://karp.is/atvinnuvegir/hugverk/" ogTitle="Hugverk & tækni">
  <main data-pg="atvinnuvegir-hugverk">
    <p class="kicker">Hagvísir Íslands · Atvinnuvegir</p>
    <h1>Hugverk &amp; tækni 💡</h1>
    <p>„Fjórða stoðin" — útflutningstekjur hugverkaiðnaðar (lyf, hugbúnaður, tölvuleikir, stoðtæki; t.d. Alvotech, CCP, Össur) eru meðal stærstu gjaldeyrislinda Íslands en teljast til þjónustuútflutnings. Hér er sýnd undirstaðan: <strong>rannsóknir og þróun</strong>.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Hugverkaiðnaður: útflutnings- og veltutölur Hagstofunnar; flokkun fylgir atvinnugreinaflokkun hennar.">ⓘ</i> Um gögnin á síðunni</p>
    <div class="kpis">
      {rdL && <div class="kpi"><div class="k-l">🔬 R&Þ-útgjöld</div><div class="k-v">{String(rdL.v).replace('.', ',')}%</div><div class="k-s">af VLF · {rdL.y}</div></div>}
      {VM && <div class="kpi"><div class="k-l">🆕 Ný vörumerki</div><div class="k-v">{groupThousands(vmTotal)}</div><div class="k-s">skráð sl. 45 daga</div></div>}
    </div>
    {C1 && <><h2>R&Þ-útgjöld eftir framkvæmdaaðila (% af VLF)</h2><div id="c1"></div></>}

    {VM && <>
      <h2>🆕 Nýskráð vörumerki</h2>
      <p class="vm-sub">Nýjustu vörumerki skráð hjá Hugverkastofunni — hugverk í mótun. Smelltu á eiganda fyrir fyrirtækjaprófíl eða merki fyrir skráninguna á hugverk.is.</p>
      <div class="vm-feed">
        {VM.map((m) => (
          <div class="vm-row">
            {m.mynd
              ? <img class="vm-i" src={m.mynd} alt="" loading="lazy" />
              : <span class={'vm-i vm-ph'}>{m.tegund === 'myndmerki' ? '🖼️' : 'Ⓡ'}</span>}
            <div class="vm-main">
              <a class="vm-t" href={m.url} target="_blank" rel="noopener">{m.titill || m.id}</a>
              {m.kt
                ? <a class="vm-o" href={'/fyrirtaeki/?q=' + m.kt}>{m.eigandi}</a>
                : <span class="vm-o">{m.eigandi}</span>}
              {m.flokkar.length > 0 && <span class="vm-cat">Nice {m.flokkar.join(', ')}</span>}
            </div>
            <div class="vm-meta"><span class="vm-type">{m.tegund}</span><span class="vm-date">{m.skrad}</span></div>
          </div>
        ))}
      </div>
      <p class="vm-foot">Sýni {VM.length} af {groupThousands(vmTotal)} · <a href="https://www.hugverk.is/leit/vorumerki" target="_blank" rel="noopener">öll á hugverk.is ↗</a></p>
    </>}

    <p class="foot">Forþjónað (SSG) {updated}. Heimildir: Hagstofa (FYR05101, R&Þ) og Hugverkastofan (nýskráð vörumerki, lifandi). Fyrirtækin bera megnið af R&Þ — einkenni hugverkadrifins hagkerfis. #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; } p a { color: #f6b13b; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 16px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 24px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #c1, #c2 { width: 100%; height: 300px; }
    .vm-sub { font-size: 13px; color: #9fb0c8; margin: 4px 0 12px; line-height: 1.5; }
    .vm-feed { display: grid; gap: 7px; }
    .vm-row { display: flex; align-items: center; gap: 11px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 8px 12px; }
    .vm-i { width: 38px; height: 38px; flex: 0 0 38px; border-radius: 7px; object-fit: contain; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 17px; }
    .vm-ph { background: rgba(246,177,59,.14); color: #f6b13b; }
    .vm-main { flex: 1 1 auto; min-width: 0; display: flex; flex-wrap: wrap; align-items: baseline; gap: 2px 10px; }
    .vm-t { font-size: 14px; font-weight: 700; color: #eaf1fb; text-decoration: none; }
    .vm-t:hover { color: #f6b13b; }
    .vm-o { font-size: 12.5px; color: #9fb0c8; text-decoration: none; }
    .vm-o:hover { color: #f6b13b; }
    .vm-cat { font-size: 10.5px; color: #6f7b8d; }
    .vm-meta { flex: 0 0 auto; text-align: right; }
    .vm-type { display: block; font-size: 11px; color: #7e8ca6; }
    .vm-date { display: block; font-size: 11px; color: #9fb0c8; font-variant-numeric: tabular-nums; }
    .vm-foot { font-size: 11.5px; color: #6f7b8d; margin: 8px 2px 0; } .vm-foot a { color: #f6b13b; }
    @media (max-width: 560px) { .vm-cat { display: none; } }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <script define:vars={{ C1, C2 }}>
    function initAtv() {
      const e1 = document.getElementById('c1');
      if (!e1 && !document.getElementById('c2')) return;
      const go = () => {
        [['c1', C1]].forEach(([id, C]) => {
          const el = document.getElementById(id);
          if (!el || !C || window.echarts.getInstanceByDom(el)) return;
          const c = window.echarts.init(el);
          c.setOption({
            backgroundColor: 'transparent',
            legend: C.series.length > 1 ? { data: C.series.map((s) => s.name), textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0 } : undefined,
            grid: { left: 52, right: 14, top: C.series.length > 1 ? 30 : 12, bottom: 24 },
            xAxis: { type: 'category', data: C.x, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ',') + ' ' + C.u) },
            series: C.series.map((s) => ({ name: s.name, type: C.type || 'line', stack: C.stack ? 'st' : undefined, data: s.data, smooth: true, symbol: 'none', lineStyle: { width: C.stack ? 0 : 2.5, color: s.color }, itemStyle: { color: s.color }, areaStyle: C.area || C.stack ? { color: s.color, opacity: C.stack ? 0.75 : 0.12 } : undefined })),
          });
          window.addEventListener('resize', () => c.resize());
        });
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="atvinnuvegir-hugverk"]')) initAtv(); });
  </script>
</Layout>
