---
// Landbúnaður — kjöt (LAN10201) + búfé (LAN10102) + uppskera/mjólk/korn/grænmeti (LAN10103)
// + útflutningur búvara (UTA06105 fl.11) + framleiðsluvirði (LAN1101) + Matvælasjóðs-úthlutanir (styrkir.json).
// Hagstofu-hlutar: daglegt snapshot úr skriptur/build_landbunadur.mjs → gogn/landbunadur.json
// (áður sótt beint á Hagstofu í frontmatter á hverri byggingu → seigla per hluta). Styrkir áfram bakað-inn import. #2 LOTA 10.
import Layout from '../../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import STYRKIR from '@gogn/styrkir.json';
import DATA from '@gogn/landbunadur.json';

const { C1, C2, C3, C4, C5, C6, C7, kjotL, milkL, grainL, expL, valL, updated } = DATA;

// 8. Matvælasjóður — úthlutanir úr styrkjaskrá (bakað-inn @gogn/styrkir.json, ekki Hagstofu-sókn) ----
let C8 = null, grantK = null;
try {
  const mat = (STYRKIR.styrkir || []).filter((s) => s.sjodur === 'Matvælasjóður');
  if (mat.length) {
    const byY = {};
    mat.forEach((s) => { if (s.ar) byY[s.ar] = (byY[s.ar] || 0) + (s.upphaed || 0); });
    const gys = Object.keys(byY).map(String).sort();
    C8 = { x: gys, u: 'm.kr', type: 'bar', series: [{ name: 'Úthlutað', color: '#46e08a', data: gys.map((y) => Math.round(byY[y] / 1e6)) }] };
    const total = mat.reduce((s, x) => s + (x.upphaed || 0), 0);
    const top = mat.filter((s) => s.upphaed).sort((a, b) => b.upphaed - a.upphaed).slice(0, 8);
    grantK = { count: mat.length, total, top, minAr: gys[0], maxAr: gys[gys.length - 1] };
  }
} catch (e) {}
const styrkKr = (n) => (n >= 1e6 ? fmtNum(n / 1e6, 1) + ' m.kr' : groupThousands(Math.round(n)) + ' kr');

const desc = `Landbúnaður á Íslandi — kjöt${kjotL ? ' ' + groupThousands(kjotL.v) + ' tonn' : ''}, mjólk${milkL ? ' ' + milkL.v + ' þús. tonn' : ''}, grænmeti, kornrækt, útflutningur búvara${expL ? ' ' + fmtNum(expL.v, 1) + ' ma.kr' : ''} og úthlutanir Matvælasjóðs. Lifandi frá Hagstofu.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Landbúnaður á Íslandi', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland' };
---
<Layout title="Landbúnaður | Karp" description={desc} canonical="https://karp.is/atvinnuvegir/landbunadur/" jsonLd={jsonLd} ogTitle="Landbúnaður">
  <main data-pg="atvinnuvegir-landbunadur">
    <p class="kicker">Hagvísir Íslands · Atvinnuvegir</p>
    <h1>Landbúnaður 🌾</h1>
    <p>Íslenskur landbúnaður er sjálfum sér nógur um mjólk, egg og lambakjöt en flytur inn stóran hluta korns og grænmetis. Hér er framleiðslan eftir tegundum, þróun bústofnsins, útflutningur búvara og úthlutanir <a href="/styrkir/">Matvælasjóðs</a>.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Landbúnaðartölur: framleiðslu-, búfjár- og uppskerutölur Hagstofunnar (LAN), útflutningur úr utanríkisverslun (UTA06105) og styrkir úr úthlutunarskrá Matvælasjóðs.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      {kjotL && <div class="kpi"><div class="k-l">🥩 Kjötframleiðsla</div><div class="k-v">{groupThousands(kjotL.v)}</div><div class="k-s">tonn · {kjotL.y}</div></div>}
      {milkL && <div class="kpi"><div class="k-l">🥛 Mjólk</div><div class="k-v">{milkL.v}</div><div class="k-s">þús. tonn · {milkL.y}</div></div>}
      {grainL && <div class="kpi"><div class="k-l">🌾 Kornuppskera</div><div class="k-v">{groupThousands(grainL.v)}</div><div class="k-s">tonn · {grainL.y}</div></div>}
      {expL && <div class="kpi"><div class="k-l">🚢 Útflutningur búvara</div><div class="k-v">{fmtNum(expL.v, 1)}</div><div class="k-s">ma.kr · {expL.y}</div></div>}
      {valL && <div class="kpi"><div class="k-l">💰 Framleiðsluvirði</div><div class="k-v">{groupThousands(valL.v)}</div><div class="k-s">ma.kr · {valL.y}</div></div>}
    </div>

    <div class="ppair">
      {C1 && <div><h2>Kjötframleiðsla eftir tegundum</h2><div id="c1"></div></div>}
      {C2 && <div><h2>Bústofninn — nautgripir og sauðfé</h2><div id="c2"></div></div>}
    </div>
    <div class="ppair">
      {C3 && <div><h2>Mjólkurframleiðsla</h2><div id="c3"></div></div>}
      {C5 && <div><h2>Kornuppskera (bygg, hafrar, hveiti)</h2><div id="c5"></div></div>}
    </div>
    <div class="ppair">
      {C4 && <div><h2>Grænmetisframleiðsla eftir tegundum</h2><div id="c4"></div></div>}
      {C6 && <div><h2>Útflutningur landbúnaðarafurða</h2><div id="c6"></div></div>}
    </div>
    {C7 && <><h2>Framleiðsluvirði landbúnaðar á framleiðsluverði (verð til bænda)</h2><div id="c7"></div></>}

    {grantK && (
      <section class="grant">
        <h2>🥬 Matvælasjóður — úthlutaðir styrkir</h2>
        <p class="gsub">Matvælasjóður styrkir þróun og nýsköpun í matvælaframleiðslu. Skráðar úthlutanir {grantK.minAr}–{grantK.maxAr} úr <a href="/styrkir/">styrkjaskrá Karp</a>.</p>
        <div class="kpis">
          <div class="kpi"><div class="k-l">Heildarúthlutun</div><div class="k-v">{fmtNum(grantK.total / 1e6, 0)}</div><div class="k-s">m.kr · {grantK.minAr}–{grantK.maxAr}</div></div>
          <div class="kpi"><div class="k-l">Fjöldi styrkja</div><div class="k-v">{grantK.count}</div><div class="k-s">skráðar úthlutanir</div></div>
        </div>
        {C8 && <><h2 class="gsm">Úthlutað eftir árum</h2><div id="c8"></div></>}
        <h2 class="gsm">Stærstu einstöku styrkir</h2>
        <ol class="glist">
          {grantK.top.map((s) => (
            <li><span class="gn">{s.nafn}</span><span class="gmeta">{s.flokkur ? s.flokkur + ' · ' : ''}{s.ar}</span><span class="gu">{styrkKr(s.upphaed)}</span></li>
          ))}
        </ol>
      </section>
    )}

    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Heimildir: Hagstofa (LAN10201 kjöt, LAN10102 búfé, LAN10103 uppskera/mjólk, LAN1101 framleiðsluvirði, UTA06105 útflutningur) og Matvælasjóður (úthlutunarskrá). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; } p a { color: #f6b13b; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 16px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 24px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #c1, #c2, #c3, #c4, #c5, #c6, #c7, #c8 { width: 100%; height: 300px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .grant { margin-top: 30px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 6px; }
    .gsub { font-size: 13px; color: #9fb0c8; }
    h2.gsm { font-size: 13px; margin: 22px 0 8px; }
    .glist { list-style: none; padding: 0; margin: 6px 0 0; }
    .glist li { display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 4px 12px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .glist .gn { font-weight: 600; color: #e8eefb; font-size: 14px; }
    .glist .gmeta { grid-column: 1; font-size: 11px; color: #7e8ca6; }
    .glist .gu { grid-row: 1 / span 2; align-self: center; color: #46e08a; font-weight: 700; font-variant-numeric: tabular-nums; font-size: 14px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <script define:vars={{ charts: { c1: C1, c2: C2, c3: C3, c4: C4, c5: C5, c6: C6, c7: C7, c8: C8 } }}>
    function initAtv() {
      const ids = Object.keys(charts);
      if (!ids.some((id) => document.getElementById(id))) return;
      const go = () => {
        ids.forEach((id) => {
          const el = document.getElementById(id); const C = charts[id];
          if (!el || !C || window.echarts.getInstanceByDom(el)) return;
          const c = window.echarts.init(el);
          c.setOption({
            backgroundColor: 'transparent',
            legend: C.series.length > 1 ? { data: C.series.map((s) => s.name), textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0 } : undefined,
            grid: { left: 52, right: 14, top: C.series.length > 1 ? 30 : 12, bottom: 24 },
            xAxis: { type: 'category', data: C.x, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ',') + ' ' + C.u) },
            series: C.series.map((s) => ({ name: s.name, type: C.type || 'line', stack: C.stack ? 'st' : undefined, data: s.data, smooth: C.type === 'bar' ? false : true, symbol: 'none', barMaxWidth: 22, lineStyle: { width: C.stack || C.type === 'bar' ? 0 : 2.5, color: s.color }, itemStyle: { color: s.color, borderRadius: C.type === 'bar' ? [3, 3, 0, 0] : 0 }, areaStyle: C.area || C.stack ? { color: s.color, opacity: C.stack ? 0.75 : 0.14 } : undefined })),
          });
          window.addEventListener('resize', () => c.resize());
        });
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="atvinnuvegir-landbunadur"]')) initAtv(); });
  </script>
</Layout>
