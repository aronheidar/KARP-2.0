---
// Stóriðja & orka (auðgað) — álverð (LME/Yahoo ALI=F), útflutningsverðmæti (UTA06105 fl.15/13),
// raforkunotkun stóriðju vs almenn + eftir grein (IDN02103), ferlalosun málmframleiðslu (UMH31107 2.C)
// og framleiðslugeta álveranna þriggja. Gögn: daglegt snapshot úr skriptur/build_storidja.mjs → gogn/storidja.json
// (áður byggingartíma-sókn á hverri byggingu → nú seigla + saga). Framleiðslugeta álvera er harðkóðuð hér. #2 LOTA 10 → auðgað.
import Layout from '../../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import DATA from '@gogn/storidja.json';

const { C_price, priceL, C_export, alL, C_use, C_sector, heavyPct, useY, C_emis, emisL, emisChg, updated } = DATA;

// 6. Álverin þrjú — framleiðslugeta (heimild: fyrirtækin) — harðkóðað (engin sókn) --------
const SMELT = [['Alcoa Fjarðaál', 344], ['Norðurál Grundartanga', 340], ['Rio Tinto ISAL', 212]];
const C_smelt = { kind: 'hbar', u: 'þús. tonn/ári', showLabel: true, gridLeft: 158, x: SMELT.map((s) => s[0]), series: [{ name: 'Framleiðslugeta', color: '#f6b13b', data: SMELT.map((s) => s[1]) }] };
const smeltTot = SMELT.reduce((s, x) => s + x[1], 0);
const desc = `Stóriðjan á Íslandi — álverð${priceL ? ' ' + groupThousands(priceL.v) + ' USD/tonn' : ''}, útflutningsverðmæti áls${alL && alL.al != null ? ' ' + fmtNum(alL.al, 0) + ' ma.kr' : ''}, raforkunotkun${heavyPct ? ' (stóriðja ' + fmtNum(heavyPct, 0) + '% raforkunnar)' : ''}, losun og framleiðslugeta álveranna þriggja. Lifandi frá Hagstofu, Orkustofnun og LME.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Stóriðja og orka á Íslandi', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland' };
---
<Layout title="Stóriðja & orka | Karp" description={desc} canonical="https://karp.is/atvinnuvegir/storidja/" jsonLd={jsonLd} ogTitle="Stóriðja & orka">
  <main data-pg="atvinnuvegir-storidja">
    <p class="kicker">Hagvísir Íslands · Atvinnuvegir</p>
    <h1>Stóriðja &amp; orka 🏗️</h1>
    <p>Álverin þrjú og kísilverin breyta endurnýjanlegri raforku í útflutningsverðmæti — stóriðjan notar um 80% raforkunnar. Afkoman ræðst mjög af heimsmarkaðsverði á áli. Sjá einnig <a href="/orka/">Raforku</a> fyrir framleiðsluhliðina.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Álverð: framvirkt LME-verð gegnum Yahoo Finance. Útflutningsverðmæti: utanríkisverslun Hagstofunnar (UTA06105). Raforkunotkun: Orkustofnun/Hagstofa (IDN02103, til 2019). Losun: gróðurhúsalofttegundabókhald Íslands (UMH31107). Framleiðslugeta álvera: uppgefin af fyrirtækjunum.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      {priceL && <div class="kpi"><div class="k-l">📈 Álverð (LME)</div><div class="k-v">{groupThousands(priceL.v)}</div><div class="k-s">USD/tonn</div></div>}
      {alL && alL.al != null && <div class="kpi"><div class="k-l">🥫 Ál — útflutningur</div><div class="k-v">{fmtNum(alL.al, 0)}</div><div class="k-s">ma.kr · {alL.y}</div></div>}
      {heavyPct && <div class="kpi"><div class="k-l">⚡ Stóriðja af raforku</div><div class="k-v">{fmtNum(heavyPct, 0)}%</div><div class="k-s">{useY}</div></div>}
      <div class="kpi"><div class="k-l">🏭 Framleiðslugeta áls</div><div class="k-v">{groupThousands(smeltTot)}</div><div class="k-s">þús. tonn/ári</div></div>
      {emisL && <div class="kpi"><div class="k-l">🌫️ Ferlalosun (2.C)</div><div class="k-v">{fmtNum(emisL.v, 0)}</div><div class="k-s">kt CO₂-íg · {emisL.y}</div></div>}
    </div>

    {C_price && <><h2>Álverð — LME framvirkt (10 ár)</h2><div id="cPrice"></div></>}

    <div class="ppair">
      {C_export && <div><h2>Útflutningsverðmæti frá 1995</h2><div id="cExport"></div></div>}
      <div><h2>Framleiðslugeta álveranna þriggja</h2><div id="cSmelt"></div><p class="src">Uppgefin ársgeta ≈ {groupThousands(smeltTot)} þús. tonn. Heimild: fyrirtækin.</p></div>
    </div>
    <div class="ppair">
      {C_use && <div><h2>Raforkunotkun — stóriðja vs. almenn</h2><div id="cUse"></div></div>}
      {C_sector && <div><h2>Raforka stóriðju eftir grein</h2><div id="cSector"></div></div>}
    </div>

    {C_emis && (
      <>
        <h2>Ferlalosun frá málmframleiðslu</h2>
        <p class="src">Raforkan er nær eingöngu endurnýjanleg, svo kolefnisspor stóriðjunnar liggur einkum í ferlalosun (flúorkolefni og kolaskaut) sem fellur undir viðskiptakerfi ESB með losunarheimildir (ETS).{emisChg != null ? ' Ferlalosun málmframleiðslu hefur ' + (emisChg < 0 ? 'lækkað' : 'hækkað') + ' um ' + Math.abs(emisChg) + '% frá upphafi mælinga.' : ''}</p>
        <div id="cEmis"></div>
      </>
    )}

    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Heimildir: LME/Yahoo Finance (álverð), Hagstofa (UTA06105 útflutningur, IDN02103 raforka til 2019, UMH31107 losun) og fyrirtækin (framleiðslugeta). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; } p a { color: #f6b13b; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 16px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 24px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #cPrice, #cExport, #cSmelt, #cUse, #cSector, #cEmis { width: 100%; height: 300px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .src { font-size: 11.5px; color: #7e8ca6; margin: 6px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <script define:vars={{ charts: { cPrice: C_price, cExport: C_export, cSmelt: C_smelt, cUse: C_use, cSector: C_sector, cEmis: C_emis } }}>
    function initAtv() {
      const ids = Object.keys(charts);
      if (!ids.some((id) => document.getElementById(id))) return;
      const go = () => {
        ids.forEach((id) => {
          const el = document.getElementById(id); const C = charts[id];
          if (!el || !C || window.echarts.getInstanceByDom(el)) return;
          const horiz = C.kind === 'hbar'; const isBar = horiz || C.kind === 'bar';
          const catAxis = { type: 'category', data: C.x, inverse: horiz, boundaryGap: true, axisLabel: { color: '#9fb0c8', fontSize: horiz ? 11 : 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } }, axisTick: { show: !horiz } };
          const valAxis = { type: 'value', max: C.max, min: C.min, axisLabel: { color: '#7e8ca6', formatter: C.pct ? '{value}%' : undefined }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } };
          const c = window.echarts.init(el);
          c.setOption({
            backgroundColor: 'transparent',
            legend: C.series.length > 1 ? { data: C.series.map((s) => s.name), textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0, type: 'scroll' } : undefined,
            grid: { left: horiz ? (C.gridLeft || 130) : 52, right: horiz ? 52 : 14, top: C.series.length > 1 ? 30 : 12, bottom: 24 },
            xAxis: horiz ? valAxis : catAxis,
            yAxis: horiz ? catAxis : valAxis,
            tooltip: { trigger: 'axis', axisPointer: { type: isBar ? 'shadow' : 'line' }, valueFormatter: (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ',') + ' ' + C.u) },
            series: C.series.map((s) => ({
              name: s.name, type: isBar ? 'bar' : 'line', stack: C.stack ? 'st' : undefined, data: s.data, smooth: isBar ? false : true, symbol: 'none', barMaxWidth: horiz ? 22 : 24,
              label: C.showLabel ? { show: true, position: horiz ? 'right' : 'top', color: '#9fb0c8', fontSize: 10, formatter: (p) => (p.value == null ? '' : String(Math.round(p.value)).replace(/\B(?=(\d{3})+(?!\d))/g, '.')) } : undefined,
              lineStyle: { width: C.stack || isBar ? 0 : 2.5, color: s.color },
              itemStyle: { color: s.color, borderRadius: isBar ? (horiz ? [0, 3, 3, 0] : [3, 3, 0, 0]) : 0 },
              areaStyle: (C.area || C.stack) && !isBar ? { color: s.color, opacity: C.stack ? 0.75 : 0.14 } : undefined,
            })),
          });
          window.addEventListener('resize', () => c.resize());
        });
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="atvinnuvegir-storidja"]')) initAtv(); });
  </script>
</Layout>
