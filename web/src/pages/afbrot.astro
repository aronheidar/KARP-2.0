---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Afbrot og öryggi: hegningarlagabrot á 10.000 íbúa,
// landsþróun 2001–2024 + eftir landshlutum + eftir brotaflokkum (glaepir.json).
// Í app-skelinni (Layout). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum } from '@lib/format.mjs';
import GLAEPIR from '@gogn/glaepir.json';

const nat = GLAEPIR.national || {};
const byReg = GLAEPIR.byRegion || {};
const year = GLAEPIR.year || 2024;
const series = nat.series || [];
const first = series[0], last = series[series.length - 1];
const change = first && last ? ((last.v - first.v) / first.v) * 100 : null;

const trendYears = series.map((s) => s.y);
const trendVals = series.map((s) => s.v);

const regionBars = Object.keys(byReg).map((n) => ({ label: n, v: byReg[n].hegn })).sort((a, b) => b.v - a.v);
const CATLABELS = { audgun: 'Auðgunarbrot', ofbeldi: 'Ofbeldisbrot', eignsp: 'Eignaspjöll', fikni: 'Fíkniefnabrot', kynf: 'Kynferðisbrot' };
const catBars = Object.keys(CATLABELS).filter((k) => nat.cats && nat.cats[k] != null).map((k) => ({ label: CATLABELS[k], v: nat.cats[k] })).sort((a, b) => b.v - a.v);

const hi = regionBars[0], lo = regionBars[regionBars.length - 1];
const updated = '2026-07-01';
const desc = `Afbrot á Íslandi — ${fmtNum(nat.hegn, 1)} hegningarlagabrot á 10.000 íbúa árið ${year}${change != null ? ` (${change > 0 ? '+' : ''}${fmtNum(change, 0)}% frá 2001)` : ''}. Þróun, landshlutar og brotaflokkar úr gögnum Ríkislögreglustjóra.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: 'Afbrot á Íslandi',
  description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: `${year}-12-31`, spatialCoverage: 'Ísland', variableMeasured: 'Hegningarlagabrot á 10.000 íbúa',
};
---

<Layout title="Afbrot og öryggi | Karp" description={desc} canonical="https://app.karp.is/afbrot/" jsonLd={jsonLd} ogTitle="Afbrot á Íslandi">
  <main>
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Afbrot og öryggi</h1>
    <p>Hegningarlagabrot á 10.000 íbúa árið {year}: <strong>{fmtNum(nat.hegn, 1)}</strong>{change != null ? <> — {change > 0 ? 'hækkun' : 'lækkun'} um {fmtNum(Math.abs(change), 0)}% frá 2001</> : ''}. Heimild: Ríkislögreglustjóri.</p>

    <div class="kpis">
      <div class="kpi"><div class="k-l">🚓 Hegningarlagabrot</div><div class="k-v">{fmtNum(nat.hegn, 1)}</div><div class="k-s">á 10þ · {year}</div></div>
      <div class="kpi"><div class="k-l">📉 Frá 2001</div><div class={`k-v ${change < 0 ? 'good' : ''}`}>{change != null ? (change > 0 ? '+' : '') + fmtNum(change, 0) + '%' : '–'}</div><div class="k-s">breyting</div></div>
      <div class="kpi"><div class="k-l">⬆️ Hæst</div><div class="k-v">{hi ? fmtNum(hi.v, 0) : '–'}</div><div class="k-s">{hi?.label}</div></div>
      <div class="kpi"><div class="k-l">⬇️ Lægst</div><div class="k-v">{lo ? fmtNum(lo.v, 0) : '–'}</div><div class="k-s">{lo?.label}</div></div>
    </div>

    <h2>Landsþróun 2001–{year}</h2>
    <div id="chart-trend"></div>

    <h2>Eftir landshlutum ({year})</h2>
    <div id="chart-region"></div>

    <h2>Eftir brotaflokkum ({year})</h2>
    <div id="chart-cat"></div>

    <p class="note">ⓘ Fjöldi brota á 10.000 íbúa. Umferðarlagabrot eru undanskilin flokkasúluritinu (annað eðli og margfalt hærri tíðni). Afbrot fást aðeins eftir lögregluumdæmi (≈landshluta), ekki sveitarfélagi.</p>
    <p class="foot">Forþjónað (SSG) {updated}. Heimild: Ríkislögreglustjóri (afbrotatölfræði). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 11px 13px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 24px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-v.good { color: #46e08a; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #chart-trend { width: 100%; height: 300px; }
    #chart-region, #chart-cat { width: 100%; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: 3 gröf (þróun/landshlutar/flokkar), astro:page-load. #2 -->
  <script define:vars={{ trendYears, trendVals, regionBars, catBars }}>
    function initCharts() {
      const ct = document.getElementById('chart-trend');
      if (!ct) return;
      const barOpt = (data, color) => ({
        backgroundColor: 'transparent', grid: { left: 118, right: 44, top: 6, bottom: 20 },
        xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        yAxis: { type: 'category', inverse: true, data: data.map((d) => d.label), axisLabel: { color: '#cdd6e6', fontSize: 11 }, axisLine: { show: false }, axisTick: { show: false } },
        tooltip: { trigger: 'axis', valueFormatter: (v) => Math.round(v) },
        series: [{ type: 'bar', barWidth: 14, data: data.map((d) => d.v), itemStyle: { color }, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10, formatter: (p) => Math.round(p.value) } }],
      });
      const go = () => {
        if (!window.echarts.getInstanceByDom(ct)) {
          const c = window.echarts.init(ct);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 44, right: 16, top: 12, bottom: 26 },
            xAxis: { type: 'category', data: trendYears, axisLabel: { color: '#7e8ca6' }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => Math.round(v) + ' /10þ' },
            series: [{ type: 'line', data: trendVals, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#f6b13b' }, areaStyle: { opacity: 0.12, color: '#f6b13b' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cr = document.getElementById('chart-region');
        if (cr && !window.echarts.getInstanceByDom(cr)) { cr.style.height = (regionBars.length * 28 + 26) + 'px'; const c = window.echarts.init(cr); c.setOption(barOpt(regionBars, '#ff6d7a')); window.addEventListener('resize', () => c.resize()); }
        const cc = document.getElementById('chart-cat');
        if (cc && !window.echarts.getInstanceByDom(cc)) { cc.style.height = (catBars.length * 30 + 26) + 'px'; const c = window.echarts.init(cc); c.setOption(barOpt(catBars, '#7c5cf7')); window.addEventListener('resize', () => c.resize()); }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', initCharts);
  </script>
</Layout>
