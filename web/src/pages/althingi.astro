  <!-- Eyja: grúppað lárétt súlurit (Nú vs Spá) -->
  <script define:vars={{ chartNames, chartCur, chartProj }}>
    function initChart() {
      const el = document.getElementById('chart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initChart, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      el.style.height = (chartNames.length * 46 + 60) + 'px';
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        legend: { data: ['Nú', 'Spá'], textStyle: { color: '#9fb0c8' }, top: 0 },
        grid: { left: 110, right: 34, top: 34, bottom: 20 },
        xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        yAxis: {
          type: 'category', inverse: true, data: chartNames,
          axisLabel: { color: '#cdd6e6', fontSize: 12 }, axisLine: { show: false }, axisTick: { show: false },
        },
        tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
        series: [
          { name: 'Nú', type: 'bar', data: chartCur, barGap: 0, itemStyle: { color: '#42506a' },
            label: { show: true, position: 'right', color: '#7e8ca6', fontSize: 10 } },
          { name: 'Spá', type: 'bar', data: chartProj,
            label: { show: true, position: 'right', color: '#eaf1fb', fontSize: 11, fontWeight: 'bold' } },
        ],
      });
      window.addEventListener('resize', () => chart.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi"]')) initChart(); });
  </script>

  <!-- Eyja: þingsalurinn (raun-sætaskipan, scatter). Keyrir á astro:page-load (VT). #2 -->
  <script define:vars={{ SEATDATA }}>
    function initSeats() {
      const el = document.getElementById('seatchart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initSeats, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const byParty = {};
      SEATDATA.forEach((s) => {
        (byParty[s.f] = byParty[s.f] || []).push({
          value: [s.x, s.y], id: s.id, nafn: s.n, fl: s.f, role: s.r, slug: s.s, ini: s.i,
          itemStyle: s.r ? { borderColor: '#ffd479', borderWidth: 2.5 } : { borderColor: 'rgba(4,8,16,.5)', borderWidth: 1 },
        });
      });
      const order = Object.keys(byParty).sort((a, b) => byParty[b].length - byParty[a].length);
      const pcol = {};
      SEATDATA.forEach((s) => { pcol[s.f] = s.c; });
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        legend: { type: 'scroll', top: 0, textStyle: { color: '#aab6cc', fontSize: 12 }, inactiveColor: '#3a455e', itemGap: 12 },
        tooltip: { trigger: 'item', backgroundColor: 'rgba(9,14,26,.95)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12.5 },
          formatter: (p) => `<b>${p.data.nafn}</b><br>${p.data.fl}${p.data.role ? `<br><span style="color:#ffd479">${p.data.role}</span>` : ''}${p.data.slug ? '<br><span style="color:#19d3c5">Smelltu fyrir síðu →</span>' : ''}` },
        grid: { left: 10, right: 10, top: 34, bottom: 16 },
        xAxis: { type: 'value', min: -3, max: 47, show: false },
        yAxis: { type: 'value', min: -1.5, max: 33, show: false, inverse: true },
        series: order.map((p) => ({
          name: p, type: 'scatter', symbolSize: 21, emphasis: { focus: 'series', scale: 1.25 },
          itemStyle: { color: pcol[p], opacity: 0.97 },
          label: { show: true, position: 'inside', fontSize: 8, fontWeight: 700, color: '#06101c', formatter: (d) => d.data.ini },
          data: byParty[p],
        })),
      });
      // Smellur á sæti opnar GLUGGA (MpModal); fullu síðurnar haldast fyrir SEO.
      chart.on('click', (p) => {
        if (!p.data) return;
        if (window.karpMpOpen && p.data.id) window.karpMpOpen(p.data.id);
        else if (p.data.slug) window.location.href = '/althingi/' + p.data.slug + '/';
      });
      window.addEventListener('resize', () => chart.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi"]')) initSeats(); });
  </script>

  <!-- Eyja: pólitíska kortið (mx/my forreiknað úr nafnaköllum) + ráðherra-smellir. #2 LOTA 12 -->
  <script define:vars={{ POLD, PCOL, SPQ, SPKEY }}>
    function initPolMap() {
      const el = document.getElementById('polmap');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initPolMap, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const ini = (n) => { const w = String(n).split(/\s+/).filter(Boolean); return ((w[0] || ' ')[0] + (w.length > 1 ? w[w.length - 1][0] : '')).toUpperCase(); };
      const fmt = (v) => String(v).replace('.', ',');
      const byP = {};
      POLD.forEach((m) => { (byP[m.f] = byP[m.f] || []).push(m); });
      const order = Object.keys(byP).sort((a, b) => byP[b].length - byP[a].length);
      const series = order.map((p) => ({
        name: p, type: 'scatter', symbolSize: 15, emphasis: { focus: 'series', scale: 1.45 },
        itemStyle: { color: PCOL[p], borderColor: 'rgba(4,8,16,.5)', borderWidth: 1, opacity: 0.92 },
        label: { show: true, position: 'top', distance: 3, fontSize: 8.5, color: '#9fb0c8', formatter: (d) => ini(d.data.n) },
        labelLayout: { hideOverlap: true },
        data: byP[p].map((m) => ({ value: m.v, id: m.id, n: m.n, f: m.f, ho: m.ho, up: m.up, ne: m.ne })),
      }));
      series[0].markLine = { silent: true, symbol: 'none', lineStyle: { color: 'rgba(255,255,255,.1)', type: 'dashed' }, data: [{ xAxis: 0 }, { yAxis: 0 }] };
      // ÞÚ á kortinu (LOTA 15b): stefnuprófs-svör → samsvörun við flokka → vegin staða flokkamiðja
      try {
        const ans = JSON.parse(localStorage.getItem('karp-stefnuprof') || '{}');
        if (Object.keys(ans).length >= 4 && SPQ && SPQ.length) {
          const score = {}, max = {};
          SPQ.forEach((q) => { const a = ans[q.id]; if (!a) return; Object.keys(q.stance).forEach((k) => { max[k] = (max[k] || 0) + 1; if (q.stance[k] === a) score[k] = (score[k] || 0) + 1; }); });
          const cent = {};
          POLD.forEach((m) => { (cent[m.f] = cent[m.f] || []).push(m.v); });
          let sx = 0, sy = 0, sw = 0;
          Object.keys(max).forEach((k) => {
            const name = SPKEY[k], pts = cent[name];
            if (!pts || !max[k]) return;
            const cx = pts.reduce((a2, p) => a2 + p[0], 0) / pts.length;
            const cy = pts.reduce((a2, p) => a2 + p[1], 0) / pts.length;
            const w = Math.pow((score[k] || 0) / max[k], 2);
            sx += cx * w; sy += cy * w; sw += w;
          });
          if (sw > 0) {
            series.push({ name: 'ÞÚ', type: 'effectScatter', symbol: 'pin', symbolSize: 34, zlevel: 5,
              rippleEffect: { brushType: 'stroke', scale: 2.6 },
              itemStyle: { color: '#ffd479', borderColor: '#06101c', borderWidth: 1.5 },
              label: { show: true, position: 'inside', formatter: 'ÞÚ', fontSize: 9, fontWeight: 800, color: '#06101c' },
              tooltip: { formatter: 'Áætluð staða ÞÍN út frá stefnuprófinu — vegið meðaltal flokkamiðja eftir samsvörun svara þinna. Nálgun, ekki nafnakallsmæling.' },
              data: [{ value: [sx / sw, sy / sw] }] });
          }
        }
      } catch (e) {}
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        legend: { type: 'scroll', top: 0, textStyle: { color: '#aab6cc', fontSize: 12 }, inactiveColor: '#3a455e', itemGap: 13, pageTextStyle: { color: '#aab6cc' }, pageIconColor: '#aab6cc', pageIconInactiveColor: '#3a455e' },
        tooltip: { trigger: 'item', backgroundColor: 'rgba(9,14,26,.95)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12.5 },
          formatter: (p) => { const d = p.data; return `<b>${esc(d.n)}</b><br>${esc(d.f)}${d.ho != null ? '<br>Flokkshollusta ' + fmt(d.ho) + '%' : ''}${d.up ? ' · ' + d.up + '× á móti flokki' : ''}${d.ne ? '<br>' + d.ne + ' fastanefndir' : ''}<br><span style="color:#19d3c5">Smelltu fyrir nánar →</span>`; } },
        grid: { left: 10, right: 10, top: 38, bottom: 24 },
        xAxis: { type: 'value', min: -108, max: 108, show: false },
        yAxis: { type: 'value', min: -108, max: 108, show: false },
        graphic: [
          { type: 'text', left: '4%', top: 'middle', style: { text: '◄ Ríkisstjórn', fill: '#56657f', font: '600 12.5px Inter, sans-serif' } },
          { type: 'text', right: '4%', top: 'middle', style: { text: 'Stjórnarandstaða ►', fill: '#56657f', font: '600 12.5px Inter, sans-serif' } },
        ],
        series,
      });
      chart.on('click', (p) => { if (p.data && p.data.id && window.karpMpOpen) window.karpMpOpen(p.data.id); });
      window.addEventListener('resize', () => chart.resize());
    }
    function initCabClicks() {
      document.querySelectorAll('.cab-clk[data-id]').forEach((b) => {
        b.addEventListener('click', () => { const id = +b.getAttribute('data-id'); if (window.karpMpOpen && id) window.karpMpOpen(id); });
      });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi"]')) { initPolMap(); initCabClicks(); } });
  </script>

  <!-- Eyja: þingfundadagatalið (mánaðarsýn + dagsupplýsingar). #2 LOTA 12 -->
  <script define:vars={{ DAGATAL }}>
    function initDagatal() {
      const grid = document.getElementById('dg-grid');
      if (!grid || grid.dataset.ready) return;
      grid.dataset.ready = '1';
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const cap = (s) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
      const pad2 = (n) => (n < 10 ? '0' + n : '' + n);
      const MNF = ['janúar', 'febrúar', 'mars', 'apríl', 'maí', 'júní', 'júlí', 'ágúst', 'september', 'október', 'nóvember', 'desember'];
      const MN = ['jan.', 'feb.', 'mars', 'apríl', 'maí', 'júní', 'júlí', 'ágúst', 'sept.', 'okt.', 'nóv.', 'des.'];
      // Næsti samkomudagur: annar þriðjudagur septembermánaðar (35. gr. stjórnarskrár)
      const now = new Date();
      const secondTue = (y) => { const d0 = new Date(y, 8, 1).getDay(); return 1 + ((2 - d0 + 7) % 7) + 7; };
      let upY = now.getFullYear();
      if (now > new Date(upY, 8, secondTue(upY))) upY++;
      const up = { y: upY, m: 8, d: secondTue(upY), term: upY - 1868 };
      up.ymd = up.y + '-09-' + pad2(up.d);
      const upEl = document.getElementById('dg-up');
      if (upEl) upEl.innerHTML = '📅 <b>Á döfinni:</b> Alþingi kemur saman að nýju þriðjudaginn ' + up.d + '. september ' + up.y + ' (' + up.term + '. löggjafarþing, skv. 35. gr. stjórnarskrár).';
      let st = { y: now.getFullYear(), m: now.getMonth() };
      const det = document.getElementById('dg-detail');
      function showDay(ds) {
        const info = DAGATAL.dates[ds];
        if (!det || !info) return;
        const pp = ds.split('-');
        let h = '<div class="dg-d-date">' + (+pp[2]) + '. ' + MN[+pp[1] - 1] + ' ' + pp[0] + '</div>';
        if (info.t) h += '<div class="dg-d-row dg-d-t"><b>⬢ Þingfundur</b> í þingsal</div>';
        if (info.c && info.c.length) h += '<div class="dg-d-h">Nefndarfundir (' + info.n + ')</div>' + info.c.map((cn) => '<div class="dg-d-row">' + esc(cap(cn)) + '</div>').join('');
        if (!info.t && !(info.c && info.c.length)) h += '<p class="dg-none">Engin skráð fundahöld.</p>';
        det.innerHTML = h;
      }
      function showUpcoming() {
        if (!det) return;
        det.innerHTML = '<div class="dg-d-date">' + up.d + '. september ' + up.y + '</div><div class="dg-d-row dg-d-u"><b>⬢ Samkomudagur Alþingis</b></div><p class="dg-none" style="margin-top:8px">' + up.term + '. löggjafarþing er sett. Reglulegt Alþingi kemur saman annan þriðjudag septembermánaðar skv. 35. gr. stjórnarskrárinnar.</p>';
      }
      function render() {
        const title = document.getElementById('dg-title');
        if (title) title.textContent = MNF[st.m] + ' ' + st.y;
        const startW = (new Date(st.y, st.m, 1).getDay() + 6) % 7;
        const dim = new Date(st.y, st.m + 1, 0).getDate();
        const todayS = now.getFullYear() + '-' + pad2(now.getMonth() + 1) + '-' + pad2(now.getDate());
        let html = ['Mán', 'Þri', 'Mið', 'Fim', 'Fös', 'Lau', 'Sun'].map((w) => '<div class="dg-wd">' + w + '</div>').join('');
        for (let i = 0; i < startW; i++) html += '<div class="dg-cell dg-empty"></div>';
        for (let d = 1; d <= dim; d++) {
          const ds = st.y + '-' + pad2(st.m + 1) + '-' + pad2(d);
          const info = DAGATAL.dates && DAGATAL.dates[ds];
          const isUp = ds === up.ymd;
          let marks = '';
          if (info) { if (info.t) marks += '<i class="dg-dot dg-t"></i>'; if (info.n) marks += '<i class="dg-dot dg-n"></i>'; }
          if (isUp) marks += '<i class="dg-dot dg-up-dot"></i>';
          const cls = 'dg-cell' + (info ? ' dg-has' : '') + (isUp ? ' dg-up' : '') + (ds === todayS ? ' dg-today' : '');
          html += '<div class="' + cls + '"' + (info ? ' data-d="' + ds + '"' : (isUp ? ' data-up="1"' : '')) + '><span class="dg-num">' + d + '</span><div class="dg-marks">' + marks + '</div></div>';
        }
        grid.innerHTML = html;
        grid.querySelectorAll('.dg-cell[data-d]').forEach((c) => { c.addEventListener('click', () => showDay(c.getAttribute('data-d'))); });
        grid.querySelectorAll('.dg-cell[data-up]').forEach((c) => { c.addEventListener('click', showUpcoming); });
      }
      document.querySelectorAll('.dg-nav').forEach((b) => {
        b.addEventListener('click', () => {
          st.m += +b.getAttribute('data-d');
          if (st.m < 0) { st.m = 11; st.y--; }
          if (st.m > 11) { st.m = 0; st.y++; }
          render();
        });
      });
      render();
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi"]')) initDagatal(); });
  </script>

