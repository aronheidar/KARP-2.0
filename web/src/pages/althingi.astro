---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2 Á3) — Sætaspá Alþingis. Byggingartíma: D'Hondt-spá
// (seats.mjs) úr könnunum + núverandi þingmenn, litað með parties.mjs.
// Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import { projectSeats } from '@lib/seats.mjs';
import { partyName, partyColor, colorByName } from '@lib/parties.mjs';
import { fmtNum, slugify } from '@lib/format.mjs';
import Layout from '../layouts/Layout.astro';
import ThingTabs from '../components/ThingTabs.astro';

import MpModal from '../components/MpModal.astro';
import POLLS from '@gogn/polls.json';
import THINGMENN from '@gogn/althingi.json';
import SEATS from '@gogn/seats.json';
import CABINET from '@gogn/cabinet.json';
import FRUMVORP from '@gogn/frumvorp.json';
import DAGATAL from '@gogn/dagatal.json';

const r = projectSeats(POLLS, THINGMENN);
const lastPoll = POLLS.polls[POLLS.polls.length - 1];
const pv = (lastPoll && lastPoll.v) || {};
const GOV = Object.keys(r.GOVK);
const govNames = GOV.map(partyName).join(', ');

const codes = [...new Set([...(POLLS.parties || []), ...Object.keys(r.cur)])];
const prows = codes
  .map((c) => ({
    code: c,
    name: partyName(c),
    color: partyColor(c),
    cur: r.cur[c] || 0,
    proj: r.proj[c] || 0,
    poll: pv[c] != null ? pv[c] : null,
    gov: !!r.GOVK[c],
  }))
  .sort((a, b) => b.proj - a.proj || b.cur - a.cur || (b.poll || 0) - (a.poll || 0));

const seatRows = prows.filter((p) => p.cur > 0 || p.proj > 0);
const chartNames = seatRows.map((p) => p.name);
const chartCur = seatRows.map((p) => p.cur);
const chartProj = seatRows.map((p) => ({ value: p.proj, itemStyle: { color: p.color } }));

const updated = '2026-07-01';

// Þingmenn eftir flokki (fyrir innri tengla → engar munaðarlausar þingmanna-síður).
const mpByParty = {};
THINGMENN.forEach((mp) => { (mpByParty[mp.flokkur] = mpByParty[mp.flokkur] || []).push(mp); });
const mpGroups = seatRows
  .map((row) => ({ party: row.name, color: row.color, mps: (mpByParty[row.name] || []).slice().sort((a, b) => a.nafn.localeCompare(b.nafn, 'is')) }))
  .filter((g) => g.mps.length);
const desc = `Sætaspá fyrir Alþingi (D'Hondt úr meðaltali síðustu ${r.used} kannana): ríkisstjórnin (${govNames}) fær ${r.govS} af 63 sætum — ${r.maj ? 'heldur meirihluta' : 'missir meirihluta'}.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Sætaspá Alþingis',
  description: "Vélræn sætaspá fyrir Alþingi reiknuð með D'Hondt-reglu úr meðaltali nýjustu skoðanakannana (5% þröskuldur, 63 sæti).",
  creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' },
  dateModified: updated,
  spatialCoverage: 'Ísland',
  measurementTechnique: "D'Hondt-sætaúthlutun úr 3-kannana meðaltali, 5% þröskuldur",
  variableMeasured: 'Þingsæti (af 63)',
};

const chg = (d) => (d > 0 ? '+' + d : d < 0 ? String(d) : '±0');

// Þingsalurinn: raun-sætaskipan (seats.json) → bakað fyrir scatter-eyjuna.
const mpSlug = {};
THINGMENN.forEach((mp) => { mpSlug[mp.id] = slugify(mp.nafn); });
const ini = (n) => { const w = String(n).split(/\s+/).filter(Boolean); return ((w[0] || ' ')[0] + (w.length > 1 ? w[w.length - 1][0] : '')).toUpperCase(); };
const SEATDATA = SEATS.map((s) => ({ id: s.id, x: s.x, y: s.y, n: s.nafn, f: s.flokkur, r: s.role || '', c: colorByName(s.flokkur), s: mpSlug[s.id] || '', i: ini(s.nafn) }));

// MpModal-gögn: smellt á sæti → gluggi (fullu síðurnar haldast fyrir SEO).
const MPS = {};
THINGMENN.forEach((m) => {
  MPS[m.id] = { n: m.nafn, f: m.flokkur, c: colorByName(m.flokkur), kj: m.kjordaemi, img: m.mynd || '', s: mpSlug[m.id] || '', aldur: m.aldur ?? null, thing: m.fjoldiThinga ?? null, hollusta: m.hollusta ?? null, raedur: m.raedur ?? null, nefndir: m.nefndir ?? null, greidd: m.greidd ?? null };
});

// ── Þingið 157: ríkisstjórnin (cabinet.json úr Alþingis-XML) ──
const capFirst = (s) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
const PM = CABINET.find((c) => (c.emb || []).some((e) => /forsætis/i.test(e))) || CABINET[0];
const MINISTERS = CABINET.filter((c) => c !== PM);
const govNum = GOV.length === 2 ? '2ja' : GOV.length === 3 ? '3ja' : GOV.length === 4 ? '4ra' : String(GOV.length);
// Ráðherrar utan þings fá lágmarks-færslu í MPS svo glugginn virki líka fyrir þá.
CABINET.forEach((c) => {
  if (!MPS[c.id]) MPS[c.id] = { n: c.nafn, f: c.flokur, c: colorByName(c.flokur), kj: 'Ráðherra utan þings', img: c.mynd || '', s: '', aldur: null, thing: null, hollusta: null, raedur: null, nefndir: null, greidd: null };
});

// ── Mál í gangi (eins og gamla billsInProgress): virk mál, ekki þingsköp ──
const PROC = /lengd þingfundar|^afbrigði|frestun á fundum|^dagskrá|þingfrest|störf þingsins|fundarstjórn/i;
const mapBill = (b) => ({ nr: b.nr, t: capFirst(b.titill), teg: b.teg || (b.hs === 'Till.' ? 'þingsályktun' : 'lagafrumvarp'), stada: (b.stada || '').replace(/\.$/, ''), d: b.d, int: b.hs === 'Frv.' || b.hs === 'Till.' });
const notProc = (b) => !PROC.test(b.titill || '') && !PROC.test(b.hs || '');
const byDate = (a, b) => (b.d || '').localeCompare(a.d || '');
const BILLS_GO = FRUMVORP
  .filter((b) => /bíður|nefnd|umræð/i.test(b.stada || '') && !/samþykkt|fell|fyrirspurn/i.test(b.stada || '') && notProc(b))
  .sort(byDate).slice(0, 24).map(mapBill);
// Utan þingtíma eru fá mál í gangi — fylla stikuna með nýafgreiddum málum.
const BILLS_DONE = BILLS_GO.length >= 22 ? [] : FRUMVORP
  .filter((b) => /samþykkt|fell/i.test(b.stada || '') && notProc(b))
  .sort(byDate).slice(0, 22 - BILLS_GO.length).map(mapBill);
// Innri tengill opnar atkvæða-gluggann á /thingmal/ (LOTA 13 — „sjá hvernig var kosið");
// mál utan þingmála-listans (önnur skjalategund) fá ferilinn á althingi.is.
const billUrl = (b) => (b.int ? `/thingmal/?nr=${b.nr}` : `https://www.althingi.is/thingstorf/thingmalalistar-eftir-thingum/ferill/?ltg=157&mnr=${b.nr}`);
const dIS = (d) => (d ? `${+d.slice(8, 10)}.${+d.slice(5, 7)}.` : '');

// Stefnuprófs-spurningar (sama smíði og Mitt svæði) → ÞÚ-punktur á pólitíska kortið (LOTA 15b)
const SPQ = FRUMVORP
  .filter((b) => (b.hs === 'Frv.' || b.hs === 'Till.') && (b.ja || 0) > 0 && (b.nei || 0) > 5 && b.sam)
  .sort((a, b) => (b.d || '').localeCompare(a.d || '')).slice(0, 12)
  .map((b) => { const P2 = b.P || {}; const st = {}; Object.keys(P2).forEach((k) => { const [ja, nei] = P2[k]; if (k === 'U' || ja + nei === 0 || ja === nei) return; st[k] = ja > nei ? 1 : -1; }); return { id: 'q' + b.nr, stance: st }; })
  .filter((q) => Object.keys(q.stance).length >= 4);
const SPKEY = {};
[...new Set(SPQ.flatMap((q) => Object.keys(q.stance)))].forEach((k) => { SPKEY[k] = partyName(k); });

// ── Pólitíska kortið: mx/my forreiknað úr öllum nafnakalls-atkvæðagreiðslum ──
const POLD = THINGMENN.filter((m) => m.mx != null).map((m) => ({ v: [m.mx, m.my], id: m.id, n: m.nafn, f: m.flokkur, ho: m.hollusta ?? null, up: m.uppreisn ?? 0, ne: m.nefndir ?? null }));
const PCOL = {};
THINGMENN.forEach((m) => { PCOL[m.flokkur] = colorByName(m.flokkur); });
---

<Layout
  title={`Sætaspá Alþingis — ${govNames.split(',')[0]} stærst | Karp`}
  description={desc}
  canonical="https://app.karp.is/althingi/"
  jsonLd={jsonLd}
  ogTitle="Sætaspá Alþingis"
>
  <main data-pg="althingi">
    <p class="kicker">Hagvísir Íslands · Alþingi</p>
    <ThingTabs active="salur" />
    <h1>Sætaspá Alþingis</h1>
    <p>
      Ef kosið væri nú — vélræn spá reiknuð með D'Hondt-reglu úr meðaltali síðustu <strong>{r.used} kannana</strong>
      (nýjust {lastPoll?.pollster}, {lastPoll?.date}). Ríkisstjórnarflokkarnir <strong>{govNames}</strong>
      fá {r.govS} af 63 sætum.
    </p>

    <div class="tiles">
      <div class="tile">
        <div class="t-l">Ríkisstjórn</div>
        <div class={`t-v ${r.maj ? 'maj-y' : 'maj-n'}`}>{r.govS}</div>
        <div class="t-s">{r.maj ? '✓ meirihluti' : '✗ fallinn meirihluti'} · þarf 32</div>
      </div>
      <div class="tile">
        <div class="t-l">Stjórnarandstaða</div>
        <div class="t-v">{r.oppS}</div>
        <div class="t-s">af 63 sætum</div>
      </div>
      <div class="tile">
        <div class="t-l">Stærsti flokkur</div>
        <div class="t-v" style={`color:${seatRows[0]?.color}`}>{seatRows[0]?.proj}</div>
        <div class="t-s">{seatRows[0]?.name}</div>
      </div>
    </div>

    <p class="note">
      ⓘ <strong>Vélræn spá</strong>, ekki opinber. D'Hondt-sætaúthlutun úr 3-kannana meðaltali með 5% þröskuldi;
      „Nú" = núverandi þingmenn. Kannanir eru óvissar og spáin breytist með þeim — þetta er ekki niðurstaða kosninga.
    </p>

    <h2>Þingið 157 — {govNum} flokka meirihlutastjórn</h2>
    <div class="cab">
      <button class="cab-pm cab-clk" data-id={PM.id} type="button" style={`--pc:${colorByName(PM.flokur)}`}>
        {PM.mynd && <img src={PM.mynd} alt={PM.nafn} loading="lazy" />}
        <div class="cab-t">
          <div class="cab-n">{PM.nafn}</div>
          <div class="cab-e">Forsætisráðherra</div>
          <div class="cab-f"><span class="cab-dot"></span>{PM.flokur}{PM.sidan ? ` · frá ${PM.sidan}` : ''}</div>
        </div>
      </button>
      <div class="cab-grid">
        {MINISTERS.map((c) => (
          <button class="cab-min cab-clk" data-id={c.id} type="button" style={`--pc:${colorByName(c.flokur)}`}>
            {c.mynd && <img src={c.mynd} alt={c.nafn} loading="lazy" />}
            <div class="cab-t">
              <div class="cab-n">{c.nafn}</div>
              <div class="cab-e">{capFirst((c.emb || [])[0] || 'ráðherra')}</div>
            </div>
            <span class="cab-dot" title={c.flokur}></span>
          </button>
        ))}
      </div>
      <p class="src">Ríkisstjórn {GOV.map(partyName).join(', ')} · {CABINET.length} ráðherrar. Smelltu á ráðherra fyrir nánari upplýsingar.</p>
    </div>

    <h2>Þingsalurinn — sætaskipan</h2>
    <div class="seat-wrap">
      <div class="seat-left">
        <div id="seatchart"></div>
        <p class="src">Raunveruleg sætaskipan þingsalsins (skv. Alþingi) — hver punktur er sæti á réttum stað í salnum, litað eftir flokki. <span style="color:#ffd479">Gyllt umgjörð</span> = ráðherra. Smelltu á sæti fyrir þingmanns-síðu.</p>
      </div>
      <aside class="seat-bills">
        <div class="sb-h">⚡ Mál í gangi</div>
        <div class="sb-list">
          {BILLS_GO.map((b) => (
            <a class="sb-item" href={billUrl(b)} target={b.int ? undefined : "_blank"} rel={b.int ? undefined : "noopener"}>
              <span class="sb-t">{b.t}</span>
              <span class="sb-meta"><i class="sb-tag">{b.teg}</i> {b.stada} · {dIS(b.d)}</span>
            </a>
          ))}
          {BILLS_GO.length === 0 && <p class="sb-none">Engin mál í virkri meðferð — þingið er milli funda.</p>}
          {BILLS_DONE.length > 0 && (
            <>
              <div class="sb-h sb-h2">✓ Nýafgreidd mál</div>
              {BILLS_DONE.map((b) => (
                <a class="sb-item" href={billUrl(b)} target={b.int ? undefined : "_blank"} rel={b.int ? undefined : "noopener"}>
                  <span class="sb-t">{b.t}</span>
                  <span class="sb-meta"><i class={`sb-tag ${/fell/i.test(b.stada) ? 'sb-no' : 'sb-ok'}`}>{/fell/i.test(b.stada) ? 'Fellt' : 'Samþykkt'}</i> {b.teg} · {dIS(b.d)}</span>
                </a>
              ))}
            </>
          )}
        </div>
        <a class="sb-all" href="/thingmal/">Öll þingmál &amp; atkvæði →</a>
      </aside>
    </div>

    <h2>Nú vs. spá — eftir flokkum</h2>
    <div id="chart"></div>

    <table>
      <thead>
        <tr><th class="l">Flokkur</th><th>Nú</th><th>Spá</th><th>Breyting</th><th>Síðasta könnun</th></tr>
      </thead>
      <tbody>
        {prows.map((p) => (
          <tr>
            <td class="l">
              <span class="dot" style={`background:${p.color}`}></span>
              <span class="party">{p.name}</span>{p.gov && <span class="gov-tag">ríkisstj.</span>}
            </td>
            <td class="num">{p.cur}</td>
            <td class="num">{p.proj}</td>
            <td class={`num ${p.proj - p.cur > 0 ? 'up' : p.proj - p.cur < 0 ? 'dn' : 'fl'}`}>{chg(p.proj - p.cur)}</td>
            <td class="num">{p.poll == null ? '–' : fmtNum(p.poll, 1) + '%'}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <h2>Pólitískt kort þingsins</h2>
    <div id="polmap"></div>
    <p class="src">Reiknað úr <strong>öllum nafnakalls-atkvæðagreiðslum þingsins 157</strong> — þingmenn sem kjósa líkt lenda nálægt hver öðrum (lárétt: stjórn ↔ stjórnarandstaða, lóðrétt: næststerkasta mynstrið). Smelltu á þingmann fyrir nánar.</p>

    <h2>Þingfundadagatal</h2>
    <div class="dg-stats">
      <span class="dg-chip"><b>{DAGATAL.days}</b> starfsdagar</span>
      <span class="dg-chip"><b>{DAGATAL.plenary}</b> þingfundir</span>
      <span class="dg-chip"><b>{DAGATAL.meetings}</b> nefndarfundir</span>
      <span class="dg-chip dg-leg"><i class="dg-dot dg-t"></i> þingfundur <i class="dg-dot dg-n"></i> nefndarfundir</span>
    </div>
    <div id="dg-up" class="dg-up-note"></div>
    <div class="dg-wrap">
      <div class="dg-cal">
        <div class="dg-head">
          <button class="dg-nav" data-d="-1" type="button" aria-label="Fyrri mánuður">◀</button>
          <div id="dg-title"></div>
          <button class="dg-nav" data-d="1" type="button" aria-label="Næsti mánuður">▶</button>
        </div>
        <div id="dg-grid" class="dg-grid"></div>
      </div>
      <div id="dg-detail" class="dg-detail"><p class="dg-hint">Smelltu á dag með punktum til að sjá fundahöld dagsins.</p></div>
    </div>
    <p class="src">Þingfundir og nefndarfundir löggjafarþingsins 157 ({DAGATAL.range[0]} – {DAGATAL.range[1]}), skv. fundargerðum Alþingis.</p>

    <p class="mini-links">
      Sjá einnig: <a href="/althingi/thingmenn/">Þingmenn (myndir)</a> · <a href="/althingi/flokkar/">Flokkar</a> · <a href="/althingi/nefndir/">Nefndir &amp; dagatal</a> · <a href="/thingmal/">Frumvörp &amp; atkvæði</a>
    </p>

    <p class="foot">
      Forþjónað (SSG) {updated}. Spáin reiknuð á <strong>byggingartíma</strong> úr sameiginlega <code>src/lib</code>
      (<code>seats</code> D'Hondt + <code>parties</code>). Kannanagögn: {POLLS.source}
      {POLLS.sourceUrl ? <> (<a href={POLLS.sourceUrl}>heimild</a>)</> : null}. #2 Á3.
    </p>
  </main>

  <style>
    main { max-width: 1020px; margin: 0 auto; padding: 44px 20px 64px; }
    /* ── Ríkisstjórnin ── */
    .cab { margin: 4px 0 8px; }
    .cab-clk { cursor: pointer; text-align: left; font: inherit; color: inherit; }
    .cab-pm { display: flex; align-items: center; gap: 14px; width: 100%; background: linear-gradient(90deg, rgba(255,255,255,.06), rgba(255,255,255,.02)); border: 1px solid rgba(255,255,255,.1); border-left: 4px solid var(--pc); border-radius: 12px; padding: 12px 16px; margin-bottom: 10px; }
    .cab-pm img { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid var(--pc); }
    .cab-pm .cab-n { font-size: 18px; font-weight: 800; color: #eaf1fb; }
    .cab-pm .cab-e { font-size: 13px; color: #f6b13b; font-weight: 600; }
    .cab-pm .cab-f { font-size: 12px; color: #9fb0c8; margin-top: 2px; }
    .cab-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: var(--pc); margin-right: 6px; flex: none; }
    .cab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(215px, 1fr)); gap: 8px; }
    .cab-min { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 8px 10px; min-width: 0; }
    .cab-min:hover, .cab-pm:hover { border-color: rgba(246,177,59,.5); }
    .cab-min img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--pc); flex: none; }
    .cab-min .cab-t { min-width: 0; flex: 1; }
    .cab-min .cab-n { font-size: 12.5px; font-weight: 700; color: #dfe7f4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cab-min .cab-e { font-size: 11px; color: #8fa0ba; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    /* ── Þingsalur + mál í gangi ── */
    .seat-wrap { display: grid; grid-template-columns: minmax(0, 1fr) 315px; gap: 16px; align-items: start; }
    .seat-bills { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 12px 12px 10px; }
    .sb-h { font-size: 13px; font-weight: 800; color: #f6b13b; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .sb-list { display: flex; flex-direction: column; max-height: 470px; overflow-y: auto; }
    .sb-item { display: block; padding: 7px 8px; border-radius: 8px; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.05); }
    .sb-item:hover { background: rgba(255,255,255,.05); }
    .sb-t { display: block; font-size: 12.5px; font-weight: 600; color: #dfe7f4; line-height: 1.3; }
    .sb-meta { display: block; font-size: 10.5px; color: #7e8ca6; margin-top: 2px; }
    .sb-tag { font-style: normal; color: #19d3c5; }
    .sb-tag.sb-ok { color: #46e08a; } .sb-tag.sb-no { color: #ff6d7a; }
    .sb-h2 { margin-top: 12px; color: #46e08a; }
    .sb-none { font-size: 12px; color: #7e8ca6; padding: 4px 8px; }
    .sb-all { display: block; text-align: right; font-size: 12px; color: #f6b13b; text-decoration: none; padding: 8px 6px 2px; }
    .sb-all:hover { text-decoration: underline; }
    @media (max-width: 900px) { .seat-wrap { grid-template-columns: 1fr; } .sb-list { max-height: 300px; } }
    /* ── Pólitískt kort ── */
    #polmap { width: 100%; height: 520px; margin: 4px 0; }
    /* ── Dagatal ── */
    .dg-stats { display: flex; flex-wrap: wrap; gap: 8px; margin: 6px 0 10px; }
    .dg-chip { font-size: 12px; color: #9fb0c8; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 999px; padding: 4px 12px; }
    .dg-chip b { color: #eaf1fb; }
    .dg-leg { display: inline-flex; align-items: center; gap: 5px; }
    .dg-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; }
    .dg-t { background: #f6b13b; } .dg-n { background: #19d3c5; } .dg-up-dot { background: #c95cf7; }
    .dg-up-note { font-size: 12.5px; color: #b9c6da; background: rgba(201,92,247,.08); border: 1px solid rgba(201,92,247,.25); border-radius: 8px; padding: 8px 12px; margin: 0 0 10px; }
