---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Utanríkisverslun: útflutningur/innflutningur (treemaps),
// vöruskiptajöfnuður eftir SITC-deildum og mánaðarleg þróun. Gögn: daglegt
// snapshot úr skriptur/build_vidskipti.mjs → gogn/vidskipti.json (áður sótt
// beint á Hagstofu í frontmatter á hverri byggingu → seigla + saga).
// ATH: heimskorta-GeoJSON helst RUNTIME-sótt í vafra (client-eyja). Í app-skelinni. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import DATA from '@gogn/vidskipti.json';

const { EXP, IMP, BAL, TREND, BYLAND, updated } = DATA;
const lastJofn = TREND ? TREND.jofn[TREND.jofn.length - 1] : null;
const desc = `Utanríkisverslun Íslands — útflutningur ${EXP ? groupThousands(EXP.total) + ' ma.kr (' + EXP.year + ')' : ''}, innflutningur ${IMP ? groupThousands(IMP.total) + ' ma.kr' : ''}, vöruskiptajöfnuður eftir vöruflokkum og mánaðarleg þróun.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Utanríkisverslun Íslands', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Vöruviðskipti (ma.kr)' };
---

<Layout title="Utanríkisverslun — út- og innflutningur | Karp" description={desc} canonical="https://karp.is/vidskipti/" jsonLd={jsonLd} ogTitle="Utanríkisverslun Íslands">
  <main data-pg="vidskipti">
    <p class="kicker">Hagvísir Íslands · Efnahagur</p>
    <h1>Utanríkisverslun</h1>
    <p>Hvað flytur Ísland út og inn — sjávarafurðir og ál á móti vélum og eldsneyti. Heimild: Hagstofa Íslands (vöruviðskipti).</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Utanríkisverslun: inn- og útflutningstölur Hagstofunnar (PxWeb) eftir vöruflokkum.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      {EXP && <div class="kpi"><div class="k-l">📦 Útflutningur</div><div class="k-v">{groupThousands(EXP.total)}</div><div class="k-s">ma.kr · {EXP.year}</div></div>}
      {IMP && <div class="kpi"><div class="k-l">🚢 Innflutningur</div><div class="k-v">{groupThousands(IMP.total)}</div><div class="k-s">ma.kr · {IMP.year}</div></div>}
      {lastJofn != null && <div class="kpi"><div class="k-l">⚖️ Jöfnuður (mán)</div><div class={`k-v ${lastJofn >= 0 ? 'up' : 'dn'}`}>{lastJofn > 0 ? '+' : ''}{fmtNum(lastJofn, 0)}</div><div class="k-s">ma.kr · nýjasti mánuður</div></div>}
    </div>

    <div class="ppair">
      {EXP && (
        <div>
          <h2>Útflutningur eftir flokkum ({EXP.year})</h2>
          <div id="chart-exp"></div>
        </div>
      )}
      {IMP && (
        <div>
          <h2>Innflutningur eftir SITC-deildum ({IMP.year})</h2>
          <div id="chart-imp"></div>
        </div>
      )}
    </div>

    {BAL && (
      <>
        <h2>Vöruskiptajöfnuður eftir vöruflokkum ({BAL.year})</h2>
        <div id="chart-bal"></div>
        <p class="src">Grænt = afgangur (útflutningur &gt; innflutningur), rautt = halli. Ma.kr.</p>
      </>
    )}

    {TREND && (
      <>
        <h2>Mánaðarleg þróun (3 ár)</h2>
        <div id="chart-trend"></div>
      </>
    )}

    {BYLAND && (
      <>
        <h2>Heimskortin — hvert fara vörurnar? (12 mán)</h2>
        <p class="src">Stærstu viðskiptalönd: útflutningur → <strong>{BYLAND.utTop.name}</strong> ({fmtNum(BYLAND.utTop.v, 0)} ma.kr) · innflutningur ← <strong>{BYLAND.innTop.name}</strong> ({fmtNum(BYLAND.innTop.v, 0)} ma.kr).</p>
        <div class="mapgrid">
          <div><div class="map-h">📦 Útflutningur eftir löndum</div><div id="map-exp" class="wmap"></div></div>
          <div><div class="map-h">🚢 Innflutningur eftir löndum</div><div id="map-imp" class="wmap"></div></div>
          <div><div class="map-h">➡️ Útflutningsflæði frá Íslandi</div><div id="map-expflow" class="wmap"></div></div>
          <div><div class="map-h">⬅️ Innflutningsflæði til Íslands</div><div id="map-impflow" class="wmap"></div></div>
        </div>
        <p class="src">Heimskortið hleðst í vafranum (ECharts world-GeoJSON). Ma.kr, samtala síðustu 12 mánaða.</p>
      </>
    )}
    <script type="application/json" id="d-byland" set:html={JSON.stringify(BYLAND || {})}></script>

    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Heimild: Hagstofa (UTA06105/UTA06202/UTA06108/UTA06002). Tölur í ma.kr. #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: var(--ink); }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: var(--muted); }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-v.up { color: #46e08a; } .k-v.dn { color: #ff6d7a; }
    .k-s { font-size: 11px; color: var(--faint); }
    #chart-exp, #chart-imp { width: 100%; height: 300px; }
    #chart-bal { width: 100%; }
    #chart-trend { width: 100%; height: 300px; }
    .mapgrid, .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 720px) { .ppair { grid-template-columns: 1fr; } }
    .map-h { font-size: 12.5px; color: var(--muted); font-weight: 700; margin: 4px 0 2px; }
    .wmap { width: 100%; height: 250px; background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.06); border-radius: 10px; }
    @media (max-width: 720px) { .mapgrid { grid-template-columns: 1fr; } }
    .src { font-size: 12px; color: var(--faint); margin: 2px 0 0; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: 2 treemaps + jöfnuðar-súlur + þróunarlínur. astro:page-load. #2 -->
  <script define:vars={{ EXP, IMP, BAL, TREND }}>
    function initCharts() {
      if (!document.getElementById('chart-exp') && !document.getElementById('chart-imp') && !document.getElementById('chart-trend')) return;
      const tree = (el, items) => {
        const c = window.echarts.init(el);
        c.setOption({
          backgroundColor: 'transparent',
          tooltip: { valueFormatter: (v) => String(v).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' ma.kr' },
          series: [{ type: 'treemap', data: items, left: 0, right: 0, top: 0, bottom: 0, roam: false, nodeClick: false, breadcrumb: { show: false }, label: { show: true, formatter: (p) => p.name + '\n' + String(p.value).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' ma', fontSize: 12, fontWeight: 600, color: '#06121a' }, itemStyle: { borderColor: '#0b1220', borderWidth: 2, gapWidth: 2 } }],
        });
        window.addEventListener('resize', () => c.resize());
      };
      const go = () => {
        const ce = document.getElementById('chart-exp');
        if (ce && EXP && !window.echarts.getInstanceByDom(ce)) tree(ce, EXP.items);
        const ci = document.getElementById('chart-imp');
        if (ci && IMP && !window.echarts.getInstanceByDom(ci)) tree(ci, IMP.items);
        const cb = document.getElementById('chart-bal');
        if (cb && BAL && !window.echarts.getInstanceByDom(cb)) {
          cb.style.height = (BAL.rows.length * 28 + 26) + 'px';
          const c = window.echarts.init(cb);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 150, right: 56, top: 6, bottom: 20 },
            xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            yAxis: { type: 'category', inverse: true, data: BAL.rows.map((r) => r.label), axisLabel: { color: '#cdd6e6', fontSize: 11 }, axisLine: { show: false }, axisTick: { show: false } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v > 0 ? '+' : '') + String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' ma.kr' },
            series: [{ type: 'bar', barWidth: 14, data: BAL.rows.map((r) => ({ value: r.v, itemStyle: { color: r.v >= 0 ? '#46e08a' : '#ff6d7a' } })), label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10, formatter: (p) => (p.value > 0 ? '+' : '') + p.value } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const ct = document.getElementById('chart-trend');
        if (ct && TREND && !window.echarts.getInstanceByDom(ct)) {
          const c = window.echarts.init(ct);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: ['Útflutningur', 'Innflutningur', 'Jöfnuður'], textStyle: { color: '#9fb0c8' }, top: 0 },
            grid: { left: 44, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: TREND.labels, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: 5 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : (v > 0 ? '+' : '') + v.toFixed(0) + ' ma.kr') },
            series: [
              { name: 'Útflutningur', type: 'line', data: TREND.ut, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#46e08a' }, itemStyle: { color: '#46e08a' } },
              { name: 'Innflutningur', type: 'line', data: TREND.inn, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#ff8a3d' }, itemStyle: { color: '#ff8a3d' } },
              { name: 'Jöfnuður', type: 'bar', data: TREND.jofn.map((v) => ({ value: v, itemStyle: { color: v >= 0 ? 'rgba(70,224,138,.6)' : 'rgba(255,109,122,.6)' } })), barWidth: 8 },
            ],
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vidskipti"]')) initCharts(); });
  </script>

  <!-- Eyja: heimskortin 4 (world-GeoJSON sótt í vafra + registerMap). #2 -->
  <script>
    const WORLD_URL = 'https://cdn.jsdelivr.net/gh/apache/echarts-website@asf-site/examples/data/asset/geo/world.json';
    const ICELAND = [-18.6, 64.9];
    function initMaps() {
      const e1 = document.getElementById('map-exp');
      if (!e1) return;
      const BY = JSON.parse((document.getElementById('d-byland') || { textContent: '{}' }).textContent || '{}');
      if (!BY.ut) return;
      const boot = () => {
        fetch(WORLD_URL).then((r) => r.json()).then((geo) => {
          try { window.echarts.registerMap('world', geo); } catch (e) {}
          // Miðjur landa reiknaðar úr GeoJSON (bbox-miðja) fyrir flæðilínur.
          const cent = {};
          (geo.features || []).forEach((f) => {
            let mnx = 999, mxx = -999, mny = 999, mxy = -999;
            const walk = (c) => { if (typeof c[0] === 'number') { mnx = Math.min(mnx, c[0]); mxx = Math.max(mxx, c[0]); mny = Math.min(mny, c[1]); mxy = Math.max(mxy, c[1]); } else c.forEach(walk); };
            walk(f.geometry.coordinates);
            cent[f.properties.name] = [(mnx + mxx) / 2, (mny + mxy) / 2];
          });
          const th = (n) => String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
          const choro = (id, arr, cols) => {
            const el = document.getElementById(id);
            if (!el || window.echarts.getInstanceByDom(el)) return;
            const c = window.echarts.init(el);
            const maxV = arr[0] ? arr[0].v : 1;
            c.setOption({
              backgroundColor: 'transparent',
              tooltip: { backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 }, formatter: (p) => (p.value ? `<b>${p.name}</b><br>${th(p.value)} ma.kr` : p.name) },
              visualMap: { min: 0, max: maxV, show: false, inRange: { color: cols } },
              series: [{ type: 'map', map: 'world', roam: false, zoom: 1.15, center: [10, 35],
                itemStyle: { areaColor: 'rgba(255,255,255,.05)', borderColor: 'rgba(7,11,22,.8)', borderWidth: 0.4 },
                emphasis: { label: { show: false }, itemStyle: { areaColor: '#f6b13b' } },
                data: [...arr.map((x) => ({ name: x.name, value: x.v })), { name: 'Iceland', itemStyle: { areaColor: '#f6b13b' } }] }],
            });
            window.addEventListener('resize', () => c.resize());
          };
          const flow = (id, arr, outward, color) => {
            const el = document.getElementById(id);
            if (!el || window.echarts.getInstanceByDom(el)) return;
            const c = window.echarts.init(el);
            const top = arr.slice(0, 14).filter((x) => cent[x.name]);
            const maxV = top[0] ? top[0].v : 1;
            c.setOption({
              backgroundColor: 'transparent',
              tooltip: { backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 } },
              geo: { map: 'world', roam: false, zoom: 1.15, center: [10, 35], itemStyle: { areaColor: 'rgba(255,255,255,.045)', borderColor: 'rgba(7,11,22,.8)', borderWidth: 0.4 }, emphasis: { disabled: true },
                regions: [{ name: 'Iceland', itemStyle: { areaColor: '#f6b13b' } }] },
              series: [
                { type: 'lines', coordinateSystem: 'geo', zlevel: 2,
                  effect: { show: true, period: 5, trailLength: 0.35, symbol: 'arrow', symbolSize: 5 },
                  lineStyle: { color, width: 1, opacity: 0.35, curveness: 0.25 },
                  data: top.map((x) => ({ coords: outward ? [ICELAND, cent[x.name]] : [cent[x.name], ICELAND], lineStyle: { width: Math.max(0.6, (x.v / maxV) * 3.2) }, name: x.name, value: x.v })),
                  tooltip: { formatter: (p) => `<b>${p.data.name}</b><br>${th(p.data.value)} ma.kr` } },
                { type: 'effectScatter', coordinateSystem: 'geo', zlevel: 3, symbolSize: 7, itemStyle: { color: '#f6b13b' }, rippleEffect: { scale: 3 }, data: [{ name: 'Ísland', value: [...ICELAND, 1] }], tooltip: { formatter: 'Ísland' } },
              ],
            });
            window.addEventListener('resize', () => c.resize());
          };
          choro('map-exp', BY.ut, ['rgba(70,224,138,.12)', 'rgba(70,224,138,.55)', '#46e08a']);
          choro('map-imp', BY.inn, ['rgba(201,92,247,.12)', 'rgba(201,92,247,.5)', '#c95cf7']);
          flow('map-expflow', BY.ut, true, '#46e08a');
          flow('map-impflow', BY.inn, false, '#1fb6c9');
        }).catch(() => {});
      };
      if (window.echarts) { boot(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', boot, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vidskipti"]')) initMaps(); });
  </script>
</Layout>
