---
// ─────────────────────────────────────────────────────────────
// PROGRAMMATIC SEO (#2 Á6) — síða per sveitarfélag. getStaticPaths býr til
// eina SSG-síðu fyrir HVERT sveitarfélag (~61), keyrir muni-klasann úr @lib
// á byggingartíma. Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import { computeMuniIndex } from '@lib/muniIndex.mjs';
import { makeMuniStats, svStab } from '@lib/muniStats.mjs';
import { makeRegionOf, makeLifsQ } from '@lib/geo.mjs';
import { fmtNum, groupThousands, slugify } from '@lib/format.mjs';
import Layout from '../../layouts/Layout.astro';

import SVFIN from '@gogn/sveitarfelog_fin.json';
import SVMETA from '@gogn/sveitarfelog_meta.json';
import SVPOP from '@gogn/sveitarfelog_pop.json';
import ATVINNULEYSI from '@gogn/atvinnuleysi.json';
import GLAEPIR from '@gogn/glaepir.json';
import FASTEIGNIR from '@gogn/fasteignir.json';
import SVCOORDS from '@gogn/sveitarfelog_coords.json';
import REGIONGEO from '@gogn/landshlutar.json';
import SVREV from '@gogn/sveitarfelog_rev.json';
import SVMAL from '@gogn/sveitarfelog_mal.json';
import JOFNUN from '@gogn/jofnun.json';
import SVSTJORN from '@gogn/sveitarstjorn_deep.json';
import RVKSTJORN from '@gogn/sveitarstjorn_rvk.json';
import SVSTJORAR from '@gogn/sveitarstjorar.json';
import { colorByName } from '@lib/parties.mjs';

export function getStaticPaths() {
  const idxMap = computeMuniIndex({ SVFIN, SVMETA, SVPOP, ATVINNULEYSI });
  const regionOf = makeRegionOf({ SVCOORDS, REGIONGEO });
  const stats = makeMuniStats({ ATVINNULEYSI, GLAEPIR, FASTEIGNIR });
  const lifsQ = makeLifsQ({ SVMETA, regionOf, svUnemp: stats.svUnemp, svCrime: stats.svCrime });
  const r0 = (v) => (v == null ? null : Math.round(v));

  const ranked = Object.keys(idxMap).filter((n) => idxMap[n].idx != null).sort((a, b) => idxMap[b].idx - idxMap[a].idx);

  // Val-röð (LOTA 12): ◀▶ örvar + fellilisti — stafrófsröð.
  const names = Object.keys(SVCOORDS).sort((a, b) => a.localeCompare(b, 'is'));
  const ALL = names.map((n) => ({ n, s: slugify(n) }));

  return names.map((name, i) => {
    const reg = regionOf(name);
    const fin = SVFIN[name] || {}, meta = SVMETA[name] || {};
    const ix = idxMap[name] || null;
    const house = stats.svHouse(name, reg);
    return {
      params: { slug: slugify(name) },
      props: {
        name, region: reg, pop: SVPOP[name] || null,
        idx: ix ? r0(ix.idx) : null, fjar: ix ? r0(ix.fjar) : null, vox: ix ? r0(ix.vox) : null, atv: ix ? r0(ix.atv) : null,
        rank: ranked.indexOf(name) + 1, rankTotal: ranked.length,
        lifs: lifsQ(name),
        unemp: stats.svUnemp(name, reg),
        house: house ? house.v : null, houseMuni: house ? house.muni : false,
        crime: stats.svCrime(reg),
        stab: svStab(fin),
        fin, meta,
        nav: { prev: ALL[(i - 1 + ALL.length) % ALL.length], next: ALL[(i + 1) % ALL.length] },
        all: ALL,
      },
    };
  });
}

const p = Astro.props;
const idxColor = (v) => `hsl(${Math.round((v == null ? 0 : v) * 1.2)}, 62%, 47%)`;
const fp = (v, d = 1) => (v == null ? '–' : fmtNum(v, d));
const updated = '2026-07-01';

const tiles = [];
if (p.idx != null) tiles.push({ e: '🏆', l: 'Vísitala', v: String(p.idx), s: `${p.rank}. af ${p.rankTotal}`, hero: true, col: idxColor(p.idx), t: 'Samsett vísitala Karp: fjárhagur, vöxtur og atvinna vegin jafnt (0–100). Reiknuð úr ársreikningum, mannfjölda- og atvinnuleysistölum — hlutlæg samantekt, ekki gæðamat.' });
tiles.push({ e: '🌿', l: 'Lífsgæði', v: p.lifs != null ? String(p.lifs) : '–', s: '0–100', t: 'Lífsgæðaskor Karp (0–100): samsett úr atvinnustigi, öryggi (afbrotatíðni landshluta) og lýðfræði. Vélræn nálgun.' });
tiles.push({ e: '📈', l: 'Fólksfjölgun', v: p.meta.breyting_pct != null ? (p.meta.breyting_pct > 0 ? '+' : '') + fp(p.meta.breyting_pct) + '%' : '–', s: 'á ári', t: 'Árleg fólksfjölgun skv. mannfjöldatölum Hagstofunnar.' });
tiles.push({ e: '👷', l: 'Atvinnuleysi', v: p.unemp != null ? fp(p.unemp) + '%' : '–', s: 'skráð', t: 'Skráð atvinnuleysi (VMST). Tölur smærri sveitarfélaga eru kvarðaðar af umdæmistölum — nálgun.' });
tiles.push({ e: '🏠', l: 'Húsnæðisverð', v: p.house != null ? groupThousands(p.house) + ' þ' : '–', s: p.houseMuni ? 'kr/m²' : 'kr/m² · landshl.', t: p.houseMuni ? 'Miðgildi fermetraverðs úr þinglýstum kaupsamningum (kaupskrá HMS), síðasta 12 mán tímabil með nægum fjölda samninga.' : 'Of fáir kaupsamningar í sveitarfélaginu — sýnt er miðgildi landshlutans (kaupskrá HMS).' });
tiles.push({ e: '🚓', l: 'Afbrot', v: p.crime ? groupThousands(p.crime.hegn) : '–', s: 'á 10þ · landshl.', t: 'Hegningarlagabrot á 10.000 íbúa í landshlutanum (afbrotatölfræði ríkislögreglustjóra) — til er ekki sundurliðun á einstök sveitarfélög.' });
tiles.push({ e: '🏛️', l: 'Stöðugleiki', v: p.stab != null ? p.stab + '%' : '–', s: 'fjárhagur', t: 'Fjárhagslegur stöðugleiki Karp (0–100): samsett úr skuldahlutfalli, afkomu og veltufé skv. ársreikningi.' });
tiles.push({ e: '💰', l: 'Útsvar', v: p.fin.utsvar != null ? fp(p.fin.utsvar) + '%' : '–', s: 'hám. 14,74%', t: 'Útsvarsprósenta sveitarfélagsins af launum íbúa. Lögbundið hámark er 14,74%.' });
tiles.push({ e: '💳', l: 'Skuldir/íbúa', v: p.fin.skuldir_ibui != null ? groupThousands(p.fin.skuldir_ibui) + ' þ' : '–', s: 'þ.kr.', t: 'Heildarskuldir og skuldbindingar samstæðu (A+B hluti) deilt á íbúa, þúsundir króna. Heimild: ársreikningur.' });
tiles.push({ e: '📊', l: 'Afkoma/íbúa', v: p.fin.afkoma_ibui != null ? (p.fin.afkoma_ibui >= 0 ? '+' : '') + groupThousands(p.fin.afkoma_ibui) + ' þ' : '–', s: 'rekstur', t: 'Rekstrarniðurstaða ársins deilt á íbúa (þ.kr.) — jákvæð tala er afgangur. Heimild: ársreikningur.' });
tiles.push({ e: '🧒', l: 'Ungt fólk', v: p.meta.ung != null ? fp(p.meta.ung) + '%' : '–', s: 'hlutfall', t: 'Hlutfall íbúa undir 18 ára (Hagstofa).' });
tiles.push({ e: '👵', l: '67 ára+', v: p.meta.pct67 != null ? fp(p.meta.pct67) + '%' : '–', s: 'hlutfall', t: 'Hlutfall íbúa 67 ára og eldri (Hagstofa).' });

// Stellaris-radar: 6 ásar, ABSÓLÚT 0–100 skor (ekki min-max). Öryggi = 100 − brot/4,5.
const oryggi = p.crime && p.crime.hegn != null ? Math.max(0, Math.min(100, Math.round(100 - p.crime.hegn / 4.5))) : null;
const RADAR = [
  { l: 'Fjárhagur', v: p.fjar }, { l: 'Vöxtur', v: p.vox }, { l: 'Atvinna', v: p.atv },
  { l: 'Lífsgæði', v: p.lifs }, { l: 'Öryggi', v: oryggi }, { l: 'Stöðugleiki', v: p.stab },
];
const hasRadar = RADAR.filter((a) => a.v != null).length >= 4;

// ── ÍTARLEGI FJÁRHAGSKAFLINN (LOTA 9) ──
const MALLBL = ['Félagsþjónusta', 'Heilbrigðismál', 'Fræðslumál', 'Menningarmál', 'Íþrótta- og æskulýðsmál', 'Brunamál og almannav.', 'Hreinlætismál', 'Skipulags- og byggingarm.', 'Umferð og samgöngur', 'Umhverfismál', 'Atvinnumál', 'Sameiginlegur kostnaður'];
const revYears = SVREV._ar || [];
const revRaw = SVREV[p.name] || null;
const REV = revRaw ? { years: revYears.slice(0, revRaw.length), vals: revRaw.map((v) => Math.round((v / 1000) * 10) / 10) } : null; // m.kr → ma.kr
const malRaw = SVMAL[p.name] || null;
const MAL = malRaw ? MALLBL.map((l, i) => ({ label: l, v: Math.round((malRaw[i] || 0) / 1000) })).filter((x) => x.v > 0).sort((a, b) => b.v - a.v) : null; // þús → m.kr
const jof = (JOFNUN.m || {})[p.name] || null;
const JOF = jof && jof.t ? {
  total: Math.round(jof.t / 1e6), perCap: jof.ibuar ? Math.round(jof.t / jof.ibuar / 1000) : null,
  cats: (jof.c || []).map((v, i) => ({ label: (JOFNUN.catLabels || [])[i] || '', v: Math.round(v / 1e6) })).filter((x) => x.v > 0).sort((a, b) => b.v - a.v).slice(0, 6),
  ar: JOFNUN.ar,
} : null;
// Sveitarstjórn: Reykjavík á sér-skrá (borgarstjórn), hinar í deep-skránni —
// og samband.is fyllir í eyðurnar (LOTA 17): stjóri + réttur titill + fulltrúar öll 61.
const stjRaw = p.name === 'Reykjavíkurborg'
  ? { bsj: RVKSTJORN.borgarstjori, stjorn: (RVKSTJORN.borgarstjorn || []).filter((m) => !m.vara) }
  : SVSTJORN[p.name] || null;
const samb = (SVSTJORAR.byName || {})[p.name] || null;
const LTR = { D: 'Sjálfstæðisflokkurinn', B: 'Framsóknarflokkurinn', S: 'Samfylkingin', M: 'Miðflokkurinn', C: 'Viðreisn', V: 'Vinstri græn', P: 'Píratar', J: 'Sósíalistaflokkurinn', F: 'Flokkur fólksins' };
const sambMembers = samb ? (samb.fulltruar || []).map((m) => ({ n: m.n, f: LTR[m.f] || (m.f ? `${m.f}-listi` : ''), c: colorByName(LTR[m.f] || ''), hl: '' })) : [];
const deepMembers = stjRaw ? (stjRaw.stjorn || []).map((m) => ({ n: m.nafn, f: m.flokkur, c: colorByName(m.flokkur), hl: m.hlutverk || '' })) : [];
const STJ = (stjRaw || samb) ? {
  bsj: (stjRaw && stjRaw.bsj) || (samb && samb.stjori) || null,
  titill: (samb && samb.stjoriTitill) || null,
  vefur: (samb && samb.vefur) || null,
  fraSamband: !(stjRaw && (stjRaw.stjorn || []).length),
  members: deepMembers.length ? deepMembers : sambMembers,
} : null;
// Fjármála-tafla (heild, þús.kr → ma.kr/m.kr)
const finRows = [
  ['Tekjur alls', p.fin.tekjur, 'ma'], ['Gjöld alls', p.fin.gjold, 'ma'],
  ['Eignir', p.fin.eignir, 'ma'], ['Skuldir', p.fin.skuldir, 'ma'],
].filter((r) => r[1] != null).map(([l, v, u]) => ({ l, txt: fmtNum(v / 1e6, 1) + ' ma.kr' }));
if (p.fin.nidur != null) finRows.push({ l: 'Niðurstaða ársins', txt: fmtNum(p.fin.nidur / 1e3, 0) + ' m.kr' });
const skuldahlutf = p.fin.skuldir && p.fin.tekjur ? Math.round((p.fin.skuldir / p.fin.tekjur) * 100) : null;

const desc = `Hagvísar fyrir ${p.name}: ${p.idx != null ? `vísitala ${p.idx} (${p.rank}. af ${p.rankTotal}), ` : ''}${p.pop ? groupThousands(p.pop) + ' íbúar, ' : ''}landshluti ${p.region || '—'}. Fjárhagur, atvinnuleysi, húsnæðisverð og lífsgæði úr opinberum gögnum.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Place', name: p.name,
  ...(p.region ? { containedInPlace: { '@type': 'AdministrativeArea', name: p.region } } : {}),
  description: desc,
};
---

<Layout
  title={`${p.name} — hagvísar & vísitala | Karp`}
  description={desc}
  canonical={`https://karp.is/sveitarfelog/${slugify(p.name)}/`}
  jsonLd={jsonLd}
  ogTitle={`${p.name} — hagvísar`}
>
  <main data-pg="sveitarfelog-slug" data-slug={slugify(p.name)}>
    <div class="topnav">
      <a class="back" href="/sveitarfelog/">← Vísitalan (öll 61)</a>
      <a class="back" href="/kort/">🗺️ Íslandskortið</a>
    </div>

    <!-- Veldu sveitarfélag: örvar + fellilisti (LOTA 12) -->
    <div class="picker">
      <a class="pk-a" href={`/sveitarfelog/${p.nav.prev.s}/`} title={p.nav.prev.n} aria-label={`Fyrra: ${p.nav.prev.n}`}>◀</a>
      <select id="sv-jump" aria-label="Veldu sveitarfélag">
        {p.all.map((m) => <option value={m.s} selected={m.n === p.name}>{m.n}</option>)}
      </select>
      <a class="pk-a" href={`/sveitarfelog/${p.nav.next.s}/`} title={p.nav.next.n} aria-label={`Næsta: ${p.nav.next.n}`}>▶</a>
    </div>

    <header class="hero-h" style={p.idx != null ? `--hc:${idxColor(p.idx)}` : '--hc:#42506a'}>
      <div class="hero-main">
        <h1>{p.name}</h1>
        <p class="sub">
          {p.region || 'sveitarfélag'}{p.pop ? ` · ${groupThousands(p.pop)} íbúar` : ''}
        </p>
        {STJ && STJ.bsj && <div class="hero-bsj">👤 {STJ.titill || (p.name === 'Reykjavíkurborg' ? 'Borgarstjóri' : 'Bæjar-/sveitarstjóri')}: <strong>{STJ.bsj}</strong>{STJ.vefur && <a class="hero-vef" href={STJ.vefur} target="_blank" rel="noopener">vefur ↗</a>}</div>}
      </div>
      {p.idx != null && (
        <div class="hero-idx">
          <div class="hi-v">{p.idx}</div>
          <div class="hi-l">vísitala</div>
          <div class="hi-r">{p.rank}. af {p.rankTotal}</div>
        </div>
      )}
    </header>

    <div class="grid">
      {tiles.map((t) => (
        <div class={`tile${t.hero ? ' hero' : ''}`}>
          <div class="t-top">{t.e} {t.l}{t.t && <i class="tip" tabindex="0" data-tip={t.t}>ⓘ</i>}</div>
          <div class="t-v" style={t.col ? `color:${t.col}` : ''}>{t.v}</div>
          <div class="t-s">{t.s}</div>
        </div>
      ))}
    </div>

    {hasRadar && (
      <>
        <h2>Staða sveitarfélagsins — 6 ásar</h2>
        <div id="sv-radar"></div>
      </>
    )}

    <h2>Fjármálin í heild</h2>
    <div class="fin-grid">
      <table class="fin-t">
        <tbody>
          {finRows.map((r) => <tr><td>{r.l}</td><td>{r.txt}</td></tr>)}
          {skuldahlutf != null && <tr><td>Skuldahlutfall (skuldir/tekjur)</td><td>{skuldahlutf}%</td></tr>}
          {p.fin.utsvar != null && <tr><td>Útsvar</td><td>{fmtNum(p.fin.utsvar, 2)}% <span class="dim">(hám. 14,97)</span></td></tr>}
        </tbody>
      </table>
      {JOF && (
        <div class="jof">
          <div class="jof-h">⚖️ Jöfnunarsjóður {JOF.ar} <a class="jof-lnk" href="/jofnunarsjodur/">sjóðurinn á landsvísu →</a></div>
          <div class="jof-v">{groupThousands(JOF.total)} <span>m.kr</span></div>
          {JOF.perCap != null && <div class="jof-s">{groupThousands(JOF.perCap)} þús á íbúa</div>}
          {JOF.cats.map((c) => <div class="jof-row"><span>{c.label}</span><b>{groupThousands(c.v)} m</b></div>)}
        </div>
      )}
    </div>

    {REV && (
      <>
        <h2>Staðgreiðsla íbúa til ríkisins</h2>
        <div id="sv-rev"></div>
        <p class="srcnote">Ma.kr á ári ({REV.years[0]}–{REV.years[REV.years.length - 1]}) — sýnir umsvif og vöxt tekjustofnsins. Heimild: Skatturinn.</p>
      </>
    )}

    {MAL && MAL.length > 0 && (
      <>
        <h2>Útgjöld eftir málaflokkum</h2>
        <div id="sv-mal"></div>
        <p class="srcnote">M.kr á ári — hvert reksturinn fer (fræðslumál jafnan stærst). Heimild: ársreikningur.</p>
      </>
    )}

    {STJ && STJ.members.length > 0 && (
      <>
        <h2>Sveitarstjórn <i class="tip" tabindex="0" data-tip={STJ.fraSamband ? 'Kjörnir fulltrúar og stjóri skv. sveitarfélagavef Sambands íslenskra sveitarfélaga (samband.is). Flokksstafir þýddir í flokksheiti; staðbundnir listar merktir sem X-listi.' : 'Skipan skv. vef sveitarfélagsins; stjóri og titill skv. samband.is þar sem við á.'}>ⓘ</i></h2>
        {STJ.bsj && <p class="stj-bsj">{STJ.titill || 'Bæjar-/sveitarstjóri'}: <strong>{STJ.bsj}</strong></p>}
        <div class="stj">
          {STJ.members.map((m) => <span class="stj-m" style={`--pc:${m.c}`}>{m.n}{m.hl ? ` · ${m.hl}` : ''}<i>{m.f}</i></span>)}
        </div>
      </>
    )}

    {p.idx == null && (
      <p class="note">ⓘ Samsett vísitala er aðeins reiknuð fyrir sveitarfélög með fleiri en 1.000 íbúa. Aðrar tölur að ofan gilda þó.</p>
    )}
    <p class="note">ⓘ Vísitalan er vélræn samsetning þriggja jafnvæginna þátta (fjárhagur, vöxtur, atvinna) — hlutlæg samantekt opinberra talna, ekki gæðamat.</p>

    <p class="foot">
      Forþjónað (SSG) {updated}. Reiknað á byggingartíma úr sameiginlega <code>src/lib</code> (muni-klasinn) og opinberum gögnum
      (Hagstofa, Samband ísl. sveitarfélaga, Ríkislögreglustjóri, HMS). #2 Á6 · ein af {p.rankTotal ? '61' : ''} sveitarfélaga-síðum.
    </p>
  </main>

  <style>
    main { max-width: 820px; margin: 0 auto; padding: 40px 20px 64px; }
    .topnav { display: flex; gap: 18px; }
    .back { font-size: 13px; color: #7e8ca6; text-decoration: none; }
    .back:hover { color: #f6b13b; }
    .picker { display: flex; gap: 8px; align-items: stretch; margin: 14px 0 4px; }
    .pk-a { display: flex; align-items: center; justify-content: center; width: 44px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 10px; color: #cdd6e6; text-decoration: none; font-size: 15px; }
    .pk-a:hover { color: #f6b13b; border-color: #f6b13b; }
    #sv-jump { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #eaf1fb; border-radius: 10px; padding: 10px 12px; font-size: 15px; font-weight: 700; cursor: pointer; }
    #sv-jump option { background: #0b1220; }
    .hero-h { display: flex; gap: 16px; align-items: center; justify-content: space-between; background: linear-gradient(90deg, rgba(255,255,255,.05), rgba(255,255,255,.015)); border: 1px solid rgba(255,255,255,.09); border-left: 5px solid var(--hc); border-radius: 14px; padding: 16px 20px; margin-top: 12px; }
    h1 { font-size: 32px; line-height: 1.1; margin: 0 0 2px; }
    .sub { color: #9fb0c8; font-size: 14.5px; margin: 0; }
    .hero-bsj { font-size: 13.5px; color: #cdd6e6; margin-top: 8px; }
    .hero-bsj strong { color: #f6b13b; }
    .hero-vef { margin-left: 10px; font-size: 12px; color: #9fb0c8; text-decoration: none; border-bottom: 1px dotted rgba(159,176,200,.5); }
    .hero-vef:hover { color: #f6b13b; }
    .hero-idx { text-align: center; flex: none; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 10px 18px; }
    .hi-v { font-size: 34px; font-weight: 800; color: var(--hc); line-height: 1; }
    .hi-l { font-size: 10.5px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .05em; }
    .hi-r { font-size: 11.5px; color: #9fb0c8; margin-top: 2px; }
    @media (max-width: 560px) { .hero-h { flex-direction: column; align-items: flex-start; } }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin: 26px 0 8px; }
    .tile { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px 16px; }
    .tile.hero { grid-column: span 2; }
    .t-top { font-size: 12px; color: #9fb0c8; }
    .t-v { font-size: 26px; font-weight: 800; margin-top: 2px; }
    .tile.hero .t-v { font-size: 40px; }
    .t-s { font-size: 12px; color: #7e8ca6; margin-top: 2px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 18px 0; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 26px 0 4px; }
    #sv-radar { width: 100%; height: 330px; }
    .fin-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 14px; margin-top: 8px; }
    @media (max-width: 680px) { .fin-grid { grid-template-columns: 1fr; } }
    .fin-t { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    .fin-t td { padding: 7px 4px; border-bottom: 1px solid rgba(255,255,255,.07); color: #cdd6e6; }
    .fin-t td:last-child { text-align: right; font-weight: 700; color: #eaf1fb; font-variant-numeric: tabular-nums; }
    .fin-t .dim { color: #7e8ca6; font-weight: 400; font-size: 11px; }
    .jof { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.3); border-radius: 12px; padding: 12px 14px; }
    .jof-h { font-size: 12px; font-weight: 700; color: #f6b13b; display: flex; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
    .jof-lnk { color: #9fb0c8; font-weight: 400; text-decoration: none; }
    .jof-lnk:hover { color: #f6b13b; }
    .jof-v { font-size: 24px; font-weight: 800; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .jof-v span { font-size: 12px; color: #9fb0c8; font-weight: 500; }
    .jof-s { font-size: 12px; color: #9fb0c8; margin-bottom: 8px; }
    .jof-row { display: flex; justify-content: space-between; gap: 8px; font-size: 11.5px; color: #cdd6e6; padding: 3px 0; border-top: 1px solid rgba(246,177,59,.15); }
    .jof-row b { font-variant-numeric: tabular-nums; }
    #sv-rev { width: 100%; height: 240px; }
    #sv-mal { width: 100%; }
    .srcnote { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    .stj-bsj { font-size: 13.5px; }
    .stj { display: flex; flex-wrap: wrap; gap: 6px; }
    .stj-m { font-size: 12px; color: #eaf1fb; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09); border-left: 3px solid var(--pc); border-radius: 8px; padding: 5px 10px; }
    .stj-m i { color: #7e8ca6; font-style: normal; margin-left: 6px; font-size: 11px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: radar + staðgreiðslu-lína + málaflokka-súlur. astro:page-load (VT). #2 -->
  <script define:vars={{ RADAR, hasRadar, muniName: p.name, REV, MAL, PGSLUG: slugify(p.name) }}>
    function initRadar() {
      // Fellilistinn: veldu sveitarfélag → beint á síðuna þess (LOTA 12)
      const jump = document.getElementById('sv-jump');
      if (jump && !jump.dataset.wired) {
        jump.dataset.wired = '1';
        jump.addEventListener('change', () => { if (/^[a-z0-9-]+$/.test(jump.value)) window.location.href = '/sveitarfelog/' + jump.value + '/'; });
      }
      const el = document.getElementById('sv-radar');
      const anyEl = el || document.getElementById('sv-rev') || document.getElementById('sv-mal');
      if (!anyEl) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initRadar, { once: true });
        return;
      }
      if (el && hasRadar && !window.echarts.getInstanceByDom(el)) {
      const c = window.echarts.init(el);
      c.setOption({
        backgroundColor: 'transparent',
        tooltip: { backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 } },
        radar: {
          indicator: RADAR.map((a) => ({ name: a.l, max: 100 })),
          center: ['50%', '54%'], radius: '68%',
          axisName: { color: '#9fb0c8', fontSize: 11.5 },
          splitArea: { areaStyle: { color: ['rgba(255,255,255,.02)', 'rgba(255,255,255,.045)'] } },
          splitLine: { lineStyle: { color: 'rgba(255,255,255,.1)' } },
          axisLine: { lineStyle: { color: 'rgba(255,255,255,.12)' } },
        },
        series: [{ type: 'radar', data: [{ name: muniName, value: RADAR.map((a) => (a.v == null ? 0 : a.v)), lineStyle: { color: '#f6b13b', width: 2.5 }, itemStyle: { color: '#f6b13b' }, areaStyle: { color: '#f6b13b', opacity: 0.22 } }] }],
      });
      window.addEventListener('resize', () => c.resize());
      }
      // Staðgreiðslu-þróun + málaflokkar (sama echarts-hleðsla)
      const cr = document.getElementById('sv-rev');
      if (cr && REV && !window.echarts.getInstanceByDom(cr)) {
        const c2 = window.echarts.init(cr);
        c2.setOption({
          backgroundColor: 'transparent', grid: { left: 44, right: 12, top: 12, bottom: 22 },
          xAxis: { type: 'category', data: REV.years, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
          yAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
          tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(v).replace('.', ',') + ' ma.kr') },
          series: [{ type: 'line', data: REV.vals, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#19d3c5' }, areaStyle: { opacity: 0.12, color: '#19d3c5' } }],
        });
        window.addEventListener('resize', () => c2.resize());
      }
      const cm = document.getElementById('sv-mal');
      if (cm && MAL && MAL.length && !window.echarts.getInstanceByDom(cm)) {
        cm.style.height = (MAL.length * 26 + 24) + 'px';
        const c3 = window.echarts.init(cm);
        c3.setOption({
          backgroundColor: 'transparent', grid: { left: 168, right: 54, top: 4, bottom: 20 },
          xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
          yAxis: { type: 'category', inverse: true, data: MAL.map((d) => d.label), axisLabel: { color: '#cdd6e6', fontSize: 10.5, width: 158, overflow: 'truncate' }, axisLine: { show: false }, axisTick: { show: false } },
          tooltip: { trigger: 'axis', valueFormatter: (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' m.kr' },
          series: [{ type: 'bar', barWidth: 13, data: MAL.map((d) => d.v), itemStyle: { color: '#7c5cf7' }, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 9.5, formatter: (p) => String(Math.round(p.value)).replace(/\B(?=(\d{3})+(?!\d))/g, '.') } }],
        });
        window.addEventListener('resize', () => c3.resize());
      }
    }
    // Slug-vörður: 61 síða deilir data-pg — aðeins hlustari ÞESSARAR síðu má mála (VT-mengunarvörn).
    document.addEventListener('astro:page-load', () => { const m = document.querySelector('main[data-pg="sveitarfelog-slug"]'); if (m && m.dataset.slug === PGSLUG) initRadar(); });
  </script>
</Layout>
