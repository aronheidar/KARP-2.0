---
// Eignatengsl (LOTA — ný vöktunarsíða) — opið yfirlit yfir hverjir eiga flest: skip og félög.
// Gögnin (skip_owners.json / eigendur_reverse.json) birtast annars per-fyrirtæki; ÞESSI síða =
// samsteypt eignatengsla-yfirlit með topplistum: stærstu skipaeigendur + stærstu eignanet félaga.
// SSR: KPIs + súlurit + topplistar. Client: leit að eiganda (nafn/kt) → skipin hans.
// Gögn: build_skip_owners.mjs (byKt+nofn) + build_eigendur_reverse.mjs (byOwner). Aðeins lögaðilar.
import Layout from '../layouts/Layout.astro';
import SKIP from '../../public/gogn/skip_owners.json';
import REV from '../../public/gogn/eigendur_reverse.json';

const byKt = SKIP.byKt || {};
const nofn = SKIP.nofn || {};
const nSkip = SKIP.skip || 0;
const nOwners = SKIP.logadilar || Object.keys(byKt).length;
const updated = (SKIP.updated || '').slice(0, 10);

const fleets = Object.entries(byKt).map(([kt, arr]) => ({
  kt, nafn: nofn[kt] || null, count: arr.length,
  ships: arr.slice().map((s) => s.nafn).filter(Boolean),
})).sort((a, b) => b.count - a.count);
const topFleets = fleets.slice(0, 24);
const chartFleets = fleets.filter((f) => f.nafn).slice(0, 15);

// Eignanet félaga (öfug eignarhaldsskrá — raunverulegir eigendur → félög í eigu)
const rev = REV.byOwner || {};
const corp = Object.values(rev)
  .map((o) => ({ nafn: o.nafn, companies: (o.a || []).filter((c) => c && c.kt) }))
  .filter((o) => o.companies.length)
  .sort((a, b) => b.companies.length - a.companies.length);
const topCorp = corp.slice(0, 12);
const nCorp = corp.length;

const shortNafn = (s) => (s || '').replace(/\s(ehf|hf|slf|sf|ohf)\.?$/i, '').slice(0, 22);
const fmt = (v) => new Intl.NumberFormat('is-IS').format(v || 0);
const biggest = topFleets[0] || { nafn: '—', count: 0 };
const chartData = chartFleets.map((f) => ({ nafn: shortNafn(f.nafn) || f.kt, count: f.count }));

const desc = `Hverjir eiga flest? Eignatengsl á einum stað — ${fmt(nSkip)} skráð skip í eigu ${fmt(nOwners)} lögaðila, plús eignanet félaga. Stærsti skipaeigandinn er ${biggest.nafn} með ${biggest.count} skip. Leitaðu að eiganda.`;
---
<Layout title="Eignatengsl — hverjir eiga flest skip og félög | Karp" description={desc} canonical="https://karp.is/tengsl/" ogTitle="Eignatengsl Íslands">
  <main data-pg="tengsl">
    <p class="kicker">Hagvísir Íslands · Karp+</p>
    <h1>Eignatengsl 🔗</h1>
    <p class="lead">Hverjir eiga flest? Opið yfirlit yfir eignatengsl íslensks atvinnulífs — <strong>{fmt(nSkip)} skráð skip</strong> í eigu <strong>{fmt(nOwners)} lögaðila</strong>, ásamt eignaneti félaga úr raunverulegra-eigenda skránni. Stærsti skipaeigandinn er <strong>{biggest.nafn}</strong> ({biggest.count} skip). Fletta má hverju félagi upp á <a href="/fyrirtaeki/">fyrirtækjaprófíl</a> — þar sést m.a. aflamark (kvóti) og endanlegir eigendur.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Skipaeign: Samgöngustofa skipaskrá um island.is (shipRegistryShipSearch) — lögaðila-eigendur skráðra skipa. Eignanet félaga: öfug eignarhaldsskrá byggð úr opinberum ársreikningum (raunverulegir eigendur → félög í eigu); sú skrá vex eftir því sem fleiri fyrirtæki eru skoðuð. Aðeins lögaðilar; einstaklinga-kt eru ekki birt í magni.">ⓘ</i> Um gögnin · aðeins lögaðilar</p>

    <div class="kpis">
      <div class="kpi"><div class="k-l">🚢 Skráð skip</div><div class="k-v">{fmt(nSkip)}</div><div class="k-s">í eigu lögaðila</div></div>
      <div class="kpi"><div class="k-l">🏢 Skipaeigendur</div><div class="k-v">{fmt(nOwners)}</div><div class="k-s">lögaðilar</div></div>
      <div class="kpi"><div class="k-l">🥇 Stærsti floti</div><div class="k-v">{biggest.count}</div><div class="k-s">{biggest.nafn}</div></div>
      <div class="kpi"><div class="k-l">🔗 Eignanet félaga</div><div class="k-v">{fmt(nCorp)}</div><div class="k-s">eigendur með ≥1 félag</div></div>
    </div>

    <h2>Stærstu skipaeigendur</h2>
    <p class="sub">Lögaðilar með flest skráð skip — útgerðir, hafnir, sjóðir og félög. Byggt á fjölda skráðra skipa (ekki aflamarki); aflamark hvers félags sést á fyrirtækjaprófíl.</p>
    <div class="cwrap"><div id="c-fleets" class="ch"></div></div>

    <h2>🏆 Topplisti skipaeigenda</h2>
    <p class="sub">Efstu {topFleets.length} eigendur eftir fjölda skráðra skipa. Smelltu á nafn til að sjá fyrirtækjaprófíl.</p>
    <div class="top-grid">
      {topFleets.map((f, i) => (
        <div class="top-card">
          <span class="top-rank">{i + 1}</span>
          <div class="top-body">
            <a class="top-n" href={'/fyrirtaeki/?q=' + f.kt}>{f.nafn || f.kt}</a>
            <div class="top-ships">{f.ships.slice(0, 4).join(' · ')}{f.count > 4 ? ` +${f.count - 4}` : ''}</div>
          </div>
          <div class="top-c">{f.count}<span>skip</span></div>
        </div>
      ))}
    </div>

    {topCorp.length > 0 && (
      <>
        <h2>Stærstu eignanet félaga</h2>
        <p class="sub">Raunverulegir eigendur með flest félög í eigu, úr öfugri eignarhaldsskrá (byggð á opinberum ársreikningum). Skráin vex eftir því sem fleiri fyrirtæki eru greind á <a href="/eigendur/">Karp</a>.</p>
        <div class="corp-list">
          {topCorp.map((o, i) => (
            <div class="corp-row">
              <span class="corp-rank">{i + 1}</span>
              <span class="corp-n">{o.nafn}</span>
              <span class="corp-co">{o.companies.slice(0, 5).map((c) => (<a class="corp-chip" href={'/fyrirtaeki/?q=' + c.kt}>{c.nafn}</a>))}{o.companies.length > 5 ? <span class="corp-chip more">+{o.companies.length - 5}</span> : null}</span>
              <span class="corp-c">{o.companies.length}</span>
            </div>
          ))}
        </div>
      </>
    )}

    <h2>Leitaðu að eiganda</h2>
    <p class="sub">Sláðu inn nafn eða kennitölu skipaeiganda til að sjá skipin hans. {fmt(nOwners)} lögaðilar í skránni; nöfn birt fyrir stærstu eigendurna.</p>
    <div class="te-controls">
      <input id="te-q" type="search" placeholder="🔎 Leita: Brim, Samherji, útgerð…" autocomplete="off" />
    </div>
    <div id="te-count" class="te-cnt"></div>
    <div id="te-list" class="te-list"><div class="te-load">Hleð skránni…</div></div>
    <button id="te-more" class="te-more" hidden>Sýna fleiri</button>

    <p class="foot">Forþjónað (SSG). Heimildir: <b>Samgöngustofa skipaskrá</b> um island.is (skipaeign lögaðila) og <b>öfug eignarhaldsskrá</b> úr opinberum ársreikningum (eignanet félaga). Uppfært {updated}. Aðeins lögaðilar; topplistar sýna fjölda skráðra skipa (ekki aflamark). Nöfn stærstu skipaeigenda eru sótt beint úr skipaskránni; aðrir birtast með kennitölu (smelltu til að sjá félagið).</p>
  </main>

  <style>
    main { max-width: 1000px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; }
    p { color: #cdd6e6; } p a { color: #f6b13b; }
    .lead { font-size: 15px; line-height: 1.6; } .lead strong { color: #eaf0fb; }
    .datainfo { font-size: 12.5px; color: #7e8ca6; margin: 6px 0 4px; }
    .tip { font-style: normal; cursor: help; color: #f6b13b; border: 1px solid rgba(246,177,59,.4); border-radius: 50%; padding: 0 5px; font-size: 11px; }
    h2 { font-size: 17px; color: #eaf0fb; margin: 38px 0 4px; }
    .sub { font-size: 13.5px; color: #9fb0c8; margin: 0 0 14px; line-height: 1.55; } .sub a { color: #f6b13b; }

    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 24px; font-weight: 800; color: #56d4dd; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .cwrap { background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.06); border-radius: 12px; padding: 12px 10px 8px; }
    .ch { width: 100%; height: 360px; }

    .top-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 9px; margin-top: 4px; }
    .top-card { display: flex; align-items: center; gap: 11px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 11px; padding: 10px 13px; }
    .top-rank { flex: 0 0 26px; width: 26px; height: 26px; border-radius: 7px; background: rgba(86,212,221,.14); color: #56d4dd; font-weight: 800; font-size: 13px; display: flex; align-items: center; justify-content: center; }
    .top-body { flex: 1 1 auto; min-width: 0; }
    .top-n { font-size: 13.5px; font-weight: 700; color: #eaf1fb; text-decoration: none; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .top-n:hover { color: #56d4dd; }
    .top-ships { font-size: 11px; color: #7e8ca6; margin-top: 1px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .top-c { flex: 0 0 auto; color: #56d4dd; font-weight: 800; font-size: 18px; text-align: right; font-variant-numeric: tabular-nums; }
    .top-c span { display: block; font-size: 10px; color: #7e8ca6; font-weight: 400; }

    .corp-list { display: flex; flex-direction: column; gap: 4px; }
    .corp-row { display: grid; grid-template-columns: 26px minmax(120px,1fr) minmax(0,2fr) auto; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 9px; background: rgba(255,255,255,.02); }
    .corp-row:hover { background: rgba(255,255,255,.04); }
    .corp-rank { width: 24px; height: 24px; border-radius: 6px; background: rgba(188,140,255,.14); color: #bc8cff; font-weight: 800; font-size: 12px; display: flex; align-items: center; justify-content: center; }
    .corp-n { font-size: 13px; font-weight: 700; color: #eaf1fb; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .corp-co { display: flex; flex-wrap: wrap; gap: 3px; min-width: 0; }
    .corp-chip { font-size: 10.5px; color: #cdd6e6; background: rgba(255,255,255,.05); border-radius: 5px; padding: 1px 6px; text-decoration: none; white-space: nowrap; }
    .corp-chip:hover { color: #bc8cff; } .corp-chip.more { color: #7e8ca6; }
    .corp-c { color: #bc8cff; font-weight: 800; font-size: 15px; font-variant-numeric: tabular-nums; }

    .te-controls { margin: 4px 0 10px; }
    #te-q { width: 100%; box-sizing: border-box; font: inherit; font-size: 14px; padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.03); color: #eaf1fb; }
    #te-q:focus { outline: none; border-color: rgba(86,212,221,.5); }
    .te-cnt { font-size: 12.5px; color: #7e8ca6; margin: 0 2px 8px; }
    .te-more { display: block; margin: 14px auto 0; font: inherit; font-size: 13px; padding: 8px 20px; border-radius: 999px; border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.03); color: #cdd6e6; cursor: pointer; }
    .te-more:hover { border-color: rgba(86,212,221,.5); color: #eaf1fb; }

    .foot { font-size: 12px; color: #6f7b8d; margin-top: 30px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; line-height: 1.6; }
    .foot b { color: #9fb0c8; }
    @media (max-width: 620px) { h1 { font-size: 26px; } .corp-row { grid-template-columns: 24px 1fr auto; } .corp-co { grid-column: 2/4; } }
  </style>

  <style is:global>
    #te-list { display: flex; flex-direction: column; gap: 6px; margin-top: 4px; }
    .te-load { color: #7e8ca6; font-size: 13px; padding: 20px; }
    .te-item { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 12px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 10px; padding: 10px 13px; }
    .te-item:hover { border-color: rgba(86,212,221,.35); }
    .te-name { font-size: 13.5px; font-weight: 700; color: #eaf1fb; text-decoration: none; }
    .te-name:hover { color: #56d4dd; }
    .te-kt { font-size: 11px; color: #7e8ca6; font-weight: 400; }
    .te-ships { font-size: 11.5px; color: #9fb0c8; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; max-width: 100%; }
    .te-cc { color: #56d4dd; font-weight: 800; font-size: 16px; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .te-cc span { font-size: 10px; color: #7e8ca6; font-weight: 400; display: block; text-align: right; }
  </style>

  <script define:vars={{ chartData }}>
    function initTengsl() {
      if (!document.querySelector('main[data-pg="tengsl"]')) return;
      const AX = '#7e8ca6', GRID = 'rgba(255,255,255,.06)', LINE = 'rgba(255,255,255,.14)';
      const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      const nf = new Intl.NumberFormat('is-IS');

      const drawChart = () => {
        if (!window.echarts) return;
        const el = document.getElementById('c-fleets');
        if (!el || window.echarts.getInstanceByDom(el)) return;
        const c = window.echarts.init(el);
        const asc = chartData.slice().reverse();
        c.setOption({
          backgroundColor: 'transparent', grid: { left: 8, right: 40, top: 8, bottom: 22, containLabel: true },
          tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, formatter: (p) => esc(p[0].name) + '<br/><b>' + nf.format(p[0].value) + ' skip</b>' },
          xAxis: { type: 'value', axisLabel: { color: AX }, splitLine: { lineStyle: { color: GRID } } },
          yAxis: { type: 'category', data: asc.map((f) => f.nafn), axisLabel: { color: AX, fontSize: 11.5, width: 150, overflow: 'truncate' }, axisLine: { lineStyle: { color: LINE } } },
          series: [{ type: 'bar', data: asc.map((f) => f.count), itemStyle: { color: '#56d4dd', borderRadius: [0, 4, 4, 0] }, barMaxWidth: 22, label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 11 } }],
        });
        window.addEventListener('resize', () => { const i = window.echarts.getInstanceByDom(el); if (i) i.resize(); });
      };
      if (window.echarts) drawChart();
      else { let s = document.getElementById('echarts-cdn'); if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); } s.addEventListener('load', drawChart, { once: true }); }

      // ── Leit að eiganda ──────────────────────────────────────
      const listEl = document.getElementById('te-list'), cntEl = document.getElementById('te-count'), moreEl = document.getElementById('te-more'), qEl = document.getElementById('te-q');
      let DATA = null, filtered = [], shown = 0; const PAGE = 40;
      const item = (o) => {
        const nm = o.nafn ? '<a class="te-name" href="/fyrirtaeki/?q=' + o.kt + '">' + esc(o.nafn) + '</a>' : '<a class="te-name" href="/fyrirtaeki/?q=' + o.kt + '">Kt. ' + esc(o.kt) + '</a>';
        return '<div class="te-item"><div style="min-width:0">' + nm + (o.nafn ? ' <span class="te-kt">' + esc(o.kt) + '</span>' : '')
          + '<span class="te-ships">' + esc(o.ships.slice(0, 8).join(' · ')) + (o.count > 8 ? ' +' + (o.count - 8) : '') + '</span></div>'
          + '<div class="te-cc">' + o.count + '<span>skip</span></div></div>';
      };
      const apply = () => {
        const q = (qEl.value || '').toLowerCase().trim();
        filtered = q ? DATA.filter((o) => (o.nafn || '').toLowerCase().includes(q) || o.kt.includes(q.replace(/\D/g, '')) && q.replace(/\D/g, '').length >= 3) : DATA;
        shown = 0; listEl.innerHTML = '';
        cntEl.textContent = nf.format(filtered.length) + ' eigendur' + (q ? ' (síað)' : '');
        more();
      };
      const more = () => {
        const next = filtered.slice(shown, shown + PAGE);
        listEl.insertAdjacentHTML('beforeend', next.map(item).join('') || (shown === 0 ? '<div class="te-load">Enginn eigandi fannst.</div>' : ''));
        shown += next.length; moreEl.hidden = shown >= filtered.length;
      };
      fetch('/gogn/skip_owners.json').then((r) => r.json()).then((j) => {
        const bk = j.byKt || {}, nm = j.nofn || {};
        DATA = Object.entries(bk).map(([kt, arr]) => ({ kt, nafn: nm[kt] || null, count: arr.length, ships: arr.map((s) => s.nafn).filter(Boolean) }))
          .sort((a, b) => b.count - a.count);
        apply();
      }).catch(() => { listEl.innerHTML = '<div class="te-load">Ekki tókst að hlaða skránni.</div>'; });
      let t; qEl.addEventListener('input', () => { clearTimeout(t); t = setTimeout(() => DATA && apply(), 160); });
      moreEl.addEventListener('click', more);
    }
    document.addEventListener('astro:page-load', initTengsl);
  </script>
</Layout>
