---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Markaðir: vísitölur + íslensk hlutabréf (SVG-sparklines
// bakaðar á byggingartíma) + ávöxtunarferill ríkisbréfa (ECharts) úr markadir.json.
// Gögnin eru TÖFÐ/lokagildi (ekki rauntími). Í app-skelinni (Layout). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum } from '@lib/format.mjs';
import MARKADIR from '@gogn/markadir.json';
import RAUNVIRDI from '@gogn/raunvirdi.json';
import SENTIMENT from '@gogn/sentiment.json';
import FYRIRTAEKI from '../data/fyrirtaeki.json';

// Gengi + rafmyntir + málmar: live-endpoint sótt á BYGGINGARTÍMA (bakað upphafsgildi),
// eyjan endurhleður svo í vafra (CORS er opið fyrir app.karp.is). Þolir bilun.
let LIVEMK = null;
try {
  const r = await fetch('https://www.karp.is/wp-json/karp/v1/markadir');
  if (r.ok) LIVEMK = await r.json();
} catch (e) { LIVEMK = null; }
const FX = (LIVEMK && LIVEMK.fx) || [];
const CRYPTO = [...((LIVEMK && LIVEMK.crypto) || []), ...((LIVEMK && LIVEMK.metals) || [])];

const indices = MARKADIR.indices || [];
const stocks = (MARKADIR.stocks || []).slice().sort((a, b) => (b.chgPct || 0) - (a.chgPct || 0));
const bondNom = ((MARKADIR.bonds && MARKADIR.bonds.nominal) || []).slice().sort((a, b) => a.yr - b.yr);
const bondIdx = ((MARKADIR.bonds && MARKADIR.bonds.indexed) || []).slice().sort((a, b) => a.yr - b.yr);
const updated = MARKADIR.updated || '2026-07-01';

// Bökuð SVG-sparkline: hist[] → punktastrengur (0..100 × 0..30).
const sparkPts = (hist, w = 96, h = 30) => {
  if (!Array.isArray(hist) || hist.length < 2) return '';
  const min = Math.min(...hist), max = Math.max(...hist), range = max - min || 1;
  return hist.map((v, i) => `${((i / (hist.length - 1)) * w).toFixed(1)},${(h - ((v - min) / range) * h).toFixed(1)}`).join(' ');
};
const stk = stocks.map((s) => ({ ...s, pts: sparkPts(s.hist), up: (s.chgPct || 0) >= 0 }));

const chartYears = [...new Set([...bondNom, ...bondIdx].map((b) => b.yr))].sort((a, b) => a - b);

// Modal-gögn: OHLC (60 d) + velta + kennitölur (raunvirdi.json) + VIÐHORF (sentiment.json,
// varpað sym→fyrirtæki um fyrirtaeki.json t-sviðið) per félag — bakað.
const RV = RAUNVIRDI.companies || {};
const SENTC = SENTIMENT.companies || {};
const symToCo = {};
FYRIRTAEKI.forEach((f) => { if (f.t) symToCo[f.t] = f.n; });
const STOCKDATA = {};
stocks.forEach((s) => {
  const rv = RV[s.sym] || null;
  const co = symToCo[s.sym] || s.name;
  const se = SENTC[co] || null;
  STOCKDATA[s.sym] = {
    name: s.name, cur: s.cur || 'ISK', price: s.price, chgPct: s.chgPct,
    dates: s.dates || [], ohlc: s.ohlc || [], vol: s.vol || [],
    rv: rv ? { mcap: rv.mcap, pe: rv.pe, pb: rv.pb, bvps: rv.bvps, roe: rv.roe } : null,
    co,
    sent: se ? { idx: se.idx, n: se.n, pos: se.pos, neu: se.neu, neg: se.neg, recent: (se.recent || []).slice(0, 4).map((x) => ({ t: x.t, l: x.l, s: x.s })) } : null,
  };
});
const chg = (v) => (v == null ? '' : (v > 0 ? '+' : '') + fmtNum(v, 2) + '%');
const desc = `Íslenskur hlutabréfamarkaður — Úrvalsvísitala, ${stocks.length} skráð félög og ávöxtunarferill ríkisbréfa. Töfð lokagildi frá Kauphöll Íslands, uppfært ${updated}.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: 'Íslenskur hlutabréfamarkaður',
  description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland',
};
---

<Layout title="Markaðir — hlutabréf & ríkisbréf | Karp" description={desc} canonical="https://app.karp.is/markadir/" jsonLd={jsonLd} ogTitle="Markaðir á Íslandi">
  <main data-pg="markadir">
    <p class="kicker">Hagvísir Íslands · Markaðir</p>
    <h1>Markaðir</h1>
    <p>Íslenskur hlutabréfamarkaður — úrvalsvísitala, {stocks.length} skráð félög og ávöxtunarferill ríkisbréfa.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Markaðsgögn: verð um opna veitu Yahoo Finance (allt að 15 mín töf) og opinber viðmiðunargengi — upplýsingar, ekki viðskiptaráðgjöf. Bókfært gengi er úr síðustu birtu ársreikningum félaganna.">ⓘ</i> Um gögnin á síðunni</p>
    <p class="note">ⓘ Gögnin eru <strong>töfð lokagildi</strong> (EOD), ekki rauntími — rauntímagögn kauphallar eru leyfisbundin. Ekki fjárfestingarráðgjöf.</p>

    <div class="idx">
      {indices.map((i) => (
        <div class="idx-c">
          <div class="idx-n">{i.name}</div>
          <div class="idx-v">{fmtNum(i.price, 2)}</div>
          <div class={`idx-ch ${(i.chgPct || 0) >= 0 ? 'up' : 'dn'}`}>{chg(i.chgPct)}</div>
        </div>
      ))}
    </div>

    <h2>Skráð félög ({stk.length}) <span class="hint">— smelltu á dálkhaus til að raða, á félag fyrir kertarit og kennitölur</span></h2>
    <div class="tw">
      <table id="stk-table">
        <thead>
          <tr>
            <th class="l srt" data-k="sym">Félag</th>
            <th class="srt" data-k="price">Verð</th>
            <th class="srt on" data-k="chg">Breyting</th>
            <th class="spark-h">30 dagar</th>
          </tr>
        </thead>
        <tbody>
          {stk.map((s) => (
            <tr class="strow" data-sym={s.sym} data-price={s.price} data-chg={s.chgPct ?? 0} role="button" tabindex="0">
              <td class="l"><b class="st-sym">{s.sym}</b><span class="st-name">{s.name}</span></td>
              <td class="num">{fmtNum(s.price, s.price < 100 ? 2 : 1)} <span class="cur">{s.cur || 'ISK'}</span></td>
              <td class={`num ${s.up ? 'up' : 'dn'}`}>{chg(s.chgPct)}</td>
              <td class="spark-c">{s.pts && <svg class="st-spark" viewBox="0 0 96 30" preserveAspectRatio="none"><polyline points={s.pts} fill="none" stroke={s.up ? '#46e08a' : '#ff6d7a'} stroke-width="1.5" vector-effect="non-scaling-stroke" /></svg>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Modal: kertarit + kennitölur + umfjöllun & viðhorf (fyllt á keyrslutíma) -->
    <div id="stk-modal" hidden>
      <div class="stk-back"></div>
      <div class="stk-box">
        <button class="stk-x" aria-label="Loka">×</button>
        <div class="stk-head"><span id="stk-sym"></span><span id="stk-name"></span></div>
        <div id="stk-tiles" class="stk-tiles"></div>
        <div id="stk-chart"></div>
        <div id="stk-sent"></div>
        <a id="stk-yh" class="stk-yh" target="_blank" rel="noopener">Skoða á Yahoo Finance ↗</a>
      </div>
    </div>
    <script type="application/json" id="d-stocks" set:html={JSON.stringify(STOCKDATA)}></script>

    <div class="ppair">
      <div>
        <h2>💱 Gengi krónunnar <span class="hint" id="fx-note">— {LIVEMK ? 'lifandi' : 'töfð'} gögn</span></h2>
        <div id="fx-grid" class="mini-grid">
          {FX.map((c) => (
            <div class="mini" data-sym={c.sym} data-name={c.name} data-cur={c.cur || 'USD'} data-hist={JSON.stringify(c.hist || [])} role="button" tabindex="0">
              <div class="mini-top"><span class="mini-n">{c.name}</span><span class={`mini-ch ${(c.chgPct || 0) >= 0 ? 'up' : 'dn'}`}>{chg(c.chgPct)}</span></div>
              {sparkPts(c.hist) && <svg class="st-spark" viewBox="0 0 96 30" preserveAspectRatio="none"><polyline points={sparkPts(c.hist)} fill="none" stroke={(c.chgPct || 0) >= 0 ? '#46e08a' : '#ff6d7a'} stroke-width="1.5" vector-effect="non-scaling-stroke" /></svg>}
              <div class="mini-p">{fmtNum(c.price, 2)} <span>kr</span></div>
            </div>
          ))}
          {FX.length === 0 && <p class="src">Náði ekki í gengisgögn við byggingu — birtast við næstu uppfærslu.</p>}
        </div>
      </div>
      <div>
        <h2>₿ Rafmyntir &amp; eðalmálmar <span class="hint">— verð í USD</span></h2>
        <div id="cr-grid" class="mini-grid">
          {CRYPTO.map((c) => (
            <div class="mini" data-sym={c.sym} data-name={c.name} data-cur={c.cur || 'USD'} data-hist={JSON.stringify(c.hist || [])} role="button" tabindex="0">
              <div class="mini-top"><span class="mini-n">{c.name}</span><span class={`mini-ch ${(c.chgPct || 0) >= 0 ? 'up' : 'dn'}`}>{chg(c.chgPct)}</span></div>
              {sparkPts(c.hist) && <svg class="st-spark" viewBox="0 0 96 30" preserveAspectRatio="none"><polyline points={sparkPts(c.hist)} fill="none" stroke={(c.chgPct || 0) >= 0 ? '#46e08a' : '#ff6d7a'} stroke-width="1.5" vector-effect="non-scaling-stroke" /></svg>}
              <div class="mini-p">{fmtNum(c.price, c.price > 1000 ? 0 : 2)} <span>$</span></div>
            </div>
          ))}
          {CRYPTO.length === 0 && <p class="src">Náði ekki í rafmyntagögn við byggingu.</p>}
        </div>
      </div>
    </div>

    {chartYears.length > 0 && (
      <>
        <h2>Ávöxtunarferill ríkisbréfa</h2>
        <div id="chart"></div>
        <p class="src">RIKB = óverðtryggð (nafnávöxtun) · RIKS = verðtryggð (raunávöxtun). Heimild: Lánamál ríkisins.</p>
      </>
    )}

    <p class="foot">Forþjónað (SSG) {updated}. Töfð lokagildi (Kauphöll/Lánamál). Sparklines bakaðar á byggingartíma. #2.</p>
  </main>

  <style>
    main { max-width: 980px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 10px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 14px 0; }
    .idx { display: flex; flex-wrap: wrap; gap: 12px; margin: 18px 0 4px; }
    .idx-c { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 12px 16px; min-width: 180px; }
    .idx-n { font-size: 12px; color: #9fb0c8; }
    .idx-v { font-size: 26px; font-weight: 800; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .idx-ch { font-size: 13px; font-weight: 600; font-variant-numeric: tabular-nums; }
    .hint { font-size: 12px; color: #7e8ca6; text-transform: none; letter-spacing: 0; font-weight: 400; }
    /* Hlutabréfa-TAFLAN (LOTA 14, eins og gamla mkStockTable) */
    .tw { overflow-x: auto; }
    #stk-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    #stk-table th, #stk-table td { text-align: right; padding: 7px 10px; border-bottom: 1px solid rgba(255,255,255,.07); white-space: nowrap; }
    #stk-table th { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
    #stk-table th.srt { cursor: pointer; user-select: none; }
    #stk-table th.srt:hover, #stk-table th.srt.on { color: #f6b13b; }
    #stk-table td.l, #stk-table th.l { text-align: left; }
    .strow { cursor: pointer; }
    .strow:hover td { background: rgba(255,255,255,.03); }
    .st-sym { font-weight: 800; font-size: 13.5px; margin-right: 8px; }
    .st-name { font-size: 11.5px; color: #7e8ca6; }
    .num { font-variant-numeric: tabular-nums; }
    .cur { font-size: 10.5px; color: #7e8ca6; }
    .spark-c, .spark-h { width: 110px; }
    .st-spark { width: 96px; height: 26px; display: block; margin-left: auto; }
    .up { color: #46e08a; } .dn { color: #ff6d7a; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .mini-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px; }
    .mini { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 11px; padding: 10px 11px; cursor: pointer; transition: border-color .12s; }
    .mini:hover { border-color: #f6b13b; }
    .mini-top { display: flex; justify-content: space-between; gap: 6px; align-items: baseline; }
    .mini-n { font-size: 11px; color: #9fb0c8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mini-ch { font-size: 11.5px; font-weight: 700; font-variant-numeric: tabular-nums; }
    .mini-p { font-size: 15px; font-weight: 800; margin-top: 4px; font-variant-numeric: tabular-nums; }
    .mini-p span { font-size: 10.5px; color: #7e8ca6; font-weight: 400; }
    #chart { width: 100%; height: 340px; margin: 4px 0; }
    .src { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Modal er fyllt á keyrslutíma → global. */
    #stk-modal { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; }
    #stk-modal[hidden] { display: none; }
    .stk-back { position: absolute; inset: 0; background: rgba(3,6,12,.72); backdrop-filter: blur(2px); }
    .stk-box { position: relative; width: min(780px, calc(100vw - 28px)); max-height: calc(100vh - 40px); overflow: auto; background: #0b1220; border: 1px solid rgba(255,255,255,.14); border-radius: 16px; padding: 18px 20px; box-shadow: 0 18px 60px rgba(0,0,0,.55); }
    .stk-x { position: absolute; top: 10px; right: 12px; background: none; border: 0; color: #7e8ca6; font-size: 24px; cursor: pointer; line-height: 1; }
    .stk-x:hover { color: #eaf1fb; }
    .stk-head { display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px; }
    #stk-sym { font-size: 22px; font-weight: 800; color: #f6b13b; }
    #stk-name { font-size: 14px; color: #9fb0c8; }
    .stk-tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(96px, 1fr)); gap: 8px; margin-bottom: 10px; }
    .stk-t { background: rgba(255,255,255,.045); border: 1px solid rgba(255,255,255,.08); border-radius: 9px; padding: 8px 10px; }
    .stk-t .l { font-size: 10px; color: #8fa0b8; text-transform: uppercase; letter-spacing: .04em; }
    .stk-t .v { font-size: 15px; font-weight: 800; color: #eaf1fb; margin-top: 1px; font-variant-numeric: tabular-nums; }
    .stk-t .v.up { color: #46e08a; } .stk-t .v.dn { color: #ff6d7a; }
    #stk-chart { width: 100%; height: 380px; }
    .stk-yh { display: inline-block; margin-top: 8px; font-size: 12.5px; color: #9fb0c8; }
    .stk-yh:hover { color: #f6b13b; }
    .stk-sec { font-size: 13px; font-weight: 800; color: #f6b13b; text-transform: uppercase; letter-spacing: .04em; margin: 14px 0 6px; }
    .stk-sec2 { font-size: 11px; font-weight: 700; color: #19d3c5; text-transform: uppercase; letter-spacing: .04em; margin: 10px 0 4px; }
    .stk-tone { text-transform: none; letter-spacing: 0; font-size: 12px; }
    .stk-tn { text-transform: none; letter-spacing: 0; font-size: 11.5px; color: #7e8ca6; font-weight: 400; }
    .stk-sbar { display: flex; height: 8px; border-radius: 4px; overflow: hidden; margin: 4px 0 8px; }
    .stk-sbar i { display: block; height: 100%; }
    .stk-news { display: block; font-size: 12.5px; color: #cdd6e6; text-decoration: none; padding: 5px 2px; border-bottom: 1px solid rgba(255,255,255,.05); line-height: 1.35; }
    .stk-news:hover { color: #f6b13b; }
    .stk-ns { margin-right: 6px; font-size: 10.5px; }
    .stk-nd { margin-left: 8px; font-size: 10.5px; color: #7e8ca6; }
    .stk-livewrap { margin-top: 4px; }
  </style>

  <!-- Eyja: stock-modal (kertarit + MA + velta + kennitölur). #2 -->
  <script>
    const $id = (x) => document.getElementById(x);
    let stkChart = null;
    function stkClose() { const m = $id('stk-modal'); if (!m) return; m.hidden = true; if (stkChart) { stkChart.dispose(); stkChart = null; } }
    function stkOpen(sym) {
      const dataEl = $id('d-stocks'); if (!dataEl) return;
      const ALL = JSON.parse(dataEl.textContent || '{}');
      const d = ALL[sym]; if (!d) return;
      const m = $id('stk-modal');
      $id('stk-sym').textContent = sym;
      $id('stk-name').textContent = d.name || '';
      $id('stk-yh').href = 'https://finance.yahoo.com/quote/' + sym + '.IC';
      const f1 = (v, dg = 1) => (v == null ? '–' : Number(v).toFixed(dg).replace('.', ','));
      const ths = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      const lows = d.ohlc.map((o) => o[2]), highs = d.ohlc.map((o) => o[1]);
      const lo60 = lows.length ? Math.min(...lows) : null, hi60 = highs.length ? Math.max(...highs) : null;
      const rv = d.rv || {};
      const tiles = [
        { l: 'Verð', v: f1(d.price, d.price < 100 ? 2 : 1) + ' ' + (d.cur || 'ISK') },
        { l: 'Dagsbreyting', v: (d.chgPct > 0 ? '+' : '') + f1(d.chgPct, 2) + '%', c: d.chgPct >= 0 ? 'up' : 'dn' },
        rv.mcap != null && { l: 'Markaðsvirði', v: ths(rv.mcap / 1e9) + ' ma' },
        rv.pe != null && { l: 'V/H', v: f1(rv.pe, 1) },
        rv.pb != null && { l: 'V/I', v: f1(rv.pb, 2) },
        rv.bvps != null && { l: '📖 Bókfært/hlut', v: f1(rv.bvps, 1) },
        rv.roe != null && { l: 'ROE', v: f1(rv.roe, 1) + '%' },
        lo60 != null && { l: '60d lægst/hæst', v: f1(lo60, 1) + ' / ' + f1(hi60, 1) },
      ].filter(Boolean);
      $id('stk-tiles').innerHTML = tiles.map((t) => `<div class="stk-t"><div class="l">${t.l}</div><div class="v ${t.c || ''}">${t.v}</div></div>`).join('');
      // ── Umfjöllun & viðhorf (LOTA 12): bakað sentiment + lifandi fyrirsagnir ──
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const safeHref = (u) => (/^https?:\/\//i.test(String(u || '')) ? String(u) : '#');
      const sEl = $id('stk-sent');
      if (sEl) {
        const se = d.sent;
        let sh = '<div class="stk-sec">📰 Umfjöllun &amp; viðhorf';
        if (se && se.n) {
          const tone = se.idx > 15 ? ['jákvæð', '#46e08a'] : se.idx < -15 ? ['neikvæð', '#ff6d7a'] : ['hlutlaus', '#9fb0c8'];
          sh += ` <span class="stk-tone" style="color:${tone[1]}">tónn ${se.idx > 0 ? '+' : ''}${se.idx} (${tone[0]})</span> <span class="stk-tn">· ${se.n} fréttir greindar</span>`;
        }
        sh += '</div>';
        if (se && (se.pos || se.neu || se.neg)) {
          const tot = (se.pos + se.neu + se.neg) || 1;
          sh += `<div class="stk-sbar"><i style="width:${(se.pos / tot) * 100}%;background:#46e08a"></i><i style="width:${(se.neu / tot) * 100}%;background:#5a6678"></i><i style="width:${(se.neg / tot) * 100}%;background:#ff6d7a"></i></div>`;
        }
        if (se && se.recent && se.recent.length) {
          sh += se.recent.map((x) => `<a class="stk-news" href="${safeHref(x.l)}" target="_blank" rel="noopener"><span class="stk-ns">${x.s > 0 ? '🟢' : x.s < 0 ? '🔴' : '⚪'}</span>${esc(x.t)}</a>`).join('');
        }
        sh += '<div id="stk-live" class="stk-livewrap"><span class="stk-tn">Sæki nýjustu umfjöllun…</span></div>';
        sEl.innerHTML = sh;
        // Lifandi fyrirsagnir um félagið (frettir-endpoint, {items}-lögun!)
        fetch('https://www.karp.is/wp-json/karp/v1/frettir?q=' + encodeURIComponent(d.co || d.name) + '&days=90')
          .then((r) => (r.ok ? r.json() : null))
          .then((res) => {
            const lv = $id('stk-live');
            if (!lv) return;
            const items = Array.isArray(res) ? res : (res && res.items) || [];
            if (!items.length) { lv.innerHTML = '<span class="stk-tn">Engin nýleg umfjöllun fannst (leitað eftir nafni félagsins).</span>'; return; }
            lv.innerHTML = '<div class="stk-sec2">Nýjast úr fjölmiðlum</div>' + items.slice(0, 5).map((x) => `<a class="stk-news" href="${safeHref(x.l || x.link)}" target="_blank" rel="noopener"><span class="stk-ns">🗞️</span>${esc(x.t || x.titill || '')}<span class="stk-nd">${esc(x.src || x.m || '')}</span></a>`).join('');
          })
          .catch(() => { const lv = $id('stk-live'); if (lv) lv.innerHTML = ''; });
      }
      m.hidden = false;
      const boot = () => {
        const el = $id('stk-chart');
        if (stkChart) stkChart.dispose();
        stkChart = window.echarts.init(el);
        const closes = d.ohlc.map((o) => o[3]);
        const ma = (n) => closes.map((_, i) => (i < n - 1 ? null : Math.round((closes.slice(i - n + 1, i + 1).reduce((a, b) => a + b, 0) / n) * 100) / 100));
        let ymin = Math.min(...lows), ymax = Math.max(...highs);
        if (rv.bvps != null) { ymin = Math.min(ymin, rv.bvps); ymax = Math.max(ymax, rv.bvps); }
        const pad = (ymax - ymin) * 0.06 || 1;
        stkChart.setOption({
          backgroundColor: 'transparent',
          legend: { data: ['Verð', 'MA5', 'MA20'], textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0 },
          tooltip: { trigger: 'axis', axisPointer: { type: 'cross' }, backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 } },
          grid: [{ left: 52, right: 14, top: 28, height: '58%' }, { left: 52, right: 14, top: '76%', height: '14%' }],
          xAxis: [
            { type: 'category', data: d.dates, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            { type: 'category', gridIndex: 1, data: d.dates, show: false },
          ],
          yAxis: [
            { type: 'value', min: Math.floor(ymin - pad), max: Math.ceil(ymax + pad), axisLabel: { color: '#7e8ca6', fontSize: 10 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            { type: 'value', gridIndex: 1, show: false },
          ],
          dataZoom: [{ type: 'inside', xAxisIndex: [0, 1] }, { type: 'slider', xAxisIndex: [0, 1], bottom: 0, height: 16, borderColor: 'rgba(255,255,255,.1)', textStyle: { color: '#7e8ca6' } }],
          series: [
            { name: 'Verð', type: 'candlestick', data: d.ohlc, itemStyle: { color: '#46e08a', color0: '#ff6d7a', borderColor: '#46e08a', borderColor0: '#ff6d7a' },
              markLine: rv.bvps != null ? { silent: true, symbol: 'none', data: [{ yAxis: rv.bvps }], lineStyle: { type: 'dashed', color: '#ffd479', width: 2 }, label: { formatter: 'bókfært virði/hlut', color: '#ffd479', fontSize: 11, fontWeight: 700 } } : undefined },
            { name: 'MA5', type: 'line', data: ma(5), smooth: true, symbol: 'none', lineStyle: { width: 1.4, color: '#3a8dff' } },
            { name: 'MA20', type: 'line', data: ma(20), smooth: true, symbol: 'none', lineStyle: { width: 1.4, color: '#7c5cf7' } },
            { name: 'Velta', type: 'bar', xAxisIndex: 1, yAxisIndex: 1, data: d.vol.map((v, i) => ({ value: v, itemStyle: { color: d.ohlc[i] && d.ohlc[i][3] >= d.ohlc[i][0] ? 'rgba(70,224,138,.55)' : 'rgba(255,109,122,.55)' } })), tooltip: { valueFormatter: (v) => ths(v) } },
          ],
        });
      };
      if (window.echarts) boot();
      else {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', boot, { once: true });
      }
    }
    function initStkModal() {
      const m = $id('stk-modal');
      if (!m) return;
      // Portal á body: transform á forföður má ekki brjóta fixed-staðsetningu
      if (m.parentElement !== document.body) document.body.appendChild(m);
      document.querySelectorAll('.strow[data-sym]').forEach((c) => {
        c.onclick = () => stkOpen(c.dataset.sym);
        c.onkeydown = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); stkOpen(c.dataset.sym); } };
      });
      // Röðun á töflunni (LOTA 14): smella á dálkhaus, aftur = öfug röð
      const tbl = document.getElementById('stk-table');
      if (tbl && !tbl.dataset.srt) {
        tbl.dataset.srt = '1';
        tbl.querySelectorAll('th.srt').forEach((h) => {
          h.addEventListener('click', () => {
            const k = h.dataset.k;
            tbl.querySelectorAll('th.srt').forEach((x) => x.classList.toggle('on', x === h));
            const dir = h.dataset.d === '1' ? -1 : 1;
            h.dataset.d = String(dir);
            const tb = tbl.querySelector('tbody');
            [...tb.querySelectorAll('tr')].sort((a, b) => {
              if (k === 'sym') return dir * a.dataset.sym.localeCompare(b.dataset.sym);
              return dir * ((+b.dataset[k]) - (+a.dataset[k]));
            }).forEach((tr) => tb.appendChild(tr));
          });
        });
      }
      m.querySelector('.stk-x').onclick = stkClose;
      m.querySelector('.stk-back').onclick = stkClose;
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') stkClose(); });
    }
    // Smellur á gjaldmiðil/rafmynt/málm → gluggi með línugrafi (LOTA 15b)
    function miniOpen(el2) {
      const m = $id('stk-modal');
      if (!m) return;
      let hist = [];
      try { hist = JSON.parse(el2.dataset.hist || '[]'); } catch (e) {}
      const name = el2.dataset.name || el2.dataset.sym;
      const isUsd = el2.dataset.cur === 'USD';
      const cur = isUsd ? 'USD' : 'kr';
      const priceTxt = (el2.querySelector('.mini-p') || {}).textContent || '';
      const chTxt = (el2.querySelector('.mini-ch') || {}).textContent || '';
      $id('stk-sym').textContent = name;
      $id('stk-name').textContent = el2.dataset.sym;
      $id('stk-yh').href = 'https://finance.yahoo.com/quote/' + encodeURIComponent(el2.dataset.sym);
      $id('stk-tiles').innerHTML = '<div class="stk-t"><div class="l">Verð</div><div class="v">' + priceTxt + '</div></div>'
        + '<div class="stk-t"><div class="l">Dagsbreyting</div><div class="v ' + (chTxt.indexOf('-') === 0 ? 'dn' : 'up') + '">' + chTxt + '</div></div>'
        + (hist.length > 1 ? '<div class="stk-t"><div class="l">22d lægst/hæst</div><div class="v">' + Math.min.apply(null, hist).toFixed(1).replace('.', ',') + ' / ' + Math.max.apply(null, hist).toFixed(1).replace('.', ',') + '</div></div>' : '');
      const se = $id('stk-sent');
      if (se) se.innerHTML = '';
      m.hidden = false;
      const boot2 = () => {
        const el3 = $id('stk-chart');
        if (stkChart) stkChart.dispose();
        stkChart = window.echarts.init(el3);
        stkChart.setOption({
          backgroundColor: 'transparent',
          grid: { left: 56, right: 16, top: 18, bottom: 24 },
          tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : Number(v).toFixed(2).replace('.', ',') + ' ' + cur) },
          xAxis: { type: 'category', data: hist.map((_, i) => (i - hist.length + 1) + ' d'), axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
          yAxis: { type: 'value', scale: true, axisLabel: { color: '#7e8ca6', fontSize: 10 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
          series: [{ type: 'line', data: hist, smooth: true, symbol: 'none', lineStyle: { color: '#f6b13b', width: 2.6 }, itemStyle: { color: '#f6b13b' }, areaStyle: { color: '#f6b13b', opacity: 0.1 } }],
        });
      };
      if (window.echarts) boot2();
      else {
        let sc = document.getElementById('echarts-cdn');
        if (!sc) { sc = document.createElement('script'); sc.id = 'echarts-cdn'; sc.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(sc); }
        sc.addEventListener('load', boot2, { once: true });
      }
    }
    function initMiniClicks() {
      document.querySelectorAll('.mini[data-sym]').forEach((el2) => {
        if (el2.dataset.wired) return;
        el2.dataset.wired = '1';
        el2.addEventListener('click', () => miniOpen(el2));
        el2.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); miniOpen(el2); } });
      });
    }
    // Lifandi endurhleðsla á gengi/rafmyntum/málmum (bökuð gildi uppfærð í vafra)
    function initLiveMk() {
      const grid = document.getElementById('fx-grid');
      if (!grid || grid.dataset.live) return;
      grid.dataset.live = '1';
      fetch('https://www.karp.is/wp-json/karp/v1/markadir')
        .then((r) => (r.ok ? r.json() : null))
        .then((mk) => {
          if (!mk) return;
          const f1 = (v, dg) => (v == null ? '–' : Number(v).toFixed(dg).replace('.', ','));
          const all = [...(mk.fx || []), ...(mk.crypto || []), ...(mk.metals || [])];
          all.forEach((c) => {
            const el = document.querySelector(`.mini[data-sym="${c.sym.replace(/"/g, '')}"]`);
            if (!el) return;
            const p = el.querySelector('.mini-p'), ch = el.querySelector('.mini-ch');
            const usd = /USD$|=F$/.test(c.sym) && c.cur === 'USD';
            if (p) p.innerHTML = f1(c.price, c.price > 1000 ? 0 : 2) + ' <span>' + (usd ? '$' : 'kr') + '</span>';
            if (ch) { ch.textContent = (c.chgPct > 0 ? '+' : '') + f1(c.chgPct, 2) + '%'; ch.className = 'mini-ch ' + (c.chgPct >= 0 ? 'up' : 'dn'); }
          });
          const note = document.getElementById('fx-note');
          if (note) note.textContent = '— 🟢 lifandi gögn';
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="markadir"]')) { initStkModal(); initLiveMk(); initMiniClicks(); } });
  </script>

  <!-- Eyja: ávöxtunarferill (ECharts), astro:page-load. #2 -->
  <script define:vars={{ chartYears, bondNom, bondIdx }}>
    function initChart() {
      const el = document.getElementById('chart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initChart, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const mk = (arr) => chartYears.map((y) => { const b = arr.find((x) => x.yr === y); return b ? b.yield : null; });
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        legend: { data: ['Óverðtryggð (RIKB)', 'Verðtryggð (RIKS)'], textStyle: { color: '#9fb0c8' }, top: 0 },
        grid: { left: 40, right: 18, top: 34, bottom: 26 },
        xAxis: { type: 'category', data: chartYears, axisLabel: { color: '#7e8ca6' }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v + '%') },
        series: [
          { name: 'Óverðtryggð (RIKB)', type: 'line', data: mk(bondNom), smooth: true, connectNulls: true, lineStyle: { width: 3, color: '#f6b13b' }, itemStyle: { color: '#f6b13b' } },
          { name: 'Verðtryggð (RIKS)', type: 'line', data: mk(bondIdx), smooth: true, connectNulls: true, lineStyle: { width: 3, color: '#3a8dff' }, itemStyle: { color: '#3a8dff' } },
        ],
      });
      window.addEventListener('resize', () => chart.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="markadir"]')) initChart(); });
  </script>
</Layout>
