---
// /okutaeki/ — SAMEINUÐ við skipaleit (Verk 1) → /okutaeki-skip/ (rofi á „Ökutæki").
// Beinum áfram og höldum ?n= fyrirspurninni svo gamlir tenglar/bókamerki virki.
// is:inline → klassísk skrifta sem keyrir SAMSTUNDIS við þáttun (á undan meta-refresh)
// og heldur fyrirspurninni; meta-refresh er varafall fyrir JS-lausa vafra.
---
<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        try {
          var n = new URLSearchParams(location.search).get('n');
          location.replace('/okutaeki-skip/?t=oku' + (n ? '&n=' + encodeURIComponent(n) : ''));
        } catch (e) {}
      })();
    </script>
    <meta http-equiv="refresh" content="0; url=/okutaeki-skip/?t=oku" />
    <link rel="canonical" href="https://karp.is/okutaeki-skip/" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Ökutækjaleit — áfram á Karp</title>
  </head>
  <body>
    <p>Ökutækjaleitin er nú hluti af <a href="/okutaeki-skip/?t=oku">Ökutækja- &amp; skipaleit</a>…</p>
  </body>
</html>
