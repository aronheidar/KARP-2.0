---
// Ökutækjaleit (LOTA 90) — bílnúmer → tegund/árgerð/litur/staða/næsta skoðun/þyngd/CO₂/VIN.
// Lifandi um worker /api/okutaeki (island.is publicVehicleSearch, @BypassAuth). Opin síða.
// ⚠ eigandi/veðbönd/skoðunarsaga eru innskráningarlæst (Mínar síður) — sýnum grunntíer.
import Layout from '../layouts/Layout.astro';
const desc = 'Ökutækjaleit — flettu upp íslensku bílnúmeri: tegund, árgerð, litur, staða, næsta skoðun, þyngd, CO₂-losun og verksmiðjunúmer (VIN). Ókeypis, beint frá Samgöngustofu um island.is.';
---
<Layout title="Ökutækjaleit — flettu upp bílnúmeri | Karp" description={desc} canonical="https://karp.is/okutaeki/" ogTitle="Ökutækjaleit">
  <main data-pg="okutaeki">
    <p class="kicker">Hagvísir Íslands · Uppfletting</p>
    <h1>Ökutækjaleit 🚗</h1>
    <p class="lead">Flettu upp íslensku bílnúmeri og sjáðu skráðar upplýsingar ökutækisins — tegund, árgerð, lit, stöðu, <strong>næstu skoðun</strong>, þyngd, CO₂-losun og verksmiðjunúmer. Ókeypis, beint frá Samgöngustofu um island.is.</p>

    <form id="ok-form" class="ok-form" autocomplete="off">
      <input id="bnr" type="text" inputmode="latin" maxlength="6" placeholder="Bílnúmer · t.d. AB123" aria-label="Bílnúmer" />
      <button type="submit" id="ok-go">Fletta upp</button>
    </form>
    <div id="ok-result" class="ok-result" aria-live="polite"></div>

    <p class="ok-lock">🔒 <strong>Eigandi, veðbönd og skoðunarsaga</strong> eru ekki í opna skránni — þau krefjast innskráningar með rafrænum skilríkjum á <a href="https://island.is/minarsidur/eignir/okutaeki/leit" target="_blank" rel="noopener">Mínum síðum</a>.</p>
    <p class="foot">Heimild: Samgöngustofa um opna ökutækjaleit island.is (<code>publicVehicleSearch</code>). Grunnupplýsingar ökutækis, engar persónuupplýsingar. Uppfletting takmörkuð (öryggisnet gegn fjöldaflettingu).</p>
  </main>

  <style>
    main { max-width: 680px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; }
    p { color: #cdd6e6; } a { color: #f6b13b; }
    .lead { font-size: 15px; line-height: 1.6; } .lead strong { color: #eaf0fb; }

    .ok-form { display: flex; gap: 8px; margin: 20px 0 4px; }
    #bnr { flex: 1 1 auto; font: inherit; font-size: 20px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; text-align: center; padding: 12px 14px; border-radius: 11px; border: 1px solid rgba(255,255,255,.16); background: rgba(255,255,255,.04); color: #eaf1fb; }
    #bnr:focus { outline: none; border-color: rgba(246,177,59,.6); }
    #bnr::placeholder { color: #6f7b8d; font-weight: 400; letter-spacing: normal; }
    #ok-go { font: inherit; font-size: 15px; font-weight: 700; padding: 0 22px; border-radius: 11px; border: 0; background: #f6b13b; color: #10151f; cursor: pointer; }
    #ok-go:disabled { opacity: .55; cursor: default; }

    .ok-result { margin-top: 14px; }
    .ok-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 14px; padding: 18px 20px; }
    .ok-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
    .ok-h h2 { font-size: 21px; margin: 0; color: #eaf1fb; }
    .ok-plate { font-size: 13px; font-weight: 800; letter-spacing: .12em; background: #12203a; color: #cfe0ff; border: 1px solid #2b4272; border-radius: 6px; padding: 3px 9px; }
    .ok-sub { font-size: 13px; color: #9fb0c8; margin: 0 0 14px; }
    .ok-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px 16px; }
    .ok-f .l { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; }
    .ok-f .v { font-size: 15px; color: #eaf1fb; font-weight: 600; margin-top: 1px; font-variant-numeric: tabular-nums; }
    .ok-f .v.ok { color: #46d086; } .ok-f .v.warn { color: #f6b13b; } .ok-f .v.bad { color: #f85149; }
    .ok-msg { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 16px 18px; color: #cdd6e6; font-size: 14px; }
    .ok-lock { font-size: 12.5px; color: #9fb0c8; margin-top: 16px; background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.18); border-radius: 10px; padding: 10px 13px; }
    .ok-lock strong { color: #eaf1fb; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 14px; line-height: 1.6; } .foot code { color: #9fb0c8; }
  </style>

  <script>
    function initOku() {
      const form = document.getElementById('ok-form');
      if (!form || form.dataset.on) return;
      form.dataset.on = '1';
      const inp = document.getElementById('bnr'), btn = document.getElementById('ok-go'), out = document.getElementById('ok-result');
      const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      const isoIS = (iso) => { if (!iso) return null; const [y, m, d] = iso.split('-'); return d ? +d + '.' + +m + '.' + y : iso; };
      const today = new Date().toISOString().slice(0, 10);
      const f = (l, v, cls) => '<div class="ok-f"><div class="l">' + l + '</div><div class="v' + (cls ? ' ' + cls : '') + '">' + (v == null || v === '' ? '—' : esc(v)) + '</div></div>';

      const render = (d) => {
        if (d.error === 'numer') { out.innerHTML = '<div class="ok-msg">Sláðu inn gilt bílnúmer (2–6 stafir).</div>'; return; }
        if (d.error === 'kvoti') { out.innerHTML = '<div class="ok-msg">⏳ Of margar flettingar í bili — reyndu aftur síðar.</div>'; return; }
        if (!d.fannst) { out.innerHTML = '<div class="ok-msg">🔍 Ökutæki með númerið <b>' + esc(d.numer || '') + '</b> fannst ekki. Athugaðu stafsetningu (fastanúmer virkar líka).</div>'; return; }
        const insp = d.naestaSkodun, inspCls = insp ? (insp < today ? 'bad' : 'ok') : '';
        const inspTxt = insp ? isoIS(insp) + (insp < today ? ' · útrunnin' : '') : '—';
        const statCls = /í lagi/i.test(d.stada || '') ? 'ok' : (/(afskrá|ónýtt|innkoll|bann)/i.test(d.stada || '') ? 'bad' : '');
        out.innerHTML = '<div class="ok-card">'
          + '<div class="ok-h"><h2>' + esc([d.tegund, d.undirheiti].filter(Boolean).join(' ') || 'Ökutæki') + '</h2><span class="ok-plate">' + esc(d.numer) + '</span></div>'
          + (d.argerd ? '<p class="ok-sub">Árgerð ' + esc(d.argerd) + (d.fyrstSkrad ? ' · fyrst skráð ' + isoIS(d.fyrstSkrad) : '') + '</p>' : '')
          + '<div class="ok-grid">'
          + f('Litur', d.litur)
          + f('Staða', d.stada, statCls)
          + f('Næsta skoðun', inspTxt, inspCls)
          + f('Eigin þyngd', d.thyngd ? d.thyngd.toLocaleString('de-DE') + ' kg' : null)
          + f('CO₂-losun', d.co2 != null ? d.co2 + ' g/km' : null)
          + f('Fastanúmer', d.fastanumer)
          + f('Verksmiðjunúmer (VIN)', d.vin)
          + '</div></div>';
      };

      const go = async () => {
        const n = (inp.value || '').trim();
        if (n.length < 2) { inp.focus(); return; }
        btn.disabled = true; out.innerHTML = '<div class="ok-msg">Leita…</div>';
        try {
          const d = await fetch('/api/okutaeki?numer=' + encodeURIComponent(n)).then((r) => r.json());
          render(d);
          try { history.replaceState(null, '', '/okutaeki/?n=' + encodeURIComponent(n.toUpperCase())); } catch (e) {}
        } catch (e) { out.innerHTML = '<div class="ok-msg">Villa við uppflettingu — reyndu aftur.</div>'; }
        btn.disabled = false;
      };
      form.addEventListener('submit', (e) => { e.preventDefault(); go(); });
      inp.addEventListener('input', () => { inp.value = inp.value.toUpperCase().replace(/[^A-Z0-9ÁÐÉÍÓÚÝÞÆÖ]/g, ''); });
      const q0 = new URLSearchParams(location.search).get('n');
      if (q0) { inp.value = q0.toUpperCase(); go(); }
      inp.focus();
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="okutaeki"]')) initOku(); });
  </script>
</Layout>
