---
// ─────────────────────────────────────────────────────────────
// 💊 LYF & LYFJAVERÐ — uppfletting í sérlyfjaskrá Lyfjastofnunar.
// SSG-flísar + client-side leit úr /gogn/lyf.json (build_lyf.js: Algolia dev_serlyfjaskra
// bin-pack fyrir öll ~3023 markaðssett lyf + verð úr /lyf-SSR (__NEXT_DATA__)).
// Grunngögn (heiti, ATC, virk efni, LYFJASKORTUR) heil fyrir öll lyf; verð þar sem það er sótt.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import LYF from '@gogn/lyf.json';
import { groupThousands } from '@lib/format.mjs';

const { updated, count, priced, shortageCount, atc } = LYF;
const pricedPct = count ? Math.round((priced / count) * 100) : 0;
const shortageList = LYF.lyf.filter((r) => r.shortage);
// ATC efsta-stigs heiti (Q = dýralyf skv. ATC-vet); síðan á heitin svo þau séu rétt óháð gögnum.
const ATC1 = { A: 'Meltingarfæri og efnaskipti', B: 'Blóð og blóðmyndandi líffæri', C: 'Hjarta og æðakerfi', D: 'Húðlyf', G: 'Þvagfæri, kynfæri og kynhormón', H: 'Hormón (ekki kyn-)', J: 'Sýkingalyf', L: 'Æxlishemjandi og ónæmislyf', M: 'Stoðkerfi', N: 'Taugakerfi', P: 'Sníkjudýralyf', Q: 'Dýralyf (ATC-vet)', R: 'Öndunarfæri', S: 'Skynfæri', V: 'Ýmislegt' };
const atcRows = Object.entries(atc).sort((a, b) => a[0].localeCompare(b[0]));
const desc = `Uppfletting í sérlyfjaskrá Lyfjastofnunar: ${count} markaðssett lyf á Íslandi — verð og greiðsluþátttaka, lyfjaskortur (${shortageCount} í skorti núna), virk efni og ATC-flokkun. Opin gögn, uppfært ${updated}.`;
---

<Layout title="💊 Lyf & lyfjaverð — sérlyfjaskrá | Karp" description={desc} canonical="https://karp.is/lyf/" ogTitle="Lyf & lyfjaverð">
  <main data-pg="lyf">
    <p class="kicker">Karp · Verðlag & neytendur</p>
    <h1>💊 Lyf &amp; lyfjaverð</h1>
    <p>Öll lyf sem eru markaðssett á Íslandi — leitaðu að lyfi, virku efni eða ATC-kóða og sjáðu verð, greiðsluþátttöku, heildsala og hvort lyf er í skorti. Byggt á opnum gögnum sérlyfjaskrár Lyfjastofnunar.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Grunngögn (heiti, styrkur, lyfjaform, virk efni, ATC-flokkur, markaðsleyfishafi og staða lyfjaskorts) koma úr leitarskrá sérlyfjaskrár (serlyfjaskra.is) og ná til allra markaðssettra lyfja. Verð (smásölu- og viðmiðunarverð, greiðsluþátttaka, heildsali) er sótt af lyfjasíðum serlyfjaskrár og uppfært reglulega af Lyfjastofnun/Sjúkratryggingum.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="grid">
      <div class="tile hero"><div class="t-top">💊 Markaðssett lyf</div><div class="t-v">{groupThousands(count)}</div><div class="t-s">í sérlyfjaskrá</div></div>
      <div class="tile"><div class="t-top">⚠️ Í skorti núna</div><div class="t-v">{groupThousands(shortageCount)}</div><div class="t-s">lyf með skráðan skort</div></div>
      <div class="tile"><div class="t-top">🏷️ Með verð</div><div class="t-v">{pricedPct}%</div><div class="t-s">{groupThousands(priced)} af {groupThousands(count)}</div></div>
      <div class="tile"><div class="t-top">🗓️ Uppfært</div><div class="t-v s">{updated}</div><div class="t-s">opin gögn Lyfjastofnunar</div></div>
    </div>

    <div class="ctl">
      <input id="lyf-q" type="search" placeholder="Leita að lyfi, virku efni eða ATC-kóða…" autocomplete="off" />
      <div class="chips">
        <button class="chip" type="button" data-f="shortage">⚠️ Í skorti</button>
        <button class="chip" type="button" data-f="rx">Lyfseðilsskylt</button>
        <button class="chip" type="button" data-f="vet">Dýralyf</button>
        <select id="lyf-atc" aria-label="ATC-flokkur">
          <option value="">Allir ATC-flokkar</option>
          {atcRows.map(([k, v]) => <option value={k}>{k} — {ATC1[k] || v.label || 'Annað'} ({v.count})</option>)}
        </select>
      </div>
    </div>

    <div id="lyf-count" class="count">Í skorti núna: <b>{shortageCount}</b> lyf</div>
    <div id="lyf-results">
      {shortageList.map((r) => (
        <article class="card is-sk">
          <div class="c-h">
            <div class="c-t">{r.name} {r.strength && <span class="c-str">{r.strength}</span>}</div>
            {r.atc.code && <span class="atc" title={r.atc.name}>{r.atc.code}</span>}
          </div>
          <div class="c-badges"><span class="bd sk">Lyfjaskortur</span>{r.vet && <span class="bd vt">Dýralyf</span>}</div>
          <div class="c-m">{r.form}{r.holder && <span> · {r.holder}</span>}</div>
          {r.ingredients && r.ingredients.length > 0 && <div class="c-i">{r.ingredients.join(', ')}</div>}
          <div class="c-f"><a href={`https://serlyfjaskra.is/lyf/${r.slug}`} target="_blank" rel="noopener">Nánar á serlyfjaskra.is ↗</a></div>
        </article>
      ))}
    </div>

    <p class="foot">Forþjónað (SSG) {updated}. Heimild: Sérlyfjaskrá Lyfjastofnunar (serlyfjaskra.is) — grunngögn úr opinni leitarskrá, verð af lyfjasíðum. Aðeins til upplýsingar; endanlegt verð og greiðsluþátttaka ræðst af gildandi lyfjaverðskrá og lyfseðli. Um build_lyf.js.</p>
  </main>

  <style>
    main { max-width: 1040px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; margin-top: 14px; }
    .tile { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 12px 14px; }
    .tile.hero { border-color: rgba(246,177,59,.4); }
    .t-top { font-size: 11.5px; color: #7e8ca6; } .t-v { font-size: 24px; font-weight: 700; color: #eaf1fb; margin: 3px 0 1px; }
    .t-v.s { font-size: 17px; } .t-s { font-size: 11.5px; color: #7e8ca6; }

    .ctl { display: flex; flex-direction: column; gap: 10px; margin: 22px 0 4px; }
    #lyf-q { width: 100%; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 10px 13px; color: #eaf1fb; font-size: 14px; }
    #lyf-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .chips { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .chip { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 6px 13px; font-size: 12.5px; cursor: pointer; }
    .chip:hover { color: #f6b13b; border-color: rgba(246,177,59,.4); }
    .chip.on { background: rgba(246,177,59,.14); border-color: #f6b13b; color: #f6b13b; }
    #lyf-atc { background: #0d1424; border: 1px solid rgba(255,255,255,.12); color: #cdd6e6; border-radius: 999px; padding: 6px 12px; font-size: 12.5px; }
    .count { font-size: 12.5px; color: #7e8ca6; margin: 12px 0; } .count b { color: #cdd6e6; }

    #lyf-results { display: grid; grid-template-columns: repeat(auto-fill, minmax(304px, 1fr)); gap: 12px; }
    /* Spjaldastílar færðir í <style is:global> að neðan — client-teiknuð spjöld (innerHTML úr
       leit) fá EKKI Astro scope-hash og yrðu annars óstíluð. Nafnrýmt á main[data-pg="lyf"]. */
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 22px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 12px; }
    @media (max-width: 520px) { #lyf-results { grid-template-columns: 1fr; } }
  </style>

  <style is:global>
    /* Spjaldastílar — is:global + nafnrýmt á main[data-pg="lyf"] því client-teiknuð spjöld (úr
       leit/síun) fá ekki Astro scope-hash. Nafnrýmingin kemur í veg fyrir leka á aðrar síður. */
    main[data-pg="lyf"] .card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 13px 15px; }
    main[data-pg="lyf"] .card.is-sk { border-color: rgba(240,120,96,.3); }
    main[data-pg="lyf"] .c-h { display: flex; justify-content: space-between; gap: 8px; align-items: flex-start; }
    main[data-pg="lyf"] .c-t { font-size: 15px; font-weight: 700; color: #eaf1fb; line-height: 1.3; }
    main[data-pg="lyf"] .c-str { color: #9fb0c8; font-weight: 600; font-size: 13px; }
    main[data-pg="lyf"] .atc { font-size: 11px; color: #8fa0b8; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 6px; padding: 2px 6px; white-space: nowrap; }
    main[data-pg="lyf"] .c-badges { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 6px; }
    main[data-pg="lyf"] .c-badges:empty { display: none; }
    main[data-pg="lyf"] .bd { font-size: 10.5px; font-weight: 700; border-radius: 6px; padding: 2px 7px; text-transform: uppercase; letter-spacing: .02em; }
    main[data-pg="lyf"] .bd.sk { background: rgba(240,120,96,.16); color: #f0917c; border: 1px solid rgba(240,120,96,.35); }
    main[data-pg="lyf"] .bd.vt { background: rgba(120,160,255,.14); color: #9db8ff; border: 1px solid rgba(120,160,255,.3); }
    main[data-pg="lyf"] .bd.nc { background: rgba(255,255,255,.06); color: #9fb0c8; border: 1px solid rgba(255,255,255,.12); }
    main[data-pg="lyf"] .c-m { font-size: 12.5px; color: #9fb0c8; margin-top: 7px; }
    main[data-pg="lyf"] .c-i { font-size: 12px; color: #7e8ca6; margin-top: 3px; }
    main[data-pg="lyf"] .pr { margin-top: 8px; display: flex; gap: 8px; align-items: baseline; flex-wrap: wrap; }
    main[data-pg="lyf"] .pr-v { color: #f6b13b; font-weight: 700; font-variant-numeric: tabular-nums; font-size: 14px; }
    main[data-pg="lyf"] .pr-b { font-size: 11px; color: #86d896; border: 1px solid rgba(134,216,150,.3); border-radius: 6px; padding: 1px 6px; }
    main[data-pg="lyf"] .pr-w { font-size: 11.5px; color: #7e8ca6; }
    main[data-pg="lyf"] .c-f { display: flex; justify-content: space-between; gap: 10px; align-items: center; margin-top: 9px; padding-top: 9px; border-top: 1px solid rgba(255,255,255,.06); }
    main[data-pg="lyf"] .c-f a { color: #f6b13b; font-size: 12px; text-decoration: none; }
    main[data-pg="lyf"] .c-f a:hover { text-decoration: underline; }
    main[data-pg="lyf"] .c-x { background: none; border: 1px solid rgba(255,255,255,.14); color: #9fb0c8; border-radius: 8px; padding: 4px 9px; font-size: 11.5px; cursor: pointer; white-space: nowrap; }
    main[data-pg="lyf"] .c-x:hover { color: #f6b13b; border-color: rgba(246,177,59,.4); }
    main[data-pg="lyf"] .c-pk { margin-top: 9px; overflow-x: auto; }
    main[data-pg="lyf"] table.pk { width: 100%; border-collapse: collapse; font-size: 11.5px; }
    main[data-pg="lyf"] table.pk th { text-align: left; color: #7e8ca6; font-weight: 600; padding: 3px 6px; border-bottom: 1px solid rgba(255,255,255,.1); text-transform: uppercase; font-size: 10px; }
    main[data-pg="lyf"] table.pk td { padding: 3px 6px; border-bottom: 1px solid rgba(255,255,255,.05); color: #cdd6e6; }
    main[data-pg="lyf"] table.pk .r { text-align: right; font-variant-numeric: tabular-nums; }
    main[data-pg="lyf"] table.pk .npn { color: #7e8ca6; }
    main[data-pg="lyf"] .count b { color: #cdd6e6; }
    main[data-pg="lyf"] .empty { color: #7e8ca6; padding: 20px 2px; grid-column: 1 / -1; }
  </style>

  <!-- LOTA lyf: client-side leit + pakkningaraukning úr /gogn/lyf.json -->
  <script>
    const escL = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const gt = (n) => (n == null ? '' : String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.'));
    let LYFALL = null, BYSLUG = null;
    const lyfData = () => LYFALL ? Promise.resolve(LYFALL) : fetch('/gogn/lyf.json').then((r) => (r.ok ? r.json() : null)).then((d) => {
      LYFALL = d; BYSLUG = {}; if (d) for (const r of d.lyf) BYSLUG[r.slug] = r; return d;
    });
    const st = { q: '', shortage: false, rx: false, vet: false, atc: '' };

    function matchLyf(r) {
      if (st.shortage && !r.shortage) return false;
      if (st.rx && !/^\(R/.test(r.rx || '')) return false;
      if (st.vet && !r.vet) return false;
      if (st.atc && (r.atc.code || '')[0] !== st.atc) return false;
      if (st.q) {
        const hay = (r.name + ' ' + (r.add || '') + ' ' + (r.atc.code || '') + ' ' + (r.atc.name || '') + ' ' + (r.ingredients || []).join(' ') + ' ' + (r.holder || '')).toLowerCase();
        if (!hay.includes(st.q)) return false;
      }
      return true;
    }
    function priceLine(r) {
      if (!r.priced) return '';
      const p = r.priceLow === r.priceHigh ? gt(r.priceLow) + ' kr' : gt(r.priceLow) + '–' + gt(r.priceHigh) + ' kr';
      const reimb = (r.packages || []).some((x) => x.reimb);
      const w = (r.packages || []).map((x) => x.wholesaler).find(Boolean);
      return `<div class="pr"><span class="pr-v">${p}</span>${reimb ? '<span class="pr-b">greiðsluþátttaka</span>' : ''}${w ? `<span class="pr-w">${escL(w)}</span>` : ''}</div>`;
    }
    function cardLyf(r) {
      const badges = (r.shortage ? '<span class="bd sk">Lyfjaskortur</span>' : '') + (r.vet ? '<span class="bd vt">Dýralyf</span>' : '') + (r.narcotic ? '<span class="bd nc">Ávana/fíkn</span>' : '');
      const hasPk = (r.packages || []).some((p) => p.retail != null);
      const url = 'https://serlyfjaskra.is/lyf/' + encodeURIComponent(r.slug);
      const ing = (r.ingredients || []).join(', ');
      return `<article class="card${r.shortage ? ' is-sk' : ''}"${hasPk ? ` data-slug="${escL(r.slug)}"` : ''}>
        <div class="c-h"><div class="c-t">${escL(r.name)}${r.strength ? ` <span class="c-str">${escL(r.strength)}</span>` : ''}</div>${r.atc.code ? `<span class="atc" title="${escL(r.atc.name)}">${escL(r.atc.code)}</span>` : ''}</div>
        <div class="c-badges">${badges}</div>
        <div class="c-m">${escL(r.form)}${r.holder ? ' · ' + escL(r.holder) : ''}</div>
        ${ing ? `<div class="c-i">${escL(ing)}</div>` : ''}
        ${priceLine(r)}
        <div class="c-f"><a href="${url}" target="_blank" rel="noopener">Nánar á serlyfjaskra.is ↗</a>${hasPk ? '<button class="c-x" type="button">Pakkningar & verð</button>' : ''}</div>
      </article>`;
    }
    function pkgTable(r) {
      const rows = (r.packages || []).map((p) => `<tr><td>${escL(p.size || '')}</td><td class="npn">${escL(p.npn || '')}</td><td class="r">${p.retail != null ? gt(p.retail) + ' kr' : '–'}</td><td class="r">${p.reference != null ? gt(p.reference) + ' kr' : '–'}</td><td>${p.reimb ? 'já' : '–'}</td></tr>`).join('');
      return `<table class="pk"><thead><tr><th>Pakkning</th><th>NPN</th><th class="r">Smásölu</th><th class="r">Viðmiðun</th><th>Greiðsluþátttaka</th></tr></thead><tbody>${rows}</tbody></table>`;
    }

    function paintLyf() {
      const resEl = document.getElementById('lyf-results'), countEl = document.getElementById('lyf-count');
      if (!resEl) return;
      lyfData().then((d) => {
        if (!d) { resEl.innerHTML = '<div class="empty">Lyfjaskráin svarar ekki í augnablikinu.</div>'; return; }
        const def = !st.q && !st.shortage && !st.rx && !st.vet && !st.atc;
        const list = def ? d.lyf.filter((r) => r.shortage) : d.lyf.filter(matchLyf);
        const shown = list.slice(0, 120);
        countEl.innerHTML = def
          ? `Í skorti núna: <b>${list.length}</b> lyf — leitaðu til að sjá öll ${gt(d.count)}`
          : `Fann <b>${list.length}</b> lyf${list.length > 120 ? ' — sýni fyrstu 120' : ''}`;
        resEl.innerHTML = shown.map(cardLyf).join('') || '<div class="empty">Ekkert lyf passar við leitina.</div>';
      });
    }

    function initLyf() {
      const main = document.querySelector('main[data-pg="lyf"]');
      if (!main || main.dataset.done) return;
      main.dataset.done = '1';
      const q = document.getElementById('lyf-q'), atcSel = document.getElementById('lyf-atc');
      if (q) q.addEventListener('input', () => { st.q = q.value.trim().toLowerCase(); paintLyf(); });
      if (atcSel) atcSel.addEventListener('change', () => { st.atc = atcSel.value; paintLyf(); });
      document.querySelectorAll('.chip[data-f]').forEach((c) => c.addEventListener('click', () => {
        const f = c.dataset.f; st[f] = !st[f]; c.classList.toggle('on', st[f]); paintLyf();
      }));
      // pakkninga-aukning (event-delegation → virkar á client-teiknuð spjöld)
      document.getElementById('lyf-results').addEventListener('click', (e) => {
        const btn = e.target.closest('.c-x'); if (!btn) return;
        const card = btn.closest('.card[data-slug]'); if (!card) return;
        const open = card.querySelector('.c-pk');
        if (open) { open.remove(); return; }
        const r = BYSLUG && BYSLUG[card.dataset.slug]; if (!r) return;
        const div = document.createElement('div'); div.className = 'c-pk'; div.innerHTML = pkgTable(r);
        card.appendChild(div);
      });
      paintLyf(); // hydra sjálfgefna sýn með ríkari spjöldum (verð + aukning)
    }
    document.addEventListener('astro:page-load', initLyf);
  </script>
</Layout>
