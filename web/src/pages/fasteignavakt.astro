---
// ─────────────────────────────────────────────────────────────
// 🏠 FASTEIGNAVAKTIN (LOTA 52) — sér undirsíða: leit í kaupskránni, götuvaktir
// m/tölvupósti, verðmat úr kaupskránni (Karp Pro) og nauðungarsölur sýslumanna.
// Flutt af /vaktir/ og gert notendavænna: EITT heimilisfangs-svæði með fléttilista
// (datalist) úr kaupskránni — valið heimilisfang fyllir m² og tegund sjálfkrafa
// inn í verðmatið. Gögn: kaupskra_nyjast.json (180d), fasteignir.json (12 mán
// tölfræði), uppbod.json (sýslumenn). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
const updated = '2026-07-04';
const desc = 'Fasteignavaktin — sjáðu hvað seldist í götunni þinni og á hvaða verði, fáðu tölvupóst við nýja sölu, áætlaðu virði eignar úr kaupskrá HMS og fylgstu með nauðungarsölum.';
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebApplication',
  name: 'Fasteignavaktin — kaupskrá, verðmat og uppboð', applicationCategory: 'FinanceApplication', operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'ISK' }, description: desc,
};
---

<Layout title="🏠 Fasteignavaktin — gata, verðmat & uppboð | Karp" description={desc} canonical="https://karp.is/fasteignavakt/" jsonLd={jsonLd} ogTitle="Fasteignavaktin">
  <main data-pg="fastvakt">
    <p class="kicker">Karp · Fasteignir</p>
    <h1>🏠 Fasteignavaktin</h1>
    <p>Öll þinglýst kaup á íbúðarhúsnæði — leitaðu að götunni þinni, settu hana á vakt og fáðu tölvupóst þegar ný sala þinglýsist. <a class="xlink" href="/fasteignir/">📈 Verðþróun markaðarins er á Fasteignir →</a></p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Kaupskrá HMS: öll þinglýst kaup á íbúðarhúsnæði (nothæfir samningar), uppfærð daglega. Þinglýsing berst með nokkurra daga/vikna töf. Uppboðsauglýsingar eru opinberar auglýsingar sýslumanna af island.is.">ⓘ</i> Um gögnin á síðunni</p>

    <div id="fv-market" class="fv-market" hidden></div>

    <h2>🔎 Leitaðu og vaktaðu <span class="hint">— Karp Pro (ókeypis aðgangur) · sláðu inn heimilisfang MEÐ póstnúmeri (eða veldu sveitarfélag) → leitað í ALLRI fasteignaskránni með fasteignamati og brunabótamati, ekki bara nýlegum sölum</span></h2>
    <div class="row">
      <select id="fv-muni" aria-label="Sveitarfélag"><option value="">Öll sveitarfélög</option></select>
      <input id="fv-q" type="text" maxlength="60" placeholder="T.d. „Melabraut“, „Melabraut 3“ eða „170“" autocomplete="off" list="fv-addr-list" />
      <datalist id="fv-addr-list"></datalist>
      <button id="fv-add" class="cta">🔔 Vakta</button>
    </div>
    <div id="fv-chips"></div>
    <div id="fv-res" class="feed" hidden></div>

    <h2>🏷️ Verðmat úr kaupskránni <span class="hint">— Karp Pro (ókeypis aðgangur)</span> <i class="tip" tabindex="0" data-tip="Nálgun byggð á þinglýstum kaupum: fyrst gatan, svo póstnúmerið, svo sveitarfélagið (12 mán miðgildi). Veldu heimilisfang úr fléttilistanum að ofan og stærð + tegund fyllast sjálfkrafa úr sölunni. Ekki fasteignamat og ekki verðmat löggilts fasteignasala.">ⓘ</i></h2>
    <div class="row">
      <input id="fvm-addr" type="text" maxlength="60" placeholder="Heimilisfang — eða veldu úr fléttilistanum" autocomplete="off" list="fv-addr-list" />
      <input id="fvm-fm" type="number" min="15" max="1200" placeholder="m²" />
      <select id="fvm-teg" aria-label="Tegund"><option value="Fjölbýli">Fjölbýli</option><option value="Sérbýli">Sérbýli</option><option value="Einbýli">Einbýli</option></select>
      <button id="fvm-go" class="cta">Meta</button>
    </div>
    <div id="fvm-fill" class="fillnote" hidden></div>
    <div id="fvm-out" hidden></div>

    <h2>🔨 Nauðungarsölur — opinberar auglýsingar sýslumanna <i class="tip" tabindex="0" data-tip="Uppboðsauglýsingar eru opinberar skv. lögum um nauðungarsölu. Staða segir hvar málið er statt: byrjun/framhald uppboðs er framundan, „Sölu lokið“ er afgreitt.">ⓘ</i></h2>
    <div id="upp-list" class="feed">Sæki uppboðsauglýsingar…</div>

    <h2>Svona virkar vaktin</h2>
    <ol class="how">
      <li><b>Leitaðu</b> að götunni þinni og smelltu á <b>🔔 Vakta</b> — vaktin vistast í vafranum þínum (hám. 6).</li>
      <li><b>Skráðu þig inn</b> (ókeypis <a href="/karp-pro/">Karp Pro</a>) og vaktin fylgir þér milli tækja — og <b>tölvupóstur</b> berst þegar ný sala þinglýsist á vaktinni, með verði og fermetraverði.</li>
      <li><b>Uppboð í götunni</b> birtast sjálfkrafa efst í leitinni með 🔨-merki.</li>
    </ol>

    <p class="foot">Forþjónað (SSG) {updated}. Kaupskrá HMS (þinglýst kaup, 180 daga gluggi + 12 mán tölfræði) og uppboðsauglýsingar sýslumanna (island.is) — uppfært daglega. #2 LOTA 52.</p>
  </main>

  <style>
    main { max-width: 880px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .hint { font-size: 12px; color: #7e8ca6; text-transform: none; letter-spacing: 0; font-weight: 400; }
    .xlink { font-size: 13px; color: #f6b13b; text-decoration: none; }
    .feed { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 11px; padding: 8px 12px; min-height: 60px; font-size: 13px; color: #9fb0c8; }
    .how { margin: 6px 0 0; padding-left: 20px; }
    .how li { font-size: 13.5px; color: #b9c6da; padding: 4px 0; line-height: 1.5; }
    .how a { color: #f6b13b; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* runtime-innerHTML → global (Astro-gildran) */
    main[data-pg="fastvakt"] .row { display: flex; gap: 8px; flex-wrap: wrap; }
    main[data-pg="fastvakt"] .row input[type="text"] { flex: 1; min-width: 220px; max-width: 360px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 12px; color: #eaf1fb; font-size: 13.5px; }
    main[data-pg="fastvakt"] .row input[type="number"] { max-width: 90px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 10px; color: #eaf1fb; font-size: 13.5px; }
    main[data-pg="fastvakt"] .row select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 10px; color: #eaf1fb; font-size: 13px; max-width: 210px; }
    main[data-pg="fastvakt"] .row select option { background: #0e1420; }
    main[data-pg="fastvakt"] .row input:focus, main[data-pg="fastvakt"] .row select:focus { outline: none; border-color: rgba(246,177,59,.55); }
    main[data-pg="fastvakt"] .cta { background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.45); color: #f6b13b; border-radius: 10px; padding: 0 16px; font-size: 13px; font-weight: 700; cursor: pointer; }
    main[data-pg="fastvakt"] .cta:hover { background: rgba(246,177,59,.22); }
    #fv-chips { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 9px; }
    #fv-chips .lvc { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #cdd6e6; border-radius: 999px; padding: 4px 6px 4px 11px; font-size: 12px; }
    #fv-chips .lvc b { color: #f6b13b; font-weight: 700; }
    #fv-chips .lvc button { background: none; border: 0; color: #7e8ca6; cursor: pointer; font-size: 13px; padding: 0 4px; }
    #fv-chips .lvc button:hover { color: #e0655f; }
    #fv-res { margin-top: 10px; max-height: 440px; overflow-y: auto; }
    .fv-head { font-size: 11.5px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .04em; padding: 4px 2px 6px; }
    .fv-upph { color: #e0655f; }
    .fv-upp { border-left: 3px solid #e0655f; padding-left: 8px; background: rgba(224,101,95,.06); border-radius: 6px; }
    .fv-fsk { border-left: 3px solid #5a6678; padding-left: 8px; }
    /* Markaðsvísir efst (LOTA 66) */
    .fv-market { margin: 14px 0 6px; }
    .fvm-dir { display: flex; align-items: center; gap: 14px; border-radius: 12px; padding: 13px 16px; border: 1px solid; }
    .fvm-dir.fvm-up { background: rgba(70,224,138,.08); border-color: rgba(70,224,138,.3); }
    .fvm-dir.fvm-dn { background: rgba(255,109,122,.08); border-color: rgba(255,109,122,.32); }
    .fvm-dir.fvm-cool { background: rgba(246,177,59,.08); border-color: rgba(246,177,59,.32); }
    .fvm-dir.fvm-flat { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.12); }
    .fvm-arrow { font-size: 28px; }
    .fvm-dir-t { font-size: 16px; color: #eaf1fb; } .fvm-dir-t b { color: #f6b13b; }
    .fvm-dir-s { font-size: 12.5px; color: #9fb0c8; margin-top: 2px; }
    .fvm-mat { font-size: 13.5px; color: #cdd6e6; margin-top: 8px; background: rgba(255,255,255,.03); border-radius: 10px; padding: 10px 14px; line-height: 1.6; }
    .fvm-mat b.up { color: #46e08a; } .fvm-mat b.dn { color: #ff6d7a; }
    .fvm-mrow { font-size: 12.5px; color: #9fb0c8; margin-top: 4px; }
    .fvm-ml { font-weight: 700; } .fvm-ml.up { color: #46e08a; } .fvm-ml.dn { color: #ff6d7a; }
    .fv-sv { color: #7e8ca6; font-size: 11.5px; font-weight: 400; }
    .fv-v { color: #f6b13b; }
    .fv-mat { font-size: 10.5px; color: #9fb0c8; background: rgba(255,255,255,.06); border-radius: 6px; padding: 1px 6px; margin-left: 4px; }
    .fvm-signal { font-size: 13px; color: #eaf1fb; background: rgba(58,141,255,.1); border: 1px solid rgba(58,141,255,.3); border-radius: 9px; padding: 8px 12px; margin-top: 8px; }
    .fvm-anchor { font-size: 12.5px; color: #cdd6e6; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; border-radius: 0 8px 8px 0; padding: 8px 12px; margin-top: 6px; line-height: 1.5; }
    main[data-pg="fastvakt"] .fi { display: block; padding: 8px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    main[data-pg="fastvakt"] .fi .t { display: block; font-size: 13px; color: #eaf1fb; line-height: 1.35; }
    main[data-pg="fastvakt"] .fi .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .fillnote { margin-top: 8px; font-size: 12px; color: #42d086; }
    #fvm-out { margin-top: 10px; font-size: 13px; color: #9fb0c8; }
    .fvm-card { background: rgba(246,177,59,.07); border: 1px solid rgba(246,177,59,.3); border-radius: 12px; padding: 14px 16px; }
    .fvm-big { font-size: 30px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
    .fvm-range { font-size: 14px; color: #eaf1fb; margin-top: 2px; }
    .fvm-meta { font-size: 12px; color: #9fb0c8; margin-top: 6px; }
    .fvm-note { font-size: 11.5px; color: #7e8ca6; margin-top: 8px; line-height: 1.45; }
    .pro-tease2 { background: rgba(255,255,255,.04); border: 1px solid rgba(246,177,59,.35); border-radius: 12px; padding: 14px 16px; font-size: 13px; color: #cdd6e6; line-height: 1.5; }
    .pt2-btns { display: flex; gap: 8px; margin-top: 10px; }
    .pt2-main { background: #f6b13b; color: #131a29; font-weight: 800; font-size: 12.5px; text-decoration: none; padding: 8px 14px; border-radius: 9px; }
    .pt2-sec { border: 1px solid rgba(255,255,255,.2); color: #cdd6e6; font-size: 12.5px; text-decoration: none; padding: 8px 14px; border-radius: 9px; }
    #upp-list .upp-pill { display: inline-block; padding: 1px 8px; border-radius: 8px; font-size: 10.5px; background: rgba(224,101,95,.14); color: #e0655f; margin-right: 6px; }
    #upp-list .upp-pill.fram { background: rgba(66,208,134,.14); color: #42d086; }
    /* 🖨️ Verðmatsskýrslan (LOTA 53): prentið einangrar skýrslukortið á hvítum grunni */
    .fvm-rephead b { display: block; font-size: 15px; letter-spacing: .04em; }
    .fvm-rephead span { display: block; font-size: 11px; margin: 2px 0 10px; }
    .fvm-tbl { border-collapse: collapse; width: 100%; font-size: 12px; margin-top: 4px; color: #cdd6e6; }
    .fvm-tbl th { text-align: left; font-size: 10px; text-transform: uppercase; color: #7e8ca6; border-bottom: 1px solid rgba(255,255,255,.15); padding: 3px 8px 3px 0; }
    .fvm-tbl td { border-bottom: 1px solid rgba(255,255,255,.07); padding: 3px 8px 3px 0; font-variant-numeric: tabular-nums; }
    body.fvm-printing #fvm-report .fvm-tbl, body.fvm-printing #fvm-report .fvm-tbl td { color: #222 !important; border-color: #ddd !important; }
    body.fvm-printing #fvm-report .fvm-tbl th { color: #444 !important; border-bottom: 2px solid #b07500 !important; }
    @media print {
      body.fvm-printing * { visibility: hidden; }
      body.fvm-printing #fvm-report, body.fvm-printing #fvm-report * { visibility: visible; }
      body.fvm-printing #fvm-report { position: absolute; left: 0; top: 0; width: 100%; background: #fff !important; border: 1px solid #ccc; color: #111; }
      body.fvm-printing #fvm-report .fvm-rephead { display: block !important; visibility: visible; color: #111; }
      body.fvm-printing #fvm-report .fvm-rephead[hidden] { display: block !important; }
      body.fvm-printing #fvm-report .fvm-big { color: #b07500; }
      body.fvm-printing #fvm-report .fvm-range, body.fvm-printing #fvm-report .fi .t { color: #111 !important; }
      body.fvm-printing #fvm-report .fvm-meta, body.fvm-printing #fvm-report .fvm-note, body.fvm-printing #fvm-report .fi .s, body.fvm-printing #fvm-report .fv-head, body.fvm-printing #fvm-report .fv-sv { color: #444 !important; }
      body.fvm-printing #fvm-report .fv-v { color: #b07500 !important; }
      body.fvm-printing #fvm-report .fvm-signal { background: #f3f7ff !important; border: 1px solid #b9cdf0 !important; color: #123 !important; }
      body.fvm-printing #fvm-report .fvm-signal b { color: #123 !important; }
      body.fvm-printing #fvm-report .fvm-anchor { background: #fdf8ec !important; border-left: 3px solid #b07500 !important; color: #222 !important; }
      body.fvm-printing #fvm-report .fvm-anchor b { color: #111 !important; }
    }
  </style>

  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    function initFastvakt() {
      const root = document.querySelector('main[data-pg="fastvakt"]');
      if (!root || root.dataset.done) return;
      root.dataset.done = '1';
      const fvKey = 'karp-fastvakt';
      let FV = null, FST = null, UPP = null;
      const fvFetch = () => FV || (FV = fetch('/gogn/kaupskra_nyjast.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fstFetch = () => FST || (FST = fetch('/gogn/fasteignir.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const uppFetch = () => UPP || (UPP = fetch('/gogn/uppbod.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      // LOTA 64: full fasteignaskrá (nánast allar seldar eignir frá 2006 m/gildandi mati), per póstnúmer
      let FSK_IDX = null, FSK_GOTUR = null; const FSK = {};
      const fskIdx = () => FSK_IDX || (FSK_IDX = fetch('/gogn/fasteignaskra/index.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fskGotur = () => FSK_GOTUR || (FSK_GOTUR = fetch('/gogn/fasteignaskra/gotur.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fskPn = (pn) => FSK[pn] || (FSK[pn] = fetch('/gogn/fasteignaskra/' + pn + '.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      // LOTA 65: finna póstnúmer út frá pn í fyrirspurn, völdu sveitarfélagi, EÐA götunafni (götuvísir)
      async function fskRows(sv, raw) {
        const idx = await fskIdx(); if (!idx) return [];
        const pnInQ = (String(raw || '').match(/\b(\d{3})\b/) || [])[1];
        let pns = pnInQ && idx.byPn[pnInQ] ? [pnInQ] : (sv && idx.bySv[sv] ? idx.bySv[sv] : []);
        if (!pns.length) {
          const street = fvNorm(String(raw || '').replace(/,?\s*\d{3}\s*$/, '').replace(/\s+\d+[a-zæöðáéíóúý]?\s*$/i, ''));
          if (street.length >= 3) {
            const g = await fskGotur();
            if (g) { const hit = new Set(); for (const name in g) { if (name.startsWith(street)) { g[name].forEach((p) => hit.add(p)); if (hit.size > 8) break; } } pns = [...hit]; }
          }
        }
        if (!pns.length || pns.length > 8) return [];   // of margar skrár → krefjast póstnúmers/sveitarfélags
        return (await Promise.all(pns.map(fskPn))).filter(Boolean).flat();
      }
      const fvLoad = () => { try { return JSON.parse(localStorage.getItem(fvKey) || '[]').filter((v) => v && typeof v.q === 'string'); } catch (e) { return []; } };
      const fvSave = (a) => { localStorage.setItem(fvKey, JSON.stringify(a.slice(0, 6))); try { karpPost('/fastvakt', { on: true, vaktir: a.slice(0, 6) }).catch(() => {}); } catch (e) {} };
      const fvNorm = (s) => String(s || '').toLowerCase().trim();
      const fvMatch = (r, sv, q) => (!sv || r.sv === sv) && (!q || (/^\d{3}$/.test(q) ? r.pn === q : fvNorm(r.a).startsWith(q)));
      const fvKr = (v) => (v / 1000).toFixed(1).replace('.', ',') + ' m.kr';
      // LOTA 62: fasteignamat + brunabótamat + hlutfall kaupverðs/mats sýnt á hverri röð
      const matPct = (r) => (r.mat && r.v ? (r.v >= r.mat ? '+' : '') + Math.round((r.v / r.mat - 1) * 100) + '% v. mat' : '');
      const fvRow = (r) => `<div class="fi"><span class="t">${esc(r.a)} <span class="fv-sv">· ${esc(r.pn)} ${esc(r.sv)}</span> — <b class="fv-v">${fvKr(r.v)}</b>${r.mat ? ` <span class="fv-mat">${matPct(r)}</span>` : ''}</span><span class="s">${dIS(r.d)} · ${String(r.fm).replace('.', ',')} m²${r.fm > 0 ? ' · ' + Math.round(r.v / r.fm) + ' þ/m²' : ''} · ${esc(r.t)}${r.ar ? ' · byggt ' + r.ar : ''}${r.mat ? ' · fasteignamat ' + fvKr(r.mat) : ''}${r.bruna ? ' · brunabótamat ' + fvKr(r.bruna) : ''}</span></div>`;
      const uppRow = (x) => `<div class="fi fv-upp"><span class="t">🔨 ${esc(x.a)} — <b>${esc(x.teg)}</b></span><span class="s">${dIS(x.d)}${x.kl ? ' kl. ' + esc(x.kl) : ''} · ${esc(x.flokkur)} · ${esc(x.e)}</span></div>`;
      // Röð fyrir eign úr fasteignaskrá (ekki nýleg sala) — fasteignamat + brunabótamat
      const fskRow = (r) => `<div class="fi fv-fsk"><span class="t">${esc(r.a)} <span class="fv-sv">· ${esc(r.pn)} ${esc(r.sv)}</span> — fasteignamat <b class="fv-v">${r.mat ? fvKr(r.mat) : '–'}</b></span><span class="s">${r.fm ? String(r.fm).replace('.', ',') + ' m² · ' : ''}${esc(r.teg)}${r.herb ? ' · ' + r.herb + ' herb.' : ''}${r.ar ? ' · byggt ' + r.ar : ''}${r.lod ? ' · lóð ' + r.lod + ' m²' : ''}${r.bruna ? ' · brunabótamat ' + fvKr(r.bruna) : ''}${r.ld ? ' · seldist síðast ' + esc(r.ld) + (r.lv ? ' á ' + fvKr(r.lv) : '') : ''}</span></div>`;
      const fvQ = document.getElementById('fv-q'), fvMuniEl = document.getElementById('fv-muni'), fvBtn = document.getElementById('fv-add');
      const dl = document.getElementById('fv-addr-list');

      // ── Fléttilistinn (LOTA 52): heimilisföng úr kaupskránni; val fyllir verðmatið ──
      async function fvSuggest(val) {
        if (!dl) return;
        const raw = String(val || '');
        const q = fvNorm(raw.replace(/,?\s*\d{3}\s*$/, '')); // strípa póstnúmer fyrir götu-samsvörun
        if (q.length < 2) { dl.innerHTML = ''; return; }
        const sv = fvMuniEl.value;
        const [d, reg] = await Promise.all([fvFetch(), fskRows(sv, raw)]);
        const seen = new Set(), opts = [];
        const add = (r) => {
          const t = r.t || r.teg; const key = fvNorm(r.a) + '|' + r.pn;
          if (seen.has(key) || (sv && r.sv !== sv) || !fvNorm(r.a).startsWith(q)) return;
          seen.add(key);
          opts.push(`<option value="${esc(r.a)}, ${esc(r.pn)}">${esc(r.sv)}${r.fm ? ' · ' + String(r.fm).replace('.', ',') + ' m²' : ''}${t ? ' ' + esc(t) : ''}</option>`);
        };
        (d && d.rows || []).forEach(add);              // nýlegar sölur fyrst
        reg.forEach((r) => { if (opts.length < 16) add(r); }); // svo öll fasteignaskráin
        dl.innerHTML = opts.slice(0, 16).join('');
      }
      // valið heimilisfang → sjálfvirk stærð + tegund inn í verðmatið (kaupskrá fyrst, svo fasteignaskrá)
      async function fvAutofill(val) {
        const m = String(val || '').match(/^(.+?),\s*(\d{3})$/);
        if (!m) return false;
        const addr = m[1].trim(), pn = m[2];
        const [d, reg] = await Promise.all([fvFetch(), fskRows('', val)]);
        const hit = (d && d.rows || []).find((r) => r.a === addr && r.pn === pn)
          || (reg || []).find((r) => r.a === addr && r.pn === pn);
        if (!hit) return false;
        const teg = hit.t || hit.teg;
        const aEl = document.getElementById('fvm-addr'), fmEl = document.getElementById('fvm-fm'), tegEl = document.getElementById('fvm-teg');
        if (aEl) aEl.value = hit.a + ', ' + hit.pn;
        if (fmEl && hit.fm) fmEl.value = Math.round(hit.fm);
        if (tegEl && teg) tegEl.value = teg;
        const note = document.getElementById('fvm-fill');
        if (note) { note.hidden = false; note.textContent = '✓ ' + (hit.fm ? 'Stærð (' + String(hit.fm).replace('.', ',') + ' m²) og t' : 'T') + 'egund (' + (teg || '') + ') sóttar sjálfkrafa' + (hit.mat ? ' · fasteignamat ' + fvKr(hit.mat) : '') + ' — smelltu á Meta.'; }
        return true;
      }

      // LOTA 54: fasteignavaktin er Karp Pro (ókeypis aðgangur) — leit+vaktir læstar,
      // uppboðin (opinberar auglýsingar) sjást öllum sem forsmekkur.
      let USER = null;
      const proTease = '<div class="pro-tease2"><b>⭐ Fasteignavaktin er hluti af Karp Pro</b> — ókeypis aðgangur sem tekur mínútu. Leit í kaupskránni, götuvaktir með tölvupósti og verðmatið opnast við innskráningu.<div class="pt2-btns"><a class="pt2-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt2-sec" href="/login/">Innskráning</a></div></div>';
      async function fvSearch() {
        const res = document.getElementById('fv-res');
        if (!res) return;
        const sv = fvMuniEl.value, q = fvNorm(fvQ.value);
        if (!sv && q.length < 2) { res.hidden = true; return; }
        res.hidden = false;
        if (USER === null) USER = await loadUser().catch(() => null);
        if (!USER || !USER.loggedIn) { res.innerHTML = proTease; return; }
        res.textContent = 'Sæki kaupskrá…';
        const [d, up] = await Promise.all([fvFetch(), uppFetch()]);
        if (!d || !d.rows) { res.textContent = 'Náði ekki í kaupskrána — reyndu aftur síðar.'; return; }
        const rawq = fvNorm(fvQ.value);
        const qq = rawq.replace(/,?\s*\d{3}\s*$/, ''); // „Melabraut 3, 170“ → gata+númer
        const rows = d.rows.filter((r) => fvMatch(r, sv, qq));
        const uppRows = (qq && !/^\d{3}$/.test(qq) && up && up.rows) ? up.rows.filter((x) => fvNorm(x.a).startsWith(qq)) : [];
        const uppHtml = uppRows.length ? `<div class="fv-head fv-upph">⚠ ${uppRows.length} nauðungarsölu-auglýsing${uppRows.length === 1 ? '' : 'ar'} passa við leitina</div>` + uppRows.slice(0, 6).map(uppRow).join('') : '';
        // LOTA 64: fasteignaskrá — eignir sem hafa EKKI selst nýlega (birtir fasteignamat/brunabótamat)
        const reg = await fskRows(sv, fvQ.value);
        const recentKeys = new Set(rows.map((r) => fvNorm(r.a) + '|' + r.pn));
        const regRows = reg.filter((r) => (!sv || r.sv === sv) && (qq ? fvNorm(r.a).startsWith(qq) : true) && !recentKeys.has(fvNorm(r.a) + '|' + r.pn));
        const regHtml = regRows.length ? `<div class="fv-head" style="margin-top:10px">📋 Úr fasteignaskrá — ${regRows.length} eign${regRows.length === 1 ? '' : 'ir'} með gildandi mati (engin nýleg sala)</div>` + regRows.slice(0, 20).map(fskRow).join('') + (regRows.length > 20 ? `<div class="s" style="padding:7px 2px">… og ${regRows.length - 20} til viðbótar.</div>` : '') : '';
        if (!rows.length && !uppRows.length && !regRows.length) { res.innerHTML = '<div class="fi"><span class="t">Ekkert fannst.</span><span class="s">Sláðu inn heimilisfang með póstnúmeri (t.d. „Brunnstígur 2, 230“) eða veldu sveitarfélag — þá leitum við í allri fasteignaskránni, ekki bara nýlegum sölum.</span></div>'; return; }
        res.innerHTML = uppHtml
          + (rows.length ? `<div class="fv-head">${rows.length} þinglýst kaup síðustu 6 mánuði${sv ? ' · ' + esc(sv) : ''}${qq ? ' · „' + esc(qq) + '“' : ''}</div>` + rows.slice(0, 25).map(fvRow).join('') + (rows.length > 25 ? `<div class="s" style="padding:7px 2px">… og ${rows.length - 25} til viðbótar — þrengdu leitina.</div>` : '') : '')
          + regHtml;
      }
      async function fvRender() {
        const el = document.getElementById('fv-chips');
        if (!el) return;
        const vaktir = fvLoad();
        el.innerHTML = vaktir.map((v, i) => `<span class="lvc" data-i="${i}">🏠 ${esc(v.q || v.sv)}${v.q && v.sv ? ' · ' + esc(v.sv) : ''} <b></b><button title="Fjarlægja" aria-label="Fjarlægja vakt">✕</button></span>`).join('')
          || '<span class="fv-sv">Engin vakt enn — leitaðu að götu og smelltu á 🔔 Vakta.</span>';
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const i = +b.closest('.lvc').dataset.i;
          const a = fvLoad(); a.splice(i, 1); fvSave(a); fvRender();
        }));
        if (vaktir.length) {
          const d = await fvFetch();
          if (d && d.rows) el.querySelectorAll('.lvc').forEach((c) => {
            const v = vaktir[+c.dataset.i];
            if (!v) return;
            const n = d.rows.filter((r) => fvMatch(r, v.sv, fvNorm(v.q))).length;
            const b = c.querySelector('b');
            if (b && n) b.textContent = n;
          });
        }
      }
      let muniDone = false;
      async function fvMunis() {
        if (muniDone) return;
        muniDone = true;
        const d = await fvFetch();
        if (!d || !d.rows || !fvMuniEl) return;
        [...new Set(d.rows.map((r) => r.sv))].sort((a, b) => a.localeCompare(b, 'is')).forEach((sv) => {
          const o = document.createElement('option'); o.value = sv; o.textContent = sv; fvMuniEl.appendChild(o);
        });
      }
      function fvAdd() {
        if (!USER || !USER.loggedIn) { const res = document.getElementById('fv-res'); if (res) { res.hidden = false; res.innerHTML = proTease; } return; }
        const q = (fvQ.value || '').trim().replace(/,\s*\d{3}$/, '').slice(0, 40), sv = fvMuniEl.value;
        if (q.length < 2 && !sv) return;
        const a = fvLoad();
        if (!a.some((v) => v.q === q && v.sv === sv) && a.length < 6) { a.push({ q, sv }); fvSave(a); }
        fvRender();
      }
      let fvT = null;
      if (fvQ) {
        fvQ.addEventListener('focus', fvMunis);
        fvQ.addEventListener('input', () => { clearTimeout(fvT); fvT = setTimeout(async () => { await fvSuggest(fvQ.value); const filled = await fvAutofill(fvQ.value); fvSearch(); if (filled) document.getElementById('fvm-out')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 200); });
        fvQ.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvAdd(); } });
      }
      if (fvMuniEl) { fvMuniEl.addEventListener('focus', fvMunis); fvMuniEl.addEventListener('change', fvSearch); }
      if (fvBtn) fvBtn.addEventListener('click', fvAdd);
      fvRender();
      karpGet('/fastvakt').then((d) => {
        const remote = (d && d.vaktir) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...fvLoad()];
          remote.forEach((rv) => { if (rv && (rv.q || rv.sv) && !merged.some((v) => v.q === rv.q && v.sv === rv.sv)) merged.push({ q: String(rv.q || ''), sv: String(rv.sv || '') }); });
          localStorage.setItem(fvKey, JSON.stringify(merged.slice(0, 6)));
          fvRender();
        }
      }).catch(() => {});

      // ── Verðmatið (Karp Pro) ──
      const fvmOut = document.getElementById('fvm-out');
      const med = (a) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const m = s.length >> 1; return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
      const pct = (a, q) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const i = (s.length - 1) * q, lo = Math.floor(i), hi = Math.ceil(i); return s[lo] + (s[hi] - s[lo]) * (i - lo); };
      const mkr = (v) => (v >= 1000 ? (v / 1000).toFixed(1).replace('.', ',') + ' m.kr' : Math.round(v) + ' þ.kr');
      async function fvmGo() {
        const raw = (document.getElementById('fvm-addr').value || '').trim();
        const fm = +(document.getElementById('fvm-fm').value || 0);
        const teg = document.getElementById('fvm-teg').value;
        if (raw.length < 3 || !(fm >= 15)) { fvmOut.hidden = false; fvmOut.innerHTML = '<div class="fvm-note">Sláðu inn heimilisfang og stærð í m² — eða veldu heimilisfang úr fléttilistanum að ofan.</div>'; return; }
        fvmOut.hidden = false;
        const u = await loadUser().catch(() => null);
        if (!u || !u.loggedIn) {
          fvmOut.innerHTML = '<div class="pro-tease2"><b>⭐ Verðmatið er hluti af Karp Pro</b> — ókeypis aðgangur. Nálgun úr þinglýstum kaupum í götunni þinni, póstnúmerinu og sveitarfélaginu.<div class="pt2-btns"><a class="pt2-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt2-sec" href="/login/">Innskráning</a></div></div>';
          return;
        }
        fvmOut.textContent = 'Reikna úr kaupskránni…';
        const pnM = raw.match(/\b(\d{3})\b/);
        const pn = pnM ? pnM[1] : '';
        const street = fvNorm(raw.replace(/\b\d{3}\b/, '').replace(/[,.]/g, ' ')).replace(/\s+\d+[a-z]?\s*$/i, '').trim();
        const d = await fvFetch();
        if (!d || !d.rows) { fvmOut.textContent = 'Náði ekki í kaupskrána — reyndu aftur.'; return; }
        const ppm = (r) => (r.fm > 15 ? r.v / r.fm : null);
        const lag = [];
        if (street.length >= 3) lag.push({ n: 'götunni (' + street + ') sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn)), min: 3 });
        if (pn) lag.push({ n: 'póstnúmeri ' + pn + ' sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && r.pn === pn), min: 6 });
        let est = null, comps = [];
        for (const L of lag) {
          const vals = L.rows.map(ppm).filter(Boolean);
          if (vals.length >= L.min) { est = { heiti: L.n, n: vals.length, m: med(vals), lo: pct(vals, 0.25), hi: pct(vals, 0.75) }; comps = L.rows.slice(0, 6); break; }
        }
        if (!est) {
          const svGuess = (pn ? d.rows.find((r) => r.pn === pn) : d.rows.find((r) => fvNorm(r.a).startsWith(street)));
          const sv = svGuess && svGuess.sv;
          const f = await fstFetch();
          const bm = sv && f && f.byMuni && f.byMuni[sv];
          const t = bm && ((bm.types && bm.types[teg]) || bm);
          if (t && t.m2) est = { heiti: sv + ' (12 mán miðgildi' + (bm.types && bm.types[teg] ? ', ' + teg : ', allar tegundir') + ')', n: t.n, m: t.m2, lo: t.p25, hi: t.p75 };
        }
        if (!est) { fvmOut.innerHTML = '<div class="fvm-note">Of fá nýleg kaup til að meta — prófaðu án póstnúmers eða athugaðu stafsetningu götunnar.</div>'; return; }
        const verd = est.m * fm, lo = (est.lo || est.m) * fm, hi = (est.hi || est.m) * fm;
        // Sveitarfélags-samhengi í skýrsluna (LOTA 54): 12 mán tölfræði + per tegund
        let svCtx = '';
        try {
          const svGuess2 = (pn ? d.rows.find((r) => r.pn === pn) : d.rows.find((r) => fvNorm(r.a).startsWith(street)));
          const sv2 = svGuess2 && svGuess2.sv;
          const f2 = await fstFetch();
          const bm2 = sv2 && f2 && f2.byMuni && f2.byMuni[sv2];
          if (bm2) {
            const line = (nafn, o) => o && o.m2 ? `<tr><td>${esc(nafn)}</td><td>${o.m2} þ.kr/m²</td><td>${o.p25}–${o.p75}</td><td>${o.n}</td><td>${mkr(o.m2 * fm)}</td></tr>` : '';
            svCtx = `<div class="fv-head" style="margin-top:10px">Samhengið í ${esc(sv2)} (12 mánuðir)</div><table class="fvm-tbl"><tr><th></th><th>Miðgildi</th><th>Fjórðungabil</th><th>Kaup</th><th>Þín stærð (${fm} m²)</th></tr>${line('Allar tegundir', bm2)}${Object.entries(bm2.types || {}).map(([t2, o]) => line(t2, o)).join('')}</table>`;
          }
        } catch (e) {}
        // LOTA 62/65: HMS-akkeri (fasteignamat/brunabótamat/herb/lóð) + markaðsmerki (kaupverð vs mat)
        let matHtml = '';
        try {
          // markaðsmerki: hafa eignir selst yfir/undir fasteignamati? gata → póstnúmer → sveitarfélag
          const svGuess = pn ? d.rows.find((r) => r.pn === pn) : d.rows.find((r) => fvNorm(r.a).startsWith(street));
          const svN = svGuess && svGuess.sv;
          const ratioOf = (rows) => rows.map((r) => r.v / r.mat).filter((x) => x > 0.2 && x < 5);
          const levels = [
            ['götunni ' + street, ratioOf(d.rows.filter((r) => r.mat > 0 && fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn))), 3],
            ['póstnúmeri ' + pn, pn ? ratioOf(d.rows.filter((r) => r.mat > 0 && r.pn === pn)) : [], 5],
            [svN, svN ? ratioOf(d.rows.filter((r) => r.mat > 0 && r.sv === svN)) : [], 8],
          ];
          const lvl = levels.find((l) => l[0] && l[1].length >= l[2]);
          if (lvl) { const pc = Math.round((med(lvl[1]) - 1) * 100); matHtml += `<div class="fvm-signal">🏷️ Eignir í ${esc(lvl[0])} hafa selst að jafnaði <b>${pc >= 0 ? '+' : ''}${pc}%</b> ${pc >= 0 ? 'yfir' : 'undir'} gildandi fasteignamati síðustu 6 mánuði (${lvl[1].length} þinglýst kaup).</div>`; }
          // akkeri: skráðar HMS-tölur nákvæmrar eignar (nýlegar sölur → öll fasteignaskráin)
          const num = raw.replace(/\b\d{3}\b/g, '').match(/\d+\s*[a-zæöðáéíóúý]?/i);
          const selfAddr = num ? fvNorm(street + ' ' + num[0].trim()) : null;
          let self = selfAddr ? d.rows.find((r) => fvNorm(r.a) === selfAddr && (!pn || r.pn === pn) && r.mat > 0) : null;
          if (!self && selfAddr) { const reg = await fskRows('', raw); self = (reg || []).find((r) => fvNorm(r.a) === selfAddr && (!pn || r.pn === pn) && r.mat > 0); }
          if (self) {
            const soldTxt = self.v ? ' Seldist á ' + mkr(self.v) + (self.d ? ' (' + dIS(self.d) + ')' : '') + '.' : (self.lv ? ' Seldist síðast á ' + mkr(self.lv) + (self.ld ? ' (' + self.ld + ')' : '') + '.' : '');
            const extra = [self.herb ? self.herb + ' herb.' : '', self.fm ? String(self.fm).replace('.', ',') + ' m²' : '', self.ar ? 'byggt ' + self.ar : '', self.lod ? 'lóð ' + self.lod + ' m²' : ''].filter(Boolean).join(' · ');
            matHtml += `<div class="fvm-anchor">📋 <b>Skráðar HMS-tölur — ${esc(self.a)}</b><br>Fasteignamat <b>${mkr(self.mat)}</b>${self.matN ? ' (fyrirhugað ' + mkr(self.matN) + ')' : ''}${self.bruna ? ' · brunabótamat <b>' + mkr(self.bruna) + '</b>' : ''}${extra ? '<br>' + esc(extra) : ''}${soldTxt ? '<br>' + soldTxt : ''}</div>`;
          }
        } catch (e) {}
        // Skýrslu-útgáfan (LOTA 53/54): prentvæn — @media print einangrar #fvm-report
        fvmOut.innerHTML = `<div class="fvm-card" id="fvm-report"><div class="fvm-rephead" hidden><b>🐟 KARP — Verðmatsskýrsla úr kaupskrá</b><span>${esc(raw)} · ${esc(teg)}, ${fm} m² · skýrsla gerð ${new Date().toLocaleDateString('is-IS')} · karp.is/fasteignavakt · heimild: kaupskrá HMS</span></div><div class="fvm-big">${mkr(verd)}</div><div class="fvm-range">líklegt bil ${mkr(lo)} – ${mkr(hi)} <span class="fv-sv">(fjórðungabil kaupverðs á m²)</span></div><div class="fvm-meta">${Math.round(est.m)} þ.kr/m² · byggt á ${est.n} þinglýstum kaupum í ${esc(est.heiti)} · ${esc(teg)}, ${fm} m²</div>${matHtml}${svCtx}<div class="fvm-comps">${comps.length ? '<div class="fv-head" style="margin-top:8px">Nýlegustu kaupin sem matið byggir á</div>' + d.rows.filter((r) => fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn)).slice(0, 10).map(fvRow).join('') : ''}</div><div class="fvm-note">Tölfræðileg nálgun úr opinberri kaupskrá HMS (þinglýst kaup) — ekki fasteignamat og ekki verðmat löggilts fasteignasala. Ástand, hæð, útsýni, bílastæði og sérstaða eignar geta hliðrað verði verulega út fyrir bilið.</div></div><button id="fvm-print" class="cta" style="margin-top:10px">🖨️ Vista sem skýrslu (PDF/prenta)</button>`;
        const pb = document.getElementById('fvm-print');
        if (pb) pb.addEventListener('click', () => { document.body.classList.add('fvm-printing'); window.print(); setTimeout(() => document.body.classList.remove('fvm-printing'), 500); });
      }
      const fvmBtn = document.getElementById('fvm-go');
      if (fvmBtn) fvmBtn.addEventListener('click', fvmGo);
      const fvmAddr = document.getElementById('fvm-addr');
      if (fvmAddr) fvmAddr.addEventListener('input', () => { clearTimeout(fvT); fvT = setTimeout(async () => { await fvSuggest(fvmAddr.value); await fvAutofill(fvmAddr.value); }, 200); });
      if (fvmAddr) fvmAddr.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvmGo(); } });

      // ── Markaðsvísir efst (LOTA 66): stefna markaðar + yfir/undir fasteignamati (land + sveitarfélög) ──
      fstFetch().then((f) => {
        const el = document.getElementById('fv-market');
        if (!el || !f || !f.direction) return;
        const dr = f.direction, ms = f.matStats || {};
        const arrow = { up: '📈', down: '📉', cooling: '🌡️', flat: '➡️' }[dr.verdict] || '➡️';
        const word = { up: 'á uppleið', down: 'á niðurleið', cooling: 'að kólna', flat: 'stöðugur' }[dr.verdict] || '';
        const cls = { up: 'up', down: 'dn', cooling: 'cool', flat: 'flat' }[dr.verdict] || 'flat';
        const sgn = (v) => (v > 0 ? '+' : '') + String(v).replace('.', ',') + '%';
        const thou = (n) => String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        const pst = (v) => String(v).replace('.', ',');
        const nat = ms.national || {};
        const overWord = (p) => (p > 0 ? 'yfir' : 'undir');
        // topp/botn sveitarfélög eftir yfir/undir-mati
        const munis = Object.entries(ms.byMuni || {}).filter(([, v]) => v.n >= 10).sort((a, b) => b[1].pct - a[1].pct);
        const top = munis.slice(0, 3).map(([n, v]) => esc(n) + ' ' + sgn(v.pct)).join(' · ');
        const bot = munis.slice(-3).reverse().map(([n, v]) => esc(n) + ' ' + sgn(v.pct)).join(' · ');
        el.hidden = false;
        el.innerHTML = `<div class="fvm-dir fvm-${cls}"><span class="fvm-arrow">${arrow}</span><div><div class="fvm-dir-t">Húsnæðismarkaðurinn er <b>${word}</b></div><div class="fvm-dir-s">Verð ${sgn(dr.chg3)} síðustu 3 mánuði · ${sgn(dr.chg12)} síðasta árið (vegið miðgildi verðs/m², ${esc(dr.updated)})</div></div></div>`
          + `<div class="fvm-mat">🏷️ Á landsvísu seljast eignir að jafnaði <b class="${nat.pct >= 0 ? 'up' : 'dn'}">${sgn(nat.pct)}</b> ${overWord(nat.pct)} gildandi fasteignamati síðustu 12 mánuði <span class="fv-sv">(${nat.n ? thou(nat.n) : 0} kaup${ms.trend != null ? '; bilið hefur ' + (ms.trend > 0 ? 'aukist' : 'minnkað') + ' um ' + pst(Math.abs(ms.trend)) + ' prósentustig' : ''})</span>.`
          + (top ? `<div class="fvm-mrow"><span class="fvm-ml up">Mest yfir mati:</span> ${top}</div>` : '')
          + (bot ? `<div class="fvm-mrow"><span class="fvm-ml dn">Mest undir mati:</span> ${bot}</div>` : '')
          + `</div>`;
      }).catch(() => {});
      // ── Uppboðslistinn: ALLTAF sýnilegur — framundan fyrst ──
      uppFetch().then((up) => {
        const el = document.getElementById('upp-list');
        if (!el) return;
        const rows = (up && up.rows) || [];
        if (!rows.length) { el.textContent = 'Engar uppboðsauglýsingar á skrá í augnablikinu.'; return; }
        const today = new Date().toISOString().slice(0, 10);
        const fram = rows.filter((x) => x.d >= today && !/lokið/i.test(x.teg)).sort((a, b) => a.d.localeCompare(b.d));
        const lokid = rows.filter((x) => !fram.includes(x)).sort((a, b) => b.d.localeCompare(a.d));
        const row = (x, isFram) => `<div class="fi"><span class="t"><span class="upp-pill ${isFram ? 'fram' : ''}">${isFram ? 'Framundan' : esc(x.teg)}</span>${esc(x.a)}</span><span class="s">${dIS(x.d)}${x.kl ? ' kl. ' + esc(x.kl) : ''} · ${esc(x.flokkur)} · ${esc(x.e)}${x.st ? ' · ' + esc(x.st) : ''}</span></div>`;
        el.innerHTML = (fram.length ? `<div class="fv-head">🔜 Framundan (${fram.length})</div>` + fram.map((x) => row(x, true)).join('') : '<div class="fv-head">Engin uppboð auglýst framundan í augnablikinu — nýjar auglýsingar birtast hér daglega.</div>')
          + (lokid.length ? `<div class="fv-head" style="margin-top:10px">Nýlega afgreidd (${lokid.length})</div>` + lokid.slice(0, 10).map((x) => row(x, false)).join('') : '');
      });
    }
    document.addEventListener('astro:page-load', () => initFastvakt());
  </script>
</Layout>
