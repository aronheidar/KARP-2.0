  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    const thouIS = (n) => String(Math.round(n || 0)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');  // íslenskur þúsundaskiljari (punktur)
    function initFastvakt() {
      const root = document.querySelector('main[data-pg="fastvakt"]');
      if (!root || root.dataset.done) return;
      root.dataset.done = '1';
      const fvKey = 'karp-fastvakt';
      let FV = null, FST = null, UPP = null;
      const fvFetch = () => FV || (FV = fetch('/gogn/kaupskra_nyjast.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fstFetch = () => FST || (FST = fetch('/gogn/fasteignir.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const uppFetch = () => UPP || (UPP = fetch('/gogn/uppbod.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      // LOTA 64: full fasteignaskrá (nánast allar seldar eignir frá 2006 m/gildandi mati), per póstnúmer
      let FSK_IDX = null, FSK_GOTUR = null; const FSK = {};
      const fskIdx = () => FSK_IDX || (FSK_IDX = fetch('/gogn/fasteignaskra/index.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fskGotur = () => FSK_GOTUR || (FSK_GOTUR = fetch('/gogn/fasteignaskra/gotur.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fskPn = (pn) => FSK[pn] || (FSK[pn] = fetch('/gogn/fasteignaskra/' + pn + '.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      // LOTA 67: sölusaga per póstnúmer (allar þinglýstar sölur sl. ~5 ár) → sölugraf + sambærilegar
      const SOL = {};
      const solPn = (pn) => SOL[pn] || (SOL[pn] = fetch('/gogn/solusaga/' + pn + '.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      // ECharts on-demand (sama mynstur og fasteignir-síðan)
      const withEcharts = (cb) => {
        if (window.echarts) return cb();
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', () => cb(), { once: true });
      };
      // LOTA 68: GPS-hnit per heimilisfang (staðfangaskrá) → kort, fjarlægð á sambærilegar, hverfi
      const HNIT = {};
      const hnitPn = (pn) => HNIT[pn] || (HNIT[pn] = fetch('/gogn/hnit/' + pn + '.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const distKm = (a, b) => { const rad = Math.PI / 180, R = 6371; const s = Math.sin((b[0] - a[0]) * rad / 2) ** 2 + Math.cos(a[0] * rad) * Math.cos(b[0] * rad) * Math.sin((b[1] - a[1]) * rad / 2) ** 2; return R * 2 * Math.asin(Math.sqrt(s)); };
      const withLeaflet = (cb) => {
        if (window.L) return cb();
        if (!document.getElementById('leaflet-css')) { const l = document.createElement('link'); l.id = 'leaflet-css'; l.rel = 'stylesheet'; l.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'; document.head.appendChild(l); }
        let s = document.getElementById('leaflet-js');
        if (!s) { s = document.createElement('script'); s.id = 'leaflet-js'; s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'; document.head.appendChild(s); }
        s.addEventListener('load', () => cb(), { once: true });
      };
      // LOTA 65: finna póstnúmer út frá pn í fyrirspurn, völdu sveitarfélagi, EÐA götunafni (götuvísir)
      async function fskRows(sv, raw) {
        const idx = await fskIdx(); if (!idx) return [];
        const pnInQ = (String(raw || '').match(/\b(\d{3})\b/) || [])[1];
        let pns = pnInQ && idx.byPn[pnInQ] ? [pnInQ] : (sv && idx.bySv[sv] ? idx.bySv[sv] : []);
        if (!pns.length) {
          const street = fvNorm(String(raw || '').replace(/,?\s*\d{3}\s*$/, '').replace(/\s+\d+[a-zæöðáéíóúý]?\s*$/i, ''));
          if (street.length >= 3) {
            const g = await fskGotur();
            if (g) { const hit = new Set(); for (const name in g) { if (name.startsWith(street)) { g[name].forEach((p) => hit.add(p)); if (hit.size > 8) break; } } pns = [...hit]; }
          }
        }
        if (!pns.length || pns.length > 8) return [];   // of margar skrár → krefjast póstnúmers/sveitarfélags
        return (await Promise.all(pns.map(fskPn))).filter(Boolean).flat();
      }
      const fvLoad = () => { try { return JSON.parse(localStorage.getItem(fvKey) || '[]').filter((v) => v && typeof v.q === 'string'); } catch (e) { return []; } };
      const fvSave = (a) => { localStorage.setItem(fvKey, JSON.stringify(a.slice(0, 6))); try { karpPost('/fastvakt', { on: true, vaktir: a.slice(0, 6) }).catch(() => {}); } catch (e) {} };
      const fvNorm = (s) => String(s || '').toLowerCase().trim();
      const fvMatch = (r, sv, q) => (!sv || r.sv === sv) && (!q || (/^\d{3}$/.test(q) ? r.pn === q : fvNorm(r.a).startsWith(q)));
      const fvKr = (v) => (v / 1000).toFixed(1).replace('.', ',') + ' m.kr';
      // LOTA 62: fasteignamat + brunabótamat + hlutfall kaupverðs/mats sýnt á hverri röð
      const matPct = (r) => (r.mat && r.v ? (r.v >= r.mat ? '+' : '') + Math.round((r.v / r.mat - 1) * 100) + '% v. mat' : '');
      const fvRow = (r) => `<div class="fi"><span class="t">${esc(r.a)} <span class="fv-sv">· ${esc(r.pn)} ${esc(r.sv)}</span> — <b class="fv-v">${fvKr(r.v)}</b>${r.mat ? ` <span class="fv-mat">${matPct(r)}</span>` : ''}</span><span class="s">${dIS(r.d)} · ${String(r.fm).replace('.', ',')} m²${r.fm > 0 ? ' · ' + Math.round(r.v / r.fm) + ' þ/m²' : ''} · ${esc(r.t)}${r.ar ? ' · byggt ' + r.ar : ''}${r.mat ? ' · fasteignamat ' + fvKr(r.mat) : ''}${r.bruna ? ' · brunabótamat ' + fvKr(r.bruna) : ''}</span></div>`;
      const uppRow = (x) => `<div class="fi fv-upp"><span class="t">🔨 ${esc(x.a)} — <b>${esc(x.teg)}</b></span><span class="s">${dIS(x.d)}${x.kl ? ' kl. ' + esc(x.kl) : ''} · ${esc(x.flokkur)} · ${esc(x.e)}</span></div>`;
      // Röð fyrir eign úr fasteignaskrá (ekki nýleg sala) — fasteignamat + brunabótamat
      const fskRow = (r) => `<div class="fi fv-fsk"><span class="t">${esc(r.a)} <span class="fv-sv">· ${esc(r.pn)} ${esc(r.sv)}</span> — fasteignamat <b class="fv-v">${r.mat ? fvKr(r.mat) : '–'}</b></span><span class="s">${r.fm ? String(r.fm).replace('.', ',') + ' m² · ' : ''}${esc(r.teg)}${r.herb ? ' · ' + r.herb + ' herb.' : ''}${r.ar ? ' · byggt ' + r.ar : ''}${r.lod ? ' · lóð ' + r.lod + ' m²' : ''}${r.bruna ? ' · brunabótamat ' + fvKr(r.bruna) : ''}${r.ld ? ' · seldist síðast ' + esc(r.ld) + (r.lv ? ' á ' + fvKr(r.lv) : '') : ''}</span></div>`;
      const fvQ = document.getElementById('fv-q'), fvMuniEl = document.getElementById('fv-muni'), fvBtn = document.getElementById('fv-add');
      const dl = document.getElementById('fv-addr-list');

      // ── Fléttilistinn (LOTA 52): heimilisföng úr kaupskránni; val fyllir verðmatið ──
      async function fvSuggest(val) {
        if (!dl) return;
        const raw = String(val || '');
        const q = fvNorm(raw.replace(/,?\s*\d{3}\s*$/, '')); // strípa póstnúmer fyrir götu-samsvörun
        if (q.length < 2) { dl.innerHTML = ''; return; }
        const sv = fvMuniEl.value;
        const [d, reg] = await Promise.all([fvFetch(), fskRows(sv, raw)]);
        const seen = new Set(), opts = [];
        const add = (r) => {
          const t = r.t || r.teg; const key = fvNorm(r.a) + '|' + r.pn;
          if (seen.has(key) || (sv && r.sv !== sv) || !fvNorm(r.a).startsWith(q)) return;
          seen.add(key);
          opts.push(`<option value="${esc(r.a)}, ${esc(r.pn)}">${esc(r.sv)}${r.fm ? ' · ' + String(r.fm).replace('.', ',') + ' m²' : ''}${t ? ' ' + esc(t) : ''}</option>`);
        };
        (d && d.rows || []).forEach(add);              // nýlegar sölur fyrst
        reg.forEach((r) => { if (opts.length < 16) add(r); }); // svo öll fasteignaskráin
        dl.innerHTML = opts.slice(0, 16).join('');
      }
      // valið heimilisfang → sjálfvirk stærð + tegund inn í verðmatið (kaupskrá fyrst, svo fasteignaskrá)
      async function fvAutofill(val) {
        const m = String(val || '').match(/^(.+?),\s*(\d{3})$/);
        if (!m) return false;
        const addr = m[1].trim(), pn = m[2];
        const [d, reg] = await Promise.all([fvFetch(), fskRows('', val)]);
        const hit = (d && d.rows || []).find((r) => r.a === addr && r.pn === pn)
          || (reg || []).find((r) => r.a === addr && r.pn === pn);
        if (!hit) return false;
        const teg = hit.t || hit.teg;
        const aEl = document.getElementById('fvm-addr'), fmEl = document.getElementById('fvm-fm'), tegEl = document.getElementById('fvm-teg');
        if (aEl) aEl.value = hit.a + ', ' + hit.pn;
        if (fmEl && hit.fm) fmEl.value = Math.round(hit.fm);
        if (tegEl && teg) tegEl.value = teg;
        const note = document.getElementById('fvm-fill');
        if (note) { note.hidden = false; note.textContent = '✓ ' + (hit.fm ? 'Stærð (' + String(hit.fm).replace('.', ',') + ' m²) og t' : 'T') + 'egund (' + (teg || '') + ') sóttar sjálfkrafa' + (hit.mat ? ' · fasteignamat ' + fvKr(hit.mat) : '') + ' — smelltu á Meta.'; }
        return true;
      }

      // LOTA 54: fasteignavaktin er Karp Pro (ókeypis aðgangur) — leit+vaktir læstar,
      // uppboðin (opinberar auglýsingar) sjást öllum sem forsmekkur.
      let USER = null;
      const proTease = '<div class="pro-tease2"><b>⭐ Fasteignavaktin er hluti af Karp Pro</b> — ókeypis aðgangur sem tekur mínútu. Leit í kaupskránni, götuvaktir með tölvupósti og verðmatið opnast við innskráningu.<div class="pt2-btns"><a class="pt2-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt2-sec" href="/login/">Innskráning</a></div></div>';
      async function fvSearch() {
        const res = document.getElementById('fv-res');
        if (!res) return;
        const sv = fvMuniEl.value, q = fvNorm(fvQ.value);
        if (!sv && q.length < 2) { res.hidden = true; return; }
        res.hidden = false;
        if (USER === null) USER = await loadUser().catch(() => null);
        if (!USER || !USER.loggedIn) { res.innerHTML = proTease; return; }
        res.textContent = 'Sæki kaupskrá…';
        const [d, up] = await Promise.all([fvFetch(), uppFetch()]);
        if (!d || !d.rows) { res.textContent = 'Náði ekki í kaupskrána — reyndu aftur síðar.'; return; }
        const rawq = fvNorm(fvQ.value);
        const qq = rawq.replace(/,?\s*\d{3}\s*$/, ''); // „Melabraut 3, 170“ → gata+númer
        const rows = d.rows.filter((r) => fvMatch(r, sv, qq));
        const uppRows = (qq && !/^\d{3}$/.test(qq) && up && up.rows) ? up.rows.filter((x) => fvNorm(x.a).startsWith(qq)) : [];
        const uppHtml = uppRows.length ? `<div class="fv-head fv-upph">⚠ ${uppRows.length} nauðungarsölu-auglýsing${uppRows.length === 1 ? '' : 'ar'} passa við leitina</div>` + uppRows.slice(0, 6).map(uppRow).join('') : '';
        // LOTA 64: fasteignaskrá — eignir sem hafa EKKI selst nýlega (birtir fasteignamat/brunabótamat)
        const reg = await fskRows(sv, fvQ.value);
        const recentKeys = new Set(rows.map((r) => fvNorm(r.a) + '|' + r.pn));
        const regRows = reg.filter((r) => (!sv || r.sv === sv) && (qq ? fvNorm(r.a).startsWith(qq) : true) && !recentKeys.has(fvNorm(r.a) + '|' + r.pn));
        const regHtml = regRows.length ? `<div class="fv-head" style="margin-top:10px">📋 Úr fasteignaskrá — ${regRows.length} eign${regRows.length === 1 ? '' : 'ir'} með gildandi mati (engin nýleg sala)</div>` + regRows.slice(0, 20).map(fskRow).join('') + (regRows.length > 20 ? `<div class="s" style="padding:7px 2px">… og ${regRows.length - 20} til viðbótar.</div>` : '') : '';
        if (!rows.length && !uppRows.length && !regRows.length) { res.innerHTML = '<div class="fi"><span class="t">Ekkert fannst.</span><span class="s">Sláðu inn heimilisfang með póstnúmeri (t.d. „Brunnstígur 2, 230“) eða veldu sveitarfélag — þá leitum við í allri fasteignaskránni, ekki bara nýlegum sölum.</span></div>'; return; }
        res.innerHTML = uppHtml
          + (rows.length ? `<div class="fv-head">${rows.length} þinglýst kaup síðustu 6 mánuði${sv ? ' · ' + esc(sv) : ''}${qq ? ' · „' + esc(qq) + '“' : ''}</div>` + rows.slice(0, 25).map(fvRow).join('') + (rows.length > 25 ? `<div class="s" style="padding:7px 2px">… og ${rows.length - 25} til viðbótar — þrengdu leitina.</div>` : '') : '')
          + regHtml;
      }
      async function fvRender() {
        const el = document.getElementById('fv-chips');
        if (!el) return;
        const vaktir = fvLoad();
        el.innerHTML = vaktir.map((v, i) => `<span class="lvc" data-i="${i}">🏠 ${esc(v.q || v.sv)}${v.q && v.sv ? ' · ' + esc(v.sv) : ''} <b></b><button title="Fjarlægja" aria-label="Fjarlægja vakt">✕</button></span>`).join('')
          || '<span class="fv-sv">Engin vakt enn — leitaðu að götu og smelltu á 🔔 Vakta.</span>';
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const i = +b.closest('.lvc').dataset.i;
          const a = fvLoad(); a.splice(i, 1); fvSave(a); fvRender();
        }));
        if (vaktir.length) {
          const d = await fvFetch();
          if (d && d.rows) el.querySelectorAll('.lvc').forEach((c) => {
            const v = vaktir[+c.dataset.i];
            if (!v) return;
            const n = d.rows.filter((r) => fvMatch(r, v.sv, fvNorm(v.q))).length;
            const b = c.querySelector('b');
            if (b && n) b.textContent = n;
          });
        }
      }
      let muniDone = false;
      async function fvMunis() {
        if (muniDone) return;
        muniDone = true;
        const d = await fvFetch();
        if (!d || !d.rows || !fvMuniEl) return;
        [...new Set(d.rows.map((r) => r.sv))].sort((a, b) => a.localeCompare(b, 'is')).forEach((sv) => {
          const o = document.createElement('option'); o.value = sv; o.textContent = sv; fvMuniEl.appendChild(o);
        });
      }
      function fvAdd() {
        if (!USER || !USER.loggedIn) { const res = document.getElementById('fv-res'); if (res) { res.hidden = false; res.innerHTML = proTease; } return; }
        const q = (fvQ.value || '').trim().replace(/,\s*\d{3}$/, '').slice(0, 40), sv = fvMuniEl.value;
        if (q.length < 2 && !sv) return;
        const a = fvLoad();
        if (!a.some((v) => v.q === q && v.sv === sv) && a.length < 6) { a.push({ q, sv }); fvSave(a); }
        fvRender();
      }
      let fvT = null;
      if (fvQ) {
        fvQ.addEventListener('focus', fvMunis);
        fvQ.addEventListener('input', () => { clearTimeout(fvT); fvT = setTimeout(async () => { await fvSuggest(fvQ.value); const filled = await fvAutofill(fvQ.value); fvSearch(); if (filled) document.getElementById('fvm-out')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 200); });
        fvQ.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvAdd(); } });
      }
      if (fvMuniEl) { fvMuniEl.addEventListener('focus', fvMunis); fvMuniEl.addEventListener('change', fvSearch); }
      if (fvBtn) fvBtn.addEventListener('click', fvAdd);
      fvRender();
      karpGet('/fastvakt').then((d) => {
        const remote = (d && d.vaktir) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...fvLoad()];
          remote.forEach((rv) => { if (rv && (rv.q || rv.sv) && !merged.some((v) => v.q === rv.q && v.sv === rv.sv)) merged.push({ q: String(rv.q || ''), sv: String(rv.sv || '') }); });
          localStorage.setItem(fvKey, JSON.stringify(merged.slice(0, 6)));
          fvRender();
        }
      }).catch(() => {});

      // ── Sölugraf + sambærilegar (LOTA 67) ──
      const TEG_COL = { 'Fjölbýli': '#3a6ea5', 'Sérbýli': '#19c3b2', 'Einbýli': '#e8952f', 'Parhús': '#c792ff', 'Raðhús': '#e8952f' };
      const qMed = (a) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const m = s.length >> 1; return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
      const qPct = (a, q) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const i = (s.length - 1) * q, lo = Math.floor(i), hi = Math.ceil(i); return s[lo] + (s[hi] - s[lo]) * (i - lo); };
      const tsOf = (d) => new Date(d + 'T00:00:00').getTime();
      const OUTLO = 180000, OUTHI = 2600000;                 // sía burt bílskúra/hlutasölur/útlaga
      // rúllandi 3ja mánaða miðgildi + fjórðungabil → matslína + öryggisbil
      function soluAgg(sales) {
        const byM = {};
        sales.filter((s) => s.ppm >= OUTLO && s.ppm <= OUTHI).forEach((s) => { const k = s.d.slice(0, 7); (byM[k] = byM[k] || []).push(s.ppm); });
        const months = Object.keys(byM).sort();
        const out = [];
        for (let idx = 0; idx < months.length; idx++) {
          const pool = months.slice(Math.max(0, idx - 2), idx + 1).flatMap((k) => byM[k]);
          if (pool.length < 4) continue;
          out.push({ ts: tsOf(months[idx] + '-15'), med: Math.round(qMed(pool)), lo: Math.round(qPct(pool, 0.25)), hi: Math.round(qPct(pool, 0.75)) });
        }
        return out;
      }
      function renderSoluGraf(elId, sales, subj) {
        const el = document.getElementById(elId);
        if (!el) return;
        const agg = soluAgg(sales);
        if (agg.length < 3) { el.style.display = 'none'; return; }
        // punktar: sölur af líkri stærð (±40%), jafndreift í tíma (ekki bara nýjustu), litað eftir tegund, merkt m²
        const cut = Date.now() - 1600 * 864e5;
        const pool = sales.filter((s) => s.ppm >= OUTLO && s.ppm <= OUTHI && s.fm >= subj.fm * 0.6 && s.fm <= subj.fm * 1.4 && tsOf(s.d) >= cut).sort((a, b) => a.d.localeCompare(b.d));
        const step = Math.max(1, Math.ceil(pool.length / 32));
        const dots = pool.filter((_, i) => i % step === 0);
        const byTeg = {}; dots.forEach((s) => (byTeg[s.teg] = byTeg[s.teg] || []).push(s));
        withEcharts(() => {
          if (!window.echarts) return;
          const c = window.echarts.init(el);
          const lower = agg.map((m) => [m.ts, m.lo]);
          const band = agg.map((m) => [m.ts, m.hi - m.lo]);
          const est = agg.map((m) => [m.ts, m.med]);
          const dotSeries = Object.entries(byTeg).map(([teg, arr]) => ({
            name: teg, type: 'scatter', symbolSize: 9, z: 5,
            itemStyle: { color: TEG_COL[teg] || '#8aa0c0', borderColor: 'rgba(0,0,0,.35)', borderWidth: .5 },
            label: { show: true, position: 'top', fontSize: 9, color: '#8fa0b8', formatter: (p) => p.data[2] + ' m' },
            data: arr.map((s) => [tsOf(s.d), s.ppm, Math.round(s.fm), s.a, s.kv, s.d]),
          }));
          const series = [
            { name: 'lower', type: 'line', data: lower, stack: 'band', symbol: 'none', lineStyle: { opacity: 0 }, areaStyle: { opacity: 0 }, silent: true, z: 1 },
            { name: 'Öryggisbil', type: 'line', data: band, stack: 'band', symbol: 'none', lineStyle: { opacity: 0 }, areaStyle: { color: 'rgba(150,165,195,.20)' }, silent: true, z: 1 },
            { name: 'Áætlað markaðsverð', type: 'line', data: est, symbol: 'none', smooth: true, lineStyle: { color: '#e8952f', width: 3 }, z: 4 },
          ];
          if (subj.ppm) series[2].markPoint = { symbol: 'pin', symbolSize: 42, data: [{ coord: [agg[agg.length - 1].ts, subj.ppm], value: 'þín', itemStyle: { color: '#f6b13b' }, label: { fontSize: 9, color: '#1a1200' } }] };
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: ['Áætlað markaðsverð', ...Object.keys(byTeg)], textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0, icon: 'circle' },
            grid: { left: 52, right: 14, top: 34, bottom: 26 },
            tooltip: {
              trigger: 'item',
              formatter: (p) => {
                if (p.seriesType === 'scatter') { const d = p.data; return `<b>${esc(d[3])}</b><br>${dIS(d[5])} · ${d[2]} m² · ${(d[4] / 1000).toFixed(1).replace('.', ',')} m.kr<br>${thouIS(d[1])} kr/m²`; }
                if (p.seriesName === 'Áætlað markaðsverð') { const dt = new Date(p.data[0]); return `${dt.getMonth() + 1}/${dt.getFullYear()}<br>Áætlað: <b>${thouIS(p.data[1])} kr/m²</b>`; }
                return '';
              },
            },
            xAxis: { type: 'time', axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', scale: true, axisLabel: { color: '#7e8ca6', fontSize: 10, formatter: (v) => Math.round(v / 1000) + ' þ' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            series: series.concat(dotSeries),
          });
          window.addEventListener('resize', () => c.resize());
          setTimeout(() => c.resize(), 60);
        });
      }
      // Sambærilegar seldar eignir — raðanleg tafla
      function compRows(sales, subj, sameTeg) {
        return sales.filter((s) => s.ppm >= OUTLO && s.ppm <= OUTHI && s.fm >= subj.fm * 0.6 && s.fm <= subj.fm * 1.4 && (!sameTeg || s.teg === subj.teg))
          .sort((a, b) => b.d.localeCompare(a.d));
      }
      const compTblHtml = (rows, withKm) => `<table class="comp-tbl"><thead><tr>`
        + [['a', 'Heimilisfang', 'l']].concat(withKm ? [['km', 'Fjarl.']] : []).concat([['ar', 'Byggt'], ['teg', 'Tegund', 'l'], ['herb', 'Herb.'], ['fm', 'Stærð'], ['d', 'Seld'], ['kv', 'Kaupverð'], ['ppm', 'Verð/m²']])
          .map(([k, lab, l]) => `<th data-k="${k}" class="${l || ''}">${lab} <span class="sar">⇅</span></th>`).join('') + `</tr></thead><tbody>`
        + rows.map((r) => `<tr><td class="l">${esc(r.a)}</td>${withKm ? `<td>${r.km != null ? String(r.km).replace('.', ',') + ' km' : '–'}</td>` : ''}<td>${r.ar || '–'}</td><td class="l">${esc(r.teg)}</td><td>${r.herb || '–'}</td><td>${String(r.fm).replace('.', ',')} m²</td><td>${dIS(r.d)}</td><td>${(r.kv / 1000).toFixed(1).replace('.', ',')} m.kr</td><td>${thouIS(r.ppm)} kr</td></tr>`).join('')
        + `</tbody></table>`;

      // ── Verðmatið (Karp Pro) ──
      const fvmOut = document.getElementById('fvm-out');
      const med = (a) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const m = s.length >> 1; return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
      const pct = (a, q) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const i = (s.length - 1) * q, lo = Math.floor(i), hi = Math.ceil(i); return s[lo] + (s[hi] - s[lo]) * (i - lo); };
      const mkr = (v) => (v >= 1000 ? (v / 1000).toFixed(1).replace('.', ',') + ' m.kr' : Math.round(v) + ' þ.kr');
      async function fvmGo() {
        const raw = (document.getElementById('fvm-addr').value || '').trim();
        const fm = +(document.getElementById('fvm-fm').value || 0);
        const teg = document.getElementById('fvm-teg').value;
        if (raw.length < 3 || !(fm >= 15)) { fvmOut.hidden = false; fvmOut.innerHTML = '<div class="fvm-note">Sláðu inn heimilisfang og stærð í m² — eða veldu heimilisfang úr fléttilistanum að ofan.</div>'; return; }
        fvmOut.hidden = false;
        const u = await loadUser().catch(() => null);
        if (!u || !u.loggedIn) {
          fvmOut.innerHTML = '<div class="pro-tease2"><b>⭐ Verðmatið er hluti af Karp Pro</b> — ókeypis aðgangur. Nálgun úr þinglýstum kaupum í götunni þinni, póstnúmerinu og sveitarfélaginu.<div class="pt2-btns"><a class="pt2-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt2-sec" href="/login/">Innskráning</a></div></div>';
          return;
        }
        fvmOut.textContent = 'Reikna úr kaupskránni…';
        const pnM = raw.match(/\b(\d{3})\b/);
        let pn = pnM ? pnM[1] : '';
        // þátta „Gata N, PNN Muni": klippa póstnúmer+muni af (styður líka 3ja stafa húsnúmer), einangra götu + húsnúmer
        const streetPart = raw.replace(/\s*,?\s*\d{3}\s+\p{L}.*$/u, '').replace(/,/g, ' ').replace(/\s+/g, ' ').trim();
        const houseM = streetPart.match(/\s(\d+\s*[a-zæöðáéíóúý]?)\s*$/i);
        const houseNum = houseM ? houseM[1].replace(/\s+/g, '') : '';
        const street = fvNorm(streetPart.replace(/\s+\d+\s*[a-zæöðáéíóúý]?\s*$/i, '')).trim();
        const krFull = (v) => thouIS(v * 1000) + ' kr.';
        const d = await fvFetch();
        if (!d || !d.rows) { fvmOut.textContent = 'Náði ekki í kaupskrána — reyndu aftur.'; return; }
        // finna sveitarfélag + póstnúmer (ef vantar) svo við getum hlaðið sölusögu
        let svN = '';
        { const g = pn ? d.rows.find((r) => r.pn === pn) : d.rows.find((r) => fvNorm(r.a).startsWith(street)); if (g) { svN = g.sv; if (!pn) pn = g.pn; } }
        if (!pn && street.length >= 3) { const gt = await fskGotur(); if (gt) { for (const nm in gt) { if (nm.startsWith(street)) { pn = gt[nm][0]; break; } } } }
        // sölusaga póstnúmers (sl. 5 ár) — knýr sölugraf, sambærilegar OG stærðarnæmt mat
        const sales = pn ? await solPn(pn) : null;
        const ppm = (r) => (r.fm > 15 ? r.v / r.fm : null);
        let est = null, comps = [];
        // 1) STÆRÐARNÆMT mat úr sölusögu: sama tegund, ±30% stærð, sl. 18 mán
        if (sales && sales.length) {
          const near = sales.filter((s) => s.teg === teg && s.fm >= fm * 0.7 && s.fm <= fm * 1.3 && s.ppm >= OUTLO && s.ppm <= OUTHI && tsOf(s.d) >= Date.now() - 560 * 864e5);
          if (near.length >= 6) { const vals = near.map((s) => s.ppm / 1000); est = { heiti: 'sambærilegum eignum í póstnúmeri ' + pn + ' (' + teg + ', ±30% stærð, sl. 18 mán)', n: near.length, m: qMed(vals), lo: qPct(vals, 0.25), hi: qPct(vals, 0.75) }; }
        }
        // 2) fallback: 180-daga kaupskrá (gata → póstnúmer)
        if (!est) {
          const lag = [];
          if (street.length >= 3) lag.push({ n: 'götunni (' + street + ') sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn)), min: 3 });
          if (pn) lag.push({ n: 'póstnúmeri ' + pn + ' sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && r.pn === pn), min: 6 });
          for (const L of lag) { const vals = L.rows.map(ppm).filter(Boolean); if (vals.length >= L.min) { est = { heiti: L.n, n: vals.length, m: med(vals), lo: pct(vals, 0.25), hi: pct(vals, 0.75) }; comps = L.rows.slice(0, 6); break; } }
        }
        // 3) fallback: sveitarfélags-miðgildi (12 mán)
        if (!est) {
          const f = await fstFetch();
          const bm = svN && f && f.byMuni && f.byMuni[svN];
          const t = bm && ((bm.types && bm.types[teg]) || bm);
          if (t && t.m2) est = { heiti: svN + ' (12 mán miðgildi' + (bm.types && bm.types[teg] ? ', ' + teg : ', allar tegundir') + ')', n: t.n, m: t.m2, lo: t.p25, hi: t.p75 };
        }
        if (!est) { fvmOut.innerHTML = '<div class="fvm-note">Of fá nýleg kaup til að meta — prófaðu án póstnúmers eða athugaðu stafsetningu götunnar.</div>'; return; }
        const verd = est.m * fm, lo = (est.lo || est.m) * fm, hi = (est.hi || est.m) * fm;
        const subj = { teg, fm, ppm: est.m * 1000 };

        // ── Nákvæm eign úr fasteignaskrá → eignaspjald (fasteignanúmer, mat, brunabótamat, byggingastig …) ──
        const selfAddr = houseNum ? fvNorm(street + ' ' + houseNum) : null;
        let self = null;
        if (selfAddr) {
          const reg = pn ? await fskPn(pn) : await fskRows('', raw);
          self = (reg || []).find((r) => fvNorm(r.a) === selfAddr && (!pn || r.pn === pn));
        }
        // GPS-hnit + hverfi úr staðfangaskrá (LOTA 68) — kort + fjarlægð á sambærilegar
        const hn = pn ? await hnitPn(pn) : null;
        const subjC = (hn && selfAddr && hn[selfAddr]) || null;      // [lat, lng, hverfi?]
        const hverfi = (subjC && subjC[2]) || '';
        // eignaspjald EIGN / GÖGN (tveir flipar)
        let cardHtml = '';
        if (self) {
          const eign = [['Fasteignanúmer', self.fnr ? 'F' + self.fnr : '–'], ['Tegund', self.teg || teg], ['Stærð', self.fm ? String(self.fm).replace('.', ',') + ' m²' : fm + ' m²'], ['Byggingarár', self.ar || '–'], ['Herbergi', self.herb || '–']];
          if (hverfi) eign.push(['Hverfi', hverfi]);
          const gogn = [['Fasteignamat', self.mat ? mkr(self.mat) : '–'], ['Fyrirhugað mat', self.matN ? mkr(self.matN) : '–'], ['Brunabótamat', self.bruna ? mkr(self.bruna) : '–'], ['Lóð', self.lod ? self.lod + ' m²' : '–'], ['Byggingastig', self.full ? 'Fullgert' : '–']];
          const rows2 = (arr) => arr.map(([k, v]) => `<div class="ec-r"><span class="ec-k">${k}</span><span class="ec-v">${esc(String(v))}</span></div>`).join('');
          cardHtml = `<div class="eign-card"><div class="ec-tabs"><button class="ec-tab on" data-tab="eign">EIGN</button><button class="ec-tab" data-tab="gogn">GÖGN</button></div><div class="ec-panel" data-panel="eign">${rows2(eign)}</div><div class="ec-panel" data-panel="gogn" hidden>${rows2(gogn)}</div></div>`;
        }
        // ── Sjónræn verðstika: neðri-/efrimörk + áætlað verð (neðri röð), fasteignamat + brunabótamat (efri röð) ──
        let barHtml = '';
        {
          const pts = [{ v: lo, l: 'Neðrimörk', c: 'lo', r: 'b' }, { v: verd, l: 'Áætlað verð', c: 'est', r: 'b' }, { v: hi, l: 'Efrimörk', c: 'hi', r: 'b' }];
          if (self && self.mat) pts.push({ v: self.mat, l: 'Fasteignamat', c: 'mat', r: 't' });
          if (self && self.bruna) pts.push({ v: self.bruna, l: 'Brunabótamat', c: 'bru', r: 't' });
          const vals = pts.map((p) => p.v);
          const mn = Math.min(...vals), mx = Math.max(...vals);
          const pad = (mx - mn) * 0.09 || mx * 0.05;
          const a0 = mn - pad, a1 = mx + pad;
          const P = (v) => Math.max(0, Math.min(100, ((v - a0) / (a1 - a0)) * 100));
          const tick = (p) => `<div class="vb-tick vb-${p.c}" style="left:${P(p.v).toFixed(1)}%"></div>`;
          const lbl = (p) => `<div class="vb-lbl vb-${p.c}" style="left:${P(p.v).toFixed(1)}%"><b>${mkr(p.v)}</b><span>${p.l}</span></div>`;
          const top = pts.filter((p) => p.r === 't'), bot = pts.filter((p) => p.r === 'b');
          barHtml = `<div class="fv-head" style="margin-top:14px">Verðbil og opinber möt</div><div class="vbar">`
            + (top.length ? `<div class="vb-row vb-top">${top.map(lbl).join('')}</div>` : '')
            + `<div class="vb-track"><div class="vb-band" style="left:${P(lo).toFixed(1)}%;width:${(P(hi) - P(lo)).toFixed(1)}%"></div>${pts.map(tick).join('')}<div class="vb-dot" style="left:${P(verd).toFixed(1)}%"></div></div>`
            + `<div class="vb-row vb-bot">${bot.map(lbl).join('')}</div></div>`;
        }

        // markaðsmerki: hafa eignir selst yfir/undir fasteignamati? gata → póstnúmer → sveitarfélag
        let matHtml = '';
        try {
          const ratioOf = (rows) => rows.map((r) => r.v / r.mat).filter((x) => x > 0.2 && x < 5);
          const levels = [
            ['götunni ' + street, ratioOf(d.rows.filter((r) => r.mat > 0 && fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn))), 3],
            ['póstnúmeri ' + pn, pn ? ratioOf(d.rows.filter((r) => r.mat > 0 && r.pn === pn)) : [], 5],
            [svN, svN ? ratioOf(d.rows.filter((r) => r.mat > 0 && r.sv === svN)) : [], 8],
          ];
          const lvl = levels.find((l) => l[0] && l[1].length >= l[2]);
          if (lvl) { const pc = Math.round((med(lvl[1]) - 1) * 100); matHtml = `<div class="fvm-signal">🏷️ Eignir í ${esc(lvl[0])} hafa selst að jafnaði <b>${pc >= 0 ? '+' : ''}${pc}%</b> ${pc >= 0 ? 'yfir' : 'undir'} gildandi fasteignamati síðustu 6 mánuði (${lvl[1].length} þinglýst kaup).</div>`; }
        } catch (e) {}

        // sölugraf + sambærilegar (ef sölusaga til) — annars gamli listinn + sveitarfélagssamhengi
        let bodyHtml = '';
        const hasGraf = sales && sales.length >= 12;
        if (hasGraf) {
          const rows = compRows(sales, subj, true).slice(0, 40);
          bodyHtml = `<div class="fv-head" style="margin-top:14px">Verð á fermetra í póstnúmeri ${esc(pn)} — matslína, öryggisbil og raunsölur</div><div id="fvm-graf" class="fvm-graf"></div>`
            + `<div class="fv-head" style="margin-top:14px">Sambærilegar seldar eignir í póstnúmeri (${esc(pn)})</div>`
            + `<div class="comp-ctl"><span><label class="comp-cb"><input type="checkbox" id="comp-same" checked> Aðeins sama tegund (${esc(teg)})</label>${subjC ? ' <label class="comp-cb"><input type="checkbox" id="comp-near"> Innan 1 km</label>' : ''}</span><span class="comp-n" id="comp-n"></span></div>`
            + `<div class="comp-wrap" id="comp-wrap">${compTblHtml(rows)}</div>`;
        } else {
          let svCtx = '';
          try {
            const f2 = await fstFetch();
            const bm2 = svN && f2 && f2.byMuni && f2.byMuni[svN];
            if (bm2) { const line = (nafn, o) => o && o.m2 ? `<tr><td>${esc(nafn)}</td><td>${o.m2} þ.kr/m²</td><td>${o.p25}–${o.p75}</td><td>${o.n}</td><td>${mkr(o.m2 * fm)}</td></tr>` : ''; svCtx = `<div class="fv-head" style="margin-top:10px">Samhengið í ${esc(svN)} (12 mánuðir)</div><table class="fvm-tbl"><tr><th></th><th>Miðgildi</th><th>Fjórðungabil</th><th>Kaup</th><th>Þín stærð (${fm} m²)</th></tr>${line('Allar tegundir', bm2)}${Object.entries(bm2.types || {}).map(([t2, o]) => line(t2, o)).join('')}</table>`; }
          } catch (e) {}
          bodyHtml = svCtx + `<div class="fvm-comps">${comps.length ? '<div class="fv-head" style="margin-top:8px">Nýlegustu kaupin sem matið byggir á</div>' + d.rows.filter((r) => fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn)).slice(0, 10).map(fvRow).join('') : ''}</div>`;
        }

        fvmOut.innerHTML = `<div class="fvm-card" id="fvm-report"><div class="fvm-rephead" hidden><b>🐟 KARP — Verðmatsskýrsla úr kaupskrá</b><span>${esc(raw)} · ${esc(teg)}, ${fm} m² · skýrsla gerð ${new Date().toLocaleDateString('is-IS')} · karp.is/fasteignavakt · heimild: kaupskrá HMS + staðfangaskrá</span></div>`
          + `<div class="rep-top"><div class="rep-val"><div class="rep-lbl">Áætlað markaðsverð</div><div class="fvm-big">${krFull(verd)}</div><div class="rep-ppm">${thouIS(est.m * 1000)} kr./m²</div><div class="fvm-range">Verðbil ${krFull(lo)} – ${krFull(hi)}</div><div class="fvm-meta">byggt á ${est.n} þinglýstum kaupum í ${esc(est.heiti)}${hverfi ? ' · hverfi: ' + esc(hverfi) : ''}</div></div>${cardHtml}</div>`
          + (subjC ? `<div id="fvm-map" class="fvm-map"></div>` : '')
          + barHtml + matHtml + bodyHtml
          + `<div class="fvm-note">Áætlað markaðsvirði og verðbil byggir á opinberri kaupskrá HMS (þinglýst kaup) með tölfræðilegri nálgun — ekki fasteignamat og ekki verðmat löggilts fasteignasala. Ástand, hæð, útsýni, bílastæði og sérstaða eignar geta hliðrað verði verulega. Við hvetjum kaupendur og seljendur til að leita til fagaðila fyrir nákvæmara mat.</div></div>`
          + `<div class="buy-row"><button id="fvm-buy" class="cta">🛒 Kaupa skýrslu — 0 kr.</button><span class="buy-note">Kynningarverð · skýrslan opnast sem PDF til að vista eða prenta</span></div>`;

        // eignaspjald flipar
        fvmOut.querySelectorAll('.ec-tab').forEach((b) => b.addEventListener('click', () => {
          fvmOut.querySelectorAll('.ec-tab').forEach((x) => x.classList.toggle('on', x === b));
          fvmOut.querySelectorAll('.ec-panel').forEach((p) => { p.hidden = p.dataset.panel !== b.dataset.tab; });
        }));
        // kort (Leaflet + OSM) — eins og Creditinfo, með gull-hring á eigninni
        if (subjC) {
          withLeaflet(() => {
            const mEl = document.getElementById('fvm-map');
            if (!mEl || !window.L || mEl.dataset.done) return;
            mEl.dataset.done = '1';
            const m = window.L.map(mEl, { scrollWheelZoom: false }).setView([subjC[0], subjC[1]], 15);
            window.L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap', maxZoom: 19 }).addTo(m);
            window.L.circleMarker([subjC[0], subjC[1]], { radius: 9, color: '#f6b13b', weight: 3, fillColor: '#f6b13b', fillOpacity: 0.35 }).addTo(m).bindTooltip(esc(self ? self.a : raw), { direction: 'top' });
            setTimeout(() => m.invalidateSize(), 120);
          });
        }
        // sölugraf + raðanleg tafla (m/fjarlægð frá eigninni þegar hnit finnast)
        if (hasGraf) {
          renderSoluGraf('fvm-graf', sales, subj);
          const withKm = !!(subjC && hn);
          const kmOf = (a) => { const c = hn && hn[fvNorm(a)]; return (c && subjC) ? Math.round(distKm(subjC, c) * 10) / 10 : null; };
          let sortK = 'd', sortDir = -1, sameTeg = true, nearOnly = false;
          const nEl = document.getElementById('comp-n'), wrap = document.getElementById('comp-wrap');
          const redraw = () => {
            let rows = compRows(sales, subj, sameTeg);
            if (withKm) { rows.forEach((r) => { r.km = kmOf(r.a); }); if (nearOnly) rows = rows.filter((r) => r.km != null && r.km <= 1); }
            rows.sort((a, b) => { const nv = (v) => (v == null ? Infinity : v); const va = a[sortK], vb = b[sortK]; const c = (typeof va === 'string' || typeof vb === 'string') ? String(va).localeCompare(String(vb), 'is') : (nv(va) - nv(vb)); return c * sortDir; });
            if (nEl) nEl.textContent = rows.length + ' sölur';
            wrap.innerHTML = compTblHtml(rows.slice(0, 60), withKm);
            wrap.querySelectorAll('th[data-k]').forEach((th) => th.addEventListener('click', () => { const k = th.dataset.k; if (k === sortK) sortDir = -sortDir; else { sortK = k; sortDir = (k === 'a' || k === 'teg') ? 1 : -1; } redraw(); }));
          };
          redraw();
          const cb = document.getElementById('comp-same');
          if (cb) cb.addEventListener('change', () => { sameTeg = cb.checked; redraw(); });
          const cbn = document.getElementById('comp-near');
          if (cbn) cbn.addEventListener('change', () => { nearOnly = cbn.checked; redraw(); });
        }
        // 🛒 kaupa skýrslu (0 kr. kynningarverð) → PDF/prent
        const bb = document.getElementById('fvm-buy');
        if (bb) bb.addEventListener('click', () => {
          bb.disabled = true; const t0 = bb.textContent; bb.textContent = '✓ Keypt — 0 kr. · útbý skýrsluna…';
          setTimeout(() => {
            document.body.classList.add('fvm-printing'); window.print();
            setTimeout(() => { document.body.classList.remove('fvm-printing'); bb.textContent = t0; bb.disabled = false; }, 600);
          }, 350);
        });
      }
      const fvmBtn = document.getElementById('fvm-go');
      if (fvmBtn) fvmBtn.addEventListener('click', fvmGo);
      const fvmAddr = document.getElementById('fvm-addr');
      if (fvmAddr) fvmAddr.addEventListener('input', () => { clearTimeout(fvT); fvT = setTimeout(async () => { await fvSuggest(fvmAddr.value); await fvAutofill(fvmAddr.value); }, 200); });
      if (fvmAddr) fvmAddr.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvmGo(); } });

      // ── Markaðsvísir efst (LOTA 66): stefna markaðar + yfir/undir fasteignamati (land + sveitarfélög) ──
      fstFetch().then((f) => {
        const el = document.getElementById('fv-market');
        if (!el || !f || !f.direction) return;
        const dr = f.direction, ms = f.matStats || {};
        const arrow = { up: '📈', down: '📉', cooling: '🌡️', flat: '➡️' }[dr.verdict] || '➡️';
        const word = { up: 'á uppleið', down: 'á niðurleið', cooling: 'að kólna', flat: 'stöðugur' }[dr.verdict] || '';
        const cls = { up: 'up', down: 'dn', cooling: 'cool', flat: 'flat' }[dr.verdict] || 'flat';
        const sgn = (v) => (v > 0 ? '+' : '') + String(v).replace('.', ',') + '%';
        const thou = (n) => String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        const pst = (v) => String(v).replace('.', ',');
        const nat = ms.national || {};
        const overWord = (p) => (p > 0 ? 'yfir' : 'undir');
        // topp/botn sveitarfélög eftir yfir/undir-mati
        const munis = Object.entries(ms.byMuni || {}).filter(([, v]) => v.n >= 10).sort((a, b) => b[1].pct - a[1].pct);
        const top = munis.slice(0, 3).map(([n, v]) => esc(n) + ' ' + sgn(v.pct)).join(' · ');
        const bot = munis.slice(-3).reverse().map(([n, v]) => esc(n) + ' ' + sgn(v.pct)).join(' · ');
        el.hidden = false;
        el.innerHTML = `<div class="fvm-dir fvm-${cls}"><span class="fvm-arrow">${arrow}</span><div><div class="fvm-dir-t">Húsnæðismarkaðurinn er <b>${word}</b></div><div class="fvm-dir-s">Verð ${sgn(dr.chg3)} síðustu 3 mánuði · ${sgn(dr.chg12)} síðasta árið (vegið miðgildi verðs/m², ${esc(dr.updated)})</div></div></div>`
          + `<div class="fvm-mat">🏷️ Á landsvísu seljast eignir að jafnaði <b class="${nat.pct >= 0 ? 'up' : 'dn'}">${sgn(nat.pct)}</b> ${overWord(nat.pct)} gildandi fasteignamati síðustu 12 mánuði <span class="fv-sv">(${nat.n ? thou(nat.n) : 0} kaup${ms.trend != null ? '; bilið hefur ' + (ms.trend > 0 ? 'aukist' : 'minnkað') + ' um ' + pst(Math.abs(ms.trend)) + ' prósentustig' : ''})</span>.`
          + (top ? `<div class="fvm-mrow"><span class="fvm-ml up">Mest yfir mati:</span> ${top}</div>` : '')
          + (bot ? `<div class="fvm-mrow"><span class="fvm-ml dn">Mest undir mati:</span> ${bot}</div>` : '')
          + `</div>`;
      }).catch(() => {});
      // ── Uppboðslistinn: ALLTAF sýnilegur — framundan fyrst ──
      uppFetch().then((up) => {
        const el = document.getElementById('upp-list');
        if (!el) return;
        const rows = (up && up.rows) || [];
        if (!rows.length) { el.textContent = 'Engar uppboðsauglýsingar á skrá í augnablikinu.'; return; }
        const today = new Date().toISOString().slice(0, 10);
        const fram = rows.filter((x) => x.d >= today && !/lokið/i.test(x.teg)).sort((a, b) => a.d.localeCompare(b.d));
        const lokid = rows.filter((x) => !fram.includes(x)).sort((a, b) => b.d.localeCompare(a.d));
        const row = (x, isFram) => `<div class="fi"><span class="t"><span class="upp-pill ${isFram ? 'fram' : ''}">${isFram ? 'Framundan' : esc(x.teg)}</span>${esc(x.a)}</span><span class="s">${dIS(x.d)}${x.kl ? ' kl. ' + esc(x.kl) : ''} · ${esc(x.flokkur)} · ${esc(x.e)}${x.st ? ' · ' + esc(x.st) : ''}</span></div>`;
        el.innerHTML = (fram.length ? `<div class="fv-head">🔜 Framundan (${fram.length})</div>` + fram.map((x) => row(x, true)).join('') : '<div class="fv-head">Engin uppboð auglýst framundan í augnablikinu — nýjar auglýsingar birtast hér daglega.</div>')
          + (lokid.length ? `<div class="fv-head" style="margin-top:10px">Nýlega afgreidd (${lokid.length})</div>` + lokid.slice(0, 10).map((x) => row(x, false)).join('') : '');
      });
    }
    document.addEventListener('astro:page-load', () => initFastvakt());
  </script>
</Layout>
