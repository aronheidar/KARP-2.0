    .ec-tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,.1); }
    .ec-tab { flex: 1; background: none; border: none; color: #9fb0c8; font-size: 12px; font-weight: 700; letter-spacing: .06em; padding: 8px 10px; cursor: pointer; border-bottom: 2px solid transparent; }
