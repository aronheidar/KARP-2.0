  <!-- Eyja: gátt + aðgangur + kaup + PDF + fylgja (module → auth.js) -->
  <script>
    import { loadUser, hasReport, isAdmin, hasSub, openThingReport, thingRemaining, thingQuotaKnown, karpCheckout, loginHref, karpAskellSubscribe, karpPost } from '../../../lib/auth.js';

    function revealReport() {
      const rep = document.getElementById('tk-report');
      const gate = document.getElementById('tk-gate');
      if (rep) rep.hidden = false;
      if (gate) gate.remove();
      // Kortið var breiddarlaust á meðan skýrslan var falin — init-a/resize-a núna
      // (initTkPolMap er global úr classic-script eyjunni; resize-event grípur restina).
      setTimeout(() => {
        try { if (window.initTkPolMap) window.initTkPolMap(); } catch (e) {}
        try { window.dispatchEvent(new Event('resize')); } catch (e) {}
      }, 80);
    }

    async function initGate() {
      const gate = document.getElementById('tk-gate');
      if (!gate || gate.dataset.done) return;
      gate.dataset.done = '1';
      const KEY = gate.dataset.key, TITLE = gate.dataset.title, NAFN = gate.dataset.nafn;
      const u = await loadUser();
      if (isAdmin() || hasReport(KEY)) { revealReport(); return; }
      const btns = document.getElementById('tkg-btns');
      const qnote = document.getElementById('tk-qnote');
      if (!u || !u.loggedIn) {
        // útskráð: kaup krefjast innskráningar — CTA breytist í innskráningu, sýnishorn alltaf aðgengilegt
        btns.innerHTML = '<a class="pg-main" href="' + loginHref() + '">Skrá inn til að kaupa eða opna →</a>';
        return;
      }
      if (hasSub('thingskyrslur')) {
        // áskrifandi: opna með kvóta (varanlegt grant server-hlið)
        const rem = thingQuotaKnown() ? thingRemaining() : null;
        const openBtn = document.createElement('button');
        openBtn.className = 'pg-main'; openBtn.type = 'button';
        openBtn.textContent = '📖 Opna með áskriftinni' + (rem != null && rem >= 0 ? ' — ' + rem + ' af 10 eftir í mánuðinum' : '');
        btns.prepend(openBtn);
        openBtn.onclick = async () => {
          openBtn.disabled = true; openBtn.textContent = 'Opna…';
          const r = await openThingReport(KEY, TITLE);
          if (r.owned || r.granted) { revealReport(); return; }
          openBtn.disabled = false;
          if (r.needPay) { openBtn.remove(); qnote.innerHTML = '<div class="tkg-open" style="color:#f6b13b">⚠ Mánaðarkvótinn (10) er fullnýttur — stök skýrsla á 990 kr eða bíddu mánaðamóta.</div>'; }
          else { openBtn.textContent = 'Náði ekki — reyndu aftur'; }
        };
      }
      const buy = document.getElementById('tk-buy');
      if (buy) buy.onclick = async () => {
        buy.disabled = true;
        const res = await karpCheckout({ kind: 'thingmadur', ref: NAFN, key: KEY }, gate.querySelector('.tkg'));
        if (res === 'redirected' || res === 'embedded') return;
        buy.disabled = false;
        qnote.innerHTML = '<div class="tkg-open" style="color:#f6b13b">Greiðslugáttin er ekki opin í augnablikinu — <a style="color:#f6b13b" href="/hjalp/?fra=thingskyrsla">hafðu samband</a> eða skoðaðu sýnishornið.</div>';
      };
      const sub = document.getElementById('tk-sub');
      if (sub) sub.onclick = () => { karpAskellSubscribe('thingskyrslur', gate.querySelector('.tkg')); };
    }

    function initPdf() {
      const b = document.getElementById('tk-pdf');
      if (!b || b.dataset.done) return;
      b.dataset.done = '1';
      b.onclick = () => {
        document.body.classList.add('tk-printing');
        window.print();
        setTimeout(() => document.body.classList.remove('tk-printing'), 600);
      };
    }

    function initFollow() {
      const el = document.getElementById('follow');
      if (!el || el.dataset.done) return;
      el.dataset.done = '1';
      const KEY = el.dataset.key;
      const lfl = () => { try { return JSON.parse(localStorage.getItem('karp-follows-local') || '[]'); } catch (e) { return []; } };
      function render() {
        const u = window.KARP_USER || { loggedIn: false };
        const follows = u.loggedIn ? (u.follows || []) : lfl();
        const following = follows.includes(KEY);
        el.innerHTML = `<button class="fbtn${following ? ' on' : ''}">${following ? '✓ Fylgist með' : '+ Fylgja'}</button>${!u.loggedIn ? '<span class="f-note">vistast á þessu tæki</span>' : ''}`;
        el.querySelector('button').onclick = async () => {
          const u2 = window.KARP_USER || { loggedIn: false };
          const cur = u2.loggedIn ? (u2.follows || []) : lfl();
          const next = cur.includes(KEY) ? cur.filter((k) => k !== KEY) : cur.concat([KEY]);
          const b = el.querySelector('button');
          b.disabled = true; b.textContent = '…';
          if (u2.loggedIn) {
            const res = await karpPost('/follows', { follows: next });
            window.KARP_USER.follows = (res && res.follows) ? res.follows : next;
          } else {
            try { localStorage.setItem('karp-follows-local', JSON.stringify(next)); } catch (e) {}
          }
          render();
        };
      }
      loadUser().then(render);
    }

    document.addEventListener('astro:page-load', () => {
      if (!document.querySelector('main[data-pg="thingskyrsla"]')) return;
      initGate(); initPdf(); initFollow();
    });
  </script>

  <!-- Eyja: pólitíska kortið m/highlight (flutt af /althingi/, LOTA 12 → skýrslan) -->
  <script define:vars={{ POLD, PCOL, SPQ, SPKEY, SELF: { id: m.id, n: m.nafn } }}>
    function initTkPolMap() {
      const el = document.getElementById('tk-polmap');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initTkPolMap, { once: true });
        return;
      }
      // VÖRN: containerinn getur verið breiddarlaus við init (skýrslan falin bak við gátt,
      // eða síðu-transition í gangi) → ECharts teiknaði örmjótt og lagaði sig aldrei.
      // Pollum þar til alvöru breidd fæst (revealReport kallar líka beint þegar gátt opnast).
      if (el.clientWidth < 120) {
        el.__tkTries = (el.__tkTries || 0) + 1;
        if (el.__tkTries < 60) setTimeout(initTkPolMap, 500);   // ≤30 sek; gátt-opnun endurræsir hvort eð er
        return;
      }
      const prev = window.echarts.getInstanceByDom(el);
      if (prev) { prev.resize(); return; }
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const ini = (n) => { const w = String(n).split(/\s+/).filter(Boolean); return ((w[0] || ' ')[0] + (w.length > 1 ? w[w.length - 1][0] : '')).toUpperCase(); };
      const fmt = (v) => String(v).replace('.', ',');
      const byP = {};
      POLD.forEach((m) => { (byP[m.f] = byP[m.f] || []).push(m); });
      const order = Object.keys(byP).sort((a, b) => byP[b].length - byP[a].length);
      const series = order.map((p) => ({
        name: p, type: 'scatter', symbolSize: 14, emphasis: { focus: 'series', scale: 1.45 },
        itemStyle: { color: PCOL[p], borderColor: 'rgba(4,8,16,.5)', borderWidth: 1, opacity: 0.8 },
        label: { show: true, position: 'top', distance: 3, fontSize: 8.5, color: '#9fb0c8', formatter: (d) => ini(d.data.n) },
        labelLayout: { hideOverlap: true },
        data: byP[p].filter((m) => m.id !== SELF.id).map((m) => ({ value: m.v, id: m.id, n: m.n, f: m.f, ho: m.ho, up: m.up, sl: m.sl })),
      })).filter((s) => s.data.length);
      // ÞESSI þingmaður: stór, gylltur hringur + nafn — alltaf efst
      const me = POLD.find((m) => m.id === SELF.id);
      if (me) {
        series.push({ name: SELF.n, type: 'effectScatter', symbolSize: 26, zlevel: 5,
          rippleEffect: { brushType: 'stroke', scale: 2.2 },
          itemStyle: { color: PCOL[me.f], borderColor: '#ffd479', borderWidth: 3 },
          label: { show: true, position: 'top', distance: 5, fontSize: 11, fontWeight: 800, color: '#ffd479', formatter: () => SELF.n },
          data: [{ value: me.v, id: me.id, n: me.n, f: me.f, ho: me.ho, up: me.up, sl: me.sl }] });
      }
      if (series[0]) series[0].markLine = { silent: true, symbol: 'none', lineStyle: { color: 'rgba(255,255,255,.1)', type: 'dashed' }, data: [{ xAxis: 0 }, { yAxis: 0 }] };
      // ÞÚ-punkturinn (stefnupróf, vistast aðeins í vafra)
      try {
        const ans = JSON.parse(localStorage.getItem('karp-stefnuprof') || '{}');
        if (Object.keys(ans).length >= 4 && SPQ && SPQ.length) {
          const score = {}, max = {};
          SPQ.forEach((q) => { const a = ans[q.id]; if (!a) return; Object.keys(q.stance).forEach((k) => { max[k] = (max[k] || 0) + 1; if (q.stance[k] === a) score[k] = (score[k] || 0) + 1; }); });
          const cent = {};
          POLD.forEach((m) => { (cent[m.f] = cent[m.f] || []).push(m.v); });
          let sx = 0, sy = 0, sw = 0;
          Object.keys(max).forEach((k) => {
            const name = SPKEY[k], pts = cent[name];
            if (!pts || !max[k]) return;
            const cx = pts.reduce((a2, p) => a2 + p[0], 0) / pts.length;
            const cy = pts.reduce((a2, p) => a2 + p[1], 0) / pts.length;
            const w = Math.pow((score[k] || 0) / max[k], 2);
            sx += cx * w; sy += cy * w; sw += w;
          });
          if (sw > 0) {
            series.push({ name: 'ÞÚ', type: 'effectScatter', symbol: 'pin', symbolSize: 32, zlevel: 6,
              rippleEffect: { brushType: 'stroke', scale: 2.4 },
              itemStyle: { color: '#ffd479', borderColor: '#06101c', borderWidth: 1.5 },
              label: { show: true, position: 'inside', formatter: 'ÞÚ', fontSize: 9, fontWeight: 800, color: '#06101c' },
              tooltip: { formatter: 'Áætluð staða ÞÍN út frá stefnuprófinu — vegið meðaltal flokkamiðja eftir samsvörun svara þinna. Nálgun, ekki nafnakallsmæling.' },
              data: [{ value: [sx / sw, sy / sw] }] });
          }
        }
      } catch (e) {}
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        legend: { type: 'scroll', top: 0, textStyle: { color: '#aab6cc', fontSize: 11.5 }, inactiveColor: '#3a455e', itemGap: 12, pageTextStyle: { color: '#aab6cc' }, pageIconColor: '#aab6cc', pageIconInactiveColor: '#3a455e' },
        tooltip: { trigger: 'item', backgroundColor: 'rgba(9,14,26,.95)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12.5 },
          formatter: (p) => { const d = p.data; if (!d || !d.n) return ''; return `<b>${esc(d.n)}</b><br>${esc(d.f)}${d.ho != null ? '<br>Flokkshollusta ' + fmt(d.ho) + '%' : ''}${d.up ? ' · ' + d.up + '× á móti flokki' : ''}<br><span style="color:#19d3c5">Smelltu fyrir skýrslu →</span>`; } },
        grid: { left: 10, right: 10, top: 38, bottom: 24 },
        xAxis: { type: 'value', min: -108, max: 108, show: false },
        yAxis: { type: 'value', min: -108, max: 108, show: false },
        graphic: [
          { type: 'text', left: '4%', top: 'middle', style: { text: '◄ Ríkisstjórn', fill: '#56657f', font: '600 12.5px Inter, sans-serif' } },
          { type: 'text', right: '4%', top: 'middle', style: { text: 'Stjórnarandstaða ►', fill: '#56657f', font: '600 12.5px Inter, sans-serif' } },
        ],
        series,
      });
      chart.on('click', (p) => { if (p.data && p.data.sl) location.href = '/althingi/' + p.data.sl + '/skyrsla/'; });
      window.addEventListener('resize', () => chart.resize());
      // Belti og axlabönd gegn rangri breidd við init (transition/leturhleðsla breytir
      // layouti á eftir): fylgjast með container-breidd + tímastillt leiðréttingar-resize.
      if (typeof ResizeObserver !== 'undefined') { new ResizeObserver(() => chart.resize()).observe(el); }
      setTimeout(() => chart.resize(), 600);
      setTimeout(() => chart.resize(), 2000);
    }
    window.initTkPolMap = initTkPolMap;   // define:vars er IIFE-skópað → revealReport() nær í fallið hér
    document.addEventListener('astro:page-load', () => {
      const mn = document.querySelector('main[data-pg="thingskyrsla"]');
      if (mn) initTkPolMap();
    });
  </script>

  <!-- Eyja: lifandi umfjöllun (sama leit og þingmanns-prófíllinn notaði) -->
  <script define:vars={{ MPNAME: m.nafn, MPSLUG: slug }}>
    function initTkUmf() {
      const el = document.getElementById('tk-umf');
      if (!el || el.dataset.done) return;
      el.dataset.done = '1';
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
      fetch('/api/firma?q=' + encodeURIComponent(MPNAME) + '&days=180')
        .then((r) => (r.ok ? r.json() : null))
        .then((f) => {
          if (!f || !f.ready || !f.total) { el.innerHTML = '<p class="umf-none">Lítil umfjöllun fannst síðustu 6 mánuði (leitað eftir fullu nafni).</p>'; return; }
          const se = f.sentiment || {};
          const tone = se.scored ? (se.idx > 15 ? ['jákvæð', '#46e08a'] : se.idx < -15 ? ['neikvæð', '#ff6d7a'] : ['hlutlaus', '#9fb0c8']) : null;
          el.innerHTML = '<div class="umf-head"><b>' + f.total + '</b> fréttir sl. 6 mán' + (tone ? ' · tónn <b style="color:' + tone[1] + '">' + (se.idx > 0 ? '+' : '') + se.idx + '</b> (' + tone[0] + ')' : '') + '</div>'
            + (f.items || []).slice(0, 8).map((x) => '<a class="umf-it" href="' + safe(x.link) + '" target="_blank" rel="noopener">' + esc(x.title) + '<span>' + esc(x.source || '') + '</span></a>').join('')
            + '<a class="umf-more" href="/frettir/">Greina nánar í Umfjöllun →</a>';
        })
        .catch(() => { el.innerHTML = '<p class="umf-none">Umfjöllunin birtist á karp.is.</p>'; });
    }
    document.addEventListener('astro:page-load', () => { const mn = document.querySelector('main[data-pg="thingskyrsla"]'); if (mn && location.pathname.includes(MPSLUG)) initTkUmf(); });
  </script>
</Layout>
