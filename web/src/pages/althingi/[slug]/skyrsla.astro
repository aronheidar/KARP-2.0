---
// ─────────────────────────────────────────────────────────────────────────────
// ÞINGMANNASKÝRSLAN — seld vara (stök 990 kr / áskrift 'thingskyrslur' 3.900 kr
// m/20 skýrslum á mánuði). Ein SSG-síða per þingmann (63) á /althingi/<slug>/skyrsla/.
// SÝNISHORN: skýrsla SAMPLE_ID (Jón Pétur Zimsen) er opin öllum — hinar gáttar.
// Gögn: thingskyrsla.json (build_thingskyrsla.js) + thingskyrsla_ai.json (djúp AI)
// + althingi.json/raedugreining.json/malrof_ai.json. Pólitíska kortið flutt HINGAÐ
// af /althingi/ (highlight á viðkomandi þingmann).
// ─────────────────────────────────────────────────────────────────────────────
import THINGMENN from '@gogn/althingi.json';
import RAEDUR from '@gogn/raedugreining.json';
import TSK from '@gogn/thingskyrsla.json';
import TSK_AI from '@gogn/thingskyrsla_ai.json';
import MALROF_AI from '@gogn/malrof_ai.json';
import FRUMVORP from '@gogn/frumvorp.json';
import CABINET from '@gogn/cabinet.json';
import { colorByName, partyName } from '@lib/parties.mjs';
import { slugify, groupThousands } from '@lib/format.mjs';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return THINGMENN.map((m) => ({ params: { slug: slugify(m.nafn) }, props: { m } }));
}

const SAMPLE_ID = 1521; // Jón Pétur Zimsen — sýnishornsskýrslan, opin öllum

const { m } = Astro.props;
const slug = slugify(m.nafn);
const color = colorByName(m.flokkur);
const IS_SAMPLE = m.id === SAMPLE_ID;
const KEY = 'thingmadur:' + slug;
const TITLE = 'Þingmannaskýrsla — ' + m.nafn;

const t = (TSK.mp || {})[m.id] || { rebel: [], man: [], voteAreas: [], speechAreas: [], fyrirspurnir: [], flutt: [], medflutt: 0, maeting: null, pct: {} };
const AREAS = TSK.areas || {};
const AVG = TSK.avg || {};
const FLAVG = (TSK.flAvg || {})[m.flokkur] || {};
const RD = (RAEDUR.mp || {})[m.id] || null;
const AI = (TSK_AI.mp || {})[m.id] || null;
const AIM = (MALROF_AI.mp || {})[m.id] || null; // grunn-AI (fallback ef djúpgreining vantar)
const minister = CABINET.find((c) => c.id === m.id) || null;
const yearFrom = m.fyrstInn ? String(m.fyrstInn).slice(0, 4) : null;
const committees = Array.isArray(m.nefndalisti) ? m.nefndalisti : [];
const updated = TSK.updated || '2026-07-12';

const fmtP = (x) => (x == null ? '–' : String(x).replace('.', ','));
const pctBadge = (p) => (p == null ? null : Math.min(99, p));

// KPI-röðin: gildi + samanburður
const kpis = [
  { e: '🤝', l: 'Flokkshollusta', v: m.hollusta != null ? fmtP(m.hollusta) + '%' : '–', s: FLAVG.hollusta != null ? 'flokksmeðaltal ' + fmtP(FLAVG.hollusta) + '%' : '' },
  { e: '⚡', l: 'Gegn eigin flokki', v: String(t.rebel.length) + '×', s: 'þingmeðaltal ' + fmtP(AVG.uppreisn) + '×' },
  { e: '🪑', l: 'Mæting í atkvgr.', v: t.maeting != null ? fmtP(t.maeting) + '%' : '–', s: AVG.maeting != null ? 'þingmeðaltal ' + fmtP(AVG.maeting) + '%' : '' },
  { e: '🗣️', l: 'Ræðutími', v: m.raedumin != null ? fmtP(Math.round(m.raedumin / 6) / 10) + ' klst' : '–', s: t.pct.raedumin != null ? 'meira en ' + pctBadge(t.pct.raedumin) + '% þingmanna' : '' },
  { e: '↩️', l: 'Andsvör', v: RD ? String(RD.andsvor) : '–', s: t.pct.andsvor != null ? 'meira en ' + pctBadge(t.pct.andsvor) + '% þingmanna' : '' },
  { e: '❓', l: 'Fyrirspurnir', v: String(t.fyrirspurnir.length), s: 'til ráðherra á þingi 157' },
  { e: '📜', l: 'Flutt mál', v: String(t.flutt.length), s: 'fyrsti flutningsm. · meðflm. á ' + t.medflutt },
  { e: '✅', l: 'Greidd atkvæði', v: m.greidd != null ? groupThousands(m.greidd) : '–', s: 'af ' + groupThousands(m.recVotes || 0) + ' skráðum' },
];

// Mánaðarleg mæting → CSS-súlur
const manRows = (t.man || []).map(([mon, rec, fj]) => {
  const p = rec ? Math.round(((rec - fj) / rec) * 100) : 0;
  return { mon, lbl: mon.slice(5) + '.' + mon.slice(2, 4), p, rec };
});

// Atkvæði eftir málaflokkum → já/nei-skipt stika (top 10 eftir fjölda)
const vaRows = (t.voteAreas || []).slice(0, 10).map(([aid, greidd, ja, nei]) => ({
  h: (AREAS[aid] || {}).h || '—', y: (AREAS[aid] || {}).y || '', greidd,
  jaPct: greidd ? Math.round((ja / greidd) * 100) : 0, ja, nei,
}));
const vaMax = Math.max(1, ...vaRows.map((r) => r.greidd));

// Ræðutími eftir málaflokkum (top 8)
const saRows = (t.speechAreas || []).slice(0, 8).map(([aid, min, n]) => ({ h: (AREAS[aid] || {}).h || '—', min, n }));
const saMax = Math.max(1, ...saRows.map((r) => r.min));

// Málróf-tölur
const MALROF = RD ? {
  n: RD.n, min: RD.min, klst: Math.round(RD.min / 6) / 10,
  andsvarPct: RD.n ? Math.round((RD.andsvor / RD.n) * 100) : 0,
  fundarstjPct: RD.n ? Math.round((RD.fundarstj / RD.n) * 100) : 0,
  flutn: RD.flutn || 0,
  topMal: RD.topMal || [], longest: RD.longest, longestHeiti: RD.longestHeiti,
  maxMin: Math.max(1, ...(RD.topMal || []).map((x) => x.min)),
} : null;

// Pólitíska kortið: allir þingmenn + highlight á þennan; smellur flakkar á skýrslu viðkomandi
const POLD = THINGMENN.filter((x) => x.mx != null).map((x) => ({ v: [x.mx, x.my], id: x.id, n: x.nafn, f: x.flokkur, ho: x.hollusta ?? null, up: x.uppreisn ?? 0, sl: slugify(x.nafn) }));
const PCOL = {};
THINGMENN.forEach((x) => { PCOL[x.flokkur] = colorByName(x.flokkur); });
// ÞÚ-punkturinn (stefnupróf) — sama smíð og var á /althingi/
const SPQ = FRUMVORP
  .filter((b) => (b.hs === 'Frv.' || b.hs === 'Till.') && (b.ja || 0) > 0 && (b.nei || 0) > 5 && b.sam)
  .sort((a, b) => (b.d || '').localeCompare(a.d || '')).slice(0, 12)
  .map((b) => { const P2 = b.P || {}; const st = {}; Object.keys(P2).forEach((k) => { const [ja, nei] = P2[k]; if (k === 'U' || ja + nei === 0 || ja === nei) return; st[k] = ja > nei ? 1 : -1; }); return { id: 'q' + b.nr, stance: st }; })
  .filter((q) => Object.keys(q.stance).length >= 4);
const SPKEY = {};
[...new Set(SPQ.flatMap((q) => Object.keys(q.stance)))].forEach((k) => { SPKEY[k] = partyName(k); });

const roleTxt = m.adalmadur ? 'Alþingismaður' : 'Varaþingmaður';
const desc = `Ítarleg þingmannaskýrsla um ${m.nafn} (${m.flokkur}): atkvæðaferill, uppreisnar-atkvæði, afstaða eftir málaflokkum, ræðugreining með gervigreind, fyrirspurnir, nefndavald og fjölmiðlaumfjöllun.`;
const dLoc = (d) => (d ? `${+d.slice(8, 10)}.${+d.slice(5, 7)}.${d.slice(0, 4)}` : '');
---

<Layout
  title={`Þingmannaskýrsla — ${m.nafn} | Karp`}
  description={desc}
  canonical={`https://karp.is/althingi/${slug}/skyrsla/`}
  ogTitle={`Þingmannaskýrsla — ${m.nafn}`}
  ogImage={m.mynd || ''}
>
  <main data-pg="thingskyrsla" style={`--pc:${color}`}>
    <a class="back" href={`/althingi/${slug}/`}>← {m.nafn}</a>

    {IS_SAMPLE && (
      <div class="tk-sample">👁️ <b>Sýnishorn</b> — þessi skýrsla er opin öllum svo þú sjáir hvað Þingmannaskýrsla Karp inniheldur.
        Skýrslur um aðra þingmenn: <b>990 kr stök</b> eða <b>3.900 kr/mán áskrift</b> með 10 skýrslum innifaldar.</div>
    )}

    <!-- GÁTTIN (aðrir en sýnishornið; JS opnar fyrir eigendur/áskrifendur) -->
    {!IS_SAMPLE && (
      <div id="tk-gate" data-key={KEY} data-title={TITLE} data-nafn={m.nafn}>
        <div class="tkg">
          <div class="tkg-badge">📊 Þingmannaskýrsla</div>
          <h2 class="tkg-h">{m.nafn} — ítarleg greining</h2>
          <p class="tkg-b">Atkvæðaferill og uppreisnar-atkvæði · mæting mánuð fyrir mánuð · afstaða eftir málaflokkum ·
            ræðugreining og 🤖 tónn &amp; áherslur með gervigreind · fyrirspurnir og flutt mál · nefndavald · fjölmiðlaumfjöllun með viðhorfsmati — allt í einni skýrslu með PDF-útprentun.</p>
          <div class="pg-btns" id="tkg-btns">
            <button class="pg-main" id="tk-buy" type="button">Kaupa skýrsluna — 990 kr</button>
            <button class="pg-sec" id="tk-sub" type="button">Áskrift — 3.900 kr/mán · 10 skýrslur</button>
          </div>
          <div id="tk-qnote"></div>
          <div class="tkg-note">Innifalið í <a href="/karp-pro/">Karp+ þingskýrslu-áskriftinni</a> · engin binding ·
            <a href={`/althingi/${slugify('Jón Pétur Zimsen')}/skyrsla/`}>👁️ Sjá sýnishorn af skýrslu</a></div>
        </div>
      </div>
    )}

    <!-- SKÝRSLAN SJÁLF -->
    <div id="tk-report" hidden={!IS_SAMPLE}>
      <div class="tk-rephead" aria-hidden="true">
        <b>Þingmannaskýrsla — {m.nafn}</b> · Karp (karp.is) · gögn frá Alþingi (althingi.is) · uppfært {updated}
      </div>

      <div class="hero">
        {m.mynd && <img src={m.mynd} alt={m.nafn} loading="lazy" onerror="this.style.display='none'" />}
        <div>
          <h1>{m.nafn}</h1>
          <div class="hero-chips">
            <span class="party">{m.flokkur}</span>
            {minister && <span class="min-chip">⭐ {(minister.emb || ['Ráðherra']).join(' · ')}</span>}
          </div>
          <div class="meta">{roleTxt} · {m.kjordaemi}{m.aldur != null && ` · ${m.aldur} ára`}{yearFrom && ` · á þingi frá ${yearFrom}`}{m.fjoldiThinga ? ` (${m.fjoldiThinga} þing)` : ''}</div>
          <div class="actions no-print">
            <button class="act-btn" id="tk-pdf" type="button">🖨️ Sækja PDF</button>
            <div id="follow" class="follow-wrap" data-key={`mp:${m.id}`}></div>
          </div>
        </div>
      </div>

      <div class="kpi-grid">
        {kpis.map((k) => (
          <div class="kpi">
            <div class="k-top">{k.e} {k.l}</div>
            <div class="k-v">{k.v}</div>
            {k.s && <div class="k-s">{k.s}</div>}
          </div>
        ))}
      </div>

      <h2>🧭 Pólitískt kort þingsins <i class="tip" tabindex="0" data-tip="Vélrænn útreikningur úr ÖLLUM nafnakalls-atkvæðagreiðslum þingsins 157 — þingmenn sem kjósa líkt lenda nálægt hver öðrum (lárétt: stjórn ↔ stjórnarandstaða). Nálgun Karp, ekki opinber flokkun. ÞÚ-punkturinn reiknast úr stefnuprófs-svörum þínum og vistast aðeins í vafranum.">ⓘ</i></h2>
      <div id="tk-polmap" class="no-print"></div>
      <p class="src no-print">{m.nafn} er <b style={`color:${color}`}>auðkennd(ur)</b> á kortinu. Smelltu á aðra þingmenn til að skoða skýrslur þeirra.</p>

      <h2>🗳️ Atkvæðahegðun</h2>
      <div class="card">
        <div class="c-sub">Uppreisnar-atkvæði — kaus gegn meirihluta eigin flokks <i class="tip" tabindex="0" data-tip="Skráð já/nei-nafnaköll þar sem atkvæði þingmannsins fór gegn meirihluta annarra þingmanna sama flokks í sömu atkvæðagreiðslu. Heimild: XML Alþingis.">ⓘ</i></div>
        {t.rebel.length === 0 ? (
          <p class="c-empty">Kaus <b>aldrei</b> gegn meirihluta eigin flokks í skráðum nafnaköllum á þingi 157 — flokkshollusta {fmtP(m.hollusta)}%.</p>
        ) : (
          <div class="rebel-list">
            {t.rebel.map((r) => (
              <a class="rebel-row" href={`/thingmal/?nr=${r.m}`}>
                <span class="rb-d">{dLoc(r.t)}</span>
                <span class="rb-h">{r.h}</span>
                <span class={`rb-atk ${r.atk === 'já' ? 'ja' : 'nei'}`}>{r.atk === 'já' ? '✓ já' : '✗ nei'}</span>
                <span class="rb-fl">flokkur {r.fj[0]}–{r.fj[1]}</span>
              </a>
            ))}
          </div>
        )}
      </div>

      {manRows.length > 1 && (
        <div class="card">
          <div class="c-sub">Mæting í atkvæðagreiðslur — mánuð fyrir mánuð</div>
          <div class="man-chart">
            {manRows.map((r) => (
              <div class="man-col" title={`${r.lbl} — ${r.p}% þátttaka (${r.rec} nafnaköll)`}>
                <div class="man-bar"><i style={`height:${r.p}%`}></i></div>
                <span class="man-l">{r.lbl}</span>
                <span class="man-v">{r.p}%</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {vaRows.length > 0 && (
        <>
          <h2>🧩 Afstaða eftir málaflokkum <i class="tip" tabindex="0" data-tip="Já/nei-atkvæði þingmannsins flokkuð eftir OPINBERUM efnisflokkum Alþingis (mál getur átt fleiri en einn flokk). Grænt = já, rautt = nei.">ⓘ</i></h2>
          <div class="card">
            {vaRows.map((r) => (
              <div class="va-row">
                <span class="va-n" title={r.y}>{r.h}</span>
                <span class="va-bar" style={`width:${Math.round((r.greidd / vaMax) * 100)}%`}>
                  <i class="va-ja" style={`width:${r.jaPct}%`}></i><i class="va-nei" style={`width:${100 - r.jaPct}%`}></i>
                </span>
                <span class="va-v">{r.ja} já · {r.nei} nei</span>
              </div>
            ))}
            <div class="va-leg"><span><i class="va-ja"></i> já</span><span><i class="va-nei"></i> nei</span></div>
          </div>
        </>
      )}

      {MALROF && MALROF.n > 3 && (
        <>
          <h2>🗣️ Málróf — hvernig talar þingmaðurinn? <i class="tip" tabindex="0" data-tip="Tölfræðileg talning úr ræðulista Alþingis (þing 157) — fjöldi, tími og tegundir ræðna. Hrein talning úr opinberu XML-i.">ⓘ</i></h2>
          <div class="mr-tiles">
            <span class="mrt"><b>{MALROF.n}</b><i>ræður alls</i></span>
            <span class="mrt"><b>{MALROF.klst >= 1 ? fmtP(MALROF.klst) + ' klst' : MALROF.min + ' mín'}</b><i>ræðutími</i></span>
            <span class="mrt"><b>{MALROF.andsvarPct}%</b><i>andsvör</i></span>
            <span class="mrt"><b>{MALROF.fundarstjPct}%</b><i>um fundarstjórn</i></span>
            <span class="mrt"><b>{MALROF.flutn}</b><i>flutningsræður</i></span>
            {MALROF.longest > 0 && <span class="mrt" title={MALROF.longestHeiti}><b>{MALROF.longest} mín</b><i>lengsta ræðan</i></span>}
          </div>
          {MALROF.topMal.length > 0 && (
            <div class="card">
              <div class="c-sub">Talar mest um (eftir ræðutíma)</div>
              {MALROF.topMal.map((x) => (
                <div class="mr-row"><span class="mr-n">{x.h}</span><span class="mr-bar"><i style={`width:${Math.round((x.min / MALROF.maxMin) * 100)}%`}></i></span><span class="mr-v">{x.min} mín · {x.n}×</span></div>
              ))}
            </div>
          )}
          {saRows.length > 0 && (
            <div class="card">
              <div class="c-sub">Ræðutími eftir málaflokkum <i class="tip" tabindex="0" data-tip="Allar ræður þingmannsins flokkaðar eftir opinberum efnisflokkum Alþingis — mál getur átt fleiri en einn flokk.">ⓘ</i></div>
              {saRows.map((r) => (
                <div class="mr-row"><span class="mr-n">{r.h}</span><span class="mr-bar"><i style={`width:${Math.round((r.min / saMax) * 100)}%`}></i></span><span class="mr-v">{r.min} mín · {r.n} ræður</span></div>
              ))}
            </div>
          )}
        </>
      )}

      {(t.flutt.length > 0 || t.fyrirspurnir.length > 0) && (
        <>
          <h2>📜 Þingmál sem {m.nafn.split(' ')[0]} flytur</h2>
          {t.flutt.length > 0 && (
            <div class="card">
              <div class="c-sub">Fyrsti flutningsmaður að {t.flutt.length} málum{t.medflutt ? ` · meðflutningsmaður á ${t.medflutt} til viðbótar` : ''}</div>
              {t.flutt.slice(0, 12).map((f) => (
                <a class="mal-row" href={`/thingmal/?nr=${f.m}`}>
                  <span class="ml-h">{f.h}</span>
                  <span class="ml-teg">{f.teg}</span>
                  {f.s && <span class={`ml-st ${/samþykkt/i.test(f.s) ? 'ok' : ''}`}>{f.s}</span>}
                </a>
              ))}
              {t.flutt.length > 12 && <div class="c-more">+ {t.flutt.length - 12} mál til viðbótar</div>}
            </div>
          )}
          {t.fyrirspurnir.length > 0 && (
            <div class="card">
              <div class="c-sub">Fyrirspurnir til ráðherra ({t.fyrirspurnir.length})</div>
              {t.fyrirspurnir.slice(0, 12).map((f) => (
                <a class="mal-row" href={`/thingmal/?nr=${f.m}`}>
                  <span class="ml-h">{f.h}</span>
                  {f.til && <span class="ml-teg">→ {f.til}</span>}
                  <span class={`ml-st ${f.sv ? 'ok' : ''}`}>{f.sv ? '✓ svarað' : 'bíður svars'}</span>
                </a>
              ))}
              {t.fyrirspurnir.length > 12 && <div class="c-more">+ {t.fyrirspurnir.length - 12} fyrirspurnir til viðbótar</div>}
            </div>
          )}
        </>
      )}

      <h2>🤖 Tónn og áherslur — AI-greining <i class="tip" tabindex="0" data-tip="Gervigreind (Claude) las brot úr raunverulegum þingræðum þingmannsins, valin þvert á málefni, og lýsti tón, rökstuðningi og áherslum — EINGÖNGU út frá textunum sjálfum. Vélrænt mat til fróðleiks, ekki dómur Karp og ekki staðreyndafullyrðing.">ⓘ</i></h2>
      {AI ? (
        <>
          <div class="aim">
            {AI.merki && AI.merki.length > 0 && <div class="aim-tags">{AI.merki.map((x) => <span class="aim-tag">{x}</span>)}</div>}
            <p class="aim-yfir">{AI.yfirlit}</p>
            <div class="aim-grid">
              <div class="aim-cell"><b>Tónn og stíll</b><p>{AI.ton}</p></div>
              <div class="aim-cell"><b>Rökstuðningur</b><p>{AI.rokstudningur}</p></div>
              {AI.samskipti && <div class="aim-cell"><b>Samskipti í andsvörum</b><p>{AI.samskipti}</p></div>}
            </div>
            <div class="aim-note">Vélrænt mat byggt á {AI.n} ræðum af þingi 157 — ekki dómur Karp.</div>
          </div>
          {(AI.malaflokkar || []).length > 0 && (
            <div class="aim-areas">
              {AI.malaflokkar.map((a) => (
                <div class="aima">
                  <div class="aima-h">{a.svid} <span class="aima-n">{a.n} ræður</span></div>
                  <p class="aima-g">{a.greining}</p>
                  <p class="aima-a"><b>Afstaða:</b> {a.afstada}</p>
                </div>
              ))}
            </div>
          )}
        </>
      ) : AIM ? (
        <div class="aim">
          {AIM.merki && AIM.merki.length > 0 && <div class="aim-tags">{AIM.merki.map((x) => <span class="aim-tag">{x}</span>)}</div>}
          <p class="aim-yfir">{AIM.ton}</p>
          <ul class="aim-list">{(AIM.aherslur || []).map((a) => <li>{a}</li>)}</ul>
          <div class="aim-note">Grunn-mat á {AIM.n} nýlegum efnisræðum — ítarleg greining eftir málaflokkum væntanleg í næstu uppfærslu skýrslunnar.</div>
        </div>
      ) : (
        <div class="aim"><p class="aim-yfir">AI-greining á ræðum þingmannsins er væntanleg — hún birtist hér sjálfkrafa í næstu uppfærslu skýrslunnar.</p></div>
      )}

      {committees.length > 0 && (
        <>
          <h2>📋 Nefndavald</h2>
          <div class="nefndir">{committees.map((n) => {
            const arr = Array.isArray(n) ? n : [n, ''];
