---
// ─────────────────────────────────────────────────────────────
// PROGRAMMATIC SEO (#2 Á6) — síða per þingmann. getStaticPaths býr til
// eina SSG-síðu fyrir HVERN þingmann (63) úr althingi.json. Litur úr @lib/parties.
// Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import THINGMENN from '@gogn/althingi.json';
import RAEDUR from '@gogn/raedugreining.json';
import { colorByName } from '@lib/parties.mjs';
import { slugify, groupThousands } from '@lib/format.mjs';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return THINGMENN.map((m) => ({ params: { slug: slugify(m.nafn) }, props: { m } }));
}

const { m } = Astro.props;
const color = colorByName(m.flokkur);
const yearFrom = m.fyrstInn ? String(m.fyrstInn).slice(0, 4) : null;
const committees = Array.isArray(m.nefndalisti) ? m.nefndalisti : (m.nefndalisti ? [m.nefndalisti] : []);
const updated = '2026-07-01';

const tiles = [
  { e: '🎂', l: 'Aldur', v: m.aldur != null ? m.aldur + ' ára' : '–' },
  { e: '🏛️', l: 'Á þingi frá', v: yearFrom || '–', s: m.fjoldiThinga != null ? m.fjoldiThinga + ' þing' : '' },
  { e: '🤝', l: 'Hollusta', v: m.hollusta != null ? m.hollusta + '%' : '–', s: 'við flokk' },
  { e: '🗣️', l: 'Ræður', v: m.raedur != null ? groupThousands(m.raedur) : '–', s: m.raedumin != null ? groupThousands(m.raedumin) + ' mín' : '' },
  { e: '📋', l: 'Nefndir', v: m.nefndir != null ? String(m.nefndir) : '–' },
  { e: '✅', l: 'Greidd atkv.', v: m.greidd != null ? groupThousands(m.greidd) : '–' },
  { e: '🚫', l: 'Fjarvistir', v: m.fjarvist != null ? String(m.fjarvist) : '–' },
  { e: '🪑', l: 'Sæti', v: m.saeti != null ? String(m.saeti) : '–' },
  { e: '💰', l: 'Laun', v: m.laun != null ? groupThousands(m.laun) + ' kr' : '–', s: 'á mánuði skv. launatöflu' },
  { e: '🧾', l: 'Kostnaður', v: m.kostn != null ? groupThousands(m.kostn) + ' kr' : '–', s: 'starfskostn./mán' },
];

// Málróf (LOTA 16): tölfræði úr ræðulista 157 — engin gervigreind, hrein talning
const RD = (RAEDUR.mp || {})[m.id] || null;
const MALROF = RD ? {
  n: RD.n, min: RD.min, klst: Math.round(RD.min / 6) / 10,
  andsvarPct: RD.n ? Math.round((RD.andsvor / RD.n) * 100) : 0,
  fundarstjPct: RD.n ? Math.round((RD.fundarstj / RD.n) * 100) : 0,
  topMal: RD.topMal || [], longest: RD.longest, longestHeiti: RD.longestHeiti,
  maxMin: Math.max(1, ...(RD.topMal || []).map((x) => x.min)),
} : null;

const roleTxt = m.adalmadur ? 'Alþingismaður' : 'Varaþingmaður';
const desc = `${m.nafn} — ${roleTxt} ${m.flokks || m.flokkur} í ${m.kjordaemi}. ${m.aldur ? m.aldur + ' ára, ' : ''}${m.fjoldiThinga ? m.fjoldiThinga + ' þing setið, ' : ''}hollusta við flokk ${m.hollusta != null ? m.hollusta + '%' : '—'}.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Person', name: m.nafn,
  jobTitle: roleTxt, ...(m.mynd ? { image: m.mynd } : {}),
  memberOf: { '@type': 'Organization', name: m.flokkur },
  description: desc,
};
---

<Layout
  title={`${m.nafn} — ${m.flokkur} | Karp`}
  description={desc}
  canonical={`https://app.karp.is/althingi/${slugify(m.nafn)}/`}
  jsonLd={jsonLd}
  ogTitle={`${m.nafn} — þingmaður`}
  ogType="profile"
  ogImage={m.mynd || ''}
>
  <main data-pg="althingi-slug" style={`--pc:${color}`}>
    <a class="back" href="/althingi/">← Sætaspá Alþingis</a>
    <div class="hero">
      {m.mynd && <img src={m.mynd} alt={m.nafn} loading="lazy" onerror="this.style.display='none'" />}
      <div>
        <h1>{m.nafn}</h1>
        <div><span class="party">{m.flokkur}</span></div>
        <div class="meta">{roleTxt} · {m.kjordaemi}</div>
        <div id="follow" class="follow-wrap" data-key={`mp:${m.id}`}></div>
      </div>
    </div>

    <div class="grid">
      {tiles.map((t) => (
        <div class="tile">
          <div class="t-top">{t.e} {t.l}</div>
          <div class="t-v">{t.v}</div>
          {t.s && <div class="t-s">{t.s}</div>}
        </div>
      ))}
    </div>

    {committees.length > 0 && (
      <>
        <h2>Nefndir</h2>
        <div class="nefndir">{committees.map((n) => <span>{n}</span>)}</div>
      </>
    )}

    {MALROF && MALROF.n > 3 && (
      <>
        <h2>🗣️ Málróf — hvernig talar þingmaðurinn? <i class="tip" tabindex="0" data-tip="Tölfræðileg talning úr ræðulista Alþingis (þing 157) — fjöldi, tími og tegundir ræðna. Engin gervigreind, hrein talning úr opinberu XML-i.">ⓘ</i></h2>
        <div class="mr-tiles">
          <span class="mrt"><b>{MALROF.n}</b><i>ræður alls</i></span>
          <span class="mrt"><b>{MALROF.klst >= 1 ? String(MALROF.klst).replace('.', ',') + ' klst' : MALROF.min + ' mín'}</b><i>ræðutími</i></span>
          <span class="mrt"><b>{MALROF.andsvarPct}%</b><i>andsvör</i></span>
          <span class="mrt"><b>{MALROF.fundarstjPct}%</b><i>um fundarstjórn</i></span>
          {MALROF.longest > 0 && <span class="mrt"><b>{MALROF.longest} mín</b><i>lengsta ræðan</i></span>}
        </div>
        {MALROF.topMal.length > 0 && (
          <div class="mr-mal">
            <div class="mr-h">Talar mest um (eftir ræðutíma):</div>
            {MALROF.topMal.map((x) => (
              <div class="mr-row"><span class="mr-n">{x.h}</span><span class="mr-bar"><i style={`width:${Math.round((x.min / MALROF.maxMin) * 100)}%`}></i></span><span class="mr-v">{x.min} mín · {x.n}×</span></div>
            ))}
          </div>
        )}
      </>
    )}

    <h2>📰 Fjölmiðlaumfjöllun <i class="tip" tabindex="0" data-tip="Lifandi leit í fréttasafni Karp eftir fullu nafni þingmannsins — viðhorf metið vélrænt. Getur vanmetið þá sem oft eru nefndir með fornafni.">ⓘ</i></h2>
    <div id="mp-umf">Sæki umfjöllun…</div>

    <p class="foot">
      Forþjónað (SSG) {updated}. Gögn frá Alþingi (althingi.is) — flokkslitur úr sameiginlega
      <code> src/lib/parties</code>. #2 Á6 · ein af 63 þingmanna-síðum.
    </p>
  </main>

  <style>
    .mr-tiles { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
    .mrt { background: rgba(255,255,255,.045); border: 1px solid rgba(255,255,255,.08); border-radius: 9px; padding: 8px 12px; }
    .mrt b { display: block; font-size: 16px; font-weight: 800; color: #eaf1fb; font-variant-numeric: tabular-nums; }
    .mrt i { display: block; font-style: normal; font-size: 10.5px; color: #8fa0ba; }
    .mr-h { font-size: 12px; color: #9fb0c8; margin-bottom: 4px; }
    .mr-row { display: grid; grid-template-columns: minmax(0, 1.3fr) 1fr 92px; gap: 8px; align-items: center; padding: 3px 0; }
    .mr-n { font-size: 12.5px; color: #cdd6e6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mr-bar { height: 9px; background: rgba(255,255,255,.05); border-radius: 5px; overflow: hidden; }
    .mr-bar i { display: block; height: 100%; background: var(--pc, #f6b13b); border-radius: 5px; }
    .mr-v { font-size: 10.5px; color: #7e8ca6; text-align: right; font-variant-numeric: tabular-nums; }
    .umf-head { font-size: 13px; color: #9fb0c8; margin-bottom: 6px; }
    .umf-head b { color: #eaf1fb; }
    .umf-it { display: block; font-size: 13.5px; color: #dfe7f4; text-decoration: none; padding: 7px 2px; border-bottom: 1px solid rgba(255,255,255,.07); line-height: 1.35; }
    .umf-it:hover { color: #f6b13b; }
    .umf-it span { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .umf-more { display: inline-block; margin-top: 8px; font-size: 12.5px; color: #f6b13b; text-decoration: none; }
    .umf-none { font-size: 13px; color: #9fb0c8; }
    main { max-width: 780px; margin: 0 auto; padding: 40px 20px 64px; }
    .back { font-size: 13px; color: #7e8ca6; text-decoration: none; }
    .back:hover { color: #f6b13b; }
    .hero { display: flex; gap: 20px; align-items: center; margin: 16px 0 6px; }
    .hero img { width: 96px; height: 120px; object-fit: cover; border-radius: 12px; border: 2px solid var(--pc); flex: none; background: #0e1626; }
    h1 { font-size: 30px; line-height: 1.1; margin: 0 0 6px; }
    .party { display: inline-block; font-size: 13px; font-weight: 700; color: #06121a; background: var(--pc); border-radius: 6px; padding: 2px 9px; }
    .meta { color: #9fb0c8; font-size: 14px; margin-top: 6px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin: 24px 0 8px; }
    .tile { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px 16px; }
    .t-top { font-size: 12px; color: #9fb0c8; }
    .t-v { font-size: 24px; font-weight: 800; margin-top: 2px; }
    .t-s { font-size: 12px; color: #7e8ca6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 26px 0 8px; }
    .nefndir { display: flex; flex-wrap: wrap; gap: 8px; }
    .nefndir span { font-size: 13px; color: #cdd6e6; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 8px; padding: 5px 10px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Fylgja-hnappur er búinn til á keyrslutíma → global. Erfir --pc frá <main>. */
    .follow-wrap { margin-top: 10px; min-height: 34px; }
    .fbtn { background: var(--pc); color: #06121a; border: 1px solid var(--pc); border-radius: 8px; padding: 7px 16px; font-weight: 700; font-size: 14px; cursor: pointer; }
    .fbtn.on { background: transparent; color: var(--pc); }
    .fbtn:disabled { opacity: .6; cursor: default; }
    .follow-gate { font-size: 13px; color: #9fb0c8; text-decoration: none; }
    .follow-gate:hover { color: #f6b13b; }
  </style>

  <!-- Eyja: Fylgja þingmann (auðkennd umferð gegnum auth.js → /follows). #2 Á5 -->
  <script>
    import { loadUser, karpPost } from '../../lib/auth.js';
    function initFollow() {
      const el = document.getElementById('follow');
      if (!el) return;
      const KEY = el.dataset.key;
      function render() {
      const u = window.KARP_USER || { loggedIn: false };
      if (!u.loggedIn) {
        el.innerHTML = `<a class="follow-gate" href="${u.loginUrl || 'https://karp.is/login/'}">🔒 Skráðu þig inn til að fylgja</a>`;
        return;
      }
      const following = (u.follows || []).includes(KEY);
      el.innerHTML = `<button class="fbtn${following ? ' on' : ''}">${following ? '✓ Fylgist með' : '+ Fylgja'}</button>`;
      el.querySelector('button').onclick = async () => {
        const cur = window.KARP_USER.follows || [];
        const next = cur.includes(KEY) ? cur.filter((k) => k !== KEY) : cur.concat([KEY]);
        const b = el.querySelector('button');
        b.disabled = true; b.textContent = '…';
        const res = await karpPost('/follows', { follows: next });
        window.KARP_USER.follows = (res && res.follows) ? res.follows : next;
        render();
      };
      }
      loadUser().then(render);
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi-slug"]')) initFollow(); });
  </script>
  <!-- Eyja: lifandi umfjöllun um þingmanninn (/firma). LOTA 15b -->
  <script define:vars={{ MPNAME: m.nafn, MPSLUG: slugify(m.nafn) }}>
    function initMpUmf() {
      const el = document.getElementById('mp-umf');
      if (!el || el.dataset.done) return;
      el.dataset.done = '1';
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
      fetch('https://www.karp.is/wp-json/karp/v1/firma?q=' + encodeURIComponent(MPNAME) + '&days=180')
        .then((r) => (r.ok ? r.json() : null))
        .then((f) => {
          if (!f || !f.ready || !f.total) { el.innerHTML = '<p class="umf-none">Lítil umfjöllun fannst síðustu 6 mánuði (leitað eftir fullu nafni).</p>'; return; }
          const se = f.sentiment || {};
          const tone = se.scored ? (se.idx > 15 ? ['jákvæð', '#46e08a'] : se.idx < -15 ? ['neikvæð', '#ff6d7a'] : ['hlutlaus', '#9fb0c8']) : null;
          el.innerHTML = '<div class="umf-head"><b>' + f.total + '</b> fréttir sl. 6 mán' + (tone ? ' · tónn <b style="color:' + tone[1] + '">' + (se.idx > 0 ? '+' : '') + se.idx + '</b> (' + tone[0] + ')' : '') + '</div>'
            + (f.items || []).slice(0, 6).map((x) => '<a class="umf-it" href="' + safe(x.link) + '" target="_blank" rel="noopener">' + esc(x.title) + '<span>' + esc(x.source || '') + '</span></a>').join('')
            + '<a class="umf-more" href="/frettir/">Greina nánar í Umfjöllun →</a>';
        })
        .catch(() => { el.innerHTML = '<p class="umf-none">Umfjöllunin birtist á app.karp.is.</p>'; });
    }
    document.addEventListener('astro:page-load', () => { const mn = document.querySelector('main[data-pg="althingi-slug"]'); if (mn && location.pathname.includes(MPSLUG)) initMpUmf(); });
  </script>
</Layout>
