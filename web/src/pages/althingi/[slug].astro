---
// ─────────────────────────────────────────────────────────────
// PROGRAMMATIC SEO (#2 Á6) — síða per þingmann. getStaticPaths býr til
// eina SSG-síðu fyrir HVERN þingmann (63) úr althingi.json. Litur úr @lib/parties.
// Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import THINGMENN from '@gogn/althingi.json';
import { colorByName } from '@lib/parties.mjs';
import { slugify, groupThousands } from '@lib/format.mjs';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return THINGMENN.map((m) => ({ params: { slug: slugify(m.nafn) }, props: { m } }));
}

const { m } = Astro.props;
const color = colorByName(m.flokkur);
const yearFrom = m.fyrstInn ? String(m.fyrstInn).slice(0, 4) : null;
const committees = Array.isArray(m.nefndalisti) ? m.nefndalisti : (m.nefndalisti ? [m.nefndalisti] : []);
const updated = '2026-07-01';

const tiles = [
  { e: '🎂', l: 'Aldur', v: m.aldur != null ? m.aldur + ' ára' : '–' },
  { e: '🏛️', l: 'Á þingi frá', v: yearFrom || '–', s: m.fjoldiThinga != null ? m.fjoldiThinga + ' þing' : '' },
  { e: '🤝', l: 'Hollusta', v: m.hollusta != null ? m.hollusta + '%' : '–', s: 'við flokk' },
  { e: '🗣️', l: 'Ræður', v: m.raedur != null ? groupThousands(m.raedur) : '–', s: m.raedumin != null ? groupThousands(m.raedumin) + ' mín' : '' },
  { e: '📋', l: 'Nefndir', v: m.nefndir != null ? String(m.nefndir) : '–' },
  { e: '✅', l: 'Greidd atkv.', v: m.greidd != null ? groupThousands(m.greidd) : '–' },
  { e: '🚫', l: 'Fjarvistir', v: m.fjarvist != null ? String(m.fjarvist) : '–' },
  { e: '🪑', l: 'Sæti', v: m.saeti != null ? String(m.saeti) : '–' },
  { e: '💰', l: 'Laun', v: m.laun != null ? groupThousands(m.laun) + ' kr' : '–', s: 'á mánuði skv. launatöflu' },
  { e: '🧾', l: 'Kostnaður', v: m.kostn != null ? groupThousands(m.kostn) + ' kr' : '–', s: 'starfskostn./mán' },
];

// Málróf, AI-tónn og fjölmiðlaumfjöllun fluttust í SELDU Þingmannaskýrsluna
// (/althingi/<slug>/skyrsla/) — hér stendur sölureitur í þeirra stað.
const SKYRSLA_URL = `/althingi/${slugify(m.nafn)}/skyrsla/`;
const SAMPLE_URL = `/althingi/${slugify('Jón Pétur Zimsen')}/skyrsla/`;

const roleTxt = m.adalmadur ? 'Alþingismaður' : 'Varaþingmaður';
const desc = `${m.nafn} — ${roleTxt} ${m.flokks || m.flokkur} í ${m.kjordaemi}. ${m.aldur ? m.aldur + ' ára, ' : ''}${m.fjoldiThinga ? m.fjoldiThinga + ' þing setið, ' : ''}hollusta við flokk ${m.hollusta != null ? m.hollusta + '%' : '—'}.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Person', name: m.nafn,
  jobTitle: roleTxt, ...(m.mynd ? { image: m.mynd } : {}),
  memberOf: { '@type': 'Organization', name: m.flokkur },
  description: desc,
};
---

<Layout
  title={`${m.nafn} — ${m.flokkur} | Karp`}
  description={desc}
  canonical={`https://karp.is/althingi/${slugify(m.nafn)}/`}
  jsonLd={jsonLd}
  ogTitle={`${m.nafn} — þingmaður`}
  ogType="profile"
  ogImage={m.mynd || ''}
>
  <main data-pg="althingi-slug" style={`--pc:${color}`}>
    <a class="back" href="/althingi/">← Sætaspá Alþingis</a>
    <div class="hero">
      {m.mynd && <img src={m.mynd} alt={m.nafn} loading="lazy" onerror="this.style.display='none'" />}
      <div>
        <h1>{m.nafn}</h1>
        <div><span class="party">{m.flokkur}</span></div>
        <div class="meta">{roleTxt} · {m.kjordaemi}</div>
        <div id="follow" class="follow-wrap" data-key={`mp:${m.id}`}></div>
      </div>
    </div>

    <div class="grid">
      {tiles.map((t) => (
        <div class="tile">
          <div class="t-top">{t.e} {t.l}</div>
          <div class="t-v">{t.v}</div>
          {t.s && <div class="t-s">{t.s}</div>}
        </div>
      ))}
    </div>

    {committees.length > 0 && (
      <>
        <h2>Nefndir</h2>
        <div class="nefndir">{committees.map((n) => <span>{n}</span>)}</div>
      </>
    )}

    <!-- SÖLUREITUR: Málróf, AI-tónn og umfjöllun fluttust í seldu Þingmannaskýrsluna -->
    <div class="tk-sell">
      <div class="tks-badge">📊 Þingmannaskýrsla Karp</div>
      <h2 class="tks-h">Ítarleg greining á {m.nafn.split(' ')[0]} — í einni skýrslu</h2>
      <ul class="tks-list">
        <li>🗳️ <b>Atkvæðaferill</b> — uppreisnar-atkvæði gegn eigin flokki, mæting mánuð fyrir mánuð</li>
        <li>🧩 <b>Afstaða eftir málaflokkum</b> — já/nei-atkvæði flokkuð eftir opinberum efnisflokkum Alþingis</li>
        <li>🗣️ <b>Málróf</b> — ræður, andsvör, ræðutími eftir málefnum og hvað er talað mest um</li>
        <li>🤖 <b>Tónn og áherslur</b> — AI-greining á raunverulegum þingræðum, eftir málaflokkum</li>
        <li>❓ <b>Fyrirspurnir og flutt mál</b> · 📋 nefndavald · 💰 laun · 🧭 pólitískt kort með staðsetningu</li>
        <li>📰 <b>Fjölmiðlaumfjöllun</b> með vélrænu viðhorfsmati + 🖨️ PDF-útprentun</li>
      </ul>
      <div class="tks-btns">
        <a class="tks-main" href={SKYRSLA_URL}>Opna skýrsluna — 990 kr →</a>
        <a class="tks-sec" href={SAMPLE_URL}>👁️ Sjá sýnishorn (ókeypis)</a>
      </div>
      <div class="tks-note">Eða <b>áskrift á 3.900 kr/mán</b> — 10 þingmannaskýrslur innifaldar í hverjum mánuði. Hluti af <a href="/karp-pro/">Karp+</a>.</div>
    </div>

    <p class="foot">
      Forþjónað (SSG) {updated}. Gögn frá Alþingi (althingi.is) — flokkslitur úr sameiginlega
      <code> src/lib/parties</code>. #2 Á6 · ein af 63 þingmanna-síðum.
    </p>
  </main>

  <style>
    /* Sölureiturinn — vísar á seldu Þingmannaskýrsluna */
    .tk-sell { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.35); border-radius: 16px; padding: 20px 22px; margin-top: 26px; }
    .tks-badge { display: inline-block; background: #f6b13b; color: var(--surface); font-weight: 800; font-size: 11.5px; letter-spacing: .05em; padding: 3px 11px; border-radius: 999px; }
    .tks-h { font-size: 19px; color: var(--ink); margin: 10px 0 8px; text-transform: none; letter-spacing: 0; }
    .tks-list { margin: 0 0 14px; padding: 0; list-style: none; }
    .tks-list li { font-size: 13px; color: #c7d2e4; line-height: 1.65; padding: 1px 0; }
    .tks-list b { color: #e6ecf7; }
    .tks-btns { display: flex; gap: 10px; flex-wrap: wrap; }
    .tks-main { background: #f6b13b; color: var(--surface); font-weight: 800; font-size: 14px; text-decoration: none; padding: 10px 18px; border-radius: 10px; }
    .tks-sec { border: 1px solid rgba(255,255,255,.2); color: var(--ink); font-size: 13.5px; text-decoration: none; padding: 10px 18px; border-radius: 10px; }
    .tks-sec:hover { border-color: #f6b13b; color: #f6b13b; }
    .tks-note { font-size: 12px; color: var(--muted); margin-top: 12px; }
    .tks-note a, .tks-note b { color: #f6b13b; text-decoration: none; }
    main { max-width: 780px; margin: 0 auto; padding: 40px 20px 64px; }
    .back { font-size: 13px; color: var(--faint); text-decoration: none; }
    .back:hover { color: #f6b13b; }
    .hero { display: flex; gap: 20px; align-items: center; margin: 16px 0 6px; }
    .hero img { width: 96px; height: 120px; object-fit: cover; border-radius: 12px; border: 2px solid var(--pc); flex: none; background: var(--surface); }
    h1 { font-size: 30px; line-height: 1.1; margin: 0 0 6px; }
    .party { display: inline-block; font-size: 13px; font-weight: 700; color: var(--bg); background: var(--pc); border-radius: 6px; padding: 2px 9px; }
    .meta { color: var(--muted); font-size: 14px; margin-top: 6px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin: 24px 0 8px; }
    .tile { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px 16px; }
    .t-top { font-size: 12px; color: var(--muted); }
    .t-v { font-size: 24px; font-weight: 800; margin-top: 2px; }
    .t-s { font-size: 12px; color: var(--faint); }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 26px 0 8px; }
    .nefndir { display: flex; flex-wrap: wrap; gap: 8px; }
    .nefndir span { font-size: 13px; color: var(--ink); background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 8px; padding: 5px 10px; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Fylgja-hnappur er búinn til á keyrslutíma → global. Erfir --pc frá <main>. */
    .follow-wrap { margin-top: 10px; min-height: 34px; }
    .fbtn { background: var(--pc); color: var(--bg); border: 1px solid var(--pc); border-radius: 8px; padding: 7px 16px; font-weight: 700; font-size: 14px; cursor: pointer; }
    .fbtn.on { background: transparent; color: var(--pc); }
    .fbtn:disabled { opacity: .6; cursor: default; }
    .follow-gate { font-size: 13px; color: var(--muted); text-decoration: none; }
    .f-note { font-size: 11px; color: var(--faint); margin-left: 8px; }
    .follow-gate:hover { color: #f6b13b; }
  </style>

  <!-- Eyja: Fylgja þingmann (auðkennd umferð gegnum auth.js → /follows). #2 Á5 -->
  <script>
    import { loadUser, karpPost } from '../../lib/auth.js';
    function initFollow() {
      const el = document.getElementById('follow');
      if (!el) return;
      const KEY = el.dataset.key;
      // LOTA 19: engin læsing — óinnskráð fylgi vistast í vafranum (karp-follows-local)
      const lfl = () => { try { return JSON.parse(localStorage.getItem('karp-follows-local') || '[]'); } catch (e) { return []; } };
      function render() {
      const u = window.KARP_USER || { loggedIn: false };
      const follows = u.loggedIn ? (u.follows || []) : lfl();
      const following = follows.includes(KEY);
      el.innerHTML = `<button class="fbtn${following ? ' on' : ''}">${following ? '✓ Fylgist með' : '+ Fylgja'}</button>${!u.loggedIn ? '<span class="f-note">vistast á þessu tæki</span>' : ''}`;
      el.querySelector('button').onclick = async () => {
        const cur = u.loggedIn ? (window.KARP_USER.follows || []) : lfl();
        const next = cur.includes(KEY) ? cur.filter((k) => k !== KEY) : cur.concat([KEY]);
        const b = el.querySelector('button');
        b.disabled = true; b.textContent = '…';
        if (u.loggedIn) {
          const res = await karpPost('/follows', { follows: next });
          window.KARP_USER.follows = (res && res.follows) ? res.follows : next;
        } else {
          try { localStorage.setItem('karp-follows-local', JSON.stringify(next)); } catch (e) {}
        }
        render();
      };
      }
      loadUser().then(render);
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="althingi-slug"]')) initFollow(); });
  </script>

</Layout>
