---
// /nyskraning/ — native Karp nýskráningarsíða. Formið er gripið client-hlið og POST-ar á
// karp21-worker (/api/auth/register → D1): býr til aðganginn, skráir samþykki skilmála og
// skráir notandann inn strax (undirrituð lotu-kaka). Skilmála-gátreitur skylda (client `required`
// + server-hlið). (Áður: admin-post.php?action=karp_register á wp.karp.is.)
import Layout from '../layouts/Layout.astro';
import AuthShell from '../components/AuthShell.astro';
const desc = 'Nýskráðu þig á Karp — ókeypis aðgangur að Karp+ vöktun, stefnuprófi og persónulegu yfirliti. Tekur mínútu.';
---
<Layout title="Nýskráning — Karp" description={desc} canonical="https://karp.is/nyskraning/" ogTitle="Nýskrá á Karp" noindex={true}>
  <AuthShell pg="nyskraning" heading="Nýskráning" sub="Ókeypis aðgangur að Karp — tekur mínútu.">
    <p class="ka-msg err" id="ka-err" hidden></p>
    <p class="ka-msg ok" id="ka-ok" hidden></p>

    <div id="ka-form-wrap">
      <form method="POST" action="/api/auth/register" id="ka-form" autocomplete="on">
        <div class="ka-field">
          <label for="ka-login">Notandanafn</label>
          <input type="text" name="user_login" id="ka-login" required autocomplete="username" autocapitalize="none" autocorrect="off" spellcheck="false" />
        </div>
        <div class="ka-field">
          <label for="ka-email">Netfang</label>
          <input type="email" name="user_email" id="ka-email" required autocomplete="email" autocapitalize="none" autocorrect="off" spellcheck="false" />
        </div>
        <div class="ka-field">
          <label for="ka-pwd">Lykilorð</label>
          <input type="password" name="password" id="ka-pwd" required minlength="8" autocomplete="new-password" />
        </div>
        <label class="ka-terms">
          <input type="checkbox" name="karp_terms" value="1" id="ka-terms" required />
          <span>Ég samþykki <a href="/skilmalar/" target="_blank" rel="noopener">skilmála og persónuverndarstefnu</a> Karp.</span>
        </label>
        <button type="submit" class="ka-btn">Nýskrá</button>
        <p class="ka-note">Lykilorðið þarf að vera a.m.k. 8 stafir. Þú verður skráð(ur) inn strax.</p>
      </form>
    </div>

    <div id="ka-already" class="ka-in" hidden>
      <p id="ka-already-txt"></p>
      <a class="ka-btn" href="/mitt-svaedi/">Fara á Mitt svæði</a>
    </div>

    <Fragment slot="alt">Ertu þegar með aðgang? <a href="/innskra/">Skráðu þig inn</a> · <a href="/hjalp/?fra=nyskraning">Þarftu aðstoð?</a></Fragment>
  </AuthShell>

  <script>
    import { loadUser, karpRegister } from '../lib/auth.js';
    // WP→Cloudflare (F3): nýskráning gegnum karp21-worker (D1). Villukóðar frá worker.
    const MSG = {
      exists: 'Netfangið eða notandanafnið er þegar skráð. Prófaðu að skrá þig inn.',
      email: 'Netfangið lítur ekki rétt út.',
      weakpass: 'Lykilorðið þarf að vera a.m.k. 8 stafir.',
      terms: 'Þú þarft að samþykkja skilmálana til að halda áfram.',
      net: 'Tenging mistókst — reyndu aftur.',
      _: 'Nýskráning tókst ekki — reyndu aftur.',
    };
    function boot() {
      const main = document.querySelector('main[data-pg="nyskraning"]');
      if (!main) return;
      const p = new URLSearchParams(location.search);
      const err = p.get('villa');
      if (err) { const box = document.getElementById('ka-err'); if (box) { box.textContent = MSG[err] || MSG._; box.hidden = false; } }
      const login = p.get('log'); if (login) { const el = document.getElementById('ka-login'); if (el && !el.value) el.value = login; }
      const email = p.get('email'); if (email) { const el = document.getElementById('ka-email'); if (el && !el.value) el.value = email; }
      // Nýskráning gegnum worker (fetch) — intercept submit → skráð(ur) inn strax.
      const form = document.getElementById('ka-form');
      if (form && !form.dataset.wired) {
        form.dataset.wired = '1';
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = form.querySelector('.ka-btn'); const eb = document.getElementById('ka-err');
          if (eb) eb.hidden = true;
          const data = {
            username: (document.getElementById('ka-login').value || '').trim(),
            name: (document.getElementById('ka-login').value || '').trim(),
            email: (document.getElementById('ka-email').value || '').trim(),
            password: document.getElementById('ka-pwd').value || '',
            terms: !!document.getElementById('ka-terms').checked,
          };
          if (btn) { btn.disabled = true; btn.textContent = 'Skrái…'; }
          const res = await window.karpAuth.karpRegister(data);
          if (res && res.ok) { location.href = 'https://karp.is/mitt-svaedi/'; return; }
          if (btn) { btn.disabled = false; btn.textContent = 'Nýskrá'; }
          if (eb) { eb.textContent = MSG[(res && res.error)] || MSG._; eb.hidden = false; }
        });
      }
      // Þegar innskráð(ur) (og ekki nýbúin(n) að skrá sig) → benda á Mitt svæði.
      loadUser().then((u) => {
        if (u && u.loggedIn) {
          const fw = document.getElementById('ka-form-wrap');
          const al = document.getElementById('ka-already');
          const tx = document.getElementById('ka-already-txt');
          if (fw) fw.hidden = true;
          if (tx) tx.textContent = 'Þú ert þegar innskráð' + (u.name ? '(ur) sem ' + u.name : '(ur)') + '.';
          if (al) al.hidden = false;
        }
      }).catch(() => {});
    }
    if (document.readyState !== 'loading') boot(); else document.addEventListener('DOMContentLoaded', boot);
    document.addEventListener('astro:page-load', boot);
  </script>
</Layout>
