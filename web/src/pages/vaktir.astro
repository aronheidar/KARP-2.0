    .fi .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    #vaktir-mine .vk { display: flex; justify-content: space-between; gap: 8px; font-size: 13px; color: #cdd6e6; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    #vaktir-mine .vk-note { font-size: 12px; color: #7e8ca6; margin-top: 8px; }
    #vaktir-mine .vk-note a { color: #9fb0c8; }
  </style>

  <!-- Eyja: mínar vaktir (auth) + lifandi útboð (worker-proxy). #2 LOTA 16 -->
  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    function initVaktir() {
      const mine = document.getElementById('vaktir-mine');
      if (!mine || mine.dataset.done) return;
      mine.dataset.done = '1';
      // 🔎 Leitarorðavaktin (LOTA 18 #7 v1): orð í localStorage, upplýsir treff í
      // öllum veitunum; samstillist við WP (/leitvakt) svari sá endapunktur.
      const lvKey = 'karp-leitvakt';
      const lvLoad = () => { try { return JSON.parse(localStorage.getItem(lvKey) || '[]').filter((x) => typeof x === 'string'); } catch (e) { return []; } };
      const lvSave = (a) => { localStorage.setItem(lvKey, JSON.stringify(a.slice(0, 12))); try { karpPost('/leitvakt', { ord: a.slice(0, 12) }).catch(() => {}); } catch (e) {} };
      const lvHi = () => {
        const words = lvLoad().map((w) => w.toLowerCase());
        const counts = {};
        document.querySelectorAll('.feed .fi').forEach((el) => {
          const t = (el.textContent || '').toLowerCase();
          const hit = words.find((w) => w && t.includes(w));
          el.classList.toggle('hit', !!hit);
          if (hit) counts[hit] = (counts[hit] || 0) + 1;
        });
        document.querySelectorAll('#lv-chips .lvc').forEach((c) => {
          const w = (c.dataset.w || '').toLowerCase();
          const b = c.querySelector('b');
          if (b) b.textContent = counts[w] ? counts[w] : '';
        });
      };
      const lvRender = () => {
        const el = document.getElementById('lv-chips');
        if (!el) return;
        el.innerHTML = lvLoad().map((w) => `<span class="lvc" data-w="${esc(w)}">${esc(w)} <b></b><button title="Fjarlægja" aria-label="Fjarlægja ${esc(w)}">✕</button></span>`).join('');
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const w = b.closest('.lvc').dataset.w;
          lvSave(lvLoad().filter((x) => x !== w));
          lvRender(); lvHi();
        }));
        lvHi();
      };
      const lvAdd = () => {
        const inp = document.getElementById('lv-q');
        const w = (inp.value || '').trim().slice(0, 40);
        if (w.length < 2) return;
        const a = lvLoad();
        if (!a.includes(w)) { a.push(w); lvSave(a); }
        inp.value = '';
        lvRender();
      };
      const addBtn = document.getElementById('lv-add');
      if (addBtn) addBtn.addEventListener('click', lvAdd);
      const lvInp = document.getElementById('lv-q');
      if (lvInp) lvInp.addEventListener('keydown', (e) => { if (e.key === 'Enter') lvAdd(); });
      lvRender();
      // veiturnar hlaðast ósamstillt → endurmerkja í nokkrum umferðum
      [1800, 4000, 8000].forEach((t) => setTimeout(lvHi, t));
      // WP-samruni: sé notandi innskráður og endapunkturinn til, sameina orðin
      karpGet('/leitvakt').then((d) => {
        const remote = (d && d.ord) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...new Set([...lvLoad(), ...remote])].slice(0, 12);
          localStorage.setItem(lvKey, JSON.stringify(merged));
          lvRender();
        }
      }).catch(() => {});
      // 🏠 Fasteignavaktin (LOTA 43): kaupskrá-leit + götuvaktir (localStorage + WP /fastvakt)
      const fvKey = 'karp-fastvakt';
      let FV = null;
      const fvFetch = () => FV || (FV = fetch('/gogn/kaupskra_nyjast.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const fvLoad = () => { try { return JSON.parse(localStorage.getItem(fvKey) || '[]').filter((v) => v && typeof v.q === 'string'); } catch (e) { return []; } };
      const fvSave = (a) => { localStorage.setItem(fvKey, JSON.stringify(a.slice(0, 6))); try { karpPost('/fastvakt', { on: true, vaktir: a.slice(0, 6) }).catch(() => {}); } catch (e) {} };
      const fvNorm = (s) => String(s || '').toLowerCase().trim();
      const fvMatch = (r, sv, q) => (!sv || r.sv === sv) && (!q || (/^\d{3}$/.test(q) ? r.pn === q : fvNorm(r.a).startsWith(q)));
      const fvKr = (v) => (v / 1000).toFixed(1).replace('.', ',') + ' m.kr';
      const fvRow = (r) => `<div class="fi"><span class="t">${esc(r.a)} <span class="fv-sv">· ${esc(r.pn)} ${esc(r.sv)}</span> — <b class="fv-v">${fvKr(r.v)}</b></span><span class="s">${dIS(r.d)} · ${String(r.fm).replace('.', ',')} m²${r.fm > 0 ? ' · ' + Math.round(r.v / r.fm) + ' þ/m²' : ''} · ${esc(r.t)}</span></div>`;
      // 🔨 Nauðungarsölur (LOTA 48): opinberar uppboðsauglýsingar sýslumanna í sömu leit
      let UPP = null;
      const uppFetch = () => UPP || (UPP = fetch('/gogn/uppbod.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const uppRow = (x) => `<div class="fi fv-upp"><span class="t">🔨 ${esc(x.a)} — <b>${esc(x.teg)}</b></span><span class="s">${dIS(x.d)}${x.kl ? ' kl. ' + esc(x.kl) : ''} · ${esc(x.flokkur)} · ${esc(x.e)}${x.st ? ' · ' + esc(x.st) : ''}</span></div>`;
      const fvQ = document.getElementById('fv-q'), fvMuniEl = document.getElementById('fv-muni'), fvBtn = document.getElementById('fv-add');
      async function fvSearch() {
        const res = document.getElementById('fv-res');
        if (!res) return;
        const sv = fvMuniEl.value, q = fvNorm(fvQ.value);
        if (!sv && q.length < 2) { res.hidden = true; return; }
        res.hidden = false;
        res.textContent = 'Sæki kaupskrá…';
        const [d, up] = await Promise.all([fvFetch(), uppFetch()]);
        if (!d || !d.rows) { res.textContent = 'Náði ekki í kaupskrána — reyndu aftur síðar.'; return; }
        const rows = d.rows.filter((r) => fvMatch(r, sv, q));
        // uppboð: götuprefix (uppboðsskráin ber heimilisfang+bæ en ekki póstnr/sveitarfélagslykil)
        const uppRows = (q && !/^\d{3}$/.test(q) && up && up.rows) ? up.rows.filter((x) => fvNorm(x.a).startsWith(q)) : [];
        const uppHtml = uppRows.length ? `<div class="fv-head fv-upph">⚠ ${uppRows.length} nauðungarsölu-auglýsing${uppRows.length === 1 ? '' : 'ar'} passa við leitina</div>` + uppRows.slice(0, 6).map(uppRow).join('') : '';
        if (!rows.length && !uppRows.length) { res.innerHTML = '<div class="fi"><span class="t">Engin þinglýst sala fannst síðustu 6 mánuði.</span><span class="s">Þinglýsing berst með nokkurra vikna töf — settu götuna á vakt og fáðu póst þegar eitthvað kemur.</span></div>'; return; }
        res.innerHTML = uppHtml
          + (rows.length ? `<div class="fv-head">${rows.length} þinglýst kaup síðustu 6 mánuði${sv ? ' · ' + esc(sv) : ''}${q ? ' · „' + esc(q) + '“' : ''}</div>` : '')
          + rows.slice(0, 25).map(fvRow).join('')
          + (rows.length > 25 ? `<div class="s" style="padding:7px 2px">… og ${rows.length - 25} til viðbótar — þrengdu leitina.</div>` : '');
      }
      async function fvRender() {
        const el = document.getElementById('fv-chips');
        if (!el) return;
        const vaktir = fvLoad();
        el.innerHTML = vaktir.map((v, i) => `<span class="lvc" data-i="${i}">🏠 ${esc(v.q || v.sv)}${v.q && v.sv ? ' · ' + esc(v.sv) : ''} <b></b><button title="Fjarlægja" aria-label="Fjarlægja vakt">✕</button></span>`).join('');
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const i = +b.closest('.lvc').dataset.i;
          const a = fvLoad(); a.splice(i, 1); fvSave(a); fvRender();
        }));
        if (vaktir.length) {
          const d = await fvFetch();
          if (d && d.rows) el.querySelectorAll('.lvc').forEach((c) => {
            const v = vaktir[+c.dataset.i];
            if (!v) return;
            const n = d.rows.filter((r) => fvMatch(r, v.sv, fvNorm(v.q))).length;
            const b = c.querySelector('b');
            if (b && n) b.textContent = n;
          });
        }
      }
      let fvMuniDone = false;
      async function fvMunis() {
        if (fvMuniDone) return;
        fvMuniDone = true;
        const d = await fvFetch();
        if (!d || !d.rows || !fvMuniEl) return;
        [...new Set(d.rows.map((r) => r.sv))].sort((a, b) => a.localeCompare(b, 'is')).forEach((sv) => {
          const o = document.createElement('option'); o.value = sv; o.textContent = sv; fvMuniEl.appendChild(o);
        });
      }
      function fvAdd() {
        const q = (fvQ.value || '').trim().slice(0, 40), sv = fvMuniEl.value;
        if (q.length < 2 && !sv) return;
        const a = fvLoad();
        if (!a.some((v) => v.q === q && v.sv === sv) && a.length < 6) { a.push({ q, sv }); fvSave(a); }
        fvRender();
      }
      let fvT = null;
      if (fvQ) {
        fvQ.addEventListener('focus', fvMunis);
        fvQ.addEventListener('input', () => { clearTimeout(fvT); fvT = setTimeout(fvSearch, 220); });
        fvQ.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvAdd(); } });
      }
      if (fvMuniEl) { fvMuniEl.addEventListener('focus', fvMunis); fvMuniEl.addEventListener('change', fvSearch); }
      if (fvBtn) fvBtn.addEventListener('click', fvAdd);
      fvRender();
      // 🏷️ Verðmat úr kaupskránni (LOTA 47, Karp Pro): gata → póstnr → sveitarfélag
      const fvmOut = document.getElementById('fvm-out');
      let FST = null; // fasteignir.json (12 mán byMuni-tölfræði) — sótt letilega
      const fstFetch = () => FST || (FST = fetch('/gogn/fasteignir.json').then((r) => (r.ok ? r.json() : null)).catch(() => null));
      const med = (a) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const m = s.length >> 1; return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2; };
      const pct = (a, q) => { if (!a.length) return null; const s = a.slice().sort((x, y) => x - y); const i = (s.length - 1) * q, lo = Math.floor(i), hi = Math.ceil(i); return s[lo] + (s[hi] - s[lo]) * (i - lo); };
      const mkr = (v) => (v >= 1000 ? (v / 1000).toFixed(1).replace('.', ',') + ' m.kr' : Math.round(v) + ' þ.kr');
      async function fvmGo() {
        const raw = (document.getElementById('fvm-addr').value || '').trim();
        const fm = +(document.getElementById('fvm-fm').value || 0);
        const teg = document.getElementById('fvm-teg').value;
        if (raw.length < 3 || !(fm >= 15)) { fvmOut.hidden = false; fvmOut.innerHTML = '<div class="fvm-note">Sláðu inn heimilisfang og stærð í m².</div>'; return; }
        fvmOut.hidden = false;
        // Pro-læsing: niðurstaðan er fyrir innskráða (ókeypis aðgangur)
        const u = await loadUser().catch(() => null);
        if (!u || !u.loggedIn) {
          fvmOut.innerHTML = '<div class="pro-tease2"><b>⭐ Verðmatið er hluti af Karp Pro</b> — ókeypis aðgangur. Nálgun úr þinglýstum kaupum í götunni þinni, póstnúmerinu og sveitarfélaginu.<div class="pt2-btns"><a class="pt2-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt2-sec" href="/login/">Innskráning</a></div></div>';
          return;
        }
        fvmOut.textContent = 'Reikna úr kaupskránni…';
        const pnM = raw.match(/\b(\d{3})\b/);
        const pn = pnM ? pnM[1] : '';
        const street = fvNorm(raw.replace(/\b\d{3}\b/, '').replace(/[,.]/g, ' ')).replace(/\s+\d+[a-z]?\s*$/i, '').trim();
        const d = await fvFetch();
        if (!d || !d.rows) { fvmOut.textContent = 'Náði ekki í kaupskrána — reyndu aftur.'; return; }
        const ppm = (r) => (r.fm > 15 ? r.v / r.fm : null); // þús.kr/m²
        const lag = [];
        if (street.length >= 3) lag.push({ n: 'götunni (' + street + ') sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && fvNorm(r.a).startsWith(street) && (!pn || r.pn === pn)), min: 3 });
        if (pn) lag.push({ n: 'póstnúmeri ' + pn + ' sl. 6 mán', rows: d.rows.filter((r) => r.t === teg && r.pn === pn), min: 6 });
        let est = null, comps = [];
        for (const L of lag) {
          const vals = L.rows.map(ppm).filter(Boolean);
          if (vals.length >= L.min) { est = { heiti: L.n, n: vals.length, m: med(vals), lo: pct(vals, 0.25), hi: pct(vals, 0.75) }; comps = L.rows.slice(0, 6); break; }
        }
        if (!est) {
          // sveitarfélags-lagið: 12 mán tölfræði úr fasteignir.json (byMuni), vörpuð um póstnr eða götutreff
          const svGuess = (pn ? d.rows.find((r) => r.pn === pn) : d.rows.find((r) => fvNorm(r.a).startsWith(street)));
          const sv = svGuess && svGuess.sv;
          const f = await fstFetch();
          const bm = sv && f && f.byMuni && f.byMuni[sv];
          const t = bm && ((bm.types && bm.types[teg]) || bm);
          if (t && t.m2) est = { heiti: sv + ' (12 mán miðgildi' + (bm.types && bm.types[teg] ? ', ' + teg : ', allar tegundir') + ')', n: t.n, m: t.m2, lo: t.p25, hi: t.p75 };
        }
        if (!est) { fvmOut.innerHTML = '<div class="fvm-note">Of fá nýleg kaup til að meta — prófaðu án póstnúmers eða athugaðu stafsetningu götunnar.</div>'; return; }
        const verd = est.m * fm, lo = (est.lo || est.m) * fm, hi = (est.hi || est.m) * fm;
        fvmOut.innerHTML = `<div class="fvm-card"><div class="fvm-big">${mkr(verd)}</div><div class="fvm-range">líklegt bil ${mkr(lo)} – ${mkr(hi)}</div><div class="fvm-meta">${Math.round(est.m)} þ.kr/m² · byggt á ${est.n} þinglýstum kaupum í ${esc(est.heiti)} · ${esc(teg)}, ${fm} m²</div><div class="fvm-note">Tölfræðileg nálgun úr kaupskrá HMS — ekki fasteignamat. Ástand, hæð, útsýni og bílastæði geta hliðrað verði verulega.</div></div>` + (comps.length ? '<div class="fv-head" style="margin-top:8px">Nýlegustu kaupin sem matið byggir á</div>' + comps.map(fvRow).join('') : '');
      }
      const fvmBtn = document.getElementById('fvm-go');
      if (fvmBtn) fvmBtn.addEventListener('click', fvmGo);
      const fvmAddr = document.getElementById('fvm-addr');
      if (fvmAddr) fvmAddr.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); fvmGo(); } });
      // WP-samstilling eins og leitvakt: sameina vaktir innskráðs notanda
      karpGet('/fastvakt').then((d) => {
        const remote = (d && d.vaktir) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...fvLoad()];
          remote.forEach((rv) => { if (rv && (rv.q || rv.sv) && !merged.some((v) => v.q === rv.q && v.sv === rv.sv)) merged.push({ q: String(rv.q || ''), sv: String(rv.sv || '') }); });
          localStorage.setItem(fvKey, JSON.stringify(merged.slice(0, 6)));
          fvRender();
        }
      }).catch(() => {});
      // Mínar hagvísavaktir
      loadUser().then(async (u) => {
        if (!u || !u.loggedIn) return;
        const vd = await karpGet('/vaktir');
        const arr = Array.isArray(vd) ? vd : (vd && vd.vaktir) || [];
        mine.innerHTML = (arr.length
          ? arr.map((v) => `<div class="vk"><span><b>${esc(v.metric || v.m || '')}</b> ${esc(v.area || '')} ${esc(v.dir === 'under' || v.dir === 'undir' ? 'fer undir' : 'fer yfir')} <b>${esc(v.threshold ?? v.vidmid ?? '')}</b></span></div>`).join('')
          : '<div class="vk">Engin vakt skráð enn.</div>')
          + '<div class="vk-note">Vaktir eru stofnaðar á <a href="/mitt-svaedi/">Mínu svæði</a> (Stillingar → Vaktir).</div>';
      }).catch(() => {});
      // ⚖️ Dómavaktin (HR + LR um /api/domar) + AI-endursögn reifunar (LOTA 44, domar_ai.json)
      Promise.all([
        fetch('/api/domar').then((r) => (r.ok ? r.json() : null)).catch(() => null),
        fetch('/gogn/domar_ai.json').then((r) => (r.ok ? r.json() : null)).catch(() => null),
      ]).then(([d, ai]) => {
        const AI = (ai && ai.byNr) || {};
        const SITES = { hr: 'https://www.haestirettur.is/domar/', lr: 'https://www.landsrettur.is/domar-og-urskurdir/' };
        for (const key of ['hr', 'lr']) {
          const el = document.getElementById('domar-' + key);
          if (!el) continue;
          const list = d && Array.isArray(d[key]) ? d[key] : [];
          if (!list.length) { el.textContent = 'Dómarnir birtast þegar veitan svarar (proxy í dreifingu).'; continue; }
          el.innerHTML = list.slice(0, 8).map((v) => {
            const a = AI[key + ':' + v.nr];
            const skyring = a && a.einfalt ? a.einfalt : (v.um ? String(v.um).trim().slice(0, 150) + (String(v.um).trim().length > 150 ? '…' : '') : '');
            return `<a class="fi" href="${SITES[key]}" target="_blank" rel="noopener" title="${esc(v.um || '')}"><span class="t">Mál ${esc(v.nr)}: ${esc(String(v.titill || '').split(' gegn ')[0].slice(0, 60))}${String(v.titill || '').includes(' gegn ') ? ' gegn …' : ''}</span>${skyring ? `<span class="s dom-ai">${a && a.einfalt ? '💡 ' : ''}${esc(skyring)}${a && a.svid ? ` <span class="pill">${esc(a.svid)}</span>` : ''}</span>` : ''}<span class="s">${dIS(v.dags)}${(v.efnisord || []).length ? ' · ' + v.efnisord.slice(0, 3).map(esc).join(' · ') : ''}</span></a>`;
          }).join('');
        }
      }).catch(() => {});
      // 💬 Samráðsvaktin (island.is GraphQL um /api/samrad) + atvinnugreina-flokkun (LOTA 44)
      const SAMRAD_GREINAR = [
        ['Sjávarútvegur', /sjávar|fisk|veiði|kvót|eldi|hafi\b/i],
        ['Landbúnaður & matvæli', /landbún|bænd|búfé|matvæl|jarðrækt/i],
        ['Orka', /orku|raforku|virkj|jarðvarm|vindork|eldsneyt/i],
        ['Byggingar & húsnæði', /skipulag|bygging|mannvirki|húsnæð|lóð/i],
        ['Fjármál & skattar', /fjármál|skatt|gjald(?!frjáls)|banka|trygging|lífeyri|fjárlög/i],
        ['Heilbrigði', /heilbrigð|heilsu|lyf|sjúkra|lækn/i],
        ['Menntun', /mennt|skóla|háskól|leikskól|nám/i],
        ['Samgöngur', /samgöng|veg(?:a|i|ur)|flug|höfn|umferð|ökutæk/i],
        ['Umhverfi & loftslag', /umhverfi|loftslag|náttúr|mengun|úrgang|friðlýs/i],
        ['Ferðaþjónusta', /ferðaþjónust|ferðamann/i],
        ['Fjarskipti & tækni', /fjarskipt|netörygg|stafræn|gervigreind|upplýsingatækn/i],
        ['Vinnumarkaður', /vinnumark|kjaramál|starfsm|atvinnuleys|réttind.*starf/i],
      ];
      const samradGrein = (c) => { const hay = (c.name || '') + ' ' + (c.typeName || '') + ' ' + (c.institutionName || ''); const g = SAMRAD_GREINAR.find(([, rx]) => rx.test(hay)); return g ? g[0] : null; };
      fetch('/api/samrad')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('samrad-list');
          if (!el) return;
          const cs = ((((d || {}).data || {}).consultationPortalGetCases || {}).cases || []).map((c) => ({ ...c, grein: samradGrein(c) }));
          if (!cs.length) { el.textContent = 'Samráðsmálin birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          const render = (filter) => {
            const list = filter ? cs.filter((c) => c.grein === filter) : cs;
            el.innerHTML = (list.length ? list : cs).slice(0, 12).map((c) => {
              const open = /umsagnar/i.test(c.statusName || '');
              const frest = open && c.processEnds ? ` · frestur til ${dIS(c.processEnds)}` : '';
              return `<a class="fi" href="https://island.is/samradsgatt/mal/${esc(c.id)}" target="_blank" rel="noopener"><span class="t">${esc(c.name)}</span><span class="s"><span class="pill ${open ? 'op' : ''}">${esc(c.statusName || '')}</span>${c.grein ? ` <span class="pill gr">${esc(c.grein)}</span>` : ''} ${esc(c.institutionName || '')} · mál ${esc(c.caseNumber)}${frest}${c.adviceCount ? ` · ${c.adviceCount} umsagnir` : ''}</span></a>`;
            }).join('');
          };
          const pillsEl = document.getElementById('samrad-pills');
          const greinar = [...new Set(cs.map((c) => c.grein).filter(Boolean))];
          if (pillsEl && greinar.length) {
            pillsEl.innerHTML = `<button class="spill on" data-g="">Allt (${cs.length})</button>` + greinar.map((g) => `<button class="spill" data-g="${esc(g)}">${esc(g)} (${cs.filter((c) => c.grein === g).length})</button>`).join('');
            pillsEl.querySelectorAll('.spill').forEach((b) => b.addEventListener('click', () => {
              pillsEl.querySelectorAll('.spill').forEach((x) => x.classList.toggle('on', x === b));
              render(b.dataset.g || null);
            }));
          }
          render(null);
        })
        .catch(() => {});
      // 💸 Greiðsluvaktin (opnirreikningar.is um /api/greidslur)
      fetch('/api/greidslur')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('greidslur-list');
          if (!el) return;
          const rows = (d && Array.isArray(d.rows)) ? d.rows : [];
          if (!rows.length) { el.textContent = 'Greiðslurnar birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          const kr = (v) => (v == null ? '' : Math.round(v).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' kr');
          el.innerHTML = rows.slice(0, 12).map((g) => `<a class="fi" href="https://opnirreikningar.is/" target="_blank" rel="noopener" title="${esc(g.lysing || '')}"><span class="t">${esc(g.stofnun)} → <b>${esc(g.birgir)}</b> · <span class="${(g.upph || 0) < 0 ? 'neg' : 'pos'}">${kr(g.upph)}</span></span><span class="s">${dIS(g.dags)}${g.lysing ? ' · ' + esc(g.lysing.slice(0, 60)) : ''}</span></a>`).join('');
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vaktir"]')) initVaktir(); });
  </script>
</Layout>
