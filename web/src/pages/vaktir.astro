    #lv-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #lv-add { background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.45); color: #f6b13b; border-radius: 10px; padding: 0 14px; font-size: 12.5px; font-weight: 600; cursor: pointer; }
    #lv-chips, #fv-chips { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 9px; }
    #lv-chips .lvc, #fv-chips .lvc { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #cdd6e6; border-radius: 999px; padding: 4px 6px 4px 11px; font-size: 12px; }
    #lv-chips .lvc b, #fv-chips .lvc b { color: #f6b13b; font-weight: 700; }
    #lv-chips .lvc button, #fv-chips .lvc button { background: none; border: 0; color: #7e8ca6; cursor: pointer; font-size: 13px; padding: 0 4px; }
    #lv-chips .lvc button:hover, #fv-chips .lvc button:hover { color: #e0655f; }
    /* 🏠 Fasteignavaktin (LOTA 43) */
    #fv-muni { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 10px; color: #eaf1fb; font-size: 13px; max-width: 210px; }
    #fv-muni:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #fv-muni option { background: #0e1420; color: #eaf1fb; }
    #fv-q { flex: 1; max-width: 340px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 12px; color: #eaf1fb; font-size: 13px; }
    #fv-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #fv-add { background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.45); color: #f6b13b; border-radius: 10px; padding: 0 14px; font-size: 12.5px; font-weight: 600; cursor: pointer; }
    #fv-res { margin-top: 10px; max-height: 420px; overflow-y: auto; }
    .fv-head { font-size: 11.5px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .04em; padding: 4px 2px 6px; }
    .fv-upph { color: #e0655f; }
    .fv-upp { border-left: 3px solid #e0655f; padding-left: 8px; background: rgba(224,101,95,.06); border-radius: 6px; }
    /* Krossvísun á fasteignavaktar-síðuna (LOTA 52) + leitvakt-kynning */
    .fv-crosslink { display: block; background: rgba(246,177,59,.07); border: 1px solid rgba(246,177,59,.35); border-radius: 12px; padding: 13px 16px; text-decoration: none; }
