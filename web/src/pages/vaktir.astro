---
// ─────────────────────────────────────────────────────────────
// 🔔 VAKTIR / Leitarorðavaktin (LOTA 16 → einföldun Verk 4) — vöktunarmiðstöð Karp.
// EITT „Bæta við vakt"-form efst (leitarorð → lýsir upp treff í öllum veitunum
// + daglegur póstur innskráðum), svo lifandi veiturnar sem orðin leita í
// (dómar/samráð/greiðslur), svo persónulegar tölvupósts-vaktir, svo krosslindir.
// Leitvakt-, digest-, mínar-vaktir- og veitu-endapunktar ÓBREYTTIR.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
const updated = '2026-07-06';
const desc = 'Leitarorðavaktin á Karp — skráðu leitarorð og láttu Karp lýsa upp allt sem nefnir það: dóma, samráðsmál og greiðslur ríkisins. Innskráðir fá daglegan póst með treffum.';
---

<Layout title="🔔 Leitarorðavaktin — vöktunarmiðstöð | Karp" description={desc} canonical="https://karp.is/vaktir/" ogTitle="Vaktir Karp">
  <main data-pg="vaktir">
    <p class="kicker">Karp · Vöktun</p>
    <h1>🔔 Leitarorðavaktin</h1>
    <p class="sub">Skráðu leitarorð — fyrirtækið þitt, götuna, atvinnugreinina eða málefni — og Karp lýsir upp allt hér að neðan sem nefnir það: dóma, samráðsmál og greiðslur ríkisins.</p>

    <!-- 1 ── Bæta við vakt (aðalatriði, efst) ── -->
    <section class="lv-box">
      <div class="lv-row">
        <input id="lv-q" type="text" maxlength="40" placeholder="Leitarorð — t.d. „vegagerð“, „fiskeldi“, „gervigreind“…" autocomplete="off" aria-label="Leitarorð" />
        <button id="lv-add">🔔 Bæta við vakt</button>
      </div>
      <p class="lv-hint">Treff lýsast upp <span class="lv-demo">svona</span> · innskráðir fá daglegan póst · orðin vistast í vafranum og fylgja þér innskráðum.</p>
      <div class="lv-active-h">Virkar vaktir</div>
      <div id="lv-chips"><span class="dim">Engin vakt enn — skráðu leitarorð að ofan.</span></div>
    </section>

    <!-- 2 ── Lifandi veiturnar sem orðin leita í ── -->
    <h2>⚖️ Dómavaktin <span class="live">lifandi</span></h2>
    <div class="ppair">
      <div><h3>Hæstiréttur</h3><div id="domar-hr" class="feed">Sæki dóma…</div></div>
      <div><h3>Landsréttur</h3><div id="domar-lr" class="feed">Sæki dóma…</div></div>
    </div>

    <h2>💬 Samráðsvaktin <span class="live">lifandi</span></h2>
    <div id="samrad-pills"></div>
    <div id="samrad-list" class="feed">Sæki samráðsmál…</div>

    <h2>💸 Greiðsluvaktin <span class="live">lifandi</span></h2>
    <div id="greidslur-list" class="feed">Sæki greiðslur ríkisins…</div>

    <!-- 3 ── Í tölvupósti (innskráð) ── -->
    <h2>📬 Vikuyfirlit í tölvupósti</h2>
    <label class="dg-row">
      <input type="checkbox" id="dg-on" />
      <span><b>Fá vikuyfirlit á mánudagsmorgnum</b> — leitarorðin, fyrirtæki/þingmenn sem þú fylgist með, fasteigna- og útboðsvaktir og hagtölur vikunnar. Ókeypis, fyrir innskráða.</span>
    </label>
    <div class="dg-note" id="dg-note" hidden></div>

    <h2>📊 Mínar hagvísavaktir</h2>
    <div id="vaktir-mine"><span class="dim">Hagvísavaktir (t.d. „verðbólga yfir 5%“) eru stofnaðar á <a href="/mitt-svaedi/">Mínu svæði</a> og birtast hér þegar þú ert innskráð(ur).</span></div>

    <!-- 4 ── Fleiri vaktir ── -->
    <h2>Fleiri vaktir</h2>
    <div class="more-grid">
      <a class="more-card" href="/fasteignavakt/"><b>🏠 Fasteignavaktin</b><span>Hvað seldist í götunni þinni og á hvaða verði, verðmat úr kaupskrá og nauðungarsölur.</span></a>
      <a class="more-card" href="/utbod/"><b>📋 Útboðsvaktin</b><span>Ný opinber útboð af Útboðsvef og TED (EES-útboð á Íslandi) — vaktaðu þína verktöku.</span></a>
      <a class="more-card" href="/frettir/"><b>📰 Fjölmiðlavöktun</b><span>Umfjöllun um fyrirtæki, flokka og fólk — viðhorf, tímalínur og frjáls leit.</span></a>
    </div>

    <p class="foot">Forþjónað (SSG) {updated}. Lifandi lindir um skyndiminnis-proxy Karp: haestirettur.is, landsrettur.is, samráðsgátt island.is og opnirreikningar.is (Fjársýslan). Dómavaktin nær til Hæstaréttar og Landsréttar. #2 LOTA 16–17.</p>
  </main>

  <style>
    main { max-width: 940px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    .sub { font-size: 15px; line-height: 1.6; margin: 0 0 6px; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; display: flex; align-items: center; gap: 9px; }
    h3 { font-size: 13px; color: #cdd6e6; margin: 0 0 6px; }
    .live { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #42d086; background: rgba(66,208,134,.13); border: 1px solid rgba(66,208,134,.3); border-radius: 999px; padding: 1px 8px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .feed { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 11px; padding: 8px 12px; min-height: 80px; font-size: 13px; color: #9fb0c8; }
    .dim { color: #7e8ca6; font-size: 13px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Feed-línur (dómar/samráð/greiðslur) — treff lýsast upp af leitarorðavaktinni */
    #domar-hr .fi, #domar-lr .fi, #samrad-list .fi, #greidslur-list .fi { display: block; padding: 8px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    #greidslur-list .pos { color: #42d086; } #greidslur-list .neg { color: #e0655f; }
    #greidslur-list b { color: #f6b13b; font-weight: 600; }
    .fi.hit { border-left: 3px solid #f6b13b; padding-left: 8px; background: rgba(246,177,59,.06); border-radius: 6px; }
    .fi .t { display: block; font-size: 13px; color: #eaf1fb; line-height: 1.35; }
    .fi:hover .t { color: #f6b13b; }
    .fi .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .dom-ai { color: #b9c6da !important; font-size: 12px !important; margin-top: 3px; line-height: 1.4; }
    #samrad-list .pill, #domar-hr .pill, #domar-lr .pill { display: inline-block; padding: 1px 7px; border-radius: 8px; font-size: 10.5px; background: rgba(255,255,255,.08); color: #9fb0c8; }
    #samrad-list .pill.op { background: rgba(66,208,134,.16); color: #42d086; }
    #samrad-list .pill.gr { background: rgba(246,177,59,.13); color: #f6b13b; }
    #samrad-pills { display: flex; flex-wrap: wrap; gap: 6px; margin: 0 0 8px; }
    #samrad-pills .spill { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #9fb0c8; border-radius: 999px; padding: 3px 11px; font-size: 11.5px; cursor: pointer; }
    #samrad-pills .spill:hover { border-color: rgba(246,177,59,.45); color: #f6b13b; }
    #samrad-pills .spill.on { background: rgba(246,177,59,.14); border-color: rgba(246,177,59,.5); color: #f6b13b; font-weight: 600; }

    /* 🔎 Leitarorðavaktin — áberandi kassi efst */
    .lv-box { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.32); border-radius: 14px; padding: 16px 18px; margin: 14px 0 6px; }
    .lv-row { display: flex; gap: 8px; }
    #lv-q { flex: 1; min-width: 0; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.16); border-radius: 10px; padding: 11px 14px; color: #eaf1fb; font-size: 14.5px; }
    #lv-q:focus { outline: none; border-color: rgba(246,177,59,.6); }
    #lv-q::placeholder { color: #7e8ca6; }
    #lv-add { flex: none; background: #f6b13b; border: 0; color: #10151f; border-radius: 10px; padding: 0 18px; font-size: 13.5px; font-weight: 800; cursor: pointer; white-space: nowrap; }
    #lv-add:hover { filter: brightness(1.05); }
    .lv-hint { font-size: 12.5px; color: #9fb0c8; margin: 9px 0 0; line-height: 1.5; }
    .lv-demo { border-left: 3px solid #f6b13b; background: rgba(246,177,59,.14); padding: 1px 6px; border-radius: 4px; color: #eaf1fb; }
    .lv-active-h { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; font-weight: 700; margin: 14px 0 7px; }
    #lv-chips { display: flex; flex-wrap: wrap; gap: 7px; }
    #lv-chips .lvc { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #cdd6e6; border-radius: 999px; padding: 5px 6px 5px 12px; font-size: 12.5px; }
    #lv-chips .lvc b { color: #f6b13b; font-weight: 700; }
    #lv-chips .lvc button { background: none; border: 0; color: #7e8ca6; cursor: pointer; font-size: 13px; padding: 0 4px; line-height: 1; }
    #lv-chips .lvc button:hover { color: #e0655f; }

    /* 📬 Vikuyfirlit */
    .dg-row { display: flex; gap: 10px; align-items: flex-start; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 12px 14px; cursor: pointer; font-size: 13px; color: #cdd6e6; line-height: 1.5; }
    .dg-row:hover { border-color: rgba(246,177,59,.4); }
    .dg-row input { margin-top: 3px; accent-color: #f6b13b; }
    .dg-row b { color: #eaf1fb; }
    .dg-note { font-size: 12px; color: #42d086; margin-top: 6px; }

    /* 📊 Mínar hagvísavaktir */
    #vaktir-mine .vk { display: flex; justify-content: space-between; gap: 8px; font-size: 13px; color: #cdd6e6; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    #vaktir-mine .vk-note { font-size: 12px; color: #7e8ca6; margin-top: 8px; }
    #vaktir-mine .vk-note a { color: #9fb0c8; }

    /* Fleiri vaktir — krosslindir */
    .more-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 10px; }
    .more-card { display: block; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 13px 15px; text-decoration: none; }
    .more-card:hover { border-color: rgba(246,177,59,.45); }
    .more-card b { color: #f6b13b; font-size: 14px; }
    .more-card span { display: block; color: #b9c6da; font-size: 12.5px; margin-top: 4px; line-height: 1.45; }
  </style>

  <!-- Eyja: leitarorðavakt (localStorage + WP /leitvakt), vikupóstur, mínar vaktir + lifandi veitur. -->
  <script>
    import { loadUser, karpGet, karpPost, loginHref } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    function initVaktir() {
      const mine = document.getElementById('vaktir-mine');
      if (!mine || mine.dataset.done) return;
      mine.dataset.done = '1';
      // 🔎 Leitarorðavaktin: orð í localStorage, upplýsir treff í öllum veitunum;
      // samstillist við WP (/leitvakt) svari sá endapunktur.
      const lvKey = 'karp-leitvakt';
      const lvLoad = () => { try { return JSON.parse(localStorage.getItem(lvKey) || '[]').filter((x) => typeof x === 'string'); } catch (e) { return []; } };
      const lvSave = (a) => { localStorage.setItem(lvKey, JSON.stringify(a.slice(0, 12))); try { karpPost('/leitvakt', { ord: a.slice(0, 12) }).catch(() => {}); } catch (e) {} };
      const lvHi = () => {
        const words = lvLoad().map((w) => w.toLowerCase());
        const counts = {};
        document.querySelectorAll('.feed .fi').forEach((el) => {
          const t = (el.textContent || '').toLowerCase();
          const hit = words.find((w) => w && t.includes(w));
          el.classList.toggle('hit', !!hit);
          if (hit) counts[hit] = (counts[hit] || 0) + 1;
        });
        document.querySelectorAll('#lv-chips .lvc').forEach((c) => {
          const w = (c.dataset.w || '').toLowerCase();
          const b = c.querySelector('b');
          if (b) b.textContent = counts[w] ? counts[w] : '';
        });
      };
      const lvRender = () => {
        const el = document.getElementById('lv-chips');
        if (!el) return;
        const words = lvLoad();
        el.innerHTML = words.length
          ? words.map((w) => `<span class="lvc" data-w="${esc(w)}">${esc(w)} <b></b><button title="Fjarlægja" aria-label="Fjarlægja ${esc(w)}">✕</button></span>`).join('')
          : '<span class="dim">Engin vakt enn — skráðu leitarorð að ofan.</span>';
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const w = b.closest('.lvc').dataset.w;
          lvSave(lvLoad().filter((x) => x !== w));
          lvRender(); lvHi();
        }));
        lvHi();
      };
      const lvAdd = () => {
        const inp = document.getElementById('lv-q');
        const w = (inp.value || '').trim().slice(0, 40);
        if (w.length < 2) return;
        const a = lvLoad();
        if (!a.includes(w)) { a.push(w); lvSave(a); }
        inp.value = '';
        lvRender();
      };
      const addBtn = document.getElementById('lv-add');
      if (addBtn) addBtn.addEventListener('click', lvAdd);
      const lvInp = document.getElementById('lv-q');
      if (lvInp) lvInp.addEventListener('keydown', (e) => { if (e.key === 'Enter') lvAdd(); });
      lvRender();
      // veiturnar hlaðast ósamstillt → endurmerkja í nokkrum umferðum
      [1800, 4000, 8000].forEach((t) => setTimeout(lvHi, t));
      // WP-samruni: sé notandi innskráður og endapunkturinn til, sameina orðin
      karpGet('/leitvakt').then((d) => {
        const remote = (d && d.ord) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...new Set([...lvLoad(), ...remote])].slice(0, 12);
          localStorage.setItem(lvKey, JSON.stringify(merged));
          lvRender();
        }
      }).catch(() => {});
      // 📬 Vikuyfirlitið: kveikja/slökkva á vikupóstinum (WP /digest, user meta)
      const dgOn = document.getElementById('dg-on'), dgNote = document.getElementById('dg-note');
      if (dgOn) {
        karpGet('/digest').then((d) => { if (d && typeof d.on === 'boolean') dgOn.checked = d.on; }).catch(() => {});
        dgOn.addEventListener('change', async () => {
          try {
            const r = await karpPost('/digest', { on: dgOn.checked });
            if (!r || r.ok !== true) throw new Error('no');
            dgNote.hidden = false;
            dgNote.textContent = r.on ? '✓ Vikuyfirlitið er virkt — fyrsti pósturinn berst næsta mánudagsmorgun.' : 'Vikuyfirlitið er óvirkt.';
          } catch (e) {
            dgOn.checked = false;
            dgNote.hidden = false;
            dgNote.innerHTML = `Vikuyfirlitið krefst innskráningar (ókeypis) — <a href="${loginHref()}" style="color:#f6b13b">skráðu þig inn</a> til að virkja það.`;
          }
        });
      }
      // 📊 Mínar hagvísavaktir
      loadUser().then(async (u) => {
        if (!u || !u.loggedIn) return;
        const vd = await karpGet('/vaktir');
        const arr = Array.isArray(vd) ? vd : (vd && vd.vaktir) || [];
        mine.innerHTML = (arr.length
          ? arr.map((v) => `<div class="vk"><span><b>${esc(v.metric || v.m || '')}</b> ${esc(v.area || '')} ${esc(v.dir === 'under' || v.dir === 'undir' ? 'fer undir' : 'fer yfir')} <b>${esc(v.threshold ?? v.vidmid ?? '')}</b></span></div>`).join('')
          : '<div class="vk">Engin vakt skráð enn.</div>')
          + '<div class="vk-note">Vaktir eru stofnaðar á <a href="/mitt-svaedi/">Mínu svæði</a> (Stillingar → Vaktir).</div>';
      }).catch(() => {});
      // ⚖️ Dómavaktin (HR + LR um /api/domar) + AI-endursögn reifunar (domar_ai.json)
      Promise.all([
        fetch('/api/domar').then((r) => (r.ok ? r.json() : null)).catch(() => null),
        fetch('/gogn/domar_ai.json').then((r) => (r.ok ? r.json() : null)).catch(() => null),
      ]).then(([d, ai]) => {
        const AI = (ai && ai.byNr) || {};
        const SITES = { hr: 'https://www.haestirettur.is/domar/', lr: 'https://www.landsrettur.is/domar-og-urskurdir/' };
        for (const key of ['hr', 'lr']) {
          const el = document.getElementById('domar-' + key);
          if (!el) continue;
          const list = d && Array.isArray(d[key]) ? d[key] : [];
          if (!list.length) { el.textContent = 'Dómarnir birtast þegar veitan svarar (proxy í dreifingu).'; continue; }
          el.innerHTML = list.slice(0, 8).map((v) => {
            const a = AI[key + ':' + v.nr];
            const skyring = a && a.einfalt ? a.einfalt : (v.um ? String(v.um).trim().slice(0, 150) + (String(v.um).trim().length > 150 ? '…' : '') : '');
            return `<a class="fi" href="${SITES[key]}" target="_blank" rel="noopener" title="${esc(v.um || '')}"><span class="t">Mál ${esc(v.nr)}: ${esc(String(v.titill || '').split(' gegn ')[0].slice(0, 60))}${String(v.titill || '').includes(' gegn ') ? ' gegn …' : ''}</span>${skyring ? `<span class="s dom-ai">${a && a.einfalt ? '💡 ' : ''}${esc(skyring)}${a && a.svid ? ` <span class="pill">${esc(a.svid)}</span>` : ''}</span>` : ''}<span class="s">${dIS(v.dags)}${(v.efnisord || []).length ? ' · ' + v.efnisord.slice(0, 3).map(esc).join(' · ') : ''}</span></a>`;
          }).join('');
        }
      }).catch(() => {});
      // 💬 Samráðsvaktin (island.is GraphQL um /api/samrad) + atvinnugreina-flokkun
      const SAMRAD_GREINAR = [
        ['Sjávarútvegur', /sjávar|fisk|veiði|kvót|eldi|hafi\b/i],
        ['Landbúnaður & matvæli', /landbún|bænd|búfé|matvæl|jarðrækt/i],
        ['Orka', /orku|raforku|virkj|jarðvarm|vindork|eldsneyt/i],
        ['Byggingar & húsnæði', /skipulag|bygging|mannvirki|húsnæð|lóð/i],
        ['Fjármál & skattar', /fjármál|skatt|gjald(?!frjáls)|banka|trygging|lífeyri|fjárlög/i],
        ['Heilbrigði', /heilbrigð|heilsu|lyf|sjúkra|lækn/i],
        ['Menntun', /mennt|skóla|háskól|leikskól|nám/i],
        ['Samgöngur', /samgöng|veg(?:a|i|ur)|flug|höfn|umferð|ökutæk/i],
        ['Umhverfi & loftslag', /umhverfi|loftslag|náttúr|mengun|úrgang|friðlýs/i],
        ['Ferðaþjónusta', /ferðaþjónust|ferðamann/i],
        ['Fjarskipti & tækni', /fjarskipt|netörygg|stafræn|gervigreind|upplýsingatækn/i],
        ['Vinnumarkaður', /vinnumark|kjaramál|starfsm|atvinnuleys|réttind.*starf/i],
      ];
      const samradGrein = (c) => { const hay = (c.name || '') + ' ' + (c.typeName || '') + ' ' + (c.institutionName || ''); const g = SAMRAD_GREINAR.find(([, rx]) => rx.test(hay)); return g ? g[0] : null; };
      fetch('/api/samrad')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('samrad-list');
          if (!el) return;
          const cs = ((((d || {}).data || {}).consultationPortalGetCases || {}).cases || []).map((c) => ({ ...c, grein: samradGrein(c) }));
          if (!cs.length) { el.textContent = 'Samráðsmálin birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          const render = (filter) => {
            const list = filter ? cs.filter((c) => c.grein === filter) : cs;
            el.innerHTML = (list.length ? list : cs).slice(0, 12).map((c) => {
              const open = /umsagnar/i.test(c.statusName || '');
              const frest = open && c.processEnds ? ` · frestur til ${dIS(c.processEnds)}` : '';
              return `<a class="fi" href="https://island.is/samradsgatt/mal/${esc(c.id)}" target="_blank" rel="noopener"><span class="t">${esc(c.name)}</span><span class="s"><span class="pill ${open ? 'op' : ''}">${esc(c.statusName || '')}</span>${c.grein ? ` <span class="pill gr">${esc(c.grein)}</span>` : ''} ${esc(c.institutionName || '')} · mál ${esc(c.caseNumber)}${frest}${c.adviceCount ? ` · ${c.adviceCount} umsagnir` : ''}</span></a>`;
            }).join('');
          };
          const pillsEl = document.getElementById('samrad-pills');
          const greinar = [...new Set(cs.map((c) => c.grein).filter(Boolean))];
          if (pillsEl && greinar.length) {
            pillsEl.innerHTML = `<button class="spill on" data-g="">Allt (${cs.length})</button>` + greinar.map((g) => `<button class="spill" data-g="${esc(g)}">${esc(g)} (${cs.filter((c) => c.grein === g).length})</button>`).join('');
            pillsEl.querySelectorAll('.spill').forEach((b) => b.addEventListener('click', () => {
              pillsEl.querySelectorAll('.spill').forEach((x) => x.classList.toggle('on', x === b));
              render(b.dataset.g || null);
            }));
          }
          render(null);
        })
        .catch(() => {});
      // 💸 Greiðsluvaktin (opnirreikningar.is um /api/greidslur)
      fetch('/api/greidslur')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('greidslur-list');
          if (!el) return;
          const rows = (d && Array.isArray(d.rows)) ? d.rows : [];
          if (!rows.length) { el.textContent = 'Greiðslurnar birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          const kr = (v) => (v == null ? '' : Math.round(v).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' kr');
          el.innerHTML = rows.slice(0, 12).map((g) => `<a class="fi" href="https://opnirreikningar.is/" target="_blank" rel="noopener" title="${esc(g.lysing || '')}"><span class="t">${esc(g.stofnun)} → <b>${esc(g.birgir)}</b> · <span class="${(g.upph || 0) < 0 ? 'neg' : 'pos'}">${kr(g.upph)}</span></span><span class="s">${dIS(g.dags)}${g.lysing ? ' · ' + esc(g.lysing.slice(0, 60)) : ''}</span></a>`).join('');
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vaktir"]')) initVaktir(); });
  </script>
</Layout>
