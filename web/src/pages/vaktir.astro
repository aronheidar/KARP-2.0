---
// ─────────────────────────────────────────────────────────────
// 🔔 VAKTIR (LOTA 16, liður 1) — vöktunarmiðstöð Karp: mínar vaktir (innskráð),
// LIFANDI útboðsvakt (utbodsvefur.is WP-REST + TED EES-útboð um worker-proxy)
// og heiðarlegur listi yfir lindir í smíðum. Grunnur að „Vakt Pro". #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
const updated = '2026-07-02';
const desc = 'Vaktir Karp — fylgstu með hagvísum, fjölmiðlaumfjöllun og opinberum útboðum á einum stað. Lifandi útboðsvakt af Útboðsvef og TED (EES-útboð á Íslandi).';
---

<Layout title="🔔 Vaktir — vöktunarmiðstöð | Karp" description={desc} canonical="https://karp.is/vaktir/" ogTitle="Vaktir Karp">
  <main data-pg="vaktir">
    <p class="kicker">Karp · Vöktun</p>
    <h1>🔔 Vaktir</h1>
    <p>Vöktunarmiðstöð Karp — það sem þú vilt frétta FYRST. Hagvísavaktir, fjölmiðlavöktun, dóma-, samráðs- og greiðsluvakt á einum stað. <a class="sec-link" href="/utbod/" style="margin-left:0">📋 Útboð eru komin á sér síðu →</a></p>

    <h2>Mínar vaktir <i class="tip" tabindex="0" data-tip="Hagvísavaktir senda tölvupóst þegar vísir nær viðmiði (t.d. verðbólga yfir 5%). Stofnaðar og sýndar hér innskráð(ur).">ⓘ</i></h2>
    <div id="vaktir-mine"><span class="dim">Tölvupósts-vaktir eru hluti af <a href="/karp-pro/" style="color:#f6b13b">Karp Pro</a> (ókeypis aðgangur) — leitarorðavaktin hér að neðan virkar án innskráningar.</span></div>

    <h2>🔎 Leitarorðavaktin <i class="tip" tabindex="0" data-tip="Skráðu leitarorð (t.d. fyrirtækið þitt, atvinnugrein eða málefni) — allt sem birtist í vöktunum hér að neðan og nefnir orðið er þá upplýst með gylltum ramma og talið. Orðin vistast í vafranum þínum; tölvupósts-tilkynningar fyrir innskráða eru næsta skref.">ⓘ</i></h2>
    <div class="lv-row">
      <input id="lv-q" type="text" maxlength="40" placeholder="T.d. „vegagerð“, „fiskeldi“, „gervigreind“…" autocomplete="off" />
      <button id="lv-add">Vakta orð</button>
    </div>
    <div id="lv-chips"></div>

    <h2>⚖️ Dómavaktin — lifandi <i class="tip" tabindex="0" data-tip="Nýjustu dómar beint af vefjum dómstólanna (opinber birting í síðukóða þeirra, engin ágiskun). Uppfærist á ~45 mín fresti um skyndiminnis-proxy Karp.">ⓘ</i></h2>
    <div class="ppair">
      <div>
        <h3>Hæstiréttur</h3>
        <div id="domar-hr" class="feed">Sæki dóma…</div>
      </div>
      <div>
        <h3>Landsréttur</h3>
        <div id="domar-lr" class="feed">Sæki dóma…</div>
      </div>
    </div>

    <h2>💬 Samráðsvaktin — lifandi <i class="tip" tabindex="0" data-tip="Nýjustu mál í samráðsgátt stjórnvalda um opna gagnagátt island.is — málsnúmer, staða, ráðuneyti og umsagnarfrestur. Smelltu til að lesa málið og senda umsögn.">ⓘ</i></h2>
    <div id="samrad-list" class="feed">Sæki samráðsmál…</div>

    <h2>💸 Greiðsluvaktin — lifandi <i class="tip" tabindex="0" data-tip="Nýjustu bókfærðu greiðslur ríkisins til birgja af opnirreikningar.is (Fjársýslan). Gögnin birtast með nokkurra vikna töf; neikvæð fjárhæð er bakfærsla/inneign. Síðustu ~45 dagar gagnatímabilsins.">ⓘ</i></h2>
    <div id="greidslur-list" class="feed">Sæki greiðslur ríkisins…</div>

    <h2>📰 Fjölmiðlavöktunin</h2>
    <p class="xref">Fyrirtæki, stofnanir, flokkar og einstaklingar — viðhorf, tímalínur og frjáls leit er á <a href="/frettir/">Vöktun (Umfjöllun)</a>. Erlend umfjöllun um Ísland er nýi 🌍-flipinn þar.</p>

    <h2>Í smíðum — næstu lindir <i class="tip" tabindex="0" data-tip="Lindirnar eru til en án opins gagnastraums: fyrirtækjaskrá birtir ekki skráningarstraum opið og héraðsdómar birta ekki dómalistann sinn í opnu formi enn.">ⓘ</i></h2>
    <ul class="soon">
      <li>🏢 <b>Fyrirtækjavakt</b> — nýskráningar og stjórnarbreytingar í fyrirtækjaskrá</li>
      <li>⚖️ <b>Héraðsdómar</b> — dómavaktin nær í dag til Hæstaréttar og Landsréttar</li>
    </ul>

    <p class="foot">Forþjónað (SSG) {updated}. Lifandi lindir: utbodsvefur.is (Ríkiskaup), api.ted.europa.eu, haestirettur.is, landsrettur.is, samráðsgátt (island.is) og opnirreikningar.is (Fjársýslan) — allt um skyndiminnis-proxy Karp. #2 LOTA 16–17.</p>
  </main>

  <style>
    main { max-width: 940px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    h3 { font-size: 13px; color: #cdd6e6; margin: 0 0 6px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .feed { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 11px; padding: 8px 12px; min-height: 80px; font-size: 13px; color: #9fb0c8; }
    .xref { font-size: 13.5px; } .xref a { color: #f6b13b; }
    .sec-link { font-size: 12px; color: #f6b13b; text-decoration: none; text-transform: none; letter-spacing: 0; margin-left: 10px; font-weight: 600; }
    .soon { margin: 0; padding-left: 4px; list-style: none; }
    .soon li { font-size: 13.5px; color: #b9c6da; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .soon b { color: #eaf1fb; }
    .dim { color: #7e8ca6; font-size: 13px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    #domar-hr .fi, #domar-lr .fi, #samrad-list .fi, #greidslur-list .fi { display: block; padding: 8px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    #greidslur-list .pos { color: #42d086; } #greidslur-list .neg { color: #e0655f; }
    #greidslur-list b { color: #f6b13b; font-weight: 600; }
    .lv-row { display: flex; gap: 8px; }
    #lv-q { flex: 1; max-width: 340px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 12px; color: #eaf1fb; font-size: 13px; }
    #lv-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #lv-add { background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.45); color: #f6b13b; border-radius: 10px; padding: 0 14px; font-size: 12.5px; font-weight: 600; cursor: pointer; }
    #lv-chips { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 9px; }
    #lv-chips .lvc { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #cdd6e6; border-radius: 999px; padding: 4px 6px 4px 11px; font-size: 12px; }
    #lv-chips .lvc b { color: #f6b13b; font-weight: 700; }
    #lv-chips .lvc button { background: none; border: 0; color: #7e8ca6; cursor: pointer; font-size: 13px; padding: 0 4px; }
    #lv-chips .lvc button:hover { color: #e0655f; }
    .fi.hit { border-left: 3px solid #f6b13b; padding-left: 8px; background: rgba(246,177,59,.06); border-radius: 6px; }
    #samrad-list .pill { display: inline-block; padding: 1px 7px; border-radius: 8px; font-size: 10.5px; background: rgba(255,255,255,.08); color: #9fb0c8; }
    #samrad-list .pill.op { background: rgba(66,208,134,.16); color: #42d086; }
    .fi .t { display: block; font-size: 13px; color: #eaf1fb; line-height: 1.35; }
    .fi:hover .t { color: #f6b13b; }
    .fi .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    #vaktir-mine .vk { display: flex; justify-content: space-between; gap: 8px; font-size: 13px; color: #cdd6e6; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    #vaktir-mine .vk-note { font-size: 12px; color: #7e8ca6; margin-top: 8px; }
    #vaktir-mine .vk-note a { color: #9fb0c8; }
  </style>

  <!-- Eyja: mínar vaktir (auth) + lifandi útboð (worker-proxy). #2 LOTA 16 -->
  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    function initVaktir() {
      const mine = document.getElementById('vaktir-mine');
      if (!mine || mine.dataset.done) return;
      mine.dataset.done = '1';
      // 🔎 Leitarorðavaktin (LOTA 18 #7 v1): orð í localStorage, upplýsir treff í
      // öllum veitunum; samstillist við WP (/leitvakt) svari sá endapunktur.
      const lvKey = 'karp-leitvakt';
      const lvLoad = () => { try { return JSON.parse(localStorage.getItem(lvKey) || '[]').filter((x) => typeof x === 'string'); } catch (e) { return []; } };
      const lvSave = (a) => { localStorage.setItem(lvKey, JSON.stringify(a.slice(0, 12))); try { karpPost('/leitvakt', { ord: a.slice(0, 12) }).catch(() => {}); } catch (e) {} };
      const lvHi = () => {
        const words = lvLoad().map((w) => w.toLowerCase());
        const counts = {};
        document.querySelectorAll('.feed .fi').forEach((el) => {
          const t = (el.textContent || '').toLowerCase();
          const hit = words.find((w) => w && t.includes(w));
          el.classList.toggle('hit', !!hit);
          if (hit) counts[hit] = (counts[hit] || 0) + 1;
        });
        document.querySelectorAll('#lv-chips .lvc').forEach((c) => {
          const w = (c.dataset.w || '').toLowerCase();
          const b = c.querySelector('b');
          if (b) b.textContent = counts[w] ? counts[w] : '';
        });
      };
      const lvRender = () => {
        const el = document.getElementById('lv-chips');
        if (!el) return;
        el.innerHTML = lvLoad().map((w) => `<span class="lvc" data-w="${esc(w)}">${esc(w)} <b></b><button title="Fjarlægja" aria-label="Fjarlægja ${esc(w)}">✕</button></span>`).join('');
        el.querySelectorAll('.lvc button').forEach((b) => b.addEventListener('click', () => {
          const w = b.closest('.lvc').dataset.w;
          lvSave(lvLoad().filter((x) => x !== w));
          lvRender(); lvHi();
        }));
        lvHi();
      };
      const lvAdd = () => {
        const inp = document.getElementById('lv-q');
        const w = (inp.value || '').trim().slice(0, 40);
        if (w.length < 2) return;
        const a = lvLoad();
        if (!a.includes(w)) { a.push(w); lvSave(a); }
        inp.value = '';
        lvRender();
      };
      const addBtn = document.getElementById('lv-add');
      if (addBtn) addBtn.addEventListener('click', lvAdd);
      const lvInp = document.getElementById('lv-q');
      if (lvInp) lvInp.addEventListener('keydown', (e) => { if (e.key === 'Enter') lvAdd(); });
      lvRender();
      // veiturnar hlaðast ósamstillt → endurmerkja í nokkrum umferðum
      [1800, 4000, 8000].forEach((t) => setTimeout(lvHi, t));
      // WP-samruni: sé notandi innskráður og endapunkturinn til, sameina orðin
      karpGet('/leitvakt').then((d) => {
        const remote = (d && d.ord) || [];
        if (Array.isArray(remote) && remote.length) {
          const merged = [...new Set([...lvLoad(), ...remote])].slice(0, 12);
          localStorage.setItem(lvKey, JSON.stringify(merged));
          lvRender();
        }
      }).catch(() => {});
      // Mínar hagvísavaktir
      loadUser().then(async (u) => {
        if (!u || !u.loggedIn) return;
        const vd = await karpGet('/vaktir');
        const arr = Array.isArray(vd) ? vd : (vd && vd.vaktir) || [];
        mine.innerHTML = (arr.length
          ? arr.map((v) => `<div class="vk"><span><b>${esc(v.metric || v.m || '')}</b> ${esc(v.area || '')} ${esc(v.dir === 'under' || v.dir === 'undir' ? 'fer undir' : 'fer yfir')} <b>${esc(v.threshold ?? v.vidmid ?? '')}</b></span></div>`).join('')
          : '<div class="vk">Engin vakt skráð enn.</div>')
          + '<div class="vk-note">Vaktir eru stofnaðar á <a href="/mitt-svaedi/">Mínu svæði</a> (Stillingar → Vaktir).</div>';
      }).catch(() => {});
      // ⚖️ Dómavaktin (HR + LR um /api/domar)
      fetch('/api/domar')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const SITES = { hr: 'https://www.haestirettur.is/domar/', lr: 'https://www.landsrettur.is/domar-og-urskurdir/' };
          for (const key of ['hr', 'lr']) {
            const el = document.getElementById('domar-' + key);
            if (!el) continue;
            const list = d && Array.isArray(d[key]) ? d[key] : [];
            if (!list.length) { el.textContent = 'Dómarnir birtast þegar veitan svarar (proxy í dreifingu).'; continue; }
            el.innerHTML = list.slice(0, 8).map((v) => `<a class="fi" href="${SITES[key]}" target="_blank" rel="noopener" title="${esc(v.um || '')}"><span class="t">Mál ${esc(v.nr)}: ${esc(String(v.titill || '').split(' gegn ')[0].slice(0, 60))}${String(v.titill || '').includes(' gegn ') ? ' gegn …' : ''}</span><span class="s">${dIS(v.dags)}${(v.efnisord || []).length ? ' · ' + v.efnisord.slice(0, 3).map(esc).join(' · ') : ''}</span></a>`).join('');
          }
        })
        .catch(() => {});
      // 💬 Samráðsvaktin (island.is GraphQL um /api/samrad)
      fetch('/api/samrad')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('samrad-list');
          if (!el) return;
          const cs = (((d || {}).data || {}).consultationPortalGetCases || {}).cases || [];
          if (!cs.length) { el.textContent = 'Samráðsmálin birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          el.innerHTML = cs.slice(0, 12).map((c) => {
            const open = /umsagnar/i.test(c.statusName || '');
            const frest = open && c.processEnds ? ` · frestur til ${dIS(c.processEnds)}` : '';
            return `<a class="fi" href="https://island.is/samradsgatt/mal/${esc(c.id)}" target="_blank" rel="noopener"><span class="t">${esc(c.name)}</span><span class="s"><span class="pill ${open ? 'op' : ''}">${esc(c.statusName || '')}</span> ${esc(c.institutionName || '')} · mál ${esc(c.caseNumber)}${frest}${c.adviceCount ? ` · ${c.adviceCount} umsagnir` : ''}</span></a>`;
          }).join('');
        })
        .catch(() => {});
      // 💸 Greiðsluvaktin (opnirreikningar.is um /api/greidslur)
      fetch('/api/greidslur')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('greidslur-list');
          if (!el) return;
          const rows = (d && Array.isArray(d.rows)) ? d.rows : [];
          if (!rows.length) { el.textContent = 'Greiðslurnar birtast þegar veitan svarar (proxy í dreifingu).'; return; }
          const kr = (v) => (v == null ? '' : Math.round(v).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' kr');
          el.innerHTML = rows.slice(0, 12).map((g) => `<a class="fi" href="https://opnirreikningar.is/" target="_blank" rel="noopener" title="${esc(g.lysing || '')}"><span class="t">${esc(g.stofnun)} → <b>${esc(g.birgir)}</b> · <span class="${(g.upph || 0) < 0 ? 'neg' : 'pos'}">${kr(g.upph)}</span></span><span class="s">${dIS(g.dags)}${g.lysing ? ' · ' + esc(g.lysing.slice(0, 60)) : ''}</span></a>`).join('');
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="vaktir"]')) initVaktir(); });
  </script>
</Layout>
