    .fv-sv { color: #7e8ca6; font-size: 11.5px; font-weight: 400; }
    .fv-v { color: #f6b13b; }
    /* 🏷️ Verðmatið (LOTA 47) */
    .fvm-row input[type="number"] { max-width: 90px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 10px; color: #eaf1fb; font-size: 13px; }
    .fvm-row input[type="number"]:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .fvm-row select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 10px; color: #eaf1fb; font-size: 13px; }
    .fvm-row select option { background: #0e1420; }
    .fvm-row input[type="text"] { flex: 1; max-width: 300px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 12px; color: #eaf1fb; font-size: 13px; }
    .fvm-row input[type="text"]:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .fvm-row button { background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.45); color: #f6b13b; border-radius: 10px; padding: 0 16px; font-size: 12.5px; font-weight: 700; cursor: pointer; }
    #fvm-out { margin-top: 10px; font-size: 13px; color: #9fb0c8; }
    .fvm-card { background: rgba(246,177,59,.07); border: 1px solid rgba(246,177,59,.3); border-radius: 12px; padding: 14px 16px; }
    .fvm-big { font-size: 30px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
