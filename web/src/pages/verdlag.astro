---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2). Keyrir á BYGGINGARTÍMA: sækir verðbólgu af Hagstofu
// og bakar inn í forþjónað HTML. Importar úr sameiginlega src/lib gegnum @lib.
// Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import { monthLabel, fmtNum, MON_LONG } from '@lib/format.mjs';
import Layout from '../layouts/Layout.astro';
import ATV from '@gogn/atvinnuleysi.json';
import NUMBEO from '@gogn/numbeo.json';

import ATVINNULEYSI from '@gogn/atvinnuleysi.json';

let rows = [];
let err = null;
try {
  const body = JSON.stringify({
    query: [
      { code: 'Mánuður', selection: { filter: 'top', values: ['24'] } },
      { code: 'Vísitala', selection: { filter: 'item', values: ['CPI'] } },
      { code: 'Liður', selection: { filter: 'item', values: ['change_A'] } },
    ],
    response: { format: 'json' },
  });
  const res = await fetch(
    'https://px.hagstofa.is/pxis/api/v1/is/Efnahagur/visitolur/1_vnv/1_vnv/VIS01000.px',
    { method: 'POST', body }
  );
  const j = await res.json();
  rows = j.data
    .map((d) => ({ t: d.key[0], v: parseFloat(String(d.values[0]).replace(',', '.')) }))
    .filter((r) => !isNaN(r.v));
} catch (e) {
  err = e.message;
}

const labels = rows.map((r) => monthLabel(r.t));   // ← @lib/format
const vals = rows.map((r) => r.v);
const latest = rows.length ? rows[rows.length - 1] : null;
const latestPct = latest ? fmtNum(latest.v, 1) : '—'; // ← @lib/format
const updated = '2026-07-01';

// --- Lykiltölur (#2 ríkari efnahagur): gengi (frankfurter/ECB á byggingartíma) + atvinnuleysi + stýrivextir ---
let fx = null;
try {
  const fr = await fetch('https://api.frankfurter.app/latest?from=EUR&to=ISK,USD,GBP');
  const fj = await fr.json();
  const eurIsk = fj.rates.ISK; // ISK per EUR
  fx = { date: fj.date, eur: eurIsk, usd: eurIsk / fj.rates.USD, gbp: eurIsk / fj.rates.GBP };
} catch (e) { /* fx null → strikin sýna – */ }
const unemp = ATVINNULEYSI.latest;         // % skráð atvinnuleysi (Vinnumálastofnun)
// Seðlabanki birtir stýrivexti EKKI um opið CORS-API → hardkóðað með dagsetningu, uppfæra eftir hverja vaxtaákvörðun.
const POLICY = { rate: 7.75, from: '20.5.2026', next: '19.8.2026' };

// Næsti mánuður (fyrir spá-eyjuna) + stöðugur topic-lykill.
let nextLabel = '', spaTopic = 'vnv_ars_next';
if (latest) {
  const mm = /^(\d{4})M(\d{2})$/.exec(latest.t);
  if (mm) { let y = +mm[1], mo = +mm[2] + 1; if (mo > 12) { mo = 1; y++; } nextLabel = `${MON_LONG[mo - 1]} ${y}`; spaTopic = `vnv_ars_${y}_${mo}`; }
}

// ── Fleiri hagvísar (allt sótt á byggingartíma, hver hluti þolir bilun) ──
const px = async (url, query) => (await fetch(url, { method: 'POST', body: JSON.stringify({ query, response: { format: 'json' } }) })).json();
const sel = (code, filter, values) => ({ code, selection: { filter, values } });

// Stýrivextir: engin opin API-heimild → handfært eftir hverja vaxtaákvörðun SÍ.
const STYRIVEXTIR = { v: 7.75, fra: '20. maí 2026', naest: '19. ágúst 2026' };

// Gengi (frankfurter/ECB): nýjasta EUR/USD/GBP + 1 árs EUR/ISK ferill.
let FX = null;
try {
  const [lat, rng] = await Promise.all([
    fetch('https://api.frankfurter.dev/v1/latest?base=EUR&symbols=ISK,USD,GBP').then((r) => r.json()),
    fetch('https://api.frankfurter.dev/v1/2025-07-01..?base=EUR&symbols=ISK').then((r) => r.json()),
  ]);
  const dates = Object.keys(rng.rates || {}).sort();
  FX = {
    eur: Math.round(lat.rates.ISK * 10) / 10,
    usd: Math.round((lat.rates.ISK / lat.rates.USD) * 10) / 10,
    gbp: Math.round((lat.rates.ISK / lat.rates.GBP) * 10) / 10,
    date: lat.date, dates, vals: dates.map((d) => Math.round(rng.rates[d].ISK * 100) / 100),
  };
  if (!FX.dates.length) FX = null;
} catch (e) { FX = null; }

// Uppruni verðbólgunnar (VIS01101): framlag = vægi × 12-mán verðbreyting flokks.
const INFLCAT = { '2a': ['Innlendar vörur', '#46e08a'], '2ai': ['Innfluttar vörur', '#3a8dff'], '2bii': ['Blandaðar vörur', '#1fb6c9'], '5a': ['Ferðaþjónusta', '#c95cf7'], '5b': ['Húsnæði', '#f6b13b'], '5c': ['Opinber þjónusta', '#ff8a3d'], '5d': ['Önnur þjónusta', '#8892a6'] };
let INFLSRC = null;
try {
  const CATS = Object.keys(INFLCAT);
  const j = await px('https://px.hagstofa.is/pxis/api/v1/is/Efnahagur/visitolur/1_vnv/3_greiningarvisitolur/VIS01101.px', [
    sel('Mánuður', 'top', ['27']), sel('Liður', 'item', ['index', 'breakdown']), sel('Útgjaldaflokkur', 'item', CATS),
  ]);
  const idx = {}, wgt = {};
  j.data.forEach((d) => {
    const t = d.key.find((k) => /^\d{4}M\d{2}$/.test(k));
    const cat = d.key.find((k) => CATS.includes(k));
    const lidur = d.key.find((k) => k === 'index' || k === 'breakdown');
    const v = parseFloat(String(d.values[0]).replace(',', '.'));
    if (!t || !cat || !lidur || isNaN(v)) return;
    const M = lidur === 'index' ? idx : wgt;
    (M[cat] = M[cat] || {})[t] = v;
  });
  const months = [...new Set(j.data.map((d) => d.key.find((k) => /^\d{4}M\d{2}$/.test(k))))].filter(Boolean).sort();
  const prev12 = (t) => { const m = /^(\d{4})M(\d{2})$/.exec(t); return m ? `${+m[1] - 1}M${m[2]}` : null; };
  const useM = months.filter((t) => months.includes(prev12(t))).slice(-13);
  const series = CATS.map((c) => ({
    name: INFLCAT[c][0], color: INFLCAT[c][1],
    data: useM.map((t) => {
      const a = idx[c] && idx[c][t], b = idx[c] && idx[c][prev12(t)], w = wgt[c] && wgt[c][t];
      return a != null && b != null && w != null ? Math.round((w / 100) * ((a / b - 1) * 100) * 100) / 100 : null;
    }),
  }));
  if (useM.length) INFLSRC = { months: useM.map(monthLabel), series };
} catch (e) { INFLSRC = null; }

// Neyslukarfan (VIS01300): vægi COICOP-yfirflokka í vísitölunni.
const CPLBL = { CP01: 'Matur & drykkir', CP02: 'Áfengi & tóbak', CP03: 'Föt & skór', CP04: 'Húsnæði & orka', CP05: 'Húsbúnaður', CP06: 'Heilsa', CP07: 'Ferðir & flutningar', CP08: 'Póstur & sími', CP09: 'Tómstundir & menning', CP10: 'Menntun', CP11: 'Hótel & veitingar', CP12: 'Annað' };
let BASKET = null;
try {
  const j = await px('https://px.hagstofa.is/pxis/api/v1/is/Efnahagur/visitolur/1_vnv/2_undirvisitolur/VIS01300.px', [
    sel('Mánuður', 'top', ['1']), sel('Liður', 'item', ['breakdown']), sel('Undirvísitala', 'item', Object.keys(CPLBL)),
  ]);
  const items = [];
  j.data.forEach((d) => {
    const cp = d.key.find((k) => CPLBL[k]);
    const v = parseFloat(String(d.values[0]).replace(',', '.'));
    if (cp && !isNaN(v)) items.push({ name: CPLBL[cp], value: Math.round(v * 10) / 10 });
  });
  if (items.length >= 8) BASKET = items.sort((a, b) => b.value - a.value);
} catch (e) { BASKET = null; }

const atvLatest = ATV.latest;

const idx = NUMBEO.indices || {};
const lab = NUMBEO.labels || {};
const order = NUMBEO.order || Object.keys(idx);
const rvk = idx.Reykjavik || {};
const cities = order.filter((c) => idx[c]).map((c) => ({ key: c, label: (lab[c] || {}).label || c, home: !!(lab[c] || {}).home, ...idx[c] }));
const colBars = cities.slice().sort((a, b) => (a.col || 0) - (b.col || 0)).map((c) => ({ label: c.label, v: c.col, home: c.home }));
const ppBars = cities.slice().sort((a, b) => (b.pp || 0) - (a.pp || 0)).map((c) => ({ label: c.label, v: c.pp, home: c.home }));
const tiles = [
  { e: '🧾', l: 'Framfærsla', v: rvk.col, s: 'vísitala (hærra=dýrara)' },
  { e: '🏠', l: 'Leiga', v: rvk.rent, s: 'vísitala' },
  { e: '🛒', l: 'Matvara', v: rvk.groceries, s: 'vísitala' },
  { e: '🍽️', l: 'Veitingar', v: rvk.restaurant, s: 'vísitala' },
  { e: '💪', l: 'Kaupmáttur', v: rvk.pp, s: 'hærra = betri' },
];
const ppRank = ppBars.findIndex((c) => c.home) + 1;
const RADCITIES = ['Reykjavik', 'Copenhagen', 'Oslo', 'New-York'].filter((c) => idx[c]);
const RADAXES = [['col', 'Framfærsla'], ['rent', 'Leiga'], ['groceries', 'Matvara'], ['restaurant', 'Veitingar'], ['pp', 'Kaupmáttur']];
const RADMAX = RADAXES.map(([k]) => Math.max(...RADCITIES.map((c) => idx[c][k] || 0)) * 1.15);
const RADCOL = { Reykjavik: '#f6b13b', Copenhagen: '#3a8dff', Oslo: '#46e08a', 'New-York': '#c95cf7' };
const RADAR = {
  ind: RADAXES.map(([k, l], i) => ({ name: l, max: Math.round(RADMAX[i]) })),
  series: RADCITIES.map((c) => ({ name: (lab[c] || {}).label || c, color: RADCOL[c] || '#8892a6', value: RADAXES.map(([k]) => idx[c][k] ?? 0) })),
};
const pr = NUMBEO.prices || {};
const items = NUMBEO.items || [];
const seenCat = {};
const PRICETABLE = items
  .map((it, i) => ({ is: it.is || it.name, cat: it.cat, rvk: (pr.Reykjavik || [])[i], cph: (pr.Copenhagen || [])[i] }))
  .filter((r) => r.rvk != null && r.cph != null)
  .filter((r) => { seenCat[r.cat] = (seenCat[r.cat] || 0) + 1; return seenCat[r.cat] <= 3; })
  .slice(0, 15);
const kr = (v) => (v == null ? '–' : String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' kr');
const desc = `Ársverðbólga á Íslandi mælist ${latestPct}%${
  latest ? ' í ' + monthLabel(latest.t) : ''
}. Þróun vísitölu neysluverðs síðustu ${rows.length} mánuði — sótt beint frá Hagstofu Íslands.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Ársverðbólga á Íslandi',
  description: 'Mánaðarleg ársverðbólga (12-mánaða breyting vísitölu neysluverðs) á Íslandi.',
  creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' },
  dateModified: updated,
  spatialCoverage: 'Ísland',
  measurementTechnique: '12-mánaða breyting vísitölu neysluverðs (Hagstofa Íslands, VIS01000)',
  variableMeasured: 'Ársverðbólga (%)',
};
---

<Layout
  title={`Verðbólga á Íslandi — ${latestPct}% | Karp`}
  description={desc}
  canonical="https://app.karp.is/verdlag/"
  jsonLd={jsonLd}
  ogTitle={`Verðbólga á Íslandi — ${latestPct}%`}
>
  <main>
    <p class="kicker">Hagvísir Íslands · Verðlag</p>
    <h1>Verðlag</h1>
    <div class="big">{latestPct}%{latest && <span>ársverðbólga · {monthLabel(latest.t)}</span>}</div>
    <p>
      Ársverðbólga — 12-mánaða breyting vísitölu neysluverðs — mælist nú <strong>{latestPct}%</strong>{
        latest ? `, í ${monthLabel(latest.t)}` : ''
      }. Grafið sýnir þróunina síðustu {rows.length} mánuði; strikalínan markar 2,5% verðbólgumarkmið
      Seðlabanka Íslands. Heimild: Hagstofa Íslands.
    </p>

    <h2>Lykiltölur</h2>
    <div class="kpis">
      <div class="kpi"><div class="k-l">📉 Verðbólga</div><div class="k-v">{latestPct}%</div><div class="k-s">ársverðbólga</div></div>
      <div class="kpi"><div class="k-l">🏦 Stýrivextir</div><div class="k-v">{fmtNum(POLICY.rate, 2)}%</div><div class="k-s">frá {POLICY.from}</div></div>
      <div class="kpi"><div class="k-l">👷 Atvinnuleysi</div><div class="k-v">{fmtNum(unemp, 1)}%</div><div class="k-s">skráð</div></div>
      <div class="kpi"><div class="k-l">€ EUR/ISK</div><div class="k-v">{fx ? fmtNum(fx.eur, 1) : '–'}</div><div class="k-s">kr. per €</div></div>
      <div class="kpi"><div class="k-l">$ USD/ISK</div><div class="k-v">{fx ? fmtNum(fx.usd, 1) : '–'}</div><div class="k-s">kr. per $</div></div>
      <div class="kpi"><div class="k-l">£ GBP/ISK</div><div class="k-v">{fx ? fmtNum(fx.gbp, 1) : '–'}</div><div class="k-s">kr. per £</div></div>
    </div>
    <p class="src">
      Gengi: frankfurter.app (ECB){fx ? `, ${fx.date}` : ''} · Stýrivextir: Seðlabanki Íslands (næsta ákvörðun {POLICY.next}) · Atvinnuleysi: Vinnumálastofnun ({ATVINNULEYSI.updated}).
    </p>

    <h2>Verðbólga — þróun</h2>
    <div class="kpis">
      <div class="kpi"><div class="k-l">🏦 Stýrivextir</div><div class="k-v">{fmtNum(STYRIVEXTIR.v, 2)}%</div><div class="k-s">frá {STYRIVEXTIR.fra}</div></div>
      {FX && <div class="kpi"><div class="k-l">💶 Evra</div><div class="k-v">{fmtNum(FX.eur, 1)}</div><div class="k-s">kr · {FX.date}</div></div>}
      {FX && <div class="kpi"><div class="k-l">💵 Dalur</div><div class="k-v">{fmtNum(FX.usd, 1)}</div><div class="k-s">kr</div></div>}
      {FX && <div class="kpi"><div class="k-l">💷 Pund</div><div class="k-v">{fmtNum(FX.gbp, 1)}</div><div class="k-s">kr</div></div>}
      <div class="kpi"><div class="k-l">👷 Atvinnuleysi</div><div class="k-v">{fmtNum(atvLatest, 1)}%</div><div class="k-s">skráð · <a href="/atvinnuleysi/">nánar</a></div></div>
    </div>

    <div id="chart" role="img" aria-label={`Línurit: ársverðbólga síðustu ${rows.length} mánuði, nú ${latestPct}%`}></div>

    <h2>Mánaðarleg gildi</h2>
    <table>
      <thead><tr><th>Mánuður</th><th>Ársverðbólga</th></tr></thead>
      <tbody>
        {rows.map((r) => (
          <tr><td>{monthLabel(r.t)}</td><td>{fmtNum(r.v, 1)}%</td></tr>
        ))}
      </tbody>
    </table>

    <div id="spa" class="spa-card" data-topic={spaTopic} data-next={nextLabel} data-now={latestPct}></div>

    {INFLSRC && (
      <>
        <h2>Hvaðan kemur verðbólgan?</h2>
        <div id="chart-src"></div>
        <p class="src">Framlag útgjaldaflokka til ársverðbólgu (vægi × 12-mánaða verðbreyting flokks) — húsnæði og þjónusta á móti inn-/útfluttum vörum. Heimild: Hagstofa (VIS01101).</p>
      </>
    )}

    {BASKET && (
      <>
        <h2>Neyslukarfan — hvað vegur þyngst?</h2>
        <div id="chart-basket"></div>
        <p class="src">Vægi útgjaldaflokka í vísitölu neysluverðs (%). Heimild: Hagstofa (VIS01300).</p>
      </>
    )}

    {FX && (
      <>
        <h2>Gengi krónunnar — evran síðasta árið</h2>
        <div id="chart-fx"></div>
        <p class="src">Krónur á evru (ECB-viðmiðunargengi). Nýjast: {fmtNum(FX.eur, 1)} kr ({FX.date}). Næsta vaxtaákvörðun SÍ: {STYRIVEXTIR.naest}.</p>
      </>
    )}

    <div class="kpis">
      {tiles.map((t) => (
        <div class="kpi"><div class="k-l">{t.e} {t.l}</div><div class="k-v">{t.v != null ? fmtNum(t.v, 1) : '–'}</div><div class="k-s">{t.s}</div></div>
      ))}
    </div>

    <div class="ppair">
      <div>
        <h2>Framfærslukostnaður — borgir</h2>
        <div id="chart-col"></div>
      </div>
      <div>
        <h2>Kaupmáttur — borgir</h2>
        <div id="chart-pp"></div>
      </div>
    </div>

    <h2>Borgaradar — Reykjavík í samanburði</h2>
    <div id="chart-radar"></div>
    <p class="srcnote">Ytri brún = hærri vísitala (dýrara — nema kaupmáttur, þar er ytra betra).</p>

    <h2>Verð á algengum vörum — Reykjavík vs Kaupmannahöfn</h2>
    <div class="tw">
      <table>
        <thead><tr><th class="l">Vara/þjónusta</th><th>Reykjavík</th><th>Kaupmannahöfn</th><th>Munur</th></tr></thead>
        <tbody>
          {PRICETABLE.map((r) => {
            const d = r.cph ? Math.round(((r.rvk - r.cph) / r.cph) * 100) : null;
            return (
              <tr>
                <td class="l">{r.is}</td>
                <td class="num">{kr(r.rvk)}</td>
                <td class="num">{kr(r.cph)}</td>
                <td class={`num ${d > 0 ? 'dn' : 'up'}`}>{d == null ? '–' : (d > 0 ? '+' : '') + d + '%'}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    {err && <p class="err">Villa við gagnasókn á byggingartíma: {err}</p>}

    <p class="foot">
      Forþjónað (SSG) {updated}. Gögnin sótt af Hagstofu Íslands <strong>á byggingartíma</strong> og bökuð
      inn í HTML-ið. Mánaðaheiti + tölur eru sniðin með <strong>sameiginlega <code>src/lib</code></strong>
      (<code>@lib/format.mjs</code>) — #2 sameining.
    </p>
  </main>

  <style>
    main { max-width: 760px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    .big { font-size: 52px; font-weight: 800; color: #f6b13b; line-height: 1; margin: 6px 0 2px; }
    .big span { font-size: 15px; font-weight: 500; color: #9fb0c8; margin-left: 6px; }
    p { color: #cdd6e6; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(118px, 1fr)); gap: 10px; margin: 4px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 11px 13px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 22px; font-weight: 800; color: #f6b13b; line-height: 1.15; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    .src { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    #chart-col, #chart-pp { width: 100%; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }

    #chart-radar { width: 100%; height: 360px; }
    .srcnote { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    .tw { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 520px; }
    th, td { text-align: right; padding: 7px 10px; border-bottom: 1px solid rgba(255,255,255,.08); white-space: nowrap; }
    th { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
    td.l, th.l { text-align: left; white-space: normal; }
    .num { font-variant-numeric: tabular-nums; }
    .up { color: #46e08a; } .dn { color: #ff6d7a; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }

    #chart { width: 100%; height: 360px; margin: 20px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(118px, 1fr)); gap: 10px; margin: 18px 0 4px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 10px 12px; }
    .k-l { font-size: 11px; color: #9fb0c8; }
    .k-v { font-size: 21px; font-weight: 800; color: #eaf1fb; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 10.5px; color: #7e8ca6; }
    .k-s a { color: #9fb0c8; }
    #chart-src { width: 100%; height: 330px; }
    #chart-basket { width: 100%; height: 340px; }
    #chart-fx { width: 100%; height: 270px; }
    .src { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th, td { text-align: left; padding: 7px 10px; border-bottom: 1px solid rgba(255,255,255,.08); }
    th { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; }
    td:last-child, th:last-child { text-align: right; font-variant-numeric: tabular-nums; }
    .err { color: #ff8e98; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Spá-eyjan er búin til á keyrslutíma → global (ekki Astro-scoped). */
    .spa-card { margin: 24px 0 6px; padding: 16px 18px; background: rgba(124,92,247,.08); border: 1px solid rgba(124,92,247,.28); border-radius: 12px; }
    .spa-h { font-weight: 700; font-size: 15px; color: #eaf1fb; }
    .spa-sub { font-size: 13px; color: #9fb0c8; margin-top: 2px; }
    .spa-avg { font-size: 14px; color: #cdd6e6; margin-top: 10px; }
    .spa-avg span { color: #7e8ca6; font-size: 12px; }
    .spa-form { display: flex; gap: 8px; margin-top: 10px; }
    .spa-form input { width: 120px; background: #0e1626; border: 1px solid rgba(255,255,255,.15); color: #eaf1fb; border-radius: 8px; padding: 7px 10px; font-size: 14px; }
    .spa-form button { background: #7c5cf7; color: #fff; border: 0; border-radius: 8px; padding: 7px 14px; font-weight: 700; cursor: pointer; font-size: 14px; }
    .spa-form button:disabled { opacity: .6; }
    .spa-mine { font-size: 13px; color: #b9a6ff; margin-top: 8px; }
    .spa-gate { font-size: 14px; color: #9fb0c8; margin-top: 10px; }
    .spa-gate a { color: #f6b13b; }
  </style>

  <!-- Eyja: ECharts hydrast í vafra með bökuðu gögnunum -->
  <script define:vars={{ labels, vals }}>
    function initChart() {
      const el = document.getElementById('chart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initChart, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        grid: { left: 46, right: 16, top: 18, bottom: 28 },
        xAxis: {
          type: 'category',
          data: labels,
          axisLabel: { color: '#7e8ca6', fontSize: 11 },
          axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } },
        },
        yAxis: {
          type: 'value',
          axisLabel: { color: '#7e8ca6', formatter: '{value}%' },
          splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } },
        },
        tooltip: { trigger: 'axis', valueFormatter: (v) => v + '%' },
        series: [{
          type: 'line',
          data: vals,
          smooth: true,
          symbol: 'circle',
          symbolSize: 6,
          lineStyle: { width: 3, color: '#f6b13b' },
          itemStyle: { color: '#f6b13b' },
          areaStyle: { opacity: 0.14, color: '#f6b13b' },
          markLine: {
            silent: true,
            symbol: 'none',
            data: [{ yAxis: 2.5 }],
            lineStyle: { type: 'dashed', color: 'rgba(255,255,255,.3)' },
            label: { formatter: 'markmið 2,5%', color: '#9fb0c8', fontSize: 11 },
          },
        }],
      });
      window.addEventListener('resize', () => chart.resize());
    }
    document.addEventListener('astro:page-load', initChart);
  </script>

  <!-- Eyja: uppruni verðbólgu + neyslukarfa + gengi (þrjú gröf). #2 -->
  <script define:vars={{ INFLSRC, BASKET, FX }}>
    function initExtra() {
      if (!document.getElementById('chart-src') && !document.getElementById('chart-basket') && !document.getElementById('chart-fx')) return;
      const go = () => {
        const cs = document.getElementById('chart-src');
        if (cs && INFLSRC && !window.echarts.getInstanceByDom(cs)) {
          const c = window.echarts.init(cs);
          const totals = INFLSRC.months.map((_, i) => Math.round(INFLSRC.series.reduce((s, x) => s + (x.data[i] || 0), 0) * 10) / 10);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { textStyle: { color: '#9fb0c8', fontSize: 10.5 }, top: 0, type: 'scroll' },
            grid: { left: 40, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: INFLSRC.months, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}pp' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v.toFixed(2).replace('.', ',') + ' pp') },
            series: [
              ...INFLSRC.series.map((s) => ({ name: s.name, type: 'bar', stack: 'infl', data: s.data, itemStyle: { color: s.color }, barWidth: 13 })),
              { name: 'Alls', type: 'line', data: totals, smooth: true, symbol: 'circle', symbolSize: 4, lineStyle: { width: 2, color: '#eaf1fb', type: 'dashed' }, itemStyle: { color: '#eaf1fb' } },
            ],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cb = document.getElementById('chart-basket');
        if (cb && BASKET && !window.echarts.getInstanceByDom(cb)) {
          const c = window.echarts.init(cb);
          const PAL = ['#f6b13b', '#3a8dff', '#46e08a', '#c95cf7', '#ff8a3d', '#1fb6c9', '#e8436f', '#5aa84a', '#8892a6', '#ffd479', '#7c5cf7', '#ff6d7a'];
          c.setOption({
            backgroundColor: 'transparent',
            tooltip: { valueFormatter: (v) => v + '%' },
            series: [{ type: 'treemap', data: BASKET.map((b, i) => ({ ...b, itemStyle: { color: PAL[i % PAL.length] } })), left: 0, right: 0, top: 0, bottom: 0, roam: false, nodeClick: false, breadcrumb: { show: false }, label: { show: true, formatter: (p) => p.name + '\n' + String(p.value).replace('.', ',') + '%', fontSize: 12, fontWeight: 600, color: '#06121a' }, itemStyle: { borderColor: '#0b1220', borderWidth: 2, gapWidth: 2 } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cf = document.getElementById('chart-fx');
        if (cf && FX && !window.echarts.getInstanceByDom(cf)) {
          const c = window.echarts.init(cf);
          c.setOption({
            backgroundColor: 'transparent',
            grid: { left: 44, right: 14, top: 14, bottom: 24 },
            xAxis: { type: 'category', data: FX.dates, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: Math.floor(FX.dates.length / 6) }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', scale: true, axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => v.toFixed(1).replace('.', ',') + ' kr' },
            series: [{ type: 'line', data: FX.vals, smooth: true, symbol: 'none', lineStyle: { width: 2.5, color: '#f6b13b' }, areaStyle: { opacity: 0.12, color: '#f6b13b' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', initExtra);
  </script>

  <!-- Eyja: spá-leikur (auðkennd umferð gegnum auth.js: karpGet/karpPost). #2 Á5 -->
  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const fp = (v) => (v == null ? '–' : String(v).replace('.', ',') + '%');
    function initSpa() {
      const el = document.getElementById('spa');
      if (!el) return;
      const TOPIC = el.dataset.topic, NEXT = el.dataset.next, NOW = el.dataset.now;
      async function render() {
      const u = window.KARP_USER || { loggedIn: false };
      const d = (await karpGet('/spa?topic=' + encodeURIComponent(TOPIC))) || {};
      const mine = d.mine;
      let h = `<div class="spa-h">🔮 Spá: næsta verðbólgumæling${NEXT ? ' (' + NEXT + ')' : ''}</div>`;
      h += `<div class="spa-sub">Hver heldurðu að ársverðbólgan verði? Núna: <b>${NOW}%</b>.</div>`;
      h += `<div class="spa-avg">Meðalspá almennings: <b>${fp(d.avg)}</b> <span>· ${d.count || 0} spár</span></div>`;
      if (u.loggedIn) {
        h += `<div class="spa-form"><input id="spa-in" type="number" step="0.1" min="0" max="20" placeholder="t.d. 5,0" value="${mine != null ? mine : ''}"><button id="spa-go">${mine != null ? 'Uppfæra' : 'Senda'} spá</button></div>`;
        if (mine != null) h += `<div class="spa-mine">Þín spá: <b>${fp(mine)}</b></div>`;
      } else {
        h += `<div class="spa-gate">🔒 <a href="${u.loginUrl || 'https://www.karp.is/innskraning/'}">Skráðu þig inn</a> til að senda spá.</div>`;
      }
      el.innerHTML = h;
      const go = document.getElementById('spa-go');
      if (go) go.onclick = async () => {
        const v = parseFloat(String(document.getElementById('spa-in').value).replace(',', '.'));
        if (!isFinite(v)) return;
        go.disabled = true; go.textContent = '…';
        await karpPost('/spa', { topic: TOPIC, value: v });
        render();
      };
      }
      loadUser().then(render);
    }
    document.addEventListener('astro:page-load', initSpa);
  </script>
  <!-- Eyja: tvö súlurit + Borgaradar, astro:page-load. #2 -->
  <script define:vars={{ colBars, ppBars, RADAR }}>
    function bar(el, data, suffix) {
      el.style.height = (data.length * 26 + 30) + 'px';
      const chart = window.echarts.init(el);
      chart.setOption({
        backgroundColor: 'transparent',
        grid: { left: 110, right: 40, top: 6, bottom: 20 },
        xAxis: { type: 'value', axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        yAxis: { type: 'category', inverse: true, data: data.map((d) => d.label), axisLabel: { color: '#cdd6e6', fontSize: 11 }, axisLine: { show: false }, axisTick: { show: false } },
        tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : v + suffix) },
        series: [{ type: 'bar', barWidth: 13, data: data.map((d) => ({ value: d.v, itemStyle: { color: d.home ? '#f6b13b' : '#42506a' } })), label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10 } }],
      });
      window.addEventListener('resize', () => chart.resize());
    }
    function initCharts() {
      const c1 = document.getElementById('chart-col'), c2 = document.getElementById('chart-pp');
      if (!c1) return;
      const go = () => {
        if (!window.echarts.getInstanceByDom(c1)) bar(c1, colBars, '');
        if (c2 && !window.echarts.getInstanceByDom(c2)) bar(c2, ppBars, '');
        const cr = document.getElementById('chart-radar');
        if (cr && RADAR && RADAR.series.length && !window.echarts.getInstanceByDom(cr)) {
          const c = window.echarts.init(cr);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: RADAR.series.map((s) => s.name), textStyle: { color: '#9fb0c8' }, top: 0 },
            tooltip: { backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12 } },
            radar: { indicator: RADAR.ind, center: ['50%', '56%'], radius: '66%', axisName: { color: '#9fb0c8', fontSize: 11 }, splitArea: { areaStyle: { color: ['rgba(255,255,255,.02)', 'rgba(255,255,255,.045)'] } }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.1)' } }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.12)' } } },
            series: [{ type: 'radar', data: RADAR.series.map((s) => ({ name: s.name, value: s.value, lineStyle: { color: s.color, width: 2 }, itemStyle: { color: s.color }, areaStyle: { color: s.color, opacity: s.name === 'Reykjavík' ? 0.22 : 0.06 } })) }],
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', initCharts);
  </script>
