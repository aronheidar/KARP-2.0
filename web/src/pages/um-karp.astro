    h1 { font-size: 34px; margin: 0 0 10px; }
    .lead { font-size: 17px; color: #dfe7f4; line-height: 1.6; }
    p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 10px; }
    .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media (max-width: 640px) { .cards { grid-template-columns: 1fr; } }
    .card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px 16px; }
    .card b { display: block; color: #f6b13b; font-size: 14.5px; margin-bottom: 4px; }
    .card span { font-size: 13px; color: #b9c6da; line-height: 1.55; }
    .rules { margin: 0; padding-left: 20px; }
    .rules li { font-size: 14px; color: #cdd6e6; line-height: 1.6; margin-bottom: 8px; }
    .rules b { color: #eaf1fb; }
    .tech { font-size: 14px; line-height: 1.65; }
    .tech a { color: #9fb0c8; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .foot a { color: #9fb0c8; }
  </style>
</Layout>
