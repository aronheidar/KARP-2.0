---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2 Á3) — Sveitarfélaga-vísitala. Keyrir á BYGGINGARTÍMA:
// les gögn úr @gogn, keyrir ALLAN muni-klasann úr @lib (muniIndex +
// muniStats + geo) og bakar raðaða töflu + graf inn í forþjónað HTML.
// Nú í app-skelinni (Layout: nav + fréttir). #2.
// ─────────────────────────────────────────────────────────────
import { computeMuniIndex } from '@lib/muniIndex.mjs';
import { makeMuniStats } from '@lib/muniStats.mjs';
import { makeRegionOf, makeLifsQ } from '@lib/geo.mjs';
import { fmtNum, groupThousands, esc, slugify } from '@lib/format.mjs';
import Layout from '../layouts/Layout.astro';

import SVFIN from '@gogn/sveitarfelog_fin.json';
import SVMETA from '@gogn/sveitarfelog_meta.json';
import SVPOP from '@gogn/sveitarfelog_pop.json';
import ATVINNULEYSI from '@gogn/atvinnuleysi.json';
import GLAEPIR from '@gogn/glaepir.json';
import FASTEIGNIR from '@gogn/fasteignir.json';
import SVCOORDS from '@gogn/sveitarfelog_coords.json';
import REGIONGEO from '@gogn/landshlutar.json';

// --- Keyra muni-klasann (öll gögn injectuð) ---
const idxMap = computeMuniIndex({ SVFIN, SVMETA, SVPOP, ATVINNULEYSI });
const regionOf = makeRegionOf({ SVCOORDS, REGIONGEO });
const stats = makeMuniStats({ ATVINNULEYSI, GLAEPIR, FASTEIGNIR });
const lifsQ = makeLifsQ({ SVMETA, regionOf, svUnemp: stats.svUnemp, svCrime: stats.svCrime });

const r0 = (v) => (v == null ? null : Math.round(v));
const rows = Object.keys(idxMap)
  .filter((n) => idxMap[n].idx != null)
  .map((n) => {
    const reg = regionOf(n);
    return {
      name: n,
      region: reg,
      pop: SVPOP[n] || null,
      idx: r0(idxMap[n].idx),
      fjar: r0(idxMap[n].fjar),
      vox: r0(idxMap[n].vox),
      atv: r0(idxMap[n].atv),
      lifs: lifsQ(n),
      unemp: stats.svUnemp(n, reg),
    };
  })
  .sort((a, b) => b.idx - a.idx);

// idx → litur (sama hsl-formúla og vísitölu-reiturinn í mælaborðinu: hue = idx*1.2)
const hue = (v) => Math.round((v == null ? 0 : v) * 1.2);
const idxColor = (v) => `hsl(${hue(v)}, 62%, 47%)`;

const chartNames = rows.map((r) => r.name);
const chartIdx = rows.map((r) => r.idx);
const chartCols = rows.map((r) => idxColor(r.idx));

// Verðlaunapallur + landshluta-síun (LOTA 13f)
const top3 = rows.slice(0, 3);
const REGIONS = [...new Set(rows.map((r) => r.region).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'is'));
const MEDALS = ['🥇', '🥈', '🥉'];

const updated = '2026-07-01';
// Öll sveitarfélög (líka <1.000 íbúa) fyrir innri tengla → engar munaðarlausar síður.
const allMunis = Object.keys(SVCOORDS).sort((a, b) => a.localeCompare(b, 'is'));
const top = rows[0];
const desc = `Vélræn vísitala fyrir ${rows.length} íslensk sveitarfélög (>1.000 íbúar) — fjárhagur, vöxtur og atvinna vegin saman úr opinberum gögnum. Efst: ${top ? top.name : ''}.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Sveitarfélaga-vísitala Íslands',
  description: 'Samsett vísitala (fjárhagur · vöxtur · atvinna) fyrir íslensk sveitarfélög með >1.000 íbúa, kvörðuð innbyrðis úr opinberum gögnum.',
  creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' },
  dateModified: updated,
  spatialCoverage: 'Ísland',
  measurementTechnique: 'Lágmarks-hámarks kvörðun þriggja þátta (afkoma+skuldir, fólksfjölgun+ungt fólk, atvinnuleysi), meðaltal',
  variableMeasured: 'Sveitarfélaga-vísitala (0–100)',
};
---

<Layout
  title={`Sveitarfélaga-vísitala — ${rows.length} sveitarfélög | Karp`}
  description={desc}
  canonical="https://app.karp.is/sveitarfelog/"
  jsonLd={jsonLd}
  ogTitle="Sveitarfélaga-vísitala Íslands"
>
  <main data-pg="sveitarfelog">
    <p class="kicker">Hagvísir Íslands · Sveitarfélög</p>
    <h1>Sveitarfélaga-vísitala</h1>
    <p>
      Samsett vísitala fyrir <strong>{rows.length} sveitarfélög</strong> með fleiri en 1.000 íbúa, kvörðuð innbyrðis
      á kvarðanum 0–100. Efst stendur <strong>{top?.name}</strong> ({top?.idx}). Heimildir: Hagstofa Íslands,
      Samband íslenskra sveitarfélaga, Ríkislögreglustjóri, HMS.
    </p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Sveitarfélagatölur: ársreikningar sveitarfélaga, mannfjöldi Hagstofunnar og kjörnir fulltrúar af vef Sambands íslenskra sveitarfélaga. Samsettu vísitölurnar reiknar Karp.">ⓘ</i> Um gögnin á síðunni</p>
    <p class="note">
      ⓘ Vísitalan er <strong>vélræn samsetning</strong> þriggja jafnvæginna þátta — 🏦 fjárhagur (afkoma + skuldir á íbúa),
      📈 vöxtur (fólksfjölgun + ungt fólk) og 👷 atvinna (skráð atvinnuleysi, öfugt) — meðaltal þeirra. Hlutlæg
      samantekt opinberra talna, <strong>ekki gæðamat</strong>.
    </p>

    <!-- Verðlaunapallurinn (LOTA 13f) -->
    <div class="podium">
      {top3.map((r, i) => (
        <a class={`pod pod-${i}`} href={`/sveitarfelog/${slugify(r.name)}/`}>
          <span class="pod-m">{MEDALS[i]}</span>
          <span class="pod-n">{r.name}</span>
          <span class="pod-v" style={`color:${idxColor(r.idx)}`}>{r.idx}</span>
          <span class="pod-r">{r.region}{r.pop ? ` · ${groupThousands(r.pop)} íbúar` : ''}</span>
        </a>
      ))}
    </div>

    <div id="chart"></div>

    <h2>Full röðun</h2>
    <div class="fbar">
      <input id="sv-filter" type="text" placeholder="🔍 Sía eftir nafni…" autocomplete="off" />
      <div class="chips" id="reg-chips">
        <button class="chip on" data-r="">Allt landið</button>
        {REGIONS.map((rg) => <button class="chip" data-r={rg}>{rg}</button>)}
      </div>
    </div>
    <div class="tw">
      <table>
        <thead>
          <tr>
            <th class="l">#</th><th class="l">Sveitarfélag</th>
            <th>Vísitala</th><th>🏦 Fjárhagur</th><th>📈 Vöxtur</th><th>👷 Atvinna</th>
            <th>🌿 Lífsgæði</th><th>Atvinnuleysi</th><th>Íbúar</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r, i) => (
            <tr data-region={r.region || ''} data-name={r.name.toLowerCase()}>
              <td class="rank">{i + 1}</td>
              <td class="l"><a class="muni" href={`/sveitarfelog/${slugify(r.name)}/`}>{r.name}</a><span class="reg">{r.region || '—'}</span></td>
              <td><span class="vis" style={`background:${idxColor(r.idx)}`}>{r.idx}</span></td>
              <td class="num fac"><i style={`width:${r.fjar ?? 0}%;background:${idxColor(r.fjar)}`}></i><span>{r.fjar ?? '–'}</span></td>
              <td class="num fac"><i style={`width:${r.vox ?? 0}%;background:${idxColor(r.vox)}`}></i><span>{r.vox ?? '–'}</span></td>
              <td class="num fac"><i style={`width:${r.atv ?? 0}%;background:${idxColor(r.atv)}`}></i><span>{r.atv ?? '–'}</span></td>
              <td class="num">{r.lifs ?? '–'}</td>
              <td class="num">{r.unemp == null ? '–' : fmtNum(r.unemp, 1) + '%'}</td>
              <td class="num">{r.pop == null ? '–' : groupThousands(r.pop)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="fempty" id="f-empty" hidden>Ekkert sveitarfélag passar við síuna.</p>
    </div>

    <h2>Öll sveitarfélög</h2>
    <div class="all-munis">
      {allMunis.map((n) => <a href={`/sveitarfelog/${slugify(n)}/`}>{n}</a>)}
    </div>

    <p class="foot">
      Forþjónað (SSG) {updated}. Röðunin reiknuð á <strong>byggingartíma</strong> úr sameiginlega
      <code> src/lib</code> (<code>muniIndex</code> + <code>muniStats</code> + <code>geo</code>) og bökuð inn í HTML-ið —
      leitarvélar sjá allar tölurnar án JavaScript. #2 Á3.
    </p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    #chart { width: 100%; margin: 22px 0 8px; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .tw { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 640px; }
    th, td { text-align: right; padding: 7px 9px; border-bottom: 1px solid rgba(255,255,255,.08); white-space: nowrap; }
    th { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
    td.l, th.l { text-align: left; }
    td.rank { color: #7e8ca6; font-variant-numeric: tabular-nums; }
    td.num { font-variant-numeric: tabular-nums; }
    .muni { font-weight: 600; color: #eaf1fb; text-decoration: none; }
    .muni:hover { color: #f6b13b; text-decoration: underline; }
    .reg { display: block; font-size: 11px; color: #7e8ca6; font-weight: 400; }
    .all-munis { display: flex; flex-wrap: wrap; gap: 6px 14px; margin: 6px 0 8px; }
    .all-munis a { color: #9fb0c8; text-decoration: none; font-size: 13px; }
    .all-munis a:hover { color: #f6b13b; text-decoration: underline; }
    .vis { display: inline-block; min-width: 30px; padding: 2px 8px; border-radius: 6px; color: #06121a; font-weight: 800; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    /* Verðlaunapallur + síun (LOTA 13f) */
    .podium { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 18px 0 8px; }
    @media (max-width: 640px) { .podium { grid-template-columns: 1fr; } }
    .pod { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 2px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 13px; padding: 14px 12px; text-decoration: none; transition: border-color .12s, transform .12s; }
    .pod:hover { border-color: #f6b13b; transform: translateY(-2px); }
    .pod-0 { border-color: rgba(246,177,59,.55); background: linear-gradient(180deg, rgba(246,177,59,.09), rgba(255,255,255,.03)); }
    .pod-m { font-size: 26px; }
    .pod-n { font-weight: 800; font-size: 14.5px; color: #eaf1fb; }
    .pod-v { font-size: 28px; font-weight: 800; font-variant-numeric: tabular-nums; }
    .pod-r { font-size: 11px; color: #7e8ca6; }
    .fbar { margin: 4px 0 10px; }
    #sv-filter { width: 100%; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #eaf1fb; border-radius: 10px; padding: 9px 13px; font-size: 13.5px; outline: none; margin-bottom: 8px; }
    #sv-filter:focus { border-color: #f6b13b; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 4px 12px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .chip:hover { color: #f6b13b; border-color: #f6b13b; }
    .chip.on { color: #06121a; background: #f6b13b; border-color: #f6b13b; }
    td.fac { position: relative; min-width: 58px; }
    td.fac i { position: absolute; left: 4px; top: 50%; transform: translateY(-50%); height: 62%; max-width: calc(100% - 8px); opacity: .18; border-radius: 4px; }
    td.fac span { position: relative; }
    .fempty { font-size: 13px; color: #9fb0c8; padding: 10px 4px; }
  </style>

  <!-- Eyja: raðað lárétt súlurit (ECharts hydrast í vafra) -->
  <script define:vars={{ chartNames, chartIdx, chartCols }}>
    function initChart() {
      const el = document.getElementById('chart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initChart, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      el.style.height = (chartNames.length * 17 + 46) + 'px';
      const chart = window.echarts.init(el);
      const data = chartIdx.map((v, i) => ({ value: v, itemStyle: { color: chartCols[i] } }));
      chart.setOption({
        backgroundColor: 'transparent',
        grid: { left: 128, right: 30, top: 8, bottom: 24 },
        xAxis: { type: 'value', max: 100, axisLabel: { color: '#7e8ca6' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        yAxis: {
          type: 'category',
          inverse: true,
          data: chartNames,
          axisLabel: { color: '#cdd6e6', fontSize: 11 },
          axisLine: { show: false }, axisTick: { show: false },
        },
        tooltip: { trigger: 'axis', valueFormatter: (v) => 'vísitala ' + v },
        series: [{
          type: 'bar', data, barWidth: 11,
          label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 11 },
        }],
      });
      window.addEventListener('resize', () => chart.resize());
    }
    // Síun: landshluta-flísar + nafnaleit (LOTA 13f) — felur raðir, röðunar-# helst
    function initFilter() {
      const inp = document.getElementById('sv-filter');
      if (!inp || inp.dataset.done) return;
      inp.dataset.done = '1';
      const rows = [...document.querySelectorAll('tbody tr[data-name]')];
      const empty = document.getElementById('f-empty');
      let reg = '';
      const apply = () => {
        const q = (inp.value || '').trim().toLowerCase();
        let shown = 0;
        rows.forEach((tr) => {
          const ok = (!reg || tr.dataset.region === reg) && (!q || tr.dataset.name.includes(q));
          tr.hidden = !ok;
          if (ok) shown++;
        });
        if (empty) empty.hidden = shown > 0;
      };
      inp.addEventListener('input', apply);
      document.querySelectorAll('#reg-chips .chip').forEach((ch) => {
        ch.addEventListener('click', () => {
          document.querySelectorAll('#reg-chips .chip').forEach((x) => x.classList.toggle('on', x === ch));
          reg = ch.dataset.r || '';
          apply();
        });
      });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="sveitarfelog"]')) { initChart(); initFilter(); } });
  </script>
</Layout>
