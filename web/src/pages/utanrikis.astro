import Layout from '../layouts/Layout.astro';
---
<Layout title="NATO | Karp" description="Efnið er flutt á /nato/" canonical="https://karp.is/nato/" noindex={true}>
  <main style="max-width:640px;margin:0 auto;padding:60px 20px;">
    <h1 style="font-size:26px;">Efnið er flutt 🚚</h1>
    <p style="color:#cdd6e6;">Þessi síða heitir nú <a href="/nato/" style="color:#f6b13b;">/nato/</a> — þú ert send(ur) þangað sjálfkrafa.</p>
  </main>
  <script>{ window.location.replace('/nato/'); }</script>
  <noscript><meta http-equiv="refresh" content={`0;url=/nato/`} /></noscript>
</Layout>
