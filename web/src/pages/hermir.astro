      lodaframbod: 'Lóðaframboð & skipulag — losar byggingarland. Lækkar húsnæðisverð með langri töf (uppstreymis-tæki vs nýbygginga-framboð).',
      atvinnuthatttaka: 'Atvinnuþátttökuhvatar — fjölga á vinnumarkaði. → aukið vinnuafl, lægra framfærsluhlutfall.',
      innflytjendastefna: 'Innflytjendastefna (atvinnuleyfi/atgervi). Stýrður vinnualdurs-innflutningur → vinnuafl↑, framfærsla↓, en húsnæðiseftirspurn↑.',
      fridun: 'Friðun/verndarsvæði sjávar. Byggir upp fiskistofn (tafið) á kostnað minni veiðisvæða til skamms tíma.',
      orkuskipti: 'Orkuskipta-hvati — rafvæðing samgangna (rafbílar/innviðir). Lækkar CO₂-losun; kostar ríkissjóð.',
      skograekt: 'Skógrækt & kolefnisbinding. Bindur kolefni (löng töf → losun↓); kostar til skamms tíma.',
      ferdamannagjald: 'Ferðamannagjald (komu-/gistináttagjald). Tekjur ríkissjóðs; dregur lítillega úr ferðaþjónustu.',
      heimshagvoxtur: 'Heimshagvöxtur (frávik) — ytra sjokk. Meiri ytri eftirspurn → aukinn útflutningur og hagvöxtur (opið hagkerfi).',
      hravaruverd: 'Hrávöruverð (ál/fiskur, frávik) — viðskiptakjör. Hærra verð → meira verðmæti útflutnings og betri viðskiptajöfnuður.',
    };
    const SCORE_KEYS = ['verdbolga', 'hagvoxtur', 'atvinnuleysi', 'husnaedi', 'afkoma'];
    // Formerki hvers hagvísis: +1 = hærra er BETRA, −1 = hærra er VERRA, 0 = hlutlaust.
    const POLARITY = { hagvoxtur: 1, kaupmattur: 1, afkoma: 1, utflutningur: 1, vinnuafl: 1, byggdajofnudur: 1, nyskopun: 1, fiskistofn: 1, verdbolga: -1, atvinnuleysi: -1, husnaedi: -1, husnaedi_hbs: -1, husnaedi_land: -1, leiga: -1, greidslubyrdi: -1, skuldir: -1, losun: -1, vanskil: -1, framfaersla: -1, mannfjoldi: 0, folksfjoldi: 0, gengi_endo: 0, lifeyriseignir: 1, hlutabref: 1, vidskiptajofnudur: 1, niip: 1, jofnudur: 1, peningamagn: 0, utlanavoxtur: 0, vaxtaalag: -1, heimilaskuldir: -1, einkajofnudur: 0, vlf_sjavar: 1, vlf_ferda: 1, vlf_idnadur: 1 };
    const GOOD = '#54d08a', NEUT = '#e8c14a', BAD = '#e78284';
    const BAND = { '#54d08a': 'rgba(84,208,138,.13)', '#e8c14a': 'rgba(232,193,74,.12)', '#e78284': 'rgba(231,130,132,.13)' };
    // Litur eftir því hvort frávik frá grunnferli (BAU) er jákvætt/hlutlaust/neikvætt FYRIR þennan hagvísi.
    function valence(k, dlt) { const pol = POLARITY[k] ?? 0; if (pol === 0 || Math.abs(dlt) < 0.05) return NEUT; return dlt * pol > 0 ? GOOD : BAD; }
    function dInfo(o, k) { const dlt = o.mid[o.mid.length - 1] - o.baseline[o.baseline.length - 1]; return { dlt, c: valence(k, dlt) }; }

    // sjálfvirk peningastefna/launaþróun: fastpunkts-ítrun (vélin ósnert).
    // Bregst við MEÐALTALI seinni helmings sjóndeildar (það sem stefnan getur haft áhrif á með töf) — ekki lokagildi.
    const midTerm = (arr) => { const s0 = Math.floor(arr.length / 2); let s = 0, n = 0; for (let i = s0; i < arr.length; i++) { s += arr[i]; n++; } return n ? s / n : arr[arr.length - 1]; };
    function solveLevers() {
      const L = { ...state.levers };
      if (!state.autoTay && !state.autoPhi) return L;
      for (let it = 0; it < 8; it++) {
        const r = simulate({ baseline: BASELINE, links: LINKS, levers: L, shocks: state.shocks, quarters: state.horizon });
        if (state.autoTay) { const infl = midTerm(r.outcomes.verdbolga.mid); const tgt = clamp(BASELINE.levers.vextir.base + 0.9 * (infl - 2.5), 0, 12); L.vextir = 0.45 * (L.vextir ?? BASELINE.levers.vextir.base) + 0.55 * tgt; }
        if (state.autoPhi) { const unem = midTerm(r.outcomes.atvinnuleysi.mid); const tgt = clamp(BASELINE.levers.laun.base + 0.35 * (4.0 - unem), 0, 14); L.laun = 0.45 * (L.laun ?? BASELINE.levers.laun.base) + 0.55 * tgt; }
      }
      if (state.autoTay) L.vextir = Math.round(L.vextir / BASELINE.levers.vextir.step) * BASELINE.levers.vextir.step;
      if (state.autoPhi) L.laun = Math.round(L.laun / BASELINE.levers.laun.step) * BASELINE.levers.laun.step;
      return L;
    }

    // URL-ástand: geymir sviðsmynd í #hash svo hægt sé að deila/vista hlekk
    function serialize() {
      const p = new URLSearchParams();
      for (const k in state.levers) if (state.levers[k] != null) p.set('l.' + k, state.levers[k]);
      for (const k in state.shocks) if (state.shocks[k] != null) p.set('s.' + k, state.shocks[k]);
      let a = ''; if (state.autoTay) a += 't'; if (state.autoPhi) a += 'p'; if (a) p.set('a', a);
      if (state.horizon !== BASELINE.quarters) p.set('h', state.horizon);
      if (state.tab !== 'yfirlit') p.set('tb', state.tab);
      const h = p.toString();
      try { history.replaceState(null, '', h ? '#' + h : location.pathname + location.search); } catch (e) {}
    }
    function deserialize() {
      if (!location.hash || location.hash.length < 2) return false;
      let any = false;
      for (const [k, v] of new URLSearchParams(location.hash.slice(1))) {
        if (k.startsWith('l.') && BASELINE.levers[k.slice(2)]) { state.levers[k.slice(2)] = +v; any = true; }
        else if (k.startsWith('s.') && BASELINE.shocks[k.slice(2)]) { state.shocks[k.slice(2)] = +v; any = true; }
        else if (k === 'a') { state.autoTay = v.includes('t'); state.autoPhi = v.includes('p'); any = true; }
        else if (k === 'h') { const hv = +v; if (hv >= BASELINE.quarters && hv <= MAXQ) { state.horizon = hv; any = true; } }
        else if (k === 'tb') { if (TABS.some((t) => t.id === v)) { state.tab = v; any = true; } }
      }
      return any;
    }

    function run() {
      if (state.mc) { state.mc = null; document.getElementById('mc').classList.remove('on'); document.getElementById('mcbar').hidden = true; } // breyting → aftur í ákveðna sýn
      const L = solveLevers();
      state._sol = { vextir: L.vextir, laun: L.laun }; // geymt svo hægt sé að „baka inn" við afvirkjun
      if (state.autoTay) syncSlider('vextir', L.vextir);
      if (state.autoPhi) syncSlider('laun', L.laun);
      const r = simulate({ baseline: BASELINE, links: LINKS, levers: L, shocks: state.shocks, quarters: state.horizon });
      state._lastR = r;
      drawHealth(r); drawScore(r); drawHero(r); drawCharts(r); if (state.gameOn) drawChallenges(r);
      serialize();
    }

    // Hero-rit hvers flipa: breið fjöl-lína af lykil-hagvísum (deilt ás), grunnferill punktaður, valkvæð markmiðs-lína.
    function drawHero(r) {
      const host = document.getElementById('hero'); host.innerHTML = '';
      const tab = curTab(); if (!tab.hero) return;
      const series = tab.hero.series.filter((k) => r.outcomes[k]); if (!series.length) return;
      const mcOn = !!state.mc;
      const eff = (k) => (mcOn && state.mc.outcomes[k]) ? { ...r.outcomes[k], lo: state.mc.outcomes[k].p5, hi: state.mc.outcomes[k].p95, mid: state.mc.outcomes[k].p50 } : r.outcomes[k];
      const card = document.createElement('div'); card.className = 'hero-card';
      const yrs = state.horizon > BASELINE.quarters ? '10' : '3';
      card.innerHTML = `<div class="hc-t">${tab.hero.title}${mcOn ? ' <span style="color:#b98cff">🎲 óvissu-hermun</span>' : ''}</div><div class="hc-s">Ferlar næstu ${yrs} ár · heil lína = ${mcOn ? 'miðgildi (50%)' : 'sviðsmynd'}, punktalína = grunnferill (BAU)${tab.hero.target != null ? ' · strikalína = markmið' : ''} · skyggt = ${mcOn ? '5–95% líkindabil (300 hermar)' : 'óvissa'}</div><canvas></canvas><div class="hero-legend"></div>`;
      host.appendChild(card);
      const cv = card.querySelector('canvas'); const dpr = Math.min(2, window.devicePixelRatio || 1);
      const w = cv.clientWidth || 600, h = 190; cv.width = w * dpr; cv.height = h * dpr; const ctx = cv.getContext('2d'); ctx.scale(dpr, dpr);
      let all = []; series.forEach((k) => { const o = eff(k); all = all.concat(o.lo, o.hi, o.baseline); }); if (tab.hero.target != null) all.push(tab.hero.target);
      let mn = Math.min(...all), mx = Math.max(...all); if (mx - mn < 1) { const m = (mx + mn) / 2; mn = m - 1; mx = m + 1; } const padY = (mx - mn) * 0.08; mn -= padY; mx += padY;
      const n = r.outcomes[series[0]].mid.length, padL = 34, padR = 8, padT = 8, padB = 18;
      const X = (i) => padL + (w - padL - padR) * i / (n - 1), Y = (v) => (h - padB) - (h - padT - padB) * (v - mn) / (mx - mn);
      // ás-merki
      ctx.strokeStyle = 'rgba(255,255,255,.08)'; ctx.fillStyle = 'rgba(159,176,200,.7)'; ctx.font = '10px system-ui'; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      for (let g = 0; g <= 4; g++) { const v = mn + (mx - mn) * g / 4, y = Y(v); ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(w - padR, y); ctx.stroke(); ctx.fillText(num(v, Math.abs(mx - mn) > 20 ? 0 : 1), padL - 4, y); }
      ctx.textAlign = 'center'; ctx.textBaseline = 'top'; ctx.fillText('í dag', X(0), h - padB + 3); ctx.fillText('+' + yrs + ' ár', X(n - 1), h - padB + 3);
      if (tab.hero.target != null) { ctx.beginPath(); ctx.setLineDash([6, 4]); ctx.moveTo(padL, Y(tab.hero.target)); ctx.lineTo(w - padR, Y(tab.hero.target)); ctx.strokeStyle = 'rgba(255,255,255,.45)'; ctx.lineWidth = 1.2; ctx.stroke(); ctx.setLineDash([]); }
      const line = (arr, col, lw, dash) => { ctx.beginPath(); arr.forEach((v, i) => (i ? ctx.lineTo(X(i), Y(v)) : ctx.moveTo(X(i), Y(v)))); ctx.strokeStyle = col; ctx.setLineDash(dash || []); ctx.lineWidth = lw; ctx.lineJoin = 'round'; ctx.stroke(); ctx.setLineDash([]); };
      series.forEach((k, si) => { const o = eff(k), col = HPAL[si % HPAL.length];
        ctx.beginPath(); ctx.moveTo(X(0), Y(o.hi[0])); for (let i = 1; i < n; i++) ctx.lineTo(X(i), Y(o.hi[i])); for (let i = n - 1; i >= 0; i--) ctx.lineTo(X(i), Y(o.lo[i])); ctx.closePath(); ctx.fillStyle = hexA(col, mcOn ? .14 : .09); ctx.fill();
        line(o.baseline, hexA(col, .5), 1.2, [3, 3]); line(o.mid, col, 2.2);
      });
      const leg = card.querySelector('.hero-legend'); series.forEach((k, si) => { const s = document.createElement('span'); s.innerHTML = `<i style="background:${HPAL[si % HPAL.length]}"></i>${r.outcomes[k].label}`; leg.appendChild(s); }); if (tab.hero.target != null) { const s = document.createElement('span'); s.innerHTML = `<i style="background:rgba(255,255,255,.5)"></i>markmið ${num(tab.hero.target)}%`; leg.appendChild(s); }
    }
    const hexA = (hex, a) => { const n = parseInt(hex.slice(1), 16); return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`; };

    // Óvissu-hermun (Monte Carlo): keyrir N herma með slembnum stuðlum innan óvissubils hvers tengsls → líkinda-viftur.
    const THRESH = { verdbolga: { op: '>', v: 4, lbl: 'verðbólga >4%' }, hagvoxtur: { op: '<', v: 0, lbl: 'samdráttur' }, atvinnuleysi: { op: '>', v: 6, lbl: 'atvinnuleysi >6%' }, afkoma: { op: '<', v: -2, lbl: 'halli >2% VLF' }, skuldir: { op: '>', v: 50, lbl: 'skuldir >50%' }, husnaedi: { op: '>', v: 10, lbl: 'húsnæði >10%' }, vanskil: { op: '>', v: 115, lbl: 'vanskil +15%' }, kaupmattur: { op: '<', v: 0, lbl: 'kaupmáttur rýrnar' }, fiskistofn: { op: '<', v: 90, lbl: 'fiskistofn <90' }, losun: { op: '>', v: 105, lbl: 'losun +5%' }, vidskiptajofnudur: { op: '<', v: 0, lbl: 'viðskiptahalli' } };
    function runMC() {
      const N = 300, L = solveLevers(), outs = Object.keys(BASELINE.outcomes), H = state.horizon, last = H - 1;
      const acc = {}, endS = {}; outs.forEach((k) => { acc[k] = Array.from({ length: H }, () => []); endS[k] = []; });
      for (let i = 0; i < N; i++) {
        const pL = LINKS.map((l) => (l.ci_lo === l.ci_hi ? l : { ...l, coef: l.ci_lo + Math.random() * (l.ci_hi - l.ci_lo) }));
        const r = simulate({ baseline: BASELINE, links: pL, levers: L, shocks: state.shocks, quarters: H });
        for (const k of outs) { const m = r.outcomes[k].mid; for (let t = 0; t < H; t++) acc[k][t].push(m[t]); endS[k].push(m[last]); }
      }
      const pct = (a, p) => { const s = a.slice().sort((x, y) => x - y); return s[Math.max(0, Math.min(s.length - 1, Math.floor(p * s.length)))]; };
      const mc = { outcomes: {}, end: endS, n: N };
      for (const k of outs) { const o = { p5: [], p50: [], p95: [] }; for (let t = 0; t < H; t++) { const a = acc[k][t]; o.p5.push(pct(a, 0.05)); o.p50.push(pct(a, 0.5)); o.p95.push(pct(a, 0.95)); } mc.outcomes[k] = o; }
      state.mc = mc;
    }
    function drawMCbar() {
      const bar = document.getElementById('mcbar'); if (!state.mc) { bar.hidden = true; return; }
      const tab = curTab(), outList = (tab.out || []).filter((k) => state.mc.outcomes[k]), yrs = state.horizon > BASELINE.quarters ? '10' : '3';
      const meds = outList.slice(0, 5).map((k) => { const o = state.mc.outcomes[k], last = o.p50.length - 1, u = BASELINE.outcomes[k].unit === '% VLF' ? '%' : BASELINE.outcomes[k].unit; return `<span class="mcp">${BASELINE.outcomes[k].label}: <b>${num(o.p50[last])}${u}</b> <span style="color:var(--faint)">(${num(o.p5[last])}–${num(o.p95[last])})</span></span>`; }).join('');
      const probs = outList.filter((k) => THRESH[k]).map((k) => { const th = THRESH[k], s = state.mc.end[k], cnt = s.filter((v) => (th.op === '>' ? v > th.v : v < th.v)).length; return `<span class="mcp">P(${th.lbl}) <b>${Math.round(100 * cnt / s.length)}%</b></span>`; }).join('');
      bar.hidden = false;
      bar.innerHTML = `🎲 <b>Óvissu-hermun</b> — ${state.mc.n} hermar, miðgildi & 90% líkindabil eftir ${yrs} ár:<br>${meds}${probs ? '<br><span style="color:var(--faint);font-size:11.5px">Líkur á áhættum: </span>' + probs : ''}`;
    }

    function syncSlider(k, v) { const el = document.querySelector(`.sl[data-k="${k}"]`); if (!el) return; const inp = el.querySelector('input'), b = el.querySelector('b'), cfg = BASELINE.levers[k]; inp.value = v; b.textContent = disp(cfg, v); el.classList.toggle('moved', v !== cfg.base); }

    // Samsett þjóðhagslegt heilsufar (0–100) — markfall sem dýnamíska leiðin (Greining) hámarkar.
    function healthAt(r, t) {
      const g = (k) => { const m = r.outcomes[k]?.mid; return m ? m[Math.min(t, m.length - 1)] : 0; };
      const pen = Math.abs(g('verdbolga') - 2.5) * 7 + Math.max(0, g('atvinnuleysi') - 4) * 6 + Math.max(0, 2 - g('hagvoxtur')) * 5 + Math.max(0, -g('afkoma')) * 4
        + Math.max(0, g('husnaedi') - 5) * 1.2 + Math.max(0, g('leiga') - 6) * 0.8 + Math.max(0, g('skuldir') - 45) * 0.3 + Math.max(0, g('vanskil') - 100) * 0.4 + Math.max(0, g('losun') - 100) * 0.3
        + Math.max(0, 1 - g('kaupmattur')) * 2 + Math.max(0, 100 - g('fiskistofn')) * 0.25 + Math.max(0, g('framfaersla') - 102) * 0.3 - Math.min(6, Math.max(0, g('nyskopun') - 100) * 0.06);
      return clamp(100 - pen, 0, 100);
    }
    function healthScore(r) { const m = r.outcomes.verdbolga?.mid; return healthAt(r, m ? m.length - 1 : 0); }   // lokastaða (óbreytt hegðun)
    // path-aware: meðal-heilsufar yfir sjóndeildina, seinni skref vega meira → umbunar hraðri leið að góðu ástandi (fyrir dýnamíska bestun)
    function healthPath(r) { const H = r.outcomes.verdbolga.mid.length; let s = 0, w = 0; for (let t = 0; t < H; t++) { const wt = 1 + t / H; s += wt * healthAt(r, t); w += wt; } return s / w; }
    function drawHealth(r) {
      const score = Math.round(healthScore(r));
      const c = score >= 70 ? GOOD : score >= 45 ? NEUT : BAD;
      const h = document.getElementById('health');
      h.title = 'Samsett þjóðhagslegt heilsufar (0–100): nær 100 þegar verðbólga ~2,5%, atvinnuleysi/skuldir/vanskil/losun lág, hagvöxtur jákvæður og afkoma í jafnvægi.';
      h.innerHTML = `<span class="h-l">Þjóðhagslegt heilsufar</span><span class="h-v" style="color:${c}">${score}<span style="font-size:14px;color:var(--faint)">/100</span></span><span class="h-bar"><i style="width:${score}%;background:${c}"></i></span>`;
    }

    function drawScore(r) {
      const h = document.getElementById('score'); h.innerHTML = '';
      for (const k of SCORE_KEYS) { const o = r.outcomes[k]; if (!o) continue; const { dlt, c } = dInfo(o, k); const end = o.mid[o.mid.length - 1];
        const t = document.createElement('div'); t.className = 'sc'; t.title = OUT_TIP[k] || o.label;
        t.innerHTML = `<span class="sc-l">${o.label}</span><span class="sc-v">${num(end)}${o.unit === '% VLF' ? '%' : o.unit}</span><span class="sc-d" style="color:${c}">${dlt >= 0 ? '▲' : '▼'} ${num(Math.abs(dlt))}</span>`;
        h.appendChild(t);
      }
    }

    function drawCharts(r) {
      const host = document.getElementById('charts'); host.innerHTML = '';
      const cmpR = state.compare ? state.compare.r : null;
      const tab = curTab(), outList = tab.out || Object.keys(r.outcomes);
      for (const k of outList) { const o = r.outcomes[k]; if (!o) continue; const { dlt, c } = dInfo(o, k); const end = o.mid[o.mid.length - 1];
        const cmp = cmpR ? cmpR.outcomes[k] : null; const us = o.unit === '% VLF' ? '%' : o.unit;
        const idx = o.unit === '' ? ' (vísitala)' : ''; // vísitölur: 100 = staðan í dag
        const today = o.baseline[0]; // raun-gildi í dag (upphaf grunnferils)
        const card = document.createElement('div'); card.className = 'card'; card.dataset.k = k;
        card.title = (OUT_TIP[k] || o.label) + (driversOf(k).length ? ' Drifið af: ' + driversOf(k).join(', ') + '.' : '') + ' (grænt=jákvæð þróun, gult=hlutlaust, rautt=neikvæð fyrir þennan hagvísi).';
        card.innerHTML = `<div class="c-h"><span class="c-t">${o.label}</span><span class="c-d" style="color:${c}">${dlt >= 0 ? '+' : ''}${num(dlt)}</span></div><div class="c-v">${num(end)}${us}${cmp ? ` <span class="c-b">⚖ ${num(cmp.mid[cmp.mid.length - 1])}${us}</span>` : ''}</div><div class="c-now">í dag: ${num(today)}${us}${idx}</div><canvas class="c-cv"></canvas><div class="c-g" title="Staða lokagildis innan mögulegs bils; hvíta strikið = grunnferill (BAU)"><span class="c-gb"></span><span class="c-gm"></span></div>`;
        host.appendChild(card);
        drawTrace(card.querySelector('canvas'), o, cmp, c);
        const cl = (BASELINE.clamp || {})[k] || [Math.min(...o.lo), Math.max(...o.hi)];
        const pos = (v) => Math.max(0, Math.min(1, (v - cl[0]) / (cl[1] - cl[0] || 1)));
        const gm = card.querySelector('.c-gm'), gb = card.querySelector('.c-gb');
        gm.style.left = (pos(end) * 100) + '%'; gm.style.background = c;
        gb.style.left = (pos(o.baseline[o.baseline.length - 1]) * 100) + '%';
      }
    }

    function drawTrace(cv, o, cmp, vcol) {
      const dpr = Math.min(2, window.devicePixelRatio || 1); const w = cv.clientWidth, h = 88; cv.width = w * dpr; cv.height = h * dpr;
      const ctx = cv.getContext('2d'); ctx.scale(dpr, dpr);
      const all = cmp ? o.mid.concat(cmp.mid) : o.lo.concat(o.hi, o.baseline); let mn = Math.min(...all), mx = Math.max(...all);
      if (mx - mn < 1) { const m = (mx + mn) / 2; mn = m - 0.6; mx = m + 0.6; }
      const pad = 6, n = o.mid.length, X = (i) => pad + (w - 2 * pad) * i / (n - 1), Y = (v) => (h - pad) - (h - 2 * pad) * (v - mn) / (mx - mn);
      const line = (arr, col, lw, dash) => { ctx.beginPath(); arr.forEach((v, i) => (i ? ctx.lineTo(X(i), Y(v)) : ctx.moveTo(X(i), Y(v)))); ctx.strokeStyle = col; ctx.setLineDash(dash || []); ctx.lineWidth = lw; ctx.lineJoin = 'round'; ctx.stroke(); ctx.setLineDash([]); };
      if (cmp) { // samanburðar-hamur: A (núverandi, appelsínugult) vs B (fest, blátt) — engin bönd/BAU
        line(cmp.mid, '#5ac8e0', 1.8, [5, 3]); line(o.mid, '#f6b13b', 2.2);
        ctx.font = '10px system-ui'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'right';
        ctx.fillStyle = '#f6b13b'; ctx.fillText(num(o.mid[n - 1]), X(n - 1) - 1, Y(o.mid[n - 1]) - 4);
        ctx.fillStyle = '#5ac8e0'; ctx.fillText(num(cmp.mid[n - 1]), X(n - 1) - 1, Y(cmp.mid[n - 1]) + 11);
        return;
      }
      const col = vcol || '#f6b13b', bandCol = BAND[col] || 'rgba(246,177,59,.13)';
      ctx.beginPath(); ctx.moveTo(X(0), Y(o.hi[0])); for (let i = 1; i < n; i++) ctx.lineTo(X(i), Y(o.hi[i])); for (let i = n - 1; i >= 0; i--) ctx.lineTo(X(i), Y(o.lo[i])); ctx.closePath(); ctx.fillStyle = bandCol; ctx.fill();
      line(o.baseline, 'rgba(255,255,255,.28)', 1.4, [4, 4]); line(o.mid, col, 2.2);
      ctx.fillStyle = 'rgba(159,176,200,.85)'; ctx.font = '10px system-ui'; ctx.textBaseline = 'alphabetic';
      ctx.textAlign = 'left'; ctx.fillText(num(o.mid[0]), X(0) + 1, Y(o.mid[0]) - 4);
      ctx.textAlign = 'right'; ctx.fillStyle = col; ctx.fillText(num(o.mid[n - 1]), X(n - 1) - 1, Y(o.mid[n - 1]) - 4);
    }

    function highlight(k) { const reach = reachFrom(k); document.querySelectorAll('#charts .card').forEach((c) => { c.classList.toggle('lit', reach.has(c.dataset.k)); c.classList.toggle('dim', !reach.has(c.dataset.k)); }); }
    function clearHighlight() { document.querySelectorAll('#charts .card').forEach((c) => c.classList.remove('lit', 'dim')); }

    function buildControls() {
      const mk = (host, k, cfg, grp) => {
        const el = document.createElement('div'); el.className = 'sl'; el.dataset.k = k; el.title = LEV_TIP[k] || cfg.label;
        const dec = cfg.realMode === 'mult' ? (cfg.realDec ?? 0) : decOf(cfg), val = state[grp][k] ?? cfg.base;
        const basePct = ((cfg.base - cfg.min) / (cfg.max - cfg.min || 1)) * 100;
        const nowLbl = grp === 'shocks' ? 'hlutlaust' : ('nú ' + disp(cfg, cfg.base, dec));
        el.innerHTML = `<div class="sl-t"><span>${cfg.label}</span><span class="sl-r"><b>${disp(cfg, val, dec)}</b> <em class="sl-now" title="Núverandi raun-gildi / sjálfgefið — daufa strikið á rásinni sýnir það">${nowLbl}</em></span></div><div class="sl-track"><input type="range" min="${cfg.min}" max="${cfg.max}" step="${cfg.step}" value="${val}"><span class="sl-base" style="left:${basePct}%"></span></div>`;
        const inp = el.querySelector('input'), b = el.querySelector('b');
        inp.addEventListener('input', () => { const v = +inp.value; state[grp][k] = v; b.textContent = disp(cfg, v, dec); el.classList.toggle('moved', v !== cfg.base); run(); });
        el.classList.toggle('moved', val !== cfg.base);
        el.addEventListener('mouseenter', () => { el.classList.add('hot'); highlight(k); }); el.addEventListener('mouseleave', () => { el.classList.remove('hot'); clearHighlight(); });
        host.appendChild(el);
      };
      const lh = document.getElementById('levers'), sh = document.getElementById('shocks'); lh.innerHTML = ''; sh.innerHTML = '';
      const tab = curTab(), levSet = new Set(tab.levers || []), shkSet = new Set(tab.shocks || []);
      let curGroup = '';
      for (const k in BASELINE.levers) { if (!levSet.has(k)) continue; const cfg = BASELINE.levers[k]; if (cfg.group && cfg.group !== curGroup) { curGroup = cfg.group; const h = document.createElement('div'); h.className = 'sl-group'; h.textContent = cfg.group; lh.appendChild(h); } mk(lh, k, cfg, 'levers'); }
      for (const k in BASELINE.shocks) { if (!shkSet.has(k)) continue; mk(sh, k, BASELINE.shocks[k], 'shocks'); }
      document.getElementById('lever-hint').hidden = levSet.size > 0;
      document.getElementById('ctl-right').hidden = shkSet.size === 0;
      document.getElementById('body3').classList.toggle('no-right', shkSet.size === 0);
      const showAuto = levSet.has('vextir') || levSet.has('laun');
      document.getElementById('lbl-tay').hidden = !levSet.has('vextir');
      document.getElementById('lbl-phi').hidden = !levSet.has('laun');
      applyAutoDisable();
    }

    function applyAutoDisable() {
      const set = (k, on) => { const el = document.querySelector(`.sl[data-k="${k}"]`); if (!el) return; el.classList.toggle('auto-on', on); const inp = el.querySelector('input'); inp.disabled = on; };
      set('vextir', state.autoTay); set('laun', state.autoPhi);
    }

    // KARP-lausnin: hnitráð (coordinate descent) yfir ákvarðana-sleðana til að hámarka heilsufar.
    // Ytri áhrif höfð hlutlaus (0) — þú velur ekki olíuskell; leitar að bestu STEFNU miðað við núverandi horfur.
    // HÓFSEMIS-REFSING: stórar (pólitískt/hagrænt óraunhæfar) stefnu-sveiflur kosta stig → KARP finnur
    // TRÚVERÐUGAN, hóflegan aðgerðapakka fremur en að keyra sleða í öfgar (Σ(frávik/svið)²·REG_W).
    const REG_W = 3.5;
    function regCost(lv) { let s = 0; for (const k in lv) { const c = BASELINE.levers[k], f = (lv[k] - c.base) / (c.max - c.min); s += f * f; } return s * REG_W; }
    function findBest() {
      const keys = Object.keys(BASELINE.levers), H = state.horizon;
      const sim = (lv) => healthScore(simulate({ baseline: BASELINE, links: LINKS, levers: lv, shocks: state.shocks, quarters: H })) - regCost(lv);
      const best = {}; let bestScore = sim(best);
      const scan = (lo, hi, step) => { // gróf leit + fín pössun deila þessu
        for (const k of keys) {
          const cfg = BASELINE.levers[k], cur = best[k] ?? cfg.base;
          const a = lo(cfg, cur), b = hi(cfg, cur), st = step(cfg);
          let lb = cur, ls = bestScore;
          for (let v = a; v <= b + 1e-9; v += st) {
            const vr = +(Math.round(v / cfg.step) * cfg.step).toFixed(4);
            if (vr < cfg.min - 1e-9 || vr > cfg.max + 1e-9) continue;
            const s = sim({ ...best, [k]: vr });
            if (s > ls + 1e-6) { ls = s; lb = vr; }
          }
          if (lb !== cur) improved = true;
          best[k] = lb; bestScore = ls;
        }
      };
      let improved;
      // 1) gróf hnitráð yfir allt bilið
      for (let pass = 0; pass < 4; pass++) { improved = false; scan((c) => c.min, (c) => c.max, (c) => Math.max(c.step, (c.max - c.min) / 16)); if (!improved) break; }
      // 2) fín pössun á fullri upplausn í glugga kringum núverandi bestu
      for (let pass = 0; pass < 2; pass++) { improved = false; scan((c, cur) => cur - (c.max - c.min) / 14, (c, cur) => cur + (c.max - c.min) / 14, (c) => c.step); if (!improved) break; }
      for (const k in best) if (best[k] === BASELINE.levers[k].base) delete best[k]; // sleppa óbreyttum
      // birta HREINT heilsufar valda pakkans (án hófsemis-refsingar, sem stýrir bara leitinni)
      const pureScore = healthScore(simulate({ baseline: BASELINE, links: LINKS, levers: best, shocks: state.shocks, quarters: H }));
      return { levers: best, score: Math.round(pureScore) };
    }

    // Dýnamísk KARP: bestar 2-fasa leið (áfangi 1 = fyrri helmingur, áfangi 2 = seinni helmingur) fyrir
    // tíma-næmar ákvarðanir, m.v. path-aware markmið (healthPath). Byrjar frá bestu FÖSTU lausn. Skilar
    // EKKI í state (state heldur skala-gildum) — aðeins niðurstöðu til birtingar í Greiningu.
    const DYN_KEYS = ['vextir', 'laun', 'utgjold', 'skattar', 'tilfaerslur', 'innvidir', 'vsk'];
    function findBestDynamic() {
      const base = findBest();
      const H = state.horizon, half = Math.max(1, Math.floor(H / 2));
      const keys = DYN_KEYS.filter((k) => BASELINE.levers[k]);
      const mkPath = (e, l) => [...new Array(half).fill(e), ...new Array(H - half).fill(l)];
      const others = { ...base.levers }; for (const k of keys) delete others[k];
      const cur = {}; for (const k of keys) { const v = base.levers[k] ?? BASELINE.levers[k].base; cur[k] = { e: v, l: v }; }
      const build = (c) => { const lv = { ...others }; for (const k in c) lv[k] = mkPath(c[k].e, c[k].l); return lv; };
      // hófsemis-refsing líka hér (bæði fasa-gildi) svo dýnamíska leiðin verði líka trúverðug, ekki öfga-sveiflur
      const regDyn = (c) => { let s = regCost(others); for (const k in c) { const cf = BASELINE.levers[k], fe = (c[k].e - cf.base) / (cf.max - cf.min), fl = (c[k].l - cf.base) / (cf.max - cf.min); s += (fe * fe + fl * fl) / 2 * REG_W; } return s; };
      const sim = (c) => healthPath(simulate({ baseline: BASELINE, links: LINKS, levers: build(c), shocks: state.shocks, quarters: H })) - regDyn(c);
      let bestScore = sim(cur);
      for (let pass = 0; pass < 3; pass++) {
        let improved = false;
        for (const k of keys) {
          const cfg = BASELINE.levers[k], st = Math.max(cfg.step, (cfg.max - cfg.min) / 12);
          for (const ph of ['e', 'l']) {
            let lb = cur[k][ph], ls = bestScore;
            for (let v = cfg.min; v <= cfg.max + 1e-9; v += st) {
              const vr = +(Math.round(v / cfg.step) * cfg.step).toFixed(4);
              if (vr < cfg.min - 1e-9 || vr > cfg.max + 1e-9) continue;
              const s = sim({ ...cur, [k]: { ...cur[k], [ph]: vr } });
              if (s > ls + 1e-6) { ls = s; lb = vr; }
            }
            if (lb !== cur[k][ph]) { cur[k][ph] = lb; improved = true; }
            bestScore = ls;
          }
        }
        if (!improved) break;
      }
      const rDyn = simulate({ baseline: BASELINE, links: LINKS, levers: build(cur), shocks: state.shocks, quarters: H });
      const rConst = simulate({ baseline: BASELINE, links: LINKS, levers: base.levers, shocks: state.shocks, quarters: H });
      return { phases: cur, keys, half, H, rDyn, rConst, base, pathDyn: healthPath(rDyn), pathConst: healthPath(rConst) };
    }
    function drawMiniLines(cv, seriesArr, mn, mx) {
      const dpr = Math.min(2, window.devicePixelRatio || 1), w = cv.clientWidth || 500, h = 150;
      cv.width = w * dpr; cv.height = h * dpr; const ctx = cv.getContext('2d'); ctx.scale(dpr, dpr);
      const n = seriesArr[0].pts.length, padL = 30, padR = 8, padT = 8, padB = 16;
      const X = (i) => padL + (w - padL - padR) * i / (n - 1), Y = (v) => (h - padB) - (h - padT - padB) * (v - mn) / (mx - mn);
      ctx.strokeStyle = 'rgba(255,255,255,.08)'; ctx.fillStyle = 'rgba(159,176,200,.7)'; ctx.font = '10px system-ui'; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      for (let g = 0; g <= 4; g++) { const v = mn + (mx - mn) * g / 4, y = Y(v); ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(w - padR, y); ctx.stroke(); ctx.fillText(num(v, 0), padL - 4, y); }
      seriesArr.forEach((s) => { ctx.beginPath(); s.pts.forEach((v, i) => (i ? ctx.lineTo(X(i), Y(v)) : ctx.moveTo(X(i), Y(v)))); ctx.strokeStyle = s.color; ctx.setLineDash(s.dash || []); ctx.lineWidth = s.lw || 2; ctx.lineJoin = 'round'; ctx.stroke(); ctx.setLineDash([]); });
    }
    function drawDynamic() {
      const host = document.getElementById('dyn-result'); if (!host) return;
      host.innerHTML = '<div style="color:var(--faint);font-size:13px">Reikna dýnamíska leið…</div>';
      setTimeout(() => {
        const d = findBestDynamic();
        const gain = d.pathDyn - d.pathConst, yr = (t) => (t / 4).toFixed(1).replace('.0', '');
        const rows = d.keys.map((k) => { const cfg = BASELINE.levers[k], p = d.phases[k]; return { k, cfg, e: p.e, l: p.l, diff: Math.abs(p.e - p.l) >= cfg.step - 1e-9 }; })
          .filter((r) => r.diff || r.e !== r.cfg.base);
        const fmt = (v, cfg) => disp(cfg, v);
        const tbl = rows.length
          ? '<table class="dyn-tbl"><thead><tr><th>Ákvörðun</th><th>Áfangi 1<br><span class="dyn-sub">ár 0–' + yr(d.half) + '</span></th><th>Áfangi 2<br><span class="dyn-sub">ár ' + yr(d.half) + '–' + yr(d.H) + '</span></th></tr></thead><tbody>'
            + rows.map((r) => '<tr><td>' + lbl(r.k) + '</td><td>' + fmt(r.e, r.cfg) + '</td><td>' + fmt(r.l, r.cfg) + (r.diff ? ' <b style="color:#f6b13b">' + (r.l > r.e ? '↑' : '↓') + '</b>' : '') + '</td></tr>').join('')
            + '</tbody></table>'
          : '<p class="an-intro">Engin tíma-næm ákvörðun batnar við fösun núna — föst stefna er þegar best.</p>';
        const verdict = gain > 0.4
          ? '<b style="color:' + GOOD + '">Fösun borgar sig.</b> Að fasa stefnuna hækkar meðal-heilsufar um <b>' + gain.toFixed(1) + ' stig</b> umfram bestu FÖSTU stillingu — það svarar sig að stilla ákvarðanir ólíkt milli áfanga.'
          : '<b>Föst stefna dugar.</b> 2-fasa leið bætir meðal-heilsufar um aðeins ' + gain.toFixed(1) + ' stig; tímasetning skiptir litlu við núverandi horfur.';
        host.innerHTML = '<p style="margin:2px 0 10px;font-size:13.5px">' + verdict + '</p>' + tbl
          + '<canvas id="dyn-canvas" style="width:100%;height:150px;display:block;margin-top:12px"></canvas>'
          + '<div class="hero-legend" style="margin-top:6px"><span><i style="background:#f6b13b"></i> Dýnamísk leið (meðal ' + d.pathDyn.toFixed(0) + ')</span><span><i style="background:#9fb0c8"></i> Föst leið (meðal ' + d.pathConst.toFixed(0) + ')</span></div>'
          + '<div class="dyn-sub" style="margin-top:4px">Þjóðhagslegt heilsufar hvern ársfjórðung yfir sjóndeildina · hærra = betra</div>';
        const ser = (r) => { const out = []; for (let t = 0; t < d.H; t++) out.push(healthAt(r, t)); return out; };
        drawMiniLines(document.getElementById('dyn-canvas'), [{ pts: ser(d.rConst), color: '#9fb0c8', lw: 1.8, dash: [4, 3] }, { pts: ser(d.rDyn), color: '#f6b13b', lw: 2.4 }], 0, 100);
      }, 30);
    }


    function buildLinkTable() {
      const host = document.getElementById('lnks'); if (!host) return;
      const rows = LINKS.map((l) => `<tr><td>${lbl(l.from)} → ${lbl(l.to)}</td><td style="text-align:right;font-variant-numeric:tabular-nums">${l.coef} ${l.unit}</td><td style="text-align:right">töf ${l.lag}</td><td style="text-align:right">±${(((l.ci_hi - l.ci_lo) / 2)).toFixed(2)}</td><td>${l.source}</td></tr>`).join('');
      host.innerHTML = `<table class="lnk-tbl"><tr><th>Keðja</th><th>Stuðull</th><th>Töf</th><th>Óvissa</th><th>Heimild</th></tr>${rows}</table><p style="font-size:11.5px;color:var(--faint);margin-top:8px">Hver stuðull er metinn úr Karp-gögnum eða úr birtum heimildum (SÍ/Hagstofa/OECD). Stílfærð sambönd — ekki opinber spá.</p>`;
    }

    function buildBacktest() {
      const host = document.getElementById('backtest'); if (!host || !HISTORY || !HISTORY.checks) return;
      const H = HISTORY, ck = H.checks, all = Object.values(ck).every(Boolean), C = BASELINE.clamp;
      const chk = (b) => (b ? '<span style="color:#54d08a">✓</span>' : '<span style="color:#e78284">✗</span>');
      const rows = [
        ['Húsnæði — höfuðborg (12-mán %)', `${H.husnaedi_hbs.range[0]} … ${H.husnaedi_hbs.range[1]}% (staðalfrávik ${H.husnaedi_hbs.std})`, `clamp ${C.husnaedi_hbs.join(' … ')}`, ck.okHouseRange],
        ['Húsnæði — landsbyggð (12-mán %)', `${H.husnaedi_land.range[0]} … ${H.husnaedi_land.range[1]}% (staðalfrávik ${H.husnaedi_land.std})`, `clamp ${C.husnaedi_land.join(' … ')}`, ck.okHouseRange],
        ['Atvinnuleysi (%)', `${H.atvinnuleysi.range[0]} … ${H.atvinnuleysi.range[1]}% · meðaltal ${H.atvinnuleysi.mean}`, `clamp ${C.atvinnuleysi.join(' … ')} · NAIRU≈4`, ck.okUnempRange && ck.okNairu],
        ['Verðbólga (12-mán %)', `${H.verdbolga.range[0]} … ${H.verdbolga.range[1]}% · AR(1)=${H.verdbolga.ar1}`, `þrálæti staðfest (infl_persist ${H.model.infl_persist})`, ck.okInflRange && ck.okInflPersist],
        ['Vextir → húsnæði (fylgni, töf 2 ár)', `höfuðb ${H.corrHbs} · landsb ${H.corrLand}`, `neikvæð staðfest (r_hbs ${H.model.r_hbs}, r_land ${H.model.r_land})`, ck.okRateHouse],
      ];
      if (H.leiga) rows.push(['Leiga (12-mán %, 5–95% bil)', `${H.leiga.range[0]} … ${H.leiga.range[1]}%`, `clamp ${C.leiga.join(' … ')}`, ck.okRentRange]);
      if (H.hagvoxtur) rows.push(['Hagvöxtur (ársfj. %)', `${H.hagvoxtur.range[0]} … ${H.hagvoxtur.range[1]}%`, `clamp ${C.hagvoxtur.join(' … ')}`, ck.okGdpRange]);
      if (H.laun) rows.push(['Launavöxtur (%)', `${H.laun.range[0]} … ${H.laun.range[1]}%`, `sleði 0 … ${BASELINE.levers.laun.max}%`, ck.okWageRange]);
      const F = H.forecast;
      const fc = F && F.infl_imf != null ? `<p style="font-size:12px;color:var(--muted);margin:12px 0 4px"><b style="color:#f6b13b">📅 Viðmið við opinbera spá (${F.src})</b></p>
        <table class="lnk-tbl"><tr><th>Hagvísir ${F.tgtYear}</th><th>RÁS grunnferill (BAU)</th><th>Opinber spá</th><th style="text-align:center">✓</th></tr>
        <tr><td>Verðbólga</td><td>${num(F.infl_bau)}%</td><td style="color:var(--faint)">${num(F.infl_imf)}%</td><td style="text-align:center">${chk(ck.okForecast)}</td></tr>
        <tr><td>Hagvöxtur</td><td>${num(F.gdp_bau)}%</td><td style="color:var(--faint)">${num(F.gdp_imf)}%</td><td style="text-align:center">${chk(ck.okForecast)}</td></tr></table>
        <p style="font-size:11.5px;color:var(--faint);margin-top:4px">Grunnferill módelsins er festur á opinberu spána — sviðsmyndir eru FRÁVIK frá henni. Staðfestir að útgangsstaðan = alþjóðleg samstaða.</p>` : '';
      host.innerHTML = `<div class="cm-title">📊 Söguleg bakprófun — raun-gögn ${H.span}${all ? ' <span style="color:#54d08a;font-weight:400">· allt í takt við gögnin ✓</span>' : ''}</div>
        <p style="font-size:12px;color:var(--muted);margin:0 0 8px">„Veruleika-próf": eru módel-mörkin (clamp) og lykil-stuðlarnir í takt við það sem raunverulega gerðist 2010–2026? Gögn: Seðlabanki (CPI/vextir/gengi), Þjóðskrá (fasteignaverð höfuðb./landsb.), Vinnumálastofnun (atvinnuleysi), HMS (leiga), Hagstofa (VLF/laun). Ekki hagfræðileg nákvæmnis-kvörðun.</p>
        <table class="lnk-tbl"><tr><th>Hagvísir</th><th>Raun-gögn 2010–2026</th><th>Módel</th><th style="text-align:center">✓</th></tr>
        ${rows.map((r) => `<tr><td>${r[0]}</td><td style="font-variant-numeric:tabular-nums">${r[1]}</td><td style="color:var(--faint)">${r[2]}</td><td style="text-align:center">${chk(r[3])}</td></tr>`).join('')}</table>${fc}
        <p style="font-size:11.5px;color:var(--faint);margin-top:8px">Lykil-niðurstöður: verðbólga er MJÖG þrálát (AR(1)=${H.verdbolga.ar1}) → réttlætir verðbólguvæntinga-lykkjuna; hærri vextir tengjast lægra húsnæðisverði (töf ~2 ár) á BÁÐUM mörkuðum; söguleg bil rúmast innan módel-marka; grunnferill = opinber spá.</p>`;
    }

    // 🏛️ Fjármálaáætlun ríkisins: grunnferill afkomu/skulda (10 ár) tekinn úr henni. Sýnir markmið + skilaboð + öldrunar-kostnað.
    function buildFiscalPlan() {
      const host = document.getElementById('fiscalplan'); if (!host || !BASELINE.fiscalPlan) return;
      const fp = BASELINE.fiscalPlan, A = BASELINE.outcomes.afkoma.path, S = BASELINE.outcomes.skuldir.path;
      const yr = (t) => 2026 + Math.round(t / 4);
      let jofnAr = null; for (let t = 0; t < A.length; t++) if (A[t] >= -0.05) { jofnAr = yr(t); break; }
      const msgs = (fp.skilabod || []).map((m) => `<li><b>${m[0]}</b> — ${m[1]}</li>`).join('');
      const heilbr = fp.heilbr ? `Öldrun: heilbrigðisútgjöld fara úr ${fp.heilbr.vlf[0]}% í ${fp.heilbr.vlf[fp.heilbr.vlf.length - 1]}% af VLF til ${fp.heilbr.ar[fp.heilbr.ar.length - 1]} — vaxandi langtíma-þrýstingur á ríkissjóð.` : '';
      const bonds = fp.bonds ? `💹 Skuldabréfamarkaður: ríkisbréf (RIKB) ${fp.bonds.short.yr} <b>${num(fp.bonds.short.yield)}%</b> → ${fp.bonds.long.yr} <b>${num(fp.bonds.long.yield)}%</b>${fp.bonds.short.yield > fp.bonds.long.yield ? ' — öfug vaxtaferill: markaðurinn verðleggur vaxtalækkanir' : ''}. Ávöxtunarkrafan sem markaðurinn rukkar til að fjármagna skuldirnar.` : '';
      host.innerHTML = `<div class="cm-title">🏛️ Fjármálaáætlun ríkisins — 10-ára grunnferill fylgir henni</div>
        <p style="font-size:12px;color:var(--muted);margin:0 0 8px">Grunnferill (BAU) afkomu og skulda er tekinn BEINT úr langtíma-fjármálaáætlun ríkisins (${fp.heimild || 'fjármálaáætlun'}) — sviðsmyndir eru FRÁVIK frá henni. Áætlunin: afkoma nær jöfnuði ~${jofnAr || 2028}, skuldir ${num(S[0])}% → ${num(S[S.length - 1])}% að ${fp.markmid || 30}%-skuldamarkmiði.</p>
        <ul style="font-size:12px;color:var(--muted);margin:0 0 6px;padding-left:18px;line-height:1.55">${msgs}</ul>
        ${heilbr ? `<p style="font-size:11.5px;color:var(--faint);margin-top:6px">${heilbr}</p>` : ''}
        ${bonds ? `<p style="font-size:11.5px;color:var(--muted);margin-top:6px;border-top:1px solid var(--line);padding-top:6px">${bonds}</p>` : ''}`;
    }

    // 📐 Econometrísk kvörðun: OLS-mat lykil-stuðla úr raun-röðum 2010-26 (calibration.json) borið saman við handsett
    // módel-gildi — sýnir hvort gögnin STAÐFESTA eða HAFNA hverju gildi (dómur = fellur módel-gildi innan 95% CI matsins).
    function buildCalibration() {
      const host = document.getElementById('calibration'); if (!host || !CALIBRATION || !CALIBRATION.regressions) return;
      const R = CALIBRATION.regressions.filter((r) => r.ok !== false);
      if (!R.length) return;
      const verdict = (r) => r.validated == null ? '<span style="color:var(--faint)">viðmið</span>'
        : r.validated ? '<span style="color:#54d08a">✓ staðfest</span>' : '<span style="color:#e78284">⚠ víkur</span>';
      const rows = R.map((r) => `<tr><td>${r.label}</td>
        <td style="font-variant-numeric:tabular-nums">${r.modelCoef == null ? '<span style="color:var(--faint)">–</span>' : num(r.modelCoef, 2)}</td>
        <td style="font-variant-numeric:tabular-nums">${num(r.coef, 2)} <span class="dyn-sub">±${num(1.96 * r.se, 2)}</span>${r.sig ? '' : ' <span class="dyn-sub">(ómarkt.)</span>'}</td>
        <td style="font-variant-numeric:tabular-nums;color:var(--faint)">${num(r.r2, 2)}</td>
        <td style="font-variant-numeric:tabular-nums;color:var(--faint)">${r.n}</td>
        <td style="text-align:center">${verdict(r)}</td></tr>`).join('');
      const nVal = R.filter((r) => r.validated === true).length, nMod = R.filter((r) => r.modelCoef != null).length;
      host.innerHTML = `<div class="cm-title">📐 Econometrísk kvörðun — hvað segja gögnin um stuðlana? ${nMod ? `<span style="font-weight:400;color:var(--faint)">· ${nVal}/${nMod} handsett gildi staðfest af gögnum</span>` : ''}</div>
        <p style="font-size:12px;color:var(--muted);margin:0 0 8px">OLS-aðhvarf á ársfjórðungslegum raun-röðum 2010–2026 metur lykil-stuðla módelsins beint úr gögnunum. „Dómur" = fellur handsetta módel-gildið innan 95% öryggisbils matsins (þá <b>hafna gögnin því ekki</b>). Færir herminn frá „stílfært" að „reynslu-grundað".</p>
        <table class="lnk-tbl"><tr><th>Samband</th><th>Módel (handsett)</th><th>OLS-mat (95%)</th><th>R²</th><th>n</th><th style="text-align:center">Dómur</th></tr>${rows}</table>
        <p style="font-size:11.5px;color:var(--faint);margin-top:8px">${CALIBRATION.note} T.d. staðfestir mat vaxta→húsnæðis (semi-teygni ~−1,1) handsetta gildið; verðbólgu-tregða mælist há (ársfj. AR1 ~0,9) en dreifist í módelinu á fleiri en eina endurgjöf; Phillips-halli er flatur/ómarktækur í íslenskum gögnum (þekkt). Einstök jöfnu-aðhvörf — ekki full kerfis-kvörðun.</p>`;
    }

    // 🏭 Raunhagkerfið: sækir samandregna ÍSAT-samsetningu úr D1 (ársreikningar) og grundar herminn í raun-fyrirtækjum.
    // Bilar hljóðlega (fela spjaldið) ef endapunktur óstilltur/tómur — módelið stendur eitt og sér án þessa.
    async function buildSectorsReal() {
      const host = document.getElementById('sectors-real'); if (!host) return;
      let d; try { const res = await fetch('/api/roads/atvinnuvegir'); if (!res.ok) return; d = await res.json(); } catch (e) { return; }
      if (!d || !d.greinar || !d.greinar.length) return;
      const mx = Math.max(...d.greinar.map((g) => g.hlutur), 1);
      const mak = (v) => v >= 1e9 ? num(v / 1e9, 0) + ' ma.kr.' : num(Math.max(0, v) / 1e6, 0) + ' m.kr.';
      const rows = d.greinar.map((g) => `<tr><td>${g.nafn}</td>
        <td style="font-variant-numeric:tabular-nums">${mak(g.sala)}</td>
        <td><span class="sec-bar"><i style="width:${(100 * g.hlutur / mx).toFixed(0)}%"></i></span> <b>${num(g.hlutur)}%</b></td>
        <td style="font-variant-numeric:tabular-nums;color:${g.framlegd == null ? 'var(--faint)' : g.framlegd >= 0 ? '#54d08a' : '#e78284'}">${g.framlegd == null ? '–' : num(g.framlegd) + '%'}</td>
        <td style="color:var(--faint);font-variant-numeric:tabular-nums">${num(g.n, 0)}</td></tr>`).join('');
      host.innerHTML = `<div class="cm-title">🏭 Raunhagkerfið í dag — samsetning atvinnuvega úr ársreikningum</div>
        <p style="font-size:12px;color:var(--muted);margin:0 0 8px">Grundar herminn í raun-fyrirtækjagögnum: heildarvelta, hlutur af heild og framlegð (hagnaður/velta) hverrar ÍSAT-greinar, dregið saman úr <b>${num(d.n_felog, 0)}</b> ársreikningum (nýjasta ár per félag). Sýnir hlutfallslega stærð greinanna sem herminn stillir. Vaxandi úrtak — ekki tæmandi þjóðhagsreikningur.</p>
        <table class="lnk-tbl"><tr><th>Atvinnugrein</th><th>Velta</th><th>Hlutur af veltu</th><th>Framlegð</th><th>Félög</th></tr>${rows}</table>
        <p style="font-size:11.5px;color:var(--faint);margin-top:8px">${d.heimild} Samandregið — engin fyrirtæki nafngreind. Sjá <a href="/topplistar-fyrirtaeki/" style="color:#6ea8fe">topplista fyrirtækja</a> fyrir einstök félög í hverri grein.</p>`;
    }

    // Keðju-kort: lagskipt net allra tengsla (dálkar eftir „dýpt" frá inntökum). Grænt=eykur, rautt=dregur úr.
    function buildChainMap() {
      const host = document.getElementById('chainmap'); if (!host) return;
      const NS = 'http://www.w3.org/2000/svg';
      const levers = Object.keys(BASELINE.levers), shocks = Object.keys(BASELINE.shocks), outs = Object.keys(BASELINE.outcomes);
      const inputs = [...levers, ...shocks];
      const isShock = (k) => BASELINE.shocks[k] != null, isOut = (k) => BASELINE.outcomes[k] != null;
      const depth = {}; inputs.forEach((k) => (depth[k] = 0)); outs.forEach((k) => (depth[k] = 1));
      for (let pass = 0; pass < 6; pass++) for (const l of LINKS) if (isOut(l.to) && depth[l.from] != null && l.from !== l.to && depth[l.to] <= depth[l.from]) depth[l.to] = Math.min(depth[l.from] + 1, 6);
      const maxD = Math.max(1, ...outs.map((k) => depth[k]));
      const cols = []; for (let c = 0; c <= maxD; c++) cols[c] = [];
      inputs.forEach((k) => cols[0].push(k)); outs.forEach((k) => cols[depth[k]].push(k));
      const M = 14, COLW = 174, NW = 136, NH = 22, VG = 9;
      const rows = Math.max(...cols.map((c) => c.length));
      const W = M * 2 + maxD * COLW + NW, H = M * 2 + rows * (NH + VG) - VG;
      const pos = {};
      cols.forEach((list, c) => { const colH = list.length * (NH + VG) - VG; const y0 = M + (H - 2 * M - colH) / 2; list.forEach((k, i) => { pos[k] = { x: M + c * COLW, y: y0 + i * (NH + VG), c }; }); });
      const svg = document.createElementNS(NS, 'svg'); svg.setAttribute('width', W); svg.setAttribute('height', H); svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
      const defs = document.createElementNS(NS, 'defs');
      defs.innerHTML = '<marker id="cm-ap" markerWidth="7" markerHeight="7" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#54d08a"/></marker><marker id="cm-an" markerWidth="7" markerHeight="7" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#e78284"/></marker>';
      svg.appendChild(defs);
      const edgeEls = [], gE = document.createElementNS(NS, 'g');
      for (const l of LINKS) {
        if (l.from === l.to) continue;
        const a = pos[l.from], b = pos[l.to]; if (!a || !b) continue;
        const sx = a.x + NW, sy = a.y + NH / 2, tx = b.x, ty = b.y + NH / 2, back = tx <= sx, dx = Math.max(30, Math.abs(tx - sx) * 0.4);
        const bow = back ? 34 + Math.abs(a.c - b.c) * 12 : 0;
        const d = back ? `M${sx},${sy} C${sx + dx},${sy - bow} ${tx - dx},${ty - bow} ${tx},${ty}` : `M${sx},${sy} C${sx + dx},${sy} ${tx - dx},${ty} ${tx},${ty}`;
        const p = document.createElementNS(NS, 'path'), pv = l.coef > 0;
        p.setAttribute('d', d); p.setAttribute('fill', 'none'); p.setAttribute('stroke', pv ? '#54d08a' : '#e78284'); p.setAttribute('stroke-width', '1.2'); p.setAttribute('opacity', '0.13'); p.setAttribute('marker-end', `url(#${pv ? 'cm-ap' : 'cm-an'})`);
        gE.appendChild(p); edgeEls.push({ el: p, from: l.from, to: l.to });
      }
      svg.appendChild(gE);
      const nodeEls = {};
      for (const k of [...inputs, ...outs]) {
        const p = pos[k]; if (!p) continue;
        const g = document.createElementNS(NS, 'g'); g.setAttribute('class', 'cm-node'); g.dataset.k = k;
        const rect = document.createElementNS(NS, 'rect'); rect.setAttribute('x', p.x); rect.setAttribute('y', p.y); rect.setAttribute('width', NW); rect.setAttribute('height', NH); rect.setAttribute('rx', 5);
        rect.setAttribute('fill', isOut(k) ? 'rgba(159,176,200,.16)' : isShock(k) ? 'rgba(246,177,59,.22)' : 'rgba(110,168,254,.22)');
        const t = document.createElementNS(NS, 'text'); t.setAttribute('x', p.x + 8); t.setAttribute('y', p.y + NH / 2 + 3.5); let la = lbl(k); if (la.length > 20) la = la.slice(0, 19) + '…'; t.textContent = la;
        const tt = document.createElementNS(NS, 'title'); tt.textContent = lbl(k) + (driversOf(k).length ? ' ← ' + driversOf(k).join(', ') : '');
        g.appendChild(rect); g.appendChild(t); g.appendChild(tt);
        g.addEventListener('mouseenter', () => hoverNode(k)); g.addEventListener('mouseleave', clearHover);
        svg.appendChild(g); nodeEls[k] = g;
      }
      host.innerHTML = ''; host.appendChild(svg);
      function hoverNode(k) {
        const conn = new Set([k]);
        edgeEls.forEach((e) => { const on = e.from === k || e.to === k; e.el.setAttribute('opacity', on ? '0.95' : '0.03'); e.el.setAttribute('stroke-width', on ? '2.2' : '1'); if (on) { conn.add(e.from); conn.add(e.to); } });
        for (const nk in nodeEls) nodeEls[nk].setAttribute('opacity', conn.has(nk) ? '1' : '0.25');
      }
      function clearHover() { edgeEls.forEach((e) => { e.el.setAttribute('opacity', '0.13'); e.el.setAttribute('stroke-width', '1.2'); }); for (const nk in nodeEls) nodeEls[nk].setAttribute('opacity', '1'); }
    }

    function describeState() {
      const p = [];
      for (const k in state.levers) if (state.levers[k] != null && state.levers[k] !== BASELINE.levers[k].base) p.push(lbl(k) + ' ' + disp(BASELINE.levers[k], state.levers[k]));
      for (const k in state.shocks) if (state.shocks[k]) p.push(lbl(k) + ' ' + (state.shocks[k] > 0 ? '+' : '') + num(state.shocks[k], 0) + BASELINE.shocks[k].unit);
      if (state.autoTay) p.push('sjálfv. vextir'); if (state.autoPhi) p.push('sjálfv. laun');
      return p.length ? p.join(', ') : 'grunnstaða';
    }
    function updateCmp() {
      const btn = document.getElementById('cmp'), bar = document.getElementById('cmpbar');
      if (state.compare) { btn.classList.add('on'); btn.textContent = '✕ Hætta samanburði'; bar.hidden = false; bar.innerHTML = `⚖️ <b>Samanburður:</b> <span style="color:#f6b13b"><span class="sw" style="background:#f6b13b"></span> A = núverandi</span> vs <span style="color:#5ac8e0"><span class="sw" style="background:#5ac8e0"></span> B = ${state.compare.desc}</span>`; }
      else { btn.classList.remove('on'); btn.textContent = '⚖️ Festa til samanburðar'; bar.hidden = true; }
    }

    function applyHorizon() {
      document.querySelectorAll('#horizon button').forEach((b) => b.classList.toggle('on', +b.dataset.h === state.horizon));
      const hn = document.getElementById('hnote');
      if (state.horizon > BASELINE.quarters) { hn.hidden = false; hn.innerHTML = '🔭 <b>10 ára sýn</b> — stílfærð langtíma-framreikning (grunnferill heldur 3-ára jafnvægi). Skýrust fyrir <b>skuldir, losun og vanskil</b> sem safnast upp; lýðfræði til langs tíma er á <a href="/mannfjoldi/">/mannfjoldi/</a>. Óvissa vex með tíma.'; }
      else hn.hidden = true;
    }

    // ── Greiningar-tól (Tier 3): keyra módelið mörgum sinnum ──
    const simFull = (ov) => simulate({ baseline: BASELINE, links: LINKS, levers: { ...state.levers, ...ov }, shocks: state.shocks, quarters: state.horizon });
    const endVal = (r, k) => r.outcomes[k].mid[r.outcomes[k].mid.length - 1];

    function drawTornado(outKey) {
      const host = document.getElementById('tornado'); if (!host || !BASELINE.outcomes[outKey]) return;
      const rows = [];
      for (const k in BASELINE.levers) { const cfg = BASELINE.levers[k], step = (cfg.max - cfg.min) * 0.25, cur = state.levers[k] ?? cfg.base;
        const up = endVal(simFull({ [k]: Math.min(cfg.max, cur + step) }), outKey), dn = endVal(simFull({ [k]: Math.max(cfg.min, cur - step) }), outKey);
        const impact = up - dn; if (Math.abs(impact) > 1e-3) rows.push({ label: cfg.label, impact }); }
      rows.sort((a, b) => Math.abs(b.impact) - Math.abs(a.impact)); const top = rows.slice(0, 12);
      const us = BASELINE.outcomes[outKey].unit === '% VLF' ? '%' : BASELINE.outcomes[outKey].unit, pol = POLARITY[outKey] ?? 0;
      if (!top.length) { host.innerHTML = '<p style="color:var(--faint);font-size:12px">Engin ákvörðun hefur mælanleg áhrif á þennan hagvísi.</p>'; return; }
      const maxA = Math.max(...top.map((r) => Math.abs(r.impact)));
      host.innerHTML = `<p style="font-size:11.5px;color:var(--faint);margin:0 0 6px">Sveifla í «${BASELINE.outcomes[outKey].label}» af ±25% hreyfingu hvers sleða (raðað eftir áhrifum). Grænt=hreyfir í jákvæða átt fyrir hagvísinn, rautt=neikvæða.</p>` +
        top.map((r) => { const col = pol === 0 ? '#6ea8fe' : (r.impact * pol > 0 ? '#54d08a' : '#e78284'); return `<div class="tor-row"><span>${r.label}</span><div class="tor-bar"><i style="left:0;width:${Math.abs(r.impact) / maxA * 100}%;background:${col}"></i></div><span class="tv">${r.impact > 0 ? '+' : ''}${num(r.impact)}${us}</span></div>`; }).join('');
    }

    function drawFrontier(levKey, xKey, yKey) {
      const host = document.getElementById('frontier'); if (!host) return; host.innerHTML = '<canvas></canvas>';
      const cfg = BASELINE.levers[levKey], N = 15, pts = [];
      for (let i = 0; i < N; i++) { const v = cfg.min + (cfg.max - cfg.min) * i / (N - 1), r = simFull({ [levKey]: v }); pts.push({ v, x: endVal(r, xKey), y: endVal(r, yKey) }); }
      const cv = host.querySelector('canvas'), dpr = Math.min(2, window.devicePixelRatio || 1), w = cv.clientWidth || 600, h = 300; cv.width = w * dpr; cv.height = h * dpr; const ctx = cv.getContext('2d'); ctx.scale(dpr, dpr);
      const xs = pts.map((p) => p.x), ys = pts.map((p) => p.y); let xmn = Math.min(...xs), xmx = Math.max(...xs), ymn = Math.min(...ys), ymx = Math.max(...ys);
      if (xmx - xmn < 0.4) { xmn -= 0.4; xmx += 0.4; } if (ymx - ymn < 0.4) { ymn -= 0.4; ymx += 0.4; } const px = (xmx - xmn) * 0.06, py = (ymx - ymn) * 0.08; xmn -= px; xmx += px; ymn -= py; ymx += py;
      const pl = 44, pr = 12, pt = 10, pb = 30, X = (v) => pl + (w - pl - pr) * (v - xmn) / (xmx - xmn || 1), Y = (v) => (h - pb) - (h - pt - pb) * (v - ymn) / (ymx - ymn || 1);
      ctx.strokeStyle = 'rgba(255,255,255,.07)'; ctx.fillStyle = 'rgba(159,176,200,.7)'; ctx.font = '10px system-ui';
      ctx.textAlign = 'right'; ctx.textBaseline = 'middle'; for (let g = 0; g <= 4; g++) { const v = ymn + (ymx - ymn) * g / 4, y = Y(v); ctx.beginPath(); ctx.moveTo(pl, y); ctx.lineTo(w - pr, y); ctx.stroke(); ctx.fillText(num(v, 1), pl - 4, y); }
      ctx.textAlign = 'center'; ctx.textBaseline = 'top'; for (let g = 0; g <= 4; g++) { const v = xmn + (xmx - xmn) * g / 4; ctx.fillText(num(v, 1), X(v), h - pb + 3); }
      ctx.beginPath(); pts.forEach((p, i) => (i ? ctx.lineTo(X(p.x), Y(p.y)) : ctx.moveTo(X(p.x), Y(p.y)))); ctx.strokeStyle = '#f6b13b'; ctx.lineWidth = 2; ctx.lineJoin = 'round'; ctx.stroke();
      const curV = state.levers[levKey] ?? cfg.base;
      pts.forEach((p, i) => { const near = Math.abs(p.v - curV) < (cfg.max - cfg.min) / (N - 1) / 2; ctx.beginPath(); ctx.arc(X(p.x), Y(p.y), near ? 5 : 2.6, 0, 7); ctx.fillStyle = near ? '#fff' : '#f6b13b'; ctx.fill(); });
      const dec = cfg.step < 1 ? 2 : 0;
      ctx.fillStyle = 'rgba(159,176,200,.9)'; ctx.textAlign = 'left'; ctx.textBaseline = 'bottom'; ctx.fillText(cfg.label + ' = ' + disp(cfg, pts[0].v, dec), X(pts[0].x) + 5, Y(pts[0].y) - 4);
      ctx.fillText(disp(cfg, pts[N - 1].v, dec), X(pts[N - 1].x) + 5, Y(pts[N - 1].y) - 4);
      ctx.fillStyle = '#f6b13b'; ctx.textAlign = 'center'; ctx.font = '11px system-ui';
      ctx.fillText('X: ' + BASELINE.outcomes[xKey].label + '  ·  Y: ' + BASELINE.outcomes[yKey].label + '  (hvítur punktur = núverandi stilling)', w / 2, h - 2);
    }

    function runInverse(outKey, target, levKey) {
      const cfg = BASELINE.levers[levKey], f = (v) => endVal(simFull({ [levKey]: v }), outKey) - target;
      let lo = cfg.min, hi = cfg.max; const flo = f(lo), fhi = f(hi);
      if (flo * fhi > 0) { const closest = Math.abs(flo) < Math.abs(fhi) ? lo : hi; return { ok: false, v: closest, achieved: endVal(simFull({ [levKey]: closest }), outKey) }; }
      for (let it = 0; it < 40; it++) { const mid = (lo + hi) / 2; if (f(lo) * f(mid) <= 0) hi = mid; else lo = mid; }
      const vr = Math.round((lo + hi) / 2 / cfg.step) * cfg.step; return { ok: true, v: vr, achieved: endVal(simFull({ [levKey]: vr }), outKey) };
    }

    function buildAnalysisSelects() {
      if (document.getElementById('tor-out').options.length) return;
      const outs = Object.keys(BASELINE.outcomes), levs = Object.keys(BASELINE.levers);
      const oopt = outs.map((k) => `<option value="${k}">${BASELINE.outcomes[k].label}</option>`).join(''), lopt = levs.map((k) => `<option value="${k}">${BASELINE.levers[k].label}</option>`).join('');
      ['tor-out', 'fr-x', 'fr-y', 'inv-out'].forEach((id) => (document.getElementById(id).innerHTML = oopt));
      ['fr-lev', 'inv-lev'].forEach((id) => (document.getElementById(id).innerHTML = lopt));
      document.getElementById('tor-out').value = 'verdbolga'; document.getElementById('fr-lev').value = 'vextir'; document.getElementById('fr-x').value = 'atvinnuleysi'; document.getElementById('fr-y').value = 'verdbolga';
      document.getElementById('inv-out').value = 'verdbolga'; document.getElementById('inv-lev').value = 'vextir'; document.getElementById('inv-target').value = 2.5;
      document.getElementById('tor-out').addEventListener('change', (e) => drawTornado(e.target.value));
      ['fr-lev', 'fr-x', 'fr-y'].forEach((id) => document.getElementById(id).addEventListener('change', () => drawFrontier(document.getElementById('fr-lev').value, document.getElementById('fr-x').value, document.getElementById('fr-y').value)));
      document.getElementById('inv-go').addEventListener('click', () => {
        const oK = document.getElementById('inv-out').value, lK = document.getElementById('inv-lev').value, tgt = +document.getElementById('inv-target').value;
        const cfg = BASELINE.levers[lK], dec = cfg.step < 1 ? 2 : 0, oL = BASELINE.outcomes[oK].label, us = BASELINE.outcomes[oK].unit === '% VLF' ? '%' : BASELINE.outcomes[oK].unit;
        const r = runInverse(oK, tgt, lK), el = document.getElementById('inv-result');
        el.innerHTML = r.ok ? `✅ Stilltu <b>${cfg.label}</b> á <b>${disp(cfg, r.v, dec)}</b> → ${oL} verður <b>${num(r.achieved)}${us}</b> (markmið ${num(tgt)}${us}).`
          : `⚠ Markmiðið næst ekki með þessum sleða einum innan sviðs. Næst kemst með <b>${disp(cfg, r.v, dec)}</b> → ${oL} = <b>${num(r.achieved)}${us}</b>. Prófaðu annan sleða eða raunhæfara markmið.`;
      });
      document.getElementById('dyn-go').addEventListener('click', drawDynamic);
    }
    const STRESS = [
      { t: 'Olíuskellur (+80%)', s: { olia: 80 } },
      { t: 'Heimskreppa (−5%)', s: { heimshagvoxtur: -5 } },
      { t: 'Ferðamannahrun (−35%)', s: { ferdamenn: -35 } },
      { t: 'Gengishrun (−20%)', s: { gengi: -20 } },
      { t: 'Aðflutningsstopp (−50%)', s: { adflutningur: -50 } },
      { t: 'Hrávöruverðfall (−30%)', s: { hravaruverd: -30 } },
      { t: 'Samsett áfall (olía + heimskreppa + ferðam.)', s: { olia: 60, heimshagvoxtur: -4, ferdamenn: -25 } },
      { t: 'Fjármálaáfall (gengi + hrávöru + heimskr.)', s: { gengi: -15, hravaruverd: -25, heimshagvoxtur: -3 } },
    ];
    function drawStress() {
      const host = document.getElementById('stress'); if (!host) return;
      const base = Math.round(healthScore(simFull({})));
      const rows = STRESS.map((sc) => {
        const r = simulate({ baseline: BASELINE, links: LINKS, levers: { ...state.levers }, shocks: { ...state.shocks, ...sc.s }, quarters: state.horizon });
        const h = Math.round(healthScore(r)), e = (k) => { const o = r.outcomes[k]; return o ? o.mid[o.mid.length - 1] : 0; }, dmg = [];
        if (e('verdbolga') > 4) dmg.push('verðbólga ' + num(e('verdbolga')) + '%');
        if (e('atvinnuleysi') > 6) dmg.push('atvinnuleysi ' + num(e('atvinnuleysi')) + '%');
        if (e('hagvoxtur') < 0) dmg.push('samdráttur ' + num(e('hagvoxtur')) + '%');
        if (e('afkoma') < -2) dmg.push('halli ' + num(e('afkoma')) + '% VLF');
        if (e('vanskil') > 115) dmg.push('vanskil +' + num(e('vanskil') - 100));
        return { t: sc.t, h, drop: base - h, dmg: dmg.slice(0, 3).join(', ') || '— þolir vel' };
      }).sort((a, b) => a.h - b.h);
      const worst = rows[0];
      host.innerHTML = `<p style="font-size:11.5px;color:var(--faint);margin:0 0 6px">Hvert áfall keyrt ofan á NÚVERANDI stefnu (heilsufar án áfalls: <b style="color:${base >= 70 ? '#54d08a' : '#f6b13b'}">${base}/100</b>). Raðað eftir tjóni. Styrktu stefnuna og keyrðu aftur til að byggja upp viðnám.</p>
        <table class="lnk-tbl"><tr><th>Áfall</th><th>Heilsufar</th><th>Fall</th><th>Helstu skemmdir</th></tr>
        ${rows.map((r) => { const col = r.h >= 70 ? '#54d08a' : r.h >= 45 ? '#f6b13b' : '#e78284'; return `<tr><td>${r.t}</td><td style="color:${col};font-weight:700">${r.h}/100</td><td style="color:${r.drop > 0 ? '#e78284' : 'var(--faint)'}">${r.drop > 0 ? '−' + r.drop : '0'}</td><td style="color:var(--faint)">${r.dmg}</td></tr>`; }).join('')}</table>
        <p style="font-size:11.5px;color:var(--faint);margin-top:6px">Versta áfallið fyrir þessa stefnu: <b style="color:#e78284">${worst.t}</b> → heilsufar ${worst.h}/100 (fall um ${worst.drop}).</p>`;
    }
    function runAnalysis() { buildAnalysisSelects(); drawTornado(document.getElementById('tor-out').value); drawFrontier(document.getElementById('fr-lev').value, document.getElementById('fr-x').value, document.getElementById('fr-y').value); drawStress(); }

    function reset() { state.levers = {}; state.shocks = {}; state.autoTay = false; state.autoPhi = false; state.compare = null; state.horizon = BASELINE.quarters; document.getElementById('auto-tay').checked = false; document.getElementById('auto-phi').checked = false; updateCmp(); applyHorizon(); document.getElementById('news').hidden = true; buildControls(); run(); }

    // Auto-frétt: sjálfvirk frásögn af núverandi sviðsmynd (fyrsta útgáfa AI-fréttalags — regla-drifið úr útkomum).
    function generateNarrative() {
      const r = state._lastR; if (!r) return; const host = document.getElementById('narrative');
      const yrs = state.horizon > BASELINE.quarters ? '10' : '3', desc = describeState(), health = Math.round(healthScore(r));
      const gk = (k) => { const o = r.outcomes[k]; return o ? o.mid[o.mid.length - 1] : 0; };
      const rangeOf = (k) => { const c = BASELINE.clamp[k]; return c ? (c[1] - c[0]) : 10; }; // stöðluð stærð hagvísis (til samanburðar % vs vísitölu)
      const outs = Object.keys(r.outcomes).map((k) => { const o = r.outcomes[k], end = o.mid[o.mid.length - 1], dlt = end - o.baseline[o.baseline.length - 1]; return { k, label: o.label, end, dlt, us: o.unit === '% VLF' ? '%' : o.unit, sig: Math.abs(dlt) / rangeOf(k) }; });
      const changed = outs.filter((x) => Math.abs(x.dlt) > 0.15).sort((a, b) => b.sig - a.sig);
      const dir = (d) => (d > 0 ? 'hækkar' : 'lækkar'), uw = (us) => (us === '%' || us === 'pp' ? ' prósentustig' : us ? '' : ' stig');
      const fmt = (x) => `${x.label.toLowerCase()} ${dir(x.dlt)} um ${num(Math.abs(x.dlt))}${uw(x.us)} og verður ${num(x.end)}${x.us}`;
      let head, body;
      if (!changed.length) {
        head = 'Óbreytt stefna: grunnspáin gildir';
        body = `Að ${yrs} árum liðnum, án breytinga á stefnu, gerir RÁS ráð fyrir verðbólgu ${num(gk('verdbolga'))}%, hagvexti ${num(gk('hagvoxtur'))}% og atvinnuleysi ${num(gk('atvinnuleysi'))}%. Þjóðhagslegt heilsufar mælist ${health}/100.`;
      } else {
        const t = changed[0];
        head = `${t.label} ${dir(t.dlt)} í ${num(t.end)}${t.us} — ${health}/100 heilsufar`;
        body = `Sviðsmyndin (${desc}) hefði þau áhrif að ${changed.slice(0, 4).map(fmt).join('; ')}. Að ${yrs} árum liðnum mælist þjóðhagslegt heilsufar ${health}/100.`;
      }
      body += ' Stílfærð sambönd byggð á opinberum gögnum — ekki opinber spá.';
      host.hidden = false;
      host.innerHTML = `<div class="nv-h">📰 ${head}</div><div class="nv-b">${body}</div><div class="nv-act"><button id="nv-copy" type="button">📋 Afrita texta</button><button id="nv-close" type="button">✕ Loka</button></div>`;
      document.getElementById('nv-copy').addEventListener('click', (e) => { navigator.clipboard.writeText('📰 ' + head + '\n\n' + body).then(() => { e.currentTarget.classList.add('ok'); e.currentTarget.textContent = '✓ Afritað'; }).catch(() => {}); });
      document.getElementById('nv-close').addEventListener('click', () => { host.hidden = true; });
    }

    // Leikja-hamur: þjóðhagslegar áskoranir sem uppfærast jafnóðum (markmið + skorður).
    const CHALLENGES = [
      { t: 'Verðbólgu-markmið', d: 'verðbólga í 2,3–2,7%', ok: (e) => e('verdbolga') >= 2.3 && e('verdbolga') <= 2.7 },
      { t: 'Afgangur + full atvinna', d: 'afkoma > 0 og atvinnuleysi < 5%', ok: (e) => e('afkoma') > 0 && e('atvinnuleysi') < 5 },
      { t: 'Grænt & vaxandi', d: 'losun < 95 og hagvöxtur > 1,5%', ok: (e) => e('losun') < 95 && e('hagvoxtur') > 1.5 },
      { t: 'Húsnæði í böndum', d: 'húsnæði < 3% og leiga < 4%', ok: (e) => e('husnaedi') < 3 && e('leiga') < 4 },
      { t: 'Sjálfbær sjávarútvegur', d: 'útflutningur > 3% og fiskistofn ≥ 98', ok: (e) => e('utflutningur') > 3 && e('fiskistofn') >= 98 },
      { t: 'Fullkomið heilsufar', d: 'heilsufar 100/100', ok: (e, r) => Math.round(healthScore(r)) >= 100 },
    ];
    function drawChallenges(r) {
      const host = document.getElementById('challenges'); if (!state.gameOn) { host.hidden = true; return; }
      const e = (k) => { const o = r.outcomes[k]; return o ? o.mid[o.mid.length - 1] : 0; };
      const res = CHALLENGES.map((c) => ({ c, done: c.ok(e, r) })), solved = res.filter((x) => x.done).length;
      host.hidden = false;
      host.innerHTML = `<div class="ch-h">🎮 Áskoranir — leyst ${solved}/${CHALLENGES.length}${solved === CHALLENGES.length ? ' · 🏆 ALLT LEYST!' : ' · stilltu ákvarðanir til að leysa'}</div><div class="ch-grid">`
        + res.map((x) => `<div class="ch ${x.done ? 'done' : 'todo'}"><span class="ci">${x.done ? '✅' : '⬜'}</span><span><b>${x.c.t}:</b> ${x.c.d}</span></div>`).join('') + '</div>';
    }

    function buildTabs() {
      const bar = document.getElementById('tabbar'); bar.innerHTML = '';
      TABS.forEach((t) => { const b = document.createElement('button'); b.type = 'button'; b.textContent = t.label; b.title = t.label; b.classList.toggle('on', t.id === state.tab); b.addEventListener('click', () => switchTab(t.id)); bar.appendChild(b); });
    }
    function switchTab(id) { state.tab = id; [...document.getElementById('tabbar').children].forEach((b, i) => b.classList.toggle('on', TABS[i].id === id)); renderTab(); serialize(); }
    function renderTab() {
      const tab = curTab(), isModel = !!tab.model, isAn = tab.special === 'analysis';
      document.getElementById('body3').hidden = isModel || isAn;
      document.getElementById('modelview').hidden = !isModel;
      document.getElementById('analysisview').hidden = !isAn;
      if (isModel) return;
      if (isAn) { runAnalysis(); return; }
      buildControls(); run();
    }
    function buildRealNow() {
      const host = document.getElementById('realnow'); if (!host) return; const O = BASELINE.outcomes, L = BASELINE.levers;
      const items = [['Stýrivextir', L.vextir.base, '%', 2], ['Verðbólga', O.verdbolga.path[0], '%'], ['Hagvöxtur', O.hagvoxtur.path[0], '%'], ['Atvinnuleysi', O.atvinnuleysi.path[0], '%'], ['Húsnæðisverð', O.husnaedi.path[0], '% 12m'], ['Leiga', O.leiga.path[0], '% 12m'], ['Afkoma ríkis', O.afkoma.path[0], '% VLF'], ['Skuldir ríkis', O.skuldir.path[0], '% VLF'], ['Fólksfjölgun', O.mannfjoldi.path[0], '%']];
      host.innerHTML = '<span class="rn-h">📍 Staðan í dag</span>' + items.map(([l, v, u, d]) => `<span class="rn">${l} <b>${num(v, d ?? 1)}${u}</b></span>`).join('');
    }

    function init() {
      const main = document.querySelector('main[data-pg="roads"]'); if (!main || main.dataset.done) return; main.dataset.done = '1';
      document.getElementById('disc').textContent = BASELINE.disclaimer + ' Óvissu-bönd = næmni fyrir stuðla-óvissu.';
      buildRealNow(); buildLinkTable(); buildChainMap(); buildBacktest(); buildFiscalPlan(); buildCalibration(); buildSectorsReal();
      const restored = deserialize(); // sviðsmynd + flipi úr hlekk (ef til)
      document.getElementById('auto-tay').checked = state.autoTay;
      document.getElementById('auto-phi').checked = state.autoPhi;
      applyHorizon();
      buildTabs(); renderTab();
      if (restored) { const n = document.getElementById('news'); n.hidden = false; n.innerHTML = '🔗 <b>Sviðsmynd úr hlekk.</b> Stýringarnar sýna deilda sviðsmynd — breyttu að vild eða núllstilltu.'; }
      document.getElementById('rs').addEventListener('click', reset);
      document.querySelectorAll('#horizon button').forEach((b) => b.addEventListener('click', () => { state.horizon = +b.dataset.h; state.compare = null; updateCmp(); applyHorizon(); run(); }));
      document.getElementById('cmp').addEventListener('click', () => { state.compare = state.compare ? null : { r: state._lastR, desc: describeState() }; updateCmp(); run(); });
      document.getElementById('mc').addEventListener('click', (e) => {
        const btn = e.currentTarget;
        if (state.mc) { state.mc = null; btn.classList.remove('on'); document.getElementById('mcbar').hidden = true; drawHero(state._lastR); return; }
        const t0 = btn.textContent; btn.textContent = '⏳ Hermar…'; btn.disabled = true;
        setTimeout(() => { runMC(); btn.classList.add('on'); btn.textContent = t0; btn.disabled = false; drawHero(state._lastR); drawMCbar(); }, 20);
      });
      document.getElementById('share').addEventListener('click', (e) => { const b = e.currentTarget; navigator.clipboard.writeText(location.href).then(() => { b.classList.add('ok'); const t = b.textContent; b.textContent = '✓ Hlekkur afritaður'; setTimeout(() => { b.classList.remove('ok'); b.textContent = t; }, 1800); }).catch(() => {}); });
      document.getElementById('frett').addEventListener('click', generateNarrative);
      document.getElementById('game').addEventListener('click', (e) => { state.gameOn = !state.gameOn; e.currentTarget.classList.toggle('on', state.gameOn); if (state.gameOn && state._lastR) drawChallenges(state._lastR); else document.getElementById('challenges').hidden = true; });
      document.getElementById('auto-tay').addEventListener('change', (e) => { state.autoTay = e.target.checked; if (!e.target.checked && state._sol) { state.levers.vextir = state._sol.vextir; syncSlider('vextir', state._sol.vextir); } applyAutoDisable(); run(); });
      document.getElementById('auto-phi').addEventListener('change', (e) => { state.autoPhi = e.target.checked; if (!e.target.checked && state._sol) { state.levers.laun = state._sol.laun; syncSlider('laun', state._sol.laun); } applyAutoDisable(); run(); });
    }
    init();
    document.addEventListener('astro:page-load', init);
  </script>
</Layout>
