---
// RÁS Íslands — hagkerfis-STJÓRNKLEFI. Vél: @lib/roads/engine.mjs (client-hlið, ósnert).
// Ákvarðanir vinstra · útkomu-net miðju · ytri sjokk hægra. Sjálfvirk peningastefna/launaþróun
// = UI fastpunkts-ítrun (vélin ósnert). Hover á sleða lýsir upp keðjurnar. Ekki opinber spá.
import Layout from '../layouts/Layout.astro';
import BASELINE from '@gogn/roads/baseline.json';
import LINKS from '@gogn/roads/links.json';
const desc = 'RÁS Íslands — Reiknilíkan Áhrifa á Samfélagið. Gagnsær hermir sem sýnir rásina frá ákvörðun til afleiðingar: stilltu vexti, laun, skatta, kvóta og fleira og sjáðu stílfærð áhrif á hagvísa næstu 3–10 árin, með óvissu og heimildum.';
---
<Layout title="RÁS Íslands — hagkerfis-stjórnklefi | Karp" description={desc} canonical="https://karp.is/hermir/" ogTitle="RÁS Íslands — stjórnklefi" wide={true}>
  <main data-pg="roads" class="dash">
    <div class="dash-top">
      <div class="dash-head"><h1>RÁS Íslands 🎛️</h1><div class="horizon" id="horizon"><span>Sjóndeildarhringur:</span><button type="button" data-h="12" class="on">3 ár</button><button type="button" data-h="40">10 ár</button></div></div>
      <p class="brandsub"><b>R</b>eiknilíkan <b>Á</b>hrifa á <b>S</b>amfélagið — rásin frá ákvörðun til afleiðingar.</p>
      <p class="disc" id="disc"></p>
      <div class="tabbar" id="tabbar"></div>
      <div class="r-topbar"><div id="health" class="health"></div><div id="score" class="score"></div></div>
      <div id="realnow" class="realnow"></div>
      <p id="news" class="news" hidden></p>
      <p id="hnote" class="hnote" hidden></p>
      <div id="cmpbar" class="cmpbar" hidden></div>
      <div id="mcbar" class="mcbar" hidden></div>
      <div id="narrative" class="narrative" hidden></div>
      <div id="challenges" class="challenges" hidden></div>
    </div>
    <div class="dash-body3" id="body3">
      <div class="controls" id="ctl-left">
        <div class="ctl-h" id="ctl-left-h">🎚️ Ákvarðanir</div>
        <label class="auto" id="lbl-tay" title="Kveikt: Seðlabankinn stillir vexti sjálfur eftir Taylor-reglu (bregst við verðbólgu). Sleðinn hreyfist sjálfkrafa."><input type="checkbox" id="auto-tay"> 🏛️ Sjálfvirk peningastefna</label>
        <label class="auto" id="lbl-phi" title="Kveikt: laun bregðast sjálf við atvinnuleysi (Phillips-kúrfa). Lítið atvinnuleysi → hærri laun."><input type="checkbox" id="auto-phi"> 💬 Sjálfvirk launaþróun</label>
        <div id="levers"></div>
        <p class="hint" id="lever-hint" hidden>Veldu efnis-flipa að ofan til að stilla ákvarðanir og rekja þráðinn frá ákvörðun til afleiðingar.</p>
        <button id="rs" type="button">↺ Núllstilla</button>
        <button id="mc" type="button" title="Keyrir hundruð herma með slembnum stuðlum innan óvissubils hvers tengsls → líkinda-viftur (5–95%) og líkinda-yfirlýsingar í stað fastra banda.">🎲 Óvissu-hermun</button>
        <button id="cmp" type="button" title="Festir núverandi sviðsmynd (B). Breyttu svo stýringum og berðu saman við hana á öllum kortum.">⚖️ Festa til samanburðar</button>
        <button id="share" type="button" title="Afritar hlekk sem geymir núverandi sviðsmynd — hægt að deila eða vista">🔗 Afrita hlekk á sviðsmynd</button>
        <button id="frett" type="button" title="Býr til skriflega lýsingu á mannamáli á núverandi sviðsmynd — tilbúna til að afrita.">📄 Skrifleg lýsing</button>
        <button id="game" type="button" title="Kveikir á áskorunum — leystu þjóðhagsleg þrautir með því að stilla ákvarðanir. Uppfærist jafnóðum.">🎮 Áskoranir</button>
      </div>
      <div class="center"><div id="hero" class="hero"></div><div id="charts" class="charts"></div></div>
      <div class="controls" id="ctl-right">
        <div class="ctl-h">⚡ Ytri áhrif</div>
        <div id="shocks"></div>
        <p class="hint" id="shock-hint">Hreyfðu bendil yfir sleða til að lýsa upp hagvísana sem hann drífur.</p>
      </div>
    </div>
    <div id="modelview" class="modelview" hidden>
      <div id="cmwrap"><div class="cm-title">🕸️ Keðju-kort — allt orsakanetið á einni mynd (hover/smelltu á hnút)</div><div class="cm-legend"><span><i class="cm-in"></i> ákvörðun</span><span><i class="cm-shk"></i> ytri áhrif</span><span><i class="cm-out"></i> hagvísir</span><span><i class="cm-pos"></i> eykur</span><span><i class="cm-neg"></i> dregur úr</span></div><div id="chainmap"></div></div>
      <div id="backtest" class="backtest"></div>
      <div id="fiscalplan" class="backtest"></div>
      <div id="calibration" class="backtest"></div>
      <div id="sectors-real" class="backtest"></div>
      <details class="transp" open><summary>⚙︎ Öll orsakasambönd, stuðlar og heimildir</summary><div id="lnks"></div></details>
    </div>
    <div id="analysisview" class="analysisview" hidden>
      <p class="an-intro">Greiningar-tól sem keyra módelið mörgum sinnum til að svara „hvað ef"- og „hvað þarf"-spurningum. Miðað við núverandi sviðsmynd og sjóndeild.</p>
      <div class="an-tool">
        <div class="an-h">📊 Næmnisgreining — hvaða ákvarðanir hreyfa hagvísi mest?</div>
        <div class="an-ctl"><label>Hagvísir: <select id="tor-out"></select></label></div>
        <div id="tornado"></div>
      </div>
      <div class="an-tool">
        <div class="an-h">📈 Skipti-jaðar — samband tveggja hagvísa þegar ein ákvörðun breytist yfir allt sviðið</div>
        <div class="an-ctl"><label>Ákvörðun: <select id="fr-lev"></select></label> <label>X-ás: <select id="fr-x"></select></label> <label>Y-ás: <select id="fr-y"></select></label></div>
        <div id="frontier"></div>
      </div>
      <div class="an-tool">
        <div class="an-h">🛡️ Álagspróf — hversu vel þolir núverandi stefna óhagstæð áföll?</div>
        <div id="stress"></div>
      </div>
      <div class="an-tool">
        <div class="an-h">🏆 Dýnamísk leið — borgar sig að fasa stefnuna (herða fyrst, slaka svo)?</div>
        <p class="an-intro" style="margin:2px 0 8px">Bestar 2-fasa leið (áfangi 1 = fyrri helmingur sjóndeildar, áfangi 2 = seinni) fyrir tíma-næmar ákvarðanir og ber saman við bestu FÖSTU stillingu. Markmið: hæst <b>meðal</b>-heilsufar yfir alla sjóndeildina — umbunar leið sem kemst hratt í gott ástand, ekki bara lokastöðu. Nýtir tímaháðar leiðir í vélinni.</p>
        <div class="an-ctl"><button id="dyn-go" type="button">Reikna dýnamíska leið</button></div>
        <div id="dyn-result" class="inv-result"></div>
      </div>
      <div class="an-tool">
        <div class="an-h">🎯 Markmiða-leit — hvaða stilling hittir markmiðið? (andhverfur hamur)</div>
        <div class="an-ctl"><label>Ég vil <select id="inv-out"></select> =</label> <input id="inv-target" type="number" step="0.1" style="width:80px"> <label>með því að stilla <select id="inv-lev"></select></label> <button id="inv-go" type="button">Finna stillingu</button></div>
        <div id="inv-result" class="inv-result"></div>
      </div>
    </div>
    <p class="foot">Forþjónað (SSG) {BASELINE.updated}. RÁS-tímaskref-líkan · {LINKS.length} kvörðuð tengsl m/heimildum · {Object.keys(BASELINE.outcomes).length} hagvísar. Stílfærð sambönd — ekki opinber spá.</p>
  </main>

  <style is:global>
    main[data-pg="roads"].dash { max-width: none; margin: 0; padding: 20px 22px 60px; }
    main[data-pg="roads"] .dash-head { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin: 0; }
    main[data-pg="roads"] .dash-head h1 { font-size: 25px; margin: 0; }
    main[data-pg="roads"] .disc { display: block; font-size: 12px; color: var(--faint); margin: 6px 0 16px; }
    main[data-pg="roads"] .brandsub { font-size: 12.5px; color: var(--muted); margin: 2px 0 0; }
    main[data-pg="roads"] .brandsub b { color: #f6b13b; }
    main[data-pg="roads"] .horizon { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; color: var(--faint); margin-left: auto; }
    main[data-pg="roads"] .horizon button { background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--muted); border-radius: 7px; padding: 3px 10px; font-size: 12px; font-weight: 700; cursor: pointer; }
    main[data-pg="roads"] .horizon button.on { color: #f6b13b; border-color: #f6b13b; background: rgba(246,177,59,.1); }
    main[data-pg="roads"] .hnote { font-size: 12px; color: var(--muted); background: rgba(110,168,254,.08); border: 1px solid rgba(110,168,254,.28); border-radius: 10px; padding: 8px 13px; margin: 0 0 12px; }
    main[data-pg="roads"] .hnote a { color: #6ea8fe; }
    main[data-pg="roads"] .r-topbar { display: flex; gap: 10px; align-items: stretch; margin: 0 0 14px; flex-wrap: wrap; }
    main[data-pg="roads"] .health { flex: 0 0 168px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px; display: flex; flex-direction: column; justify-content: center; }
    main[data-pg="roads"] .health .h-l { font-size: 11px; color: var(--faint); text-transform: uppercase; letter-spacing: .03em; }
    main[data-pg="roads"] .health .h-v { font-size: 27px; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1.05; }
    main[data-pg="roads"] .health .h-bar { height: 5px; border-radius: 3px; background: rgba(255,255,255,.08); margin-top: 5px; overflow: hidden; }
    main[data-pg="roads"] .health .h-bar > i { display: block; height: 100%; border-radius: 3px; }
    main[data-pg="roads"] .score { flex: 1 1 400px; display: flex; flex-wrap: wrap; gap: 8px; }
    main[data-pg="roads"] .sc { flex: 1 1 118px; min-width: 118px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 7px 11px; display: flex; flex-direction: column; }
    main[data-pg="roads"] .sc-l { font-size: 10.5px; color: var(--faint); text-transform: uppercase; letter-spacing: .03em; }
    main[data-pg="roads"] .sc-v { font-size: 20px; font-weight: 800; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sc-d { font-size: 11px; font-weight: 700; }
    main[data-pg="roads"] .scn { display: flex; flex-wrap: wrap; gap: 6px; margin: 6px 0 10px; }
    main[data-pg="roads"] .scn button { background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--muted); border-radius: 8px; padding: 5px 11px; font-size: 12px; font-weight: 600; cursor: pointer; }
    main[data-pg="roads"] .scn button:hover, main[data-pg="roads"] .scn button.on { color: #f6b13b; border-color: #f6b13b; }
    main[data-pg="roads"] .news { font-size: 14px; color: var(--ink); background: rgba(246,177,59,.08); border: 1px solid rgba(246,177,59,.3); border-radius: 10px; padding: 10px 14px; margin: 0 0 12px; }
    main[data-pg="roads"] .news b { color: #f6b13b; }
    main[data-pg="roads"] .dash-body3 { display: grid; grid-template-columns: 232px minmax(0,1fr) 232px; gap: 14px; align-items: start; }
    @media (max-width: 1080px) { main[data-pg="roads"] .dash-body3 { grid-template-columns: 210px minmax(0,1fr); } main[data-pg="roads"] .controls:last-child { grid-column: 1 / -1; } }
    @media (max-width: 720px) { main[data-pg="roads"] .dash-body3 { grid-template-columns: 1fr; } }
    main[data-pg="roads"] .dash-body3.no-right { grid-template-columns: 232px minmax(0,1fr); }
    @media (max-width: 1080px) { main[data-pg="roads"] .dash-body3.no-right { grid-template-columns: 210px minmax(0,1fr); } }
    main[data-pg="roads"] .tabbar { display: flex; flex-wrap: wrap; gap: 4px; margin: 8px 0 12px; border-bottom: 1px solid var(--line); }
    main[data-pg="roads"] .tabbar button { background: transparent; border: 1px solid transparent; border-bottom: none; color: var(--muted); border-radius: 9px 9px 0 0; padding: 8px 13px; font-size: 13px; font-weight: 700; cursor: pointer; margin-bottom: -1px; }
    main[data-pg="roads"] .tabbar button:hover { color: var(--ink); }
    main[data-pg="roads"] .tabbar button.on { color: #f6b13b; border-color: var(--line); border-bottom: 1px solid var(--panel); background: var(--panel); }
    main[data-pg="roads"] .realnow { display: flex; flex-wrap: wrap; gap: 7px 16px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 9px 14px; margin: 0 0 12px; }
    main[data-pg="roads"] .realnow .rn-h { font-size: 11px; font-weight: 800; color: var(--faint); text-transform: uppercase; letter-spacing: .04em; align-self: center; margin-right: 4px; }
    main[data-pg="roads"] .realnow .rn { font-size: 12.5px; color: var(--muted); }
    main[data-pg="roads"] .realnow .rn b { color: var(--ink); font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .center { min-width: 0; }
    main[data-pg="roads"] .hero { margin-bottom: 12px; }
    main[data-pg="roads"] .hero:empty { display: none; }
    main[data-pg="roads"] .hero-card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 12px 14px; }
    main[data-pg="roads"] .hero-card .hc-t { font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 2px; }
    main[data-pg="roads"] .hero-card .hc-s { font-size: 11.5px; color: var(--faint); margin-bottom: 8px; }
    main[data-pg="roads"] .hero-card canvas { width: 100%; height: 190px; display: block; }
    main[data-pg="roads"] .hero-legend { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 6px; font-size: 11.5px; color: var(--muted); }
    main[data-pg="roads"] .hero-legend span { display: inline-flex; align-items: center; gap: 5px; }
    main[data-pg="roads"] .hero-legend i { width: 14px; height: 3px; border-radius: 2px; display: inline-block; }
    main[data-pg="roads"] .c-now { font-size: 10px; color: var(--faint); font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .modelview { margin-top: 6px; }
    main[data-pg="roads"] .cm-title { font-size: 13px; font-weight: 700; color: #f6b13b; margin-bottom: 8px; }
    main[data-pg="roads"] .backtest { margin: 18px 0; }
    main[data-pg="roads"] .analysisview { margin-top: 6px; }
    main[data-pg="roads"] .an-intro { font-size: 12.5px; color: var(--muted); margin: 0 0 14px; }
    main[data-pg="roads"] .an-tool { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 13px 15px; margin-bottom: 14px; }
    main[data-pg="roads"] .an-h { font-size: 13.5px; font-weight: 700; color: #f6b13b; margin-bottom: 8px; }
    main[data-pg="roads"] .an-ctl { font-size: 12.5px; color: var(--muted); margin-bottom: 10px; display: flex; flex-wrap: wrap; gap: 10px 14px; align-items: center; }
    main[data-pg="roads"] .an-ctl select, main[data-pg="roads"] .an-ctl input { background: #12161f; border: 1px solid var(--line); color: var(--ink); border-radius: 7px; padding: 4px 7px; font-size: 12.5px; }
    /* opinn fellilisti (<option>) fellur á hvítan browser-bakgrunn ef select-bg er gegnsær (var(--panel) er hálfgegnsætt) → læsa ÓGEGNSÆjum dökkum lit */
    main[data-pg="roads"] select { background: #12161f; color: var(--ink); }
    main[data-pg="roads"] select option { background: #12161f; color: var(--ink); }
    main[data-pg="roads"] .an-ctl button { background: linear-gradient(180deg,#f6b13b,#e0961f); border: none; color: #1a1204; border-radius: 8px; padding: 5px 12px; font-weight: 800; font-size: 12.5px; cursor: pointer; }
    main[data-pg="roads"] .tor-row { display: grid; grid-template-columns: 210px 1fr 96px; gap: 8px; align-items: center; font-size: 12px; margin: 3px 0; }
    main[data-pg="roads"] .tor-bar { position: relative; height: 16px; background: rgba(255,255,255,.05); border-radius: 4px; }
    main[data-pg="roads"] .tor-bar > i { position: absolute; top: 0; height: 100%; border-radius: 4px; }
    main[data-pg="roads"] .tor-mid { position: absolute; top: -3px; height: 22px; width: 1px; background: rgba(255,255,255,.3); left: 50%; }
    main[data-pg="roads"] .tor-row .tv { text-align: right; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] #frontier canvas { width: 100%; height: 300px; display: block; }
    main[data-pg="roads"] .inv-result { font-size: 13px; margin-top: 8px; }
    main[data-pg="roads"] .inv-result b { color: #f6b13b; }
    main[data-pg="roads"] .dyn-tbl { width: 100%; border-collapse: collapse; font-size: 12.5px; margin-top: 4px; }
    main[data-pg="roads"] .dyn-tbl th, main[data-pg="roads"] .dyn-tbl td { text-align: right; padding: 5px 8px; border-bottom: 1px solid var(--line); font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .dyn-tbl th:first-child, main[data-pg="roads"] .dyn-tbl td:first-child { text-align: left; color: var(--muted); font-variant-numeric: normal; }
    main[data-pg="roads"] .dyn-tbl thead th { color: var(--faint); font-weight: 700; }
    main[data-pg="roads"] .dyn-sub { font-size: 10.5px; color: var(--faint); }
    main[data-pg="roads"] .sec-bar { display: inline-block; width: 70px; height: 7px; border-radius: 4px; background: rgba(255,255,255,.08); overflow: hidden; vertical-align: middle; margin-right: 5px; }
    main[data-pg="roads"] .sec-bar > i { display: block; height: 100%; background: #6ea8fe; border-radius: 4px; }
    main[data-pg="roads"] .controls { position: sticky; top: 60px; background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 12px; }
    main[data-pg="roads"] .ctl-h { font-size: 12px; font-weight: 800; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 2px 0 8px; }
    main[data-pg="roads"] .auto { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--ink); margin-bottom: 6px; cursor: pointer; }
    main[data-pg="roads"] .auto input { accent-color: #f6b13b; }
    main[data-pg="roads"] .sl-group { font-size: 10px; font-weight: 800; color: #f6b13b; text-transform: uppercase; letter-spacing: .04em; margin: 12px 0 5px; padding-bottom: 3px; border-bottom: 1px solid var(--line); opacity: .85; }
    main[data-pg="roads"] .sl-group:first-child { margin-top: 2px; }
    main[data-pg="roads"] .sl { margin-bottom: 8px; padding: 3px 4px; border-radius: 6px; }
    main[data-pg="roads"] .sl.auto-on { opacity: .55; }
    main[data-pg="roads"] .sl.hot { background: rgba(246,177,59,.1); }
    main[data-pg="roads"] .sl-t { display: flex; justify-content: space-between; font-size: 12.5px; color: var(--ink); }
    main[data-pg="roads"] .sl-r { display: inline-flex; align-items: baseline; gap: 5px; }
    main[data-pg="roads"] .sl-t b { color: #f6b13b; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sl-now { font-size: 10px; color: var(--faint); font-style: normal; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sl.moved .sl-now { color: #6ea8fe; }
    main[data-pg="roads"] .sl-track { position: relative; margin: 2px 0 0; }
    main[data-pg="roads"] .sl-track input[type=range] { width: 100%; accent-color: #f6b13b; margin: 0; display: block; }
    main[data-pg="roads"] .sl-base { position: absolute; top: 50%; width: 2px; height: 13px; background: rgba(255,255,255,.5); border-radius: 1px; transform: translate(-50%,-50%); pointer-events: none; }
    main[data-pg="roads"] .hint { font-size: 11px; color: var(--faint); margin: 10px 0 0; }
    main[data-pg="roads"] #karp { width: 100%; margin: 0 0 10px; background: linear-gradient(180deg, #f6b13b, #e0961f); border: none; color: #1a1204; border-radius: 9px; padding: 9px; font-size: 13px; font-weight: 800; cursor: pointer; box-shadow: 0 1px 6px rgba(246,177,59,.3); }
    main[data-pg="roads"] #karp:hover { filter: brightness(1.06); }
    main[data-pg="roads"] #karp:disabled, main[data-pg="roads"] #karp.busy { opacity: .7; cursor: progress; }
    main[data-pg="roads"] #rs, main[data-pg="roads"] #share, main[data-pg="roads"] #cmp { margin-top: 8px; width: 100%; background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--ink); border-radius: 9px; padding: 7px; font-size: 12.5px; cursor: pointer; }
    main[data-pg="roads"] #share.ok { color: #54d08a; border-color: #54d08a; }
    main[data-pg="roads"] #cmp.on { color: #5ac8e0; border-color: #5ac8e0; }
    main[data-pg="roads"] #mc { margin-top: 8px; width: 100%; background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--ink); border-radius: 9px; padding: 7px; font-size: 12.5px; cursor: pointer; }
    main[data-pg="roads"] #mc.on { color: #b98cff; border-color: #b98cff; }
    main[data-pg="roads"] .mcbar { font-size: 12.5px; color: var(--ink); background: rgba(185,140,255,.08); border: 1px solid rgba(185,140,255,.3); border-radius: 10px; padding: 9px 13px; margin: 0 0 12px; }
    main[data-pg="roads"] .mcbar b { color: #b98cff; }
    main[data-pg="roads"] .mcbar .mcp { display: inline-block; margin-right: 16px; }
    main[data-pg="roads"] .mcbar .mcp b { color: var(--ink); font-variant-numeric: tabular-nums; }
