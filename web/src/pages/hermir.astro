---
// ROADS Íslands — hagkerfis-STJÓRNKLEFI. Vél: @lib/roads/engine.mjs (client-hlið, ósnert).
// Ákvarðanir vinstra · útkomu-net miðju · ytri sjokk hægra. Sjálfvirk peningastefna/launaþróun
// = UI fastpunkts-ítrun (vélin ósnert). Hover á sleða lýsir upp keðjurnar. Ekki opinber spá.
import Layout from '../layouts/Layout.astro';
import BASELINE from '@gogn/roads/baseline.json';
import LINKS from '@gogn/roads/links.json';
import SCENARIOS from '@gogn/roads/scenarios.json';
const desc = 'ROADS Íslands — gagnsær hagkerfis-stjórnklefi: stilltu vexti, laun, skatta, kvóta og fleira (eða láttu peningastefnuna vera sjálfvirka) og sjáðu stílfærð áhrif á 13 hagvísa næstu 3 árin, með óvissu og heimildum.';
---
<Layout title="ROADS Íslands — hagkerfis-stjórnklefi | Karp" description={desc} canonical="https://karp.is/hermir/" ogTitle="ROADS Íslands — stjórnklefi" wide={true}>
  <main data-pg="roads" class="dash">
    <div class="dash-top">
      <div class="dash-head"><h1>ROADS Íslands 🎛️</h1><div class="horizon" id="horizon"><span>Sjóndeildarhringur:</span><button type="button" data-h="12" class="on">3 ár</button><button type="button" data-h="40">10 ár</button></div><span class="disc" id="disc"></span></div>
      <div class="topbar"><div id="health" class="health"></div><div id="score" class="score"></div></div>
      <div id="scn" class="scn"></div>
      <p id="news" class="news" hidden></p>
      <p id="hnote" class="hnote" hidden></p>
      <div id="cmpbar" class="cmpbar" hidden></div>
    </div>
    <div class="dash-body3">
      <div class="controls">
        <div class="ctl-h">🎚️ Þínar ákvarðanir</div>
        <button id="karp" type="button" title="Leitar sjálfkrafa í gegnum allar ákvarðana-stillingar að þeirri samsetningu sem hámarkar þjóðhagslegt heilsufar (miðað við núverandi sjóndeildarhring og hlutlaus ytri áhrif).">🏆 KARP-lausnin — besta útkoman</button>
        <label class="auto" title="Kveikt: Seðlabankinn stillir vexti sjálfur eftir Taylor-reglu (bregst við verðbólgu). Sleðinn hreyfist sjálfkrafa."><input type="checkbox" id="auto-tay"> 🏛️ Sjálfvirk peningastefna</label>
        <label class="auto" title="Kveikt: laun bregðast sjálf við atvinnuleysi (Phillips-kúrfa). Lítið atvinnuleysi → hærri laun."><input type="checkbox" id="auto-phi"> 💬 Sjálfvirk launaþróun</label>
        <div id="levers"></div>
        <button id="rs" type="button">↺ Núllstilla</button>
        <button id="cmp" type="button" title="Festir núverandi sviðsmynd (B). Breyttu svo stýringum og berðu saman við hana á öllum kortum.">⚖️ Festa til samanburðar</button>
        <button id="share" type="button" title="Afritar hlekk sem geymir núverandi sviðsmynd — hægt að deila eða vista">🔗 Afrita hlekk á sviðsmynd</button>
      </div>
      <div id="charts" class="charts"></div>
      <div class="controls">
        <div class="ctl-h">⚡ Heimurinn / ytri áhrif</div>
        <div id="shocks"></div>
        <p class="hint">Hreyfðu bendil yfir sleða til að lýsa upp hagvísana sem hann drífur.</p>
      </div>
    </div>
    <details class="chainmap"><summary>🕸️ Keðju-kort — allt orsakanetið á einni mynd (hover/smelltu á hnút)</summary><div id="cmwrap"><div class="cm-legend"><span><i class="cm-in"></i> ákvörðun</span><span><i class="cm-shk"></i> ytri áhrif</span><span><i class="cm-out"></i> hagvísir</span><span><i class="cm-pos"></i> eykur</span><span><i class="cm-neg"></i> dregur úr</span></div><div id="chainmap"></div></div></details>
    <details class="transp"><summary>⚙︎ Sjá öll orsakasambönd, stuðla og heimildir</summary><div id="lnks"></div></details>
    <p class="foot">Forþjónað (SSG) {BASELINE.updated}. ROADS-tímaskref-líkan · {LINKS.length} kvörðuð tengsl m/heimildum · {Object.keys(BASELINE.outcomes).length} hagvísar. Stílfærð sambönd — ekki opinber spá.</p>
  </main>

  <style is:global>
    main[data-pg="roads"].dash { max-width: none; margin: 0; padding: 20px 22px 60px; }
    main[data-pg="roads"] .dash-head { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
    main[data-pg="roads"] .dash-head h1 { font-size: 25px; margin: 0; }
    main[data-pg="roads"] .disc { font-size: 12px; color: var(--faint); }
    main[data-pg="roads"] .horizon { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; color: var(--faint); }
    main[data-pg="roads"] .horizon button { background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--muted); border-radius: 7px; padding: 3px 10px; font-size: 12px; font-weight: 700; cursor: pointer; }
    main[data-pg="roads"] .horizon button.on { color: #f6b13b; border-color: #f6b13b; background: rgba(246,177,59,.1); }
    main[data-pg="roads"] .hnote { font-size: 12px; color: var(--muted); background: rgba(110,168,254,.08); border: 1px solid rgba(110,168,254,.28); border-radius: 10px; padding: 8px 13px; margin: 0 0 12px; }
    main[data-pg="roads"] .hnote a { color: #6ea8fe; }
    main[data-pg="roads"] .dash-head { margin-bottom: 6px; }
    main[data-pg="roads"] .topbar { display: flex; gap: 10px; align-items: stretch; margin: 18px 0 10px; flex-wrap: wrap; }
    main[data-pg="roads"] .health { flex: 0 0 168px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px; display: flex; flex-direction: column; justify-content: center; }
    main[data-pg="roads"] .health .h-l { font-size: 11px; color: var(--faint); text-transform: uppercase; letter-spacing: .03em; }
    main[data-pg="roads"] .health .h-v { font-size: 27px; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1.05; }
    main[data-pg="roads"] .health .h-bar { height: 5px; border-radius: 3px; background: rgba(255,255,255,.08); margin-top: 5px; overflow: hidden; }
    main[data-pg="roads"] .health .h-bar > i { display: block; height: 100%; border-radius: 3px; }
    main[data-pg="roads"] .score { flex: 1 1 400px; display: flex; flex-wrap: wrap; gap: 8px; }
    main[data-pg="roads"] .sc { flex: 1 1 118px; min-width: 118px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 7px 11px; display: flex; flex-direction: column; }
    main[data-pg="roads"] .sc-l { font-size: 10.5px; color: var(--faint); text-transform: uppercase; letter-spacing: .03em; }
    main[data-pg="roads"] .sc-v { font-size: 20px; font-weight: 800; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sc-d { font-size: 11px; font-weight: 700; }
    main[data-pg="roads"] .scn { display: flex; flex-wrap: wrap; gap: 6px; margin: 6px 0 10px; }
    main[data-pg="roads"] .scn button { background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--muted); border-radius: 8px; padding: 5px 11px; font-size: 12px; font-weight: 600; cursor: pointer; }
    main[data-pg="roads"] .scn button:hover, main[data-pg="roads"] .scn button.on { color: #f6b13b; border-color: #f6b13b; }
    main[data-pg="roads"] .news { font-size: 14px; color: var(--ink); background: rgba(246,177,59,.08); border: 1px solid rgba(246,177,59,.3); border-radius: 10px; padding: 10px 14px; margin: 0 0 12px; }
    main[data-pg="roads"] .news b { color: #f6b13b; }
    main[data-pg="roads"] .dash-body3 { display: grid; grid-template-columns: 232px minmax(0,1fr) 232px; gap: 14px; align-items: start; }
    @media (max-width: 1080px) { main[data-pg="roads"] .dash-body3 { grid-template-columns: 210px minmax(0,1fr); } main[data-pg="roads"] .controls:last-child { grid-column: 1 / -1; } }
    @media (max-width: 720px) { main[data-pg="roads"] .dash-body3 { grid-template-columns: 1fr; } }
    main[data-pg="roads"] .controls { position: sticky; top: 60px; background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 12px; }
    main[data-pg="roads"] .ctl-h { font-size: 12px; font-weight: 800; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 2px 0 8px; }
    main[data-pg="roads"] .auto { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--ink); margin-bottom: 6px; cursor: pointer; }
    main[data-pg="roads"] .auto input { accent-color: #f6b13b; }
    main[data-pg="roads"] .sl { margin-bottom: 8px; padding: 3px 4px; border-radius: 6px; }
    main[data-pg="roads"] .sl.auto-on { opacity: .55; }
    main[data-pg="roads"] .sl.hot { background: rgba(246,177,59,.1); }
    main[data-pg="roads"] .sl-t { display: flex; justify-content: space-between; font-size: 12.5px; color: var(--ink); }
    main[data-pg="roads"] .sl-r { display: inline-flex; align-items: baseline; gap: 5px; }
    main[data-pg="roads"] .sl-t b { color: #f6b13b; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sl-now { font-size: 10px; color: var(--faint); font-style: normal; font-variant-numeric: tabular-nums; }
    main[data-pg="roads"] .sl.moved .sl-now { color: #6ea8fe; }
    main[data-pg="roads"] .sl-track { position: relative; margin: 2px 0 0; }
    main[data-pg="roads"] .sl-track input[type=range] { width: 100%; accent-color: #f6b13b; margin: 0; display: block; }
    main[data-pg="roads"] .sl-base { position: absolute; top: 50%; width: 2px; height: 13px; background: rgba(255,255,255,.5); border-radius: 1px; transform: translate(-50%,-50%); pointer-events: none; }
    main[data-pg="roads"] .hint { font-size: 11px; color: var(--faint); margin: 10px 0 0; }
    main[data-pg="roads"] #karp { width: 100%; margin: 0 0 10px; background: linear-gradient(180deg, #f6b13b, #e0961f); border: none; color: #1a1204; border-radius: 9px; padding: 9px; font-size: 13px; font-weight: 800; cursor: pointer; box-shadow: 0 1px 6px rgba(246,177,59,.3); }
    main[data-pg="roads"] #karp:hover { filter: brightness(1.06); }
    main[data-pg="roads"] #karp:disabled, main[data-pg="roads"] #karp.busy { opacity: .7; cursor: progress; }
    main[data-pg="roads"] #rs, main[data-pg="roads"] #share, main[data-pg="roads"] #cmp { margin-top: 8px; width: 100%; background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--ink); border-radius: 9px; padding: 7px; font-size: 12.5px; cursor: pointer; }
    main[data-pg="roads"] #share.ok { color: #54d08a; border-color: #54d08a; }
    main[data-pg="roads"] #cmp.on { color: #5ac8e0; border-color: #5ac8e0; }
    main[data-pg="roads"] .cmpbar { font-size: 12.5px; color: var(--ink); background: rgba(90,200,224,.08); border: 1px solid rgba(90,200,224,.3); border-radius: 10px; padding: 8px 13px; margin: 0 0 12px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    main[data-pg="roads"] .cmpbar .sw { display: inline-block; width: 20px; height: 3px; border-radius: 2px; vertical-align: middle; }
    main[data-pg="roads"] .charts { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 10px; }
    main[data-pg="roads"] .card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 9px 11px; transition: opacity .15s, border-color .15s; }
    main[data-pg="roads"] .card.dim { opacity: .28; }
    main[data-pg="roads"] .card.lit { border-color: rgba(246,177,59,.6); }
    main[data-pg="roads"] .c-h { display: flex; justify-content: space-between; align-items: baseline; }
    main[data-pg="roads"] .c-t { font-size: 12px; color: var(--muted); font-weight: 600; }
    main[data-pg="roads"] .c-d { font-size: 11.5px; font-weight: 700; }
    main[data-pg="roads"] .c-v { font-size: 22px; font-weight: 800; font-variant-numeric: tabular-nums; margin: 1px 0 2px; }
    main[data-pg="roads"] .c-b { font-size: 12px; color: #5ac8e0; font-weight: 700; }
    main[data-pg="roads"] .c-cv { width: 100%; height: 88px; display: block; }
    main[data-pg="roads"] .c-g { position: relative; height: 6px; background: rgba(255,255,255,.06); border-radius: 3px; margin-top: 7px; }
    main[data-pg="roads"] .c-gm { position: absolute; top: -2px; width: 3px; height: 10px; border-radius: 2px; transform: translateX(-50%); }
    main[data-pg="roads"] .c-gb { position: absolute; top: -1px; width: 2px; height: 8px; background: rgba(255,255,255,.4); transform: translateX(-50%); }
    main[data-pg="roads"] .lnk-tbl { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 8px; }
    main[data-pg="roads"] .lnk-tbl th, main[data-pg="roads"] .lnk-tbl td { text-align: left; padding: 4px 8px; border-bottom: 1px solid var(--line); color: var(--muted); }
    main[data-pg="roads"] details.transp { margin: 18px 0 0; }
    main[data-pg="roads"] details.transp summary { cursor: pointer; color: #f6b13b; font-size: 13px; font-weight: 700; }
    main[data-pg="roads"] details.chainmap { margin: 18px 0 0; }
    main[data-pg="roads"] details.chainmap summary { cursor: pointer; color: #f6b13b; font-size: 13px; font-weight: 700; }
    main[data-pg="roads"] #cmwrap { margin-top: 10px; }
    main[data-pg="roads"] .cm-legend { display: flex; flex-wrap: wrap; gap: 14px; font-size: 11.5px; color: var(--muted); margin-bottom: 8px; }
    main[data-pg="roads"] .cm-legend span { display: inline-flex; align-items: center; gap: 5px; }
    main[data-pg="roads"] .cm-legend i { width: 12px; height: 12px; border-radius: 3px; display: inline-block; }
    main[data-pg="roads"] .cm-legend .cm-in { background: #6ea8fe; } .cm-legend .cm-shk { background: #f6b13b; } .cm-legend .cm-out { background: #9fb0c8; }
    main[data-pg="roads"] .cm-legend .cm-pos { background: #54d08a; border-radius: 1px; height: 3px; } .cm-legend .cm-neg { background: #e78284; border-radius: 1px; height: 3px; }
    main[data-pg="roads"] #chainmap { overflow-x: auto; border: 1px solid var(--line); border-radius: 10px; background: rgba(0,0,0,.15); }
    main[data-pg="roads"] #chainmap svg { display: block; }
    main[data-pg="roads"] .cm-node { cursor: pointer; }
    main[data-pg="roads"] .cm-node rect { stroke: rgba(255,255,255,.18); }
    main[data-pg="roads"] .cm-node text { font-size: 10.5px; fill: var(--ink); pointer-events: none; }
    main[data-pg="roads"] .foot { font-size: 12px; color: var(--faint); margin-top: 16px; border-top: 1px solid var(--line); padding-top: 12px; }
  </style>

  <script>
    import { simulate } from '@lib/roads/engine.mjs';
    import BASELINE from '@gogn/roads/baseline.json';
    import LINKS from '@gogn/roads/links.json';
    import SCENARIOS from '@gogn/roads/scenarios.json';

    const state = { levers: {}, shocks: {}, autoTay: false, autoPhi: false, horizon: BASELINE.quarters };
    const MAXQ = BASELINE.maxQuarters || BASELINE.quarters;
    const num = (v, d = 1) => (v == null ? '–' : v.toLocaleString('is-IS', { minimumFractionDigits: d, maximumFractionDigits: d }));
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const lbl = (k) => BASELINE.levers[k]?.label || BASELINE.shocks[k]?.label || BASELINE.outcomes[k]?.label || k;
    const driversOf = (k) => [...new Set(LINKS.filter((l) => l.to === k && l.from !== k).map((l) => lbl(l.from)))];
    // Transitive reach: hvaða útkomur nær tiltekinn sleði (fyrir hover-highlight)
    const reachFrom = (start) => { const seen = new Set(), stack = [start]; while (stack.length) { const n = stack.pop(); for (const l of LINKS) if (l.from === n && !seen.has(l.to)) { seen.add(l.to); stack.push(l.to); } } return seen; };

    const OUT_TIP = {
      verdbolga: 'Verðbólga — árshækkun neysluverðs.', hagvoxtur: 'Hagvöxtur — árs-breyting raun-VLF.',
      atvinnuleysi: 'Skráð atvinnuleysi (% af vinnuafli).', kaupmattur: 'Kaupmáttur launa — nafnlaun umfram verðbólgu.',
      husnaedi: 'Húsnæðisverð — 12-mán breyting.', leiga: 'Leiga — 12-mán breyting.',
      greidslubyrdi: 'Greiðslubyrði húsnæðislána — vísitala (100 = núverandi).', mannfjoldi: 'Fólksfjölgun — árs-breyting.',
      vinnuafl: 'Vinnuaflsvöxtur — árs-breyting vinnuafls.', afkoma: 'Afkoma ríkissjóðs (% VLF; mínus = halli).',
      skuldir: 'Skuldir ríkissjóðs (% VLF).', utflutningur: 'Útflutningsvöxtur — árs-breyting.', losun: 'CO₂-losun — vísitala (100 = núverandi).',
      vanskil: 'Vanskil heimila & fyrirtækja — vísitala fjárhagsvanda (100 = núverandi). Hækkar með vöxtum, atvinnuleysi og greiðslubyrði.',
    };
    const LEV_TIP = {
      vextir: 'Stýrivextir Seðlabankans. Hærri → hægir á verðbólgu/húsnæði (töf), dregur úr hagvexti.',
      laun: 'Launahækkun kjarasamninga. Eykur kaupmátt/neyslu en ýtir undir verðbólgu/húsnæði.',
      vedhlutfall: 'Hámarks veðsetningarhlutfall (þjóðhagsvarúð). Hærra þak → hærra húsnæðisverð.',
      frambod: 'Framboð nýrra íbúða. Meira → lægra verð/leiga (töf).',
      skattar: 'Skattbreyting ríkisins. Meiri skattar bæta afkomu, draga lítillega úr hagvexti.',
      utgjold: 'Útgjöld ríkisins. Meiri útgjöld örva hagvöxt en versna afkomu.',
      kvoti: 'Aflamark (kvóti). Meira → meiri sjávarafurða-útflutningur.',
      orka: 'Orka til stóriðju / ný virkjun. Meira → meiri útflutningur en hærri losun.',
      kolefnisgjald: 'Kolefnisgjald. Hærra → minni CO₂-losun, lítið hagvaxtar-drag.',
      olia: 'Olíuverð. Hærra → meiri verðbólga.', gengi: 'Gengi krónu (+ = styrking). Sterk króna → lægri innflutt verðbólga.',
      ferdamenn: 'Ferðamannafjöldi. Fleiri → meiri hagvöxtur, minna atvinnuleysi, hærri leiga.',
      adflutningur: 'Aðflutningur (nettó). Meiri → fjölgun, meira vinnuafl, húsnæðis-þrýstingur.',
      frjosemi: 'Frjósemi. Langtíma — hverfandi á 3 árum (sjá /mannfjoldi/).',
    };
    const SCORE_KEYS = ['verdbolga', 'hagvoxtur', 'atvinnuleysi', 'husnaedi', 'afkoma'];
    // Formerki hvers hagvísis: +1 = hærra er BETRA, −1 = hærra er VERRA, 0 = hlutlaust.
    const POLARITY = { hagvoxtur: 1, kaupmattur: 1, afkoma: 1, utflutningur: 1, vinnuafl: 1, verdbolga: -1, atvinnuleysi: -1, husnaedi: -1, leiga: -1, greidslubyrdi: -1, skuldir: -1, losun: -1, vanskil: -1, mannfjoldi: 0 };
    const GOOD = '#54d08a', NEUT = '#e8c14a', BAD = '#e78284';
    const BAND = { '#54d08a': 'rgba(84,208,138,.13)', '#e8c14a': 'rgba(232,193,74,.12)', '#e78284': 'rgba(231,130,132,.13)' };
    // Litur eftir því hvort frávik frá grunnferli (BAU) er jákvætt/hlutlaust/neikvætt FYRIR þennan hagvísi.
    function valence(k, dlt) { const pol = POLARITY[k] ?? 0; if (pol === 0 || Math.abs(dlt) < 0.05) return NEUT; return dlt * pol > 0 ? GOOD : BAD; }
    function dInfo(o, k) { const dlt = o.mid[o.mid.length - 1] - o.baseline[o.baseline.length - 1]; return { dlt, c: valence(k, dlt) }; }

    // sjálfvirk peningastefna/launaþróun: fastpunkts-ítrun (vélin ósnert).
    // Bregst við MEÐALTALI seinni helmings sjóndeildar (það sem stefnan getur haft áhrif á með töf) — ekki lokagildi.
    const midTerm = (arr) => { const s0 = Math.floor(arr.length / 2); let s = 0, n = 0; for (let i = s0; i < arr.length; i++) { s += arr[i]; n++; } return n ? s / n : arr[arr.length - 1]; };
    function solveLevers() {
      const L = { ...state.levers };
      if (!state.autoTay && !state.autoPhi) return L;
      for (let it = 0; it < 8; it++) {
        const r = simulate({ baseline: BASELINE, links: LINKS, levers: L, shocks: state.shocks, quarters: state.horizon });
        if (state.autoTay) { const infl = midTerm(r.outcomes.verdbolga.mid); const tgt = clamp(BASELINE.levers.vextir.base + 0.9 * (infl - 2.5), 0, 12); L.vextir = 0.45 * (L.vextir ?? BASELINE.levers.vextir.base) + 0.55 * tgt; }
        if (state.autoPhi) { const unem = midTerm(r.outcomes.atvinnuleysi.mid); const tgt = clamp(BASELINE.levers.laun.base + 0.35 * (4.0 - unem), 0, 14); L.laun = 0.45 * (L.laun ?? BASELINE.levers.laun.base) + 0.55 * tgt; }
      }
      if (state.autoTay) L.vextir = Math.round(L.vextir / BASELINE.levers.vextir.step) * BASELINE.levers.vextir.step;
      if (state.autoPhi) L.laun = Math.round(L.laun / BASELINE.levers.laun.step) * BASELINE.levers.laun.step;
      return L;
    }

    // URL-ástand: geymir sviðsmynd í #hash svo hægt sé að deila/vista hlekk
    function serialize() {
      const p = new URLSearchParams();
      for (const k in state.levers) if (state.levers[k] != null) p.set('l.' + k, state.levers[k]);
      for (const k in state.shocks) if (state.shocks[k] != null) p.set('s.' + k, state.shocks[k]);
      let a = ''; if (state.autoTay) a += 't'; if (state.autoPhi) a += 'p'; if (a) p.set('a', a);
      if (state.horizon !== BASELINE.quarters) p.set('h', state.horizon);
      const h = p.toString();
      try { history.replaceState(null, '', h ? '#' + h : location.pathname + location.search); } catch (e) {}
    }
    function deserialize() {
      if (!location.hash || location.hash.length < 2) return false;
      let any = false;
      for (const [k, v] of new URLSearchParams(location.hash.slice(1))) {
        if (k.startsWith('l.') && BASELINE.levers[k.slice(2)]) { state.levers[k.slice(2)] = +v; any = true; }
        else if (k.startsWith('s.') && BASELINE.shocks[k.slice(2)]) { state.shocks[k.slice(2)] = +v; any = true; }
        else if (k === 'a') { state.autoTay = v.includes('t'); state.autoPhi = v.includes('p'); any = true; }
        else if (k === 'h') { const hv = +v; if (hv >= BASELINE.quarters && hv <= MAXQ) { state.horizon = hv; any = true; } }
      }
      return any;
    }

    function run() {
      const L = solveLevers();
      state._sol = { vextir: L.vextir, laun: L.laun }; // geymt svo hægt sé að „baka inn" við afvirkjun
      if (state.autoTay) syncSlider('vextir', L.vextir);
      if (state.autoPhi) syncSlider('laun', L.laun);
      const r = simulate({ baseline: BASELINE, links: LINKS, levers: L, shocks: state.shocks, quarters: state.horizon });
      state._lastR = r;
      drawHealth(r); drawScore(r); drawCharts(r);
      serialize();
    }

    function syncSlider(k, v) { const el = document.querySelector(`.sl[data-k="${k}"]`); if (!el) return; const inp = el.querySelector('input'), b = el.querySelector('b'), cfg = BASELINE.levers[k]; inp.value = v; b.textContent = num(v, cfg.step < 1 ? 2 : 0) + cfg.unit; el.classList.toggle('moved', v !== cfg.base); }

    // Samsett þjóðhagslegt heilsufar (0–100) — markfall sem KARP-hnappurinn hámarkar.
    function healthScore(r) {
      const g = (k) => { const m = r.outcomes[k]?.mid; return m ? m[m.length - 1] : 0; };
      const pen = Math.abs(g('verdbolga') - 2.5) * 7 + Math.max(0, g('atvinnuleysi') - 4) * 6 + Math.max(0, 2 - g('hagvoxtur')) * 5 + Math.max(0, -g('afkoma')) * 4
        + Math.max(0, g('husnaedi') - 5) * 1.2 + Math.max(0, g('leiga') - 6) * 0.8 + Math.max(0, g('skuldir') - 45) * 0.3 + Math.max(0, g('vanskil') - 100) * 0.4 + Math.max(0, g('losun') - 100) * 0.3;
      return clamp(100 - pen, 0, 100);
    }
    function drawHealth(r) {
      const score = Math.round(healthScore(r));
      const c = score >= 70 ? GOOD : score >= 45 ? NEUT : BAD;
      const h = document.getElementById('health');
      h.title = 'Samsett heilsufar: nær 100 þegar verðbólga ~2,5%, atvinnuleysi/skuldir/vanskil/losun lág, hagvöxtur jákvæður og afkoma í jafnvægi. „🏆 KARP-lausnin" leitar að stillingum sem hámarka þetta.';
      h.innerHTML = `<span class="h-l">Þjóðhagslegt heilsufar</span><span class="h-v" style="color:${c}">${score}<span style="font-size:14px;color:var(--faint)">/100</span></span><span class="h-bar"><i style="width:${score}%;background:${c}"></i></span>`;
    }

    function drawScore(r) {
      const h = document.getElementById('score'); h.innerHTML = '';
      for (const k of SCORE_KEYS) { const o = r.outcomes[k]; if (!o) continue; const { dlt, c } = dInfo(o, k); const end = o.mid[o.mid.length - 1];
        const t = document.createElement('div'); t.className = 'sc'; t.title = OUT_TIP[k] || o.label;
        t.innerHTML = `<span class="sc-l">${o.label}</span><span class="sc-v">${num(end)}${o.unit === '% VLF' ? '%' : o.unit}</span><span class="sc-d" style="color:${c}">${dlt >= 0 ? '▲' : '▼'} ${num(Math.abs(dlt))}</span>`;
        h.appendChild(t);
      }
    }

    function drawCharts(r) {
      const host = document.getElementById('charts'); host.innerHTML = '';
      const cmpR = state.compare ? state.compare.r : null;
      for (const k of Object.keys(r.outcomes)) { const o = r.outcomes[k]; const { dlt, c } = dInfo(o, k); const end = o.mid[o.mid.length - 1];
        const cmp = cmpR ? cmpR.outcomes[k] : null; const us = o.unit === '% VLF' ? '%' : o.unit;
        const card = document.createElement('div'); card.className = 'card'; card.dataset.k = k;
        card.title = (OUT_TIP[k] || o.label) + (driversOf(k).length ? ' Drifið af: ' + driversOf(k).join(', ') + '.' : '') + ' (grænt=jákvæð þróun, gult=hlutlaust, rautt=neikvæð fyrir þennan hagvísi).';
        card.innerHTML = `<div class="c-h"><span class="c-t">${o.label}</span><span class="c-d" style="color:${c}">${dlt >= 0 ? '+' : ''}${num(dlt)}</span></div><div class="c-v">${num(end)}${us}${cmp ? ` <span class="c-b">⚖ ${num(cmp.mid[cmp.mid.length - 1])}${us}</span>` : ''}</div><canvas class="c-cv"></canvas><div class="c-g" title="Staða lokagildis innan mögulegs bils; hvíta strikið = grunnferill (BAU)"><span class="c-gb"></span><span class="c-gm"></span></div>`;
        host.appendChild(card);
        drawTrace(card.querySelector('canvas'), o, cmp, c);
        const cl = (BASELINE.clamp || {})[k] || [Math.min(...o.lo), Math.max(...o.hi)];
        const pos = (v) => Math.max(0, Math.min(1, (v - cl[0]) / (cl[1] - cl[0] || 1)));
        const gm = card.querySelector('.c-gm'), gb = card.querySelector('.c-gb');
        gm.style.left = (pos(end) * 100) + '%'; gm.style.background = c;
        gb.style.left = (pos(o.baseline[o.baseline.length - 1]) * 100) + '%';
      }
    }

    function drawTrace(cv, o, cmp, vcol) {
      const dpr = Math.min(2, window.devicePixelRatio || 1); const w = cv.clientWidth, h = 88; cv.width = w * dpr; cv.height = h * dpr;
      const ctx = cv.getContext('2d'); ctx.scale(dpr, dpr);
      const all = cmp ? o.mid.concat(cmp.mid) : o.lo.concat(o.hi, o.baseline); let mn = Math.min(...all), mx = Math.max(...all);
      if (mx - mn < 1) { const m = (mx + mn) / 2; mn = m - 0.6; mx = m + 0.6; }
      const pad = 6, n = o.mid.length, X = (i) => pad + (w - 2 * pad) * i / (n - 1), Y = (v) => (h - pad) - (h - 2 * pad) * (v - mn) / (mx - mn);
      const line = (arr, col, lw, dash) => { ctx.beginPath(); arr.forEach((v, i) => (i ? ctx.lineTo(X(i), Y(v)) : ctx.moveTo(X(i), Y(v)))); ctx.strokeStyle = col; ctx.setLineDash(dash || []); ctx.lineWidth = lw; ctx.lineJoin = 'round'; ctx.stroke(); ctx.setLineDash([]); };
      if (cmp) { // samanburðar-hamur: A (núverandi, appelsínugult) vs B (fest, blátt) — engin bönd/BAU
        line(cmp.mid, '#5ac8e0', 1.8, [5, 3]); line(o.mid, '#f6b13b', 2.2);
        ctx.font = '10px system-ui'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'right';
        ctx.fillStyle = '#f6b13b'; ctx.fillText(num(o.mid[n - 1]), X(n - 1) - 1, Y(o.mid[n - 1]) - 4);
        ctx.fillStyle = '#5ac8e0'; ctx.fillText(num(cmp.mid[n - 1]), X(n - 1) - 1, Y(cmp.mid[n - 1]) + 11);
        return;
      }
      const col = vcol || '#f6b13b', bandCol = BAND[col] || 'rgba(246,177,59,.13)';
      ctx.beginPath(); ctx.moveTo(X(0), Y(o.hi[0])); for (let i = 1; i < n; i++) ctx.lineTo(X(i), Y(o.hi[i])); for (let i = n - 1; i >= 0; i--) ctx.lineTo(X(i), Y(o.lo[i])); ctx.closePath(); ctx.fillStyle = bandCol; ctx.fill();
      line(o.baseline, 'rgba(255,255,255,.28)', 1.4, [4, 4]); line(o.mid, col, 2.2);
      ctx.fillStyle = 'rgba(159,176,200,.85)'; ctx.font = '10px system-ui'; ctx.textBaseline = 'alphabetic';
      ctx.textAlign = 'left'; ctx.fillText(num(o.mid[0]), X(0) + 1, Y(o.mid[0]) - 4);
      ctx.textAlign = 'right'; ctx.fillStyle = col; ctx.fillText(num(o.mid[n - 1]), X(n - 1) - 1, Y(o.mid[n - 1]) - 4);
    }

    function highlight(k) { const reach = reachFrom(k); document.querySelectorAll('#charts .card').forEach((c) => { c.classList.toggle('lit', reach.has(c.dataset.k)); c.classList.toggle('dim', !reach.has(c.dataset.k)); }); }
    function clearHighlight() { document.querySelectorAll('#charts .card').forEach((c) => c.classList.remove('lit', 'dim')); }

    function buildControls() {
      const mk = (host, k, cfg, grp) => {
        const el = document.createElement('div'); el.className = 'sl'; el.dataset.k = k; el.title = LEV_TIP[k] || cfg.label;
        const dec = cfg.step < 1 ? 2 : 0, val = state[grp][k] ?? cfg.base;
        const basePct = ((cfg.base - cfg.min) / (cfg.max - cfg.min || 1)) * 100;
        const nowLbl = grp === 'shocks' ? 'hlutlaust' : ('nú ' + num(cfg.base, dec) + cfg.unit);
        el.innerHTML = `<div class="sl-t"><span>${cfg.label}</span><span class="sl-r"><b>${num(val, dec)}${cfg.unit}</b> <em class="sl-now" title="Núverandi raun-gildi / sjálfgefið — daufa strikið á rásinni sýnir það">${nowLbl}</em></span></div><div class="sl-track"><input type="range" min="${cfg.min}" max="${cfg.max}" step="${cfg.step}" value="${val}"><span class="sl-base" style="left:${basePct}%"></span></div>`;
        const inp = el.querySelector('input'), b = el.querySelector('b');
        inp.addEventListener('input', () => { const v = +inp.value; state[grp][k] = v; b.textContent = num(v, dec) + cfg.unit; el.classList.toggle('moved', v !== cfg.base); run(); });
        el.classList.toggle('moved', val !== cfg.base);
        el.addEventListener('mouseenter', () => { el.classList.add('hot'); highlight(k); }); el.addEventListener('mouseleave', () => { el.classList.remove('hot'); clearHighlight(); });
        host.appendChild(el);
      };
      const lh = document.getElementById('levers'), sh = document.getElementById('shocks'); lh.innerHTML = ''; sh.innerHTML = '';
      for (const k in BASELINE.levers) mk(lh, k, BASELINE.levers[k], 'levers');
      for (const k in BASELINE.shocks) mk(sh, k, BASELINE.shocks[k], 'shocks');
      applyAutoDisable();
    }

    function applyAutoDisable() {
      const set = (k, on) => { const el = document.querySelector(`.sl[data-k="${k}"]`); if (!el) return; el.classList.toggle('auto-on', on); const inp = el.querySelector('input'); inp.disabled = on; };
      set('vextir', state.autoTay); set('laun', state.autoPhi);
    }

    // KARP-lausnin: hnitráð (coordinate descent) yfir ákvarðana-sleðana til að hámarka heilsufar.
    // Ytri áhrif höfð hlutlaus (0) — þú velur ekki olíuskell; leitar að bestu STEFNU miðað við núverandi horfur.
    function findBest() {
      const keys = Object.keys(BASELINE.levers), H = state.horizon;
      const sim = (lv) => healthScore(simulate({ baseline: BASELINE, links: LINKS, levers: lv, shocks: state.shocks, quarters: H }));
      const best = {}; let bestScore = sim(best);
      for (let pass = 0; pass < 3; pass++) {
        let improved = false;
        for (const k of keys) {
          const cfg = BASELINE.levers[k], step = Math.max(cfg.step, (cfg.max - cfg.min) / 16);
          let lb = best[k] ?? cfg.base, ls = bestScore;
          for (let v = cfg.min; v <= cfg.max + 1e-9; v += step) {
            const vr = +(Math.round(v / cfg.step) * cfg.step).toFixed(4);
            const s = sim({ ...best, [k]: vr });
            if (s > ls + 1e-6) { ls = s; lb = vr; }
          }
          if (lb !== (best[k] ?? cfg.base)) improved = true;
          best[k] = lb; bestScore = ls;
        }
        if (!improved) break;
      }
      for (const k in best) if (best[k] === BASELINE.levers[k].base) delete best[k]; // sleppa óbreyttum
      return { levers: best, score: Math.round(bestScore) };
    }

    function buildScenarios() {
      const box = document.getElementById('scn'); box.innerHTML = '';
      SCENARIOS.forEach((s) => { const b = document.createElement('button'); b.textContent = s.label; b.title = s.tldr;
        b.addEventListener('click', () => { state.levers = { ...s.levers }; state.shocks = { ...s.shocks }; [...box.children].forEach((c) => c.classList.remove('on')); b.classList.add('on');
          const news = document.getElementById('news'); news.hidden = false; news.innerHTML = '📰 <b>' + s.label + ':</b> ' + s.sentence; buildControls(); run(); });
        box.appendChild(b);
      });
    }

    function buildLinkTable() {
      const host = document.getElementById('lnks'); if (!host) return;
      const rows = LINKS.map((l) => `<tr><td>${lbl(l.from)} → ${lbl(l.to)}</td><td style="text-align:right;font-variant-numeric:tabular-nums">${l.coef} ${l.unit}</td><td style="text-align:right">töf ${l.lag}</td><td style="text-align:right">±${(((l.ci_hi - l.ci_lo) / 2)).toFixed(2)}</td><td>${l.source}</td></tr>`).join('');
      host.innerHTML = `<table class="lnk-tbl"><tr><th>Keðja</th><th>Stuðull</th><th>Töf</th><th>Óvissa</th><th>Heimild</th></tr>${rows}</table><p style="font-size:11.5px;color:var(--faint);margin-top:8px">Hver stuðull er metinn úr Karp-gögnum eða úr birtum heimildum (SÍ/Hagstofa/OECD). Stílfærð sambönd — ekki opinber spá.</p>`;
    }

    // Keðju-kort: lagskipt net allra tengsla (dálkar eftir „dýpt" frá inntökum). Grænt=eykur, rautt=dregur úr.
    function buildChainMap() {
      const host = document.getElementById('chainmap'); if (!host) return;
      const NS = 'http://www.w3.org/2000/svg';
      const levers = Object.keys(BASELINE.levers), shocks = Object.keys(BASELINE.shocks), outs = Object.keys(BASELINE.outcomes);
      const inputs = [...levers, ...shocks];
      const isShock = (k) => BASELINE.shocks[k] != null, isOut = (k) => BASELINE.outcomes[k] != null;
      const depth = {}; inputs.forEach((k) => (depth[k] = 0)); outs.forEach((k) => (depth[k] = 1));
      for (let pass = 0; pass < 6; pass++) for (const l of LINKS) if (isOut(l.to) && depth[l.from] != null && l.from !== l.to && depth[l.to] <= depth[l.from]) depth[l.to] = Math.min(depth[l.from] + 1, 6);
      const maxD = Math.max(1, ...outs.map((k) => depth[k]));
      const cols = []; for (let c = 0; c <= maxD; c++) cols[c] = [];
      inputs.forEach((k) => cols[0].push(k)); outs.forEach((k) => cols[depth[k]].push(k));
      const M = 14, COLW = 174, NW = 136, NH = 22, VG = 9;
      const rows = Math.max(...cols.map((c) => c.length));
      const W = M * 2 + maxD * COLW + NW, H = M * 2 + rows * (NH + VG) - VG;
      const pos = {};
      cols.forEach((list, c) => { const colH = list.length * (NH + VG) - VG; const y0 = M + (H - 2 * M - colH) / 2; list.forEach((k, i) => { pos[k] = { x: M + c * COLW, y: y0 + i * (NH + VG), c }; }); });
      const svg = document.createElementNS(NS, 'svg'); svg.setAttribute('width', W); svg.setAttribute('height', H); svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
      const defs = document.createElementNS(NS, 'defs');
      defs.innerHTML = '<marker id="cm-ap" markerWidth="7" markerHeight="7" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#54d08a"/></marker><marker id="cm-an" markerWidth="7" markerHeight="7" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#e78284"/></marker>';
      svg.appendChild(defs);
      const edgeEls = [], gE = document.createElementNS(NS, 'g');
      for (const l of LINKS) {
        if (l.from === l.to) continue;
        const a = pos[l.from], b = pos[l.to]; if (!a || !b) continue;
        const sx = a.x + NW, sy = a.y + NH / 2, tx = b.x, ty = b.y + NH / 2, back = tx <= sx, dx = Math.max(30, Math.abs(tx - sx) * 0.4);
        const bow = back ? 34 + Math.abs(a.c - b.c) * 12 : 0;
        const d = back ? `M${sx},${sy} C${sx + dx},${sy - bow} ${tx - dx},${ty - bow} ${tx},${ty}` : `M${sx},${sy} C${sx + dx},${sy} ${tx - dx},${ty} ${tx},${ty}`;
        const p = document.createElementNS(NS, 'path'), pv = l.coef > 0;
        p.setAttribute('d', d); p.setAttribute('fill', 'none'); p.setAttribute('stroke', pv ? '#54d08a' : '#e78284'); p.setAttribute('stroke-width', '1.2'); p.setAttribute('opacity', '0.13'); p.setAttribute('marker-end', `url(#${pv ? 'cm-ap' : 'cm-an'})`);
        gE.appendChild(p); edgeEls.push({ el: p, from: l.from, to: l.to });
      }
      svg.appendChild(gE);
      const nodeEls = {};
      for (const k of [...inputs, ...outs]) {
        const p = pos[k]; if (!p) continue;
        const g = document.createElementNS(NS, 'g'); g.setAttribute('class', 'cm-node'); g.dataset.k = k;
        const rect = document.createElementNS(NS, 'rect'); rect.setAttribute('x', p.x); rect.setAttribute('y', p.y); rect.setAttribute('width', NW); rect.setAttribute('height', NH); rect.setAttribute('rx', 5);
        rect.setAttribute('fill', isOut(k) ? 'rgba(159,176,200,.16)' : isShock(k) ? 'rgba(246,177,59,.22)' : 'rgba(110,168,254,.22)');
        const t = document.createElementNS(NS, 'text'); t.setAttribute('x', p.x + 8); t.setAttribute('y', p.y + NH / 2 + 3.5); let la = lbl(k); if (la.length > 20) la = la.slice(0, 19) + '…'; t.textContent = la;
        const tt = document.createElementNS(NS, 'title'); tt.textContent = lbl(k) + (driversOf(k).length ? ' ← ' + driversOf(k).join(', ') : '');
        g.appendChild(rect); g.appendChild(t); g.appendChild(tt);
        g.addEventListener('mouseenter', () => hoverNode(k)); g.addEventListener('mouseleave', clearHover);
        svg.appendChild(g); nodeEls[k] = g;
      }
      host.innerHTML = ''; host.appendChild(svg);
      function hoverNode(k) {
        const conn = new Set([k]);
        edgeEls.forEach((e) => { const on = e.from === k || e.to === k; e.el.setAttribute('opacity', on ? '0.95' : '0.03'); e.el.setAttribute('stroke-width', on ? '2.2' : '1'); if (on) { conn.add(e.from); conn.add(e.to); } });
        for (const nk in nodeEls) nodeEls[nk].setAttribute('opacity', conn.has(nk) ? '1' : '0.25');
      }
      function clearHover() { edgeEls.forEach((e) => { e.el.setAttribute('opacity', '0.13'); e.el.setAttribute('stroke-width', '1.2'); }); for (const nk in nodeEls) nodeEls[nk].setAttribute('opacity', '1'); }
    }

    function describeState() {
      const p = [];
      for (const k in state.levers) if (state.levers[k] != null && state.levers[k] !== BASELINE.levers[k].base) p.push(lbl(k) + ' ' + num(state.levers[k], BASELINE.levers[k].step < 1 ? 2 : 0) + BASELINE.levers[k].unit);
      for (const k in state.shocks) if (state.shocks[k]) p.push(lbl(k) + ' ' + (state.shocks[k] > 0 ? '+' : '') + num(state.shocks[k], 0) + BASELINE.shocks[k].unit);
      if (state.autoTay) p.push('sjálfv. vextir'); if (state.autoPhi) p.push('sjálfv. laun');
      return p.length ? p.join(', ') : 'grunnstaða';
    }
    function updateCmp() {
      const btn = document.getElementById('cmp'), bar = document.getElementById('cmpbar');
      if (state.compare) { btn.classList.add('on'); btn.textContent = '✕ Hætta samanburði'; bar.hidden = false; bar.innerHTML = `⚖️ <b>Samanburður:</b> <span style="color:#f6b13b"><span class="sw" style="background:#f6b13b"></span> A = núverandi</span> vs <span style="color:#5ac8e0"><span class="sw" style="background:#5ac8e0"></span> B = ${state.compare.desc}</span>`; }
      else { btn.classList.remove('on'); btn.textContent = '⚖️ Festa til samanburðar'; bar.hidden = true; }
    }

    function applyHorizon() {
      document.querySelectorAll('#horizon button').forEach((b) => b.classList.toggle('on', +b.dataset.h === state.horizon));
      const hn = document.getElementById('hnote');
      if (state.horizon > BASELINE.quarters) { hn.hidden = false; hn.innerHTML = '🔭 <b>10 ára sýn</b> — stílfærð langtíma-framreikning (grunnferill heldur 3-ára jafnvægi). Skýrust fyrir <b>skuldir, losun og vanskil</b> sem safnast upp; lýðfræði til langs tíma er á <a href="/mannfjoldi/">/mannfjoldi/</a>. Óvissa vex með tíma.'; }
      else hn.hidden = true;
    }

    function reset() { state.levers = {}; state.shocks = {}; state.autoTay = false; state.autoPhi = false; state.compare = null; state.horizon = BASELINE.quarters; document.getElementById('auto-tay').checked = false; document.getElementById('auto-phi').checked = false; updateCmp(); applyHorizon(); [...document.getElementById('scn').children].forEach((c) => c.classList.remove('on')); document.getElementById('news').hidden = true; buildControls(); run(); }

    function init() {
      const main = document.querySelector('main[data-pg="roads"]'); if (!main || main.dataset.done) return; main.dataset.done = '1';
      document.getElementById('disc').textContent = BASELINE.disclaimer + ' Óvissu-bönd = næmni fyrir stuðla-óvissu.';
      buildScenarios();
      const restored = deserialize(); // sviðsmynd úr hlekk (ef til)
      document.getElementById('auto-tay').checked = state.autoTay;
      document.getElementById('auto-phi').checked = state.autoPhi;
      applyHorizon();
      buildControls(); run(); buildLinkTable(); buildChainMap();
      if (restored) { const n = document.getElementById('news'); n.hidden = false; n.innerHTML = '🔗 <b>Sviðsmynd úr hlekk.</b> Stýringarnar sýna deilda sviðsmynd — breyttu að vild eða núllstilltu.'; }
      document.getElementById('rs').addEventListener('click', reset);
      document.getElementById('karp').addEventListener('click', (e) => {
        const btn = e.currentTarget, t0 = btn.textContent; btn.textContent = '⏳ Reikna bestu lausn…'; btn.disabled = true; btn.classList.add('busy');
        setTimeout(() => {
          const best = findBest();
          state.levers = { ...best.levers }; state.autoTay = false; state.autoPhi = false; state.compare = null;
          document.getElementById('auto-tay').checked = false; document.getElementById('auto-phi').checked = false;
          [...document.getElementById('scn').children].forEach((c) => c.classList.remove('on'));
          updateCmp(); buildControls(); run();
          const extra = Object.values(state.shocks).some((v) => v) ? ' — besta stefnu-svar við núverandi ytri áhrifum' : '';
          const n = document.getElementById('news'); n.hidden = false; n.innerHTML = `🏆 <b>KARP-lausnin</b>${extra} — hæsta þjóðhagslega heilsufar sem fannst (${best.score}/100) á ${state.horizon > BASELINE.quarters ? '10 ára' : '3 ára'} sjóndeild: ${describeState() === 'grunnstaða' ? 'engin breyting bætir núverandi horfur' : describeState()}. (Heuristísk leit — ekki opinber ráðgjöf.)`;
          btn.textContent = t0; btn.disabled = false; btn.classList.remove('busy');
        }, 30);
      });
      document.querySelectorAll('#horizon button').forEach((b) => b.addEventListener('click', () => { state.horizon = +b.dataset.h; state.compare = null; updateCmp(); applyHorizon(); run(); }));
      document.getElementById('cmp').addEventListener('click', () => { state.compare = state.compare ? null : { r: state._lastR, desc: describeState() }; updateCmp(); run(); });
      document.getElementById('share').addEventListener('click', (e) => { const b = e.currentTarget; navigator.clipboard.writeText(location.href).then(() => { b.classList.add('ok'); const t = b.textContent; b.textContent = '✓ Hlekkur afritaður'; setTimeout(() => { b.classList.remove('ok'); b.textContent = t; }, 1800); }).catch(() => {}); });
      document.getElementById('auto-tay').addEventListener('change', (e) => { state.autoTay = e.target.checked; if (!e.target.checked && state._sol) { state.levers.vextir = state._sol.vextir; syncSlider('vextir', state._sol.vextir); } applyAutoDisable(); run(); });
      document.getElementById('auto-phi').addEventListener('change', (e) => { state.autoPhi = e.target.checked; if (!e.target.checked && state._sol) { state.levers.laun = state._sol.laun; syncSlider('laun', state._sol.laun); } applyAutoDisable(); run(); });
    }
    init();
    document.addEventListener('astro:page-load', init);
  </script>
</Layout>
