---
// Ökutækja- & skipaleit (Verk 1, LOTA 106) — SAMEINUÐ síða með kveðju-rofa.
// 🚗 Ökutæki: bílnúmer → /api/okutaeki (island.is publicVehicleSearch).
// 🚢 Skip: skipaskrárnr EÐA nafn → /api/skip (island.is shipRegistryShipSearch) + eigendur.
// Rofinn skiptir um API + niðurstöðu-render; báðar virknir haldast óbreyttar.
// Gömlu slóðirnar /okutaeki/ og /skip/ redirect-a hingað (m/?t= og fyrirspurn).
import Layout from '../layouts/Layout.astro';
const desc = 'Ökutækja-, skipa- og loftfaraleit — flettu upp íslensku bílnúmeri, skipi (skipaskrárnúmer/nafn) eða loftfari (TF-númer/nafn) og sjáðu skráðar upplýsingar frá Samgöngustofu um island.is. Ókeypis.';
---
<Layout title="Ökutækja-, skipa- & loftfaraleit | Karp" description={desc} canonical="https://karp.is/okutaeki-skip/" ogTitle="Ökutækja-, skipa- & loftfaraleit">
  <main data-pg="okuskip">
    <p class="kicker">Hagvísir Íslands · Uppfletting</p>
    <h1 id="os-title">Ökutækjaleit 🚗</h1>

    <div class="os-toggle" role="tablist" aria-label="Veldu leit">
      <button class="os-tab on" type="button" data-mode="oku" role="tab" aria-selected="true">🚗 Ökutæki</button>
      <button class="os-tab" type="button" data-mode="skip" role="tab" aria-selected="false">🚢 Skip</button>
      <button class="os-tab" type="button" data-mode="loft" role="tab" aria-selected="false">✈️ Loftför</button>
    </div>

    <p class="lead" id="os-lead">Flettu upp íslensku bílnúmeri og sjáðu skráðar upplýsingar ökutækisins — tegund, árgerð, lit, stöðu, <strong>næstu skoðun</strong>, þyngd, CO₂-losun og verksmiðjunúmer. Ókeypis, beint frá Samgöngustofu um island.is.</p>

    <form id="os-form" class="os-form" autocomplete="off">
      <input id="os-q" class="plate" type="text" inputmode="latin" maxlength="6" placeholder="Bílnúmer · t.d. AB123" aria-label="Leit" />
      <button type="submit" id="os-go">Fletta upp</button>
    </form>
    <div id="os-result" class="os-result" aria-live="polite"></div>

    <p class="os-lock" id="os-lock">🔒 <strong>Eigandi, veðbönd og skoðunarsaga</strong> eru ekki í opna skránni — þau krefjast innskráningar með rafrænum skilríkjum á <a href="https://island.is/minarsidur/eignir/okutaeki/leit" target="_blank" rel="noopener">Mínum síðum</a>.</p>
    <p class="foot" id="os-foot">Heimild: Samgöngustofa um opna ökutækjaleit island.is (<code>publicVehicleSearch</code>). Grunnupplýsingar ökutækis, engar persónuupplýsingar. Uppfletting takmörkuð (öryggisnet gegn fjöldaflettingu).</p>
  </main>

  <style>
    main { max-width: 680px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; }
    p { color: #cdd6e6; } a { color: #f6b13b; }
    .lead { font-size: 15px; line-height: 1.6; } .lead strong { color: #eaf0fb; }

    /* Kveðju-rofi (segmented) */
    .os-toggle { display: inline-flex; gap: 4px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 4px; margin: 2px 0 14px; }
    .os-tab { font: inherit; font-size: 14px; font-weight: 700; padding: 8px 18px; border-radius: 9px; border: 0; background: none; color: #9fb0c8; cursor: pointer; }
    .os-tab:hover { color: #eaf1fb; }
    .os-tab.on { background: #f6b13b; color: #10151f; }

    .os-form { display: flex; gap: 8px; margin: 6px 0 4px; }
    #os-q { flex: 1 1 auto; font: inherit; font-size: 18px; font-weight: 600; padding: 12px 14px; border-radius: 11px; border: 1px solid rgba(255,255,255,.16); background: rgba(255,255,255,.04); color: #eaf1fb; }
    #os-q:focus { outline: none; border-color: rgba(246,177,59,.6); }
    #os-q::placeholder { color: #6f7b8d; font-weight: 400; letter-spacing: normal; }
    #os-q.plate { font-size: 20px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; text-align: center; }
    #os-go { font: inherit; font-size: 15px; font-weight: 700; padding: 0 22px; border-radius: 11px; border: 0; background: #f6b13b; color: #10151f; cursor: pointer; }
    #os-go:disabled { opacity: .55; cursor: default; }

    .os-result { margin-top: 14px; }
    .os-msg { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 16px 18px; color: #cdd6e6; font-size: 14px; }
    .os-lock { font-size: 12.5px; color: #9fb0c8; margin-top: 16px; background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.18); border-radius: 10px; padding: 10px 13px; }
    .os-lock strong { color: #eaf1fb; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 14px; line-height: 1.6; } .foot code { color: #9fb0c8; }

    /* 🚗 Ökutæki-spjald */
    .ok-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 14px; padding: 18px 20px; }
    .ok-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
    .ok-h h2 { font-size: 21px; margin: 0; color: #eaf1fb; }
    .ok-plate { font-size: 13px; font-weight: 800; letter-spacing: .12em; background: #12203a; color: #cfe0ff; border: 1px solid #2b4272; border-radius: 6px; padding: 3px 9px; }
    .ok-sub { font-size: 13px; color: #9fb0c8; margin: 0 0 14px; }
    .ok-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px 16px; }
    .ok-f .l { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; }
    .ok-f .v { font-size: 15px; color: #eaf1fb; font-weight: 600; margin-top: 1px; font-variant-numeric: tabular-nums; }
    .ok-f .v.ok { color: #46d086; } .ok-f .v.warn { color: #f6b13b; } .ok-f .v.bad { color: #f85149; }

    /* 🚢 Skip-spjald + listi */
    .sk-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 14px; padding: 18px 20px; }
    .sk-card + .sk-card { margin-top: 12px; }
    .sk-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
    .sk-h h2 { font-size: 21px; margin: 0; color: #eaf1fb; }
    .sk-reg { font-size: 13px; font-weight: 800; letter-spacing: .06em; background: #12203a; color: #cfe0ff; border: 1px solid #2b4272; border-radius: 6px; padding: 3px 9px; }
    .sk-sub { font-size: 13px; color: #9fb0c8; margin: 0 0 14px; }
    .sk-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px 16px; }
    .sk-f .l { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; }
    .sk-f .v { font-size: 15px; color: #eaf1fb; font-weight: 600; margin-top: 1px; font-variant-numeric: tabular-nums; }
    .sk-own { margin-top: 16px; }
    .sk-own .l { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; margin-bottom: 6px; }
    .sk-own ul { list-style: none; margin: 0; padding: 0; }
    .sk-own li { font-size: 15px; color: #eaf1fb; padding: 4px 0; border-top: 1px solid rgba(255,255,255,.06); }
    .sk-own li:first-child { border-top: 0; }
    .sk-own a { font-weight: 600; }
    .sk-pct { font-size: 12.5px; color: #9fb0c8; font-variant-numeric: tabular-nums; }
    .sk-fisk { display: inline-block; margin-top: 12px; font-size: 13px; }
    .sk-list-h { font-size: 13px; color: #9fb0c8; margin: 0 0 10px; }
    .sk-row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; width: 100%; text-align: left; cursor: pointer; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 12px 15px; margin-bottom: 8px; color: inherit; font: inherit; }
    .sk-row:hover { border-color: rgba(246,177,59,.5); background: rgba(255,255,255,.05); }
    .sk-row-nm { font-size: 16px; font-weight: 700; color: #eaf1fb; }
    .sk-row-reg { font-size: 12px; font-weight: 800; letter-spacing: .06em; background: #12203a; color: #cfe0ff; border: 1px solid #2b4272; border-radius: 5px; padding: 2px 7px; }
    .sk-row-meta { font-size: 12.5px; color: #9fb0c8; margin-left: auto; }
    .sk-back { display: inline-block; margin-bottom: 10px; font-size: 13px; color: #f6b13b; cursor: pointer; background: none; border: 0; padding: 0; font: inherit; }
  </style>

  <script>
    function initOkuSkip() {
      const form = document.getElementById('os-form');
      if (!form || form.dataset.on) return;
      form.dataset.on = '1';
      const inp = document.getElementById('os-q'), btn = document.getElementById('os-go'), out = document.getElementById('os-result');
      const titleEl = document.getElementById('os-title'), leadEl = document.getElementById('os-lead'), lockEl = document.getElementById('os-lock'), footEl = document.getElementById('os-foot');
      const tabs = [...document.querySelectorAll('.os-tab')];
      const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

      // ── Mode-stillingar ──
      const MODES = {
        oku: {
          title: 'Ökutækjaleit 🚗', maxlen: 6, plate: true,
          placeholder: 'Bílnúmer · t.d. AB123',
          lead: 'Flettu upp íslensku bílnúmeri og sjáðu skráðar upplýsingar ökutækisins — tegund, árgerð, lit, stöðu, <strong>næstu skoðun</strong>, þyngd, CO₂-losun og verksmiðjunúmer. Ókeypis, beint frá Samgöngustofu um island.is.',
          lock: '🔒 <strong>Eigandi, veðbönd og skoðunarsaga</strong> eru ekki í opna skránni — þau krefjast innskráningar með rafrænum skilríkjum á <a href="https://island.is/minarsidur/eignir/okutaeki/leit" target="_blank" rel="noopener">Mínum síðum</a>.',
          foot: 'Heimild: Samgöngustofa um opna ökutækjaleit island.is (<code>publicVehicleSearch</code>). Grunnupplýsingar ökutækis, engar persónuupplýsingar. Uppfletting takmörkuð (öryggisnet gegn fjöldaflettingu).',
        },
        skip: {
          title: 'Skipaleit 🚢', maxlen: 64, plate: false,
          placeholder: 'Skipaskrárnúmer eða nafn · t.d. 2881 eða Venus',
          lead: 'Flettu upp íslensku skipi eftir <strong>skipaskrárnúmeri eða nafni</strong> og sjáðu skráðar upplýsingar úr skipaskrá Samgöngustofu — tegund, smíðaár og -stöð, brúttótonn, lengd, heimahöfn, umdæmi, stöðu og skráða eigendur. Ókeypis, beint um island.is.',
          lock: '🔒 <strong>Vél/afl, kallmerki, haffærisskírteini og skoðunarsaga</strong> eru ekki í opnu skránni — þau liggja að baki X-Road-gátt Samgöngustofu og innskráningar (t.d. „mín skip" á <a href="https://island.is/skipaskra" target="_blank" rel="noopener">island.is</a>).',
          foot: 'Heimild: Samgöngustofa um opna skipaleit island.is (<code>shipRegistryShipSearch</code>). Skipaskrárnúmer er sami lykill og hjá Fiskistofu (aflamark). Opinber skipaskrá; einstaklingseigendur einkabáta birtir með hófsemi. Uppfletting takmörkuð (öryggisnet gegn fjöldaflettingu).',
        },
        loft: {
          title: 'Loftfaraleit ✈️', maxlen: 40, plate: false,
          placeholder: 'TF-númer eða nafn · t.d. TF-FIA eða Icelandair',
          lead: 'Flettu upp íslensku loftfari eftir <strong>skráningarnúmeri (TF-…) eða nafni/eiganda</strong> og sjáðu skráðar upplýsingar úr loftfaraskrá Samgöngustofu — tegund, árgerð, hámarksþyngd, raðnúmer og skráða eigendur/rekanda. Ókeypis, beint um island.is.',
          lock: '🔒 <strong>Veðbönd, lofthæfi og skoðunarsaga</strong> eru ekki í opnu skránni — þau liggja að baki innskráningar hjá Samgöngustofu.',
          foot: 'Heimild: Samgöngustofa um opna loftfaraskrá island.is (<code>aircraftRegistryAllAircrafts</code>). Opinber loftfaraskrá (356 loftför); lögaðila-eigendur tengjast fyrirtækjaskrá, einstaklingar birtir með hófsemi (án kennitölu). Uppfletting takmörkuð.',
        },
      };
      let mode = 'oku';

      // ── Ökutæki-render (verbatim úr okutaeki.astro) ──
      const isoIS = (iso) => { if (!iso) return null; const [y, m, d] = iso.split('-'); return d ? +d + '.' + +m + '.' + y : iso; };
      const today = new Date().toISOString().slice(0, 10);
      const fO = (l, v, cls) => '<div class="ok-f"><div class="l">' + l + '</div><div class="v' + (cls ? ' ' + cls : '') + '">' + (v == null || v === '' ? '—' : esc(v)) + '</div></div>';
      const renderOku = (d) => {
        if (d.error === 'numer') { out.innerHTML = '<div class="os-msg">Sláðu inn gilt bílnúmer (2–6 stafir).</div>'; return; }
        if (d.error === 'kvoti') { out.innerHTML = '<div class="os-msg">⏳ Of margar flettingar í bili — reyndu aftur síðar.</div>'; return; }
        if (!d.fannst) { out.innerHTML = '<div class="os-msg">🔍 Ökutæki með númerið <b>' + esc(d.numer || '') + '</b> fannst ekki. Athugaðu stafsetningu (fastanúmer virkar líka).</div>'; return; }
        const insp = d.naestaSkodun, inspCls = insp ? (insp < today ? 'bad' : 'ok') : '';
        const inspTxt = insp ? isoIS(insp) + (insp < today ? ' · útrunnin' : '') : '—';
        const statCls = /í lagi/i.test(d.stada || '') ? 'ok' : (/(afskrá|ónýtt|innkoll|bann)/i.test(d.stada || '') ? 'bad' : '');
        out.innerHTML = '<div class="ok-card">'
          + '<div class="ok-h"><h2>' + esc([d.tegund, d.undirheiti].filter(Boolean).join(' ') || 'Ökutæki') + '</h2><span class="ok-plate">' + esc(d.numer) + '</span></div>'
          + (d.argerd ? '<p class="ok-sub">Árgerð ' + esc(d.argerd) + (d.fyrstSkrad ? ' · fyrst skráð ' + isoIS(d.fyrstSkrad) : '') + '</p>' : '')
          + '<div class="ok-grid">'
          + fO('Litur', d.litur)
          + fO('Staða', d.stada, statCls)
          + fO('Næsta skoðun', inspTxt, inspCls)
          + fO('Eigin þyngd', d.thyngd ? d.thyngd.toLocaleString('de-DE') + ' kg' : null)
          + fO('CO₂-losun', d.co2 != null ? d.co2 + ' g/km' : null)
          + fO('Fastanúmer', d.fastanumer)
          + fO('Verksmiðjunúmer (VIN)', d.vin)
          + '</div></div>';
      };

      // ── Skip-render (verbatim úr skip.astro) ──
      const num = (n, d) => (n == null || n === '' ? null : Number(n).toLocaleString('de-DE', { maximumFractionDigits: d == null ? 0 : d }));
      const fS = (l, v) => '<div class="sk-f"><div class="l">' + l + '</div><div class="v">' + (v == null || v === '' ? '—' : esc(v)) + '</div></div>';
      let skState = [];
      const ownersHtml = (eig) => {
        if (!eig || !eig.length) return '';
        const rows = eig.map((o) => {
          const nm = esc(o.nafn || '—');
          const pct = (o.hlutur != null && o.hlutur !== '') ? ' <span class="sk-pct">' + esc(num(o.hlutur, 0)) + '%</span>' : '';
          if (o.erFyrirtaeki && o.kt) return '<li><a href="/fyrirtaeki/?q=' + encodeURIComponent(o.kt) + '">' + nm + '</a>' + pct + '</li>';
          return '<li>' + nm + pct + '</li>';
        }).join('');
        return '<div class="sk-own"><div class="l">Skráðir eigendur</div><ul>' + rows + '</ul></div>';
      };
      const cardHtml = (s) => {
        return '<div class="sk-card">'
          + '<div class="sk-h"><h2>' + esc(s.nafn || 'Skip') + '</h2>'
          + (s.skipaskrarnumer != null ? '<span class="sk-reg">Skipaskrá ' + esc(s.skipaskrarnumer) + '</span>' : '') + '</div>'
          + '<p class="sk-sub">' + esc([s.tegund, s.heimahofn].filter(Boolean).join(' · ') || '—') + '</p>'
          + '<div class="sk-grid">'
          + fS('Staða', s.stada)
          + fS('Umdæmi', s.umdaemi)
          + fS('Brúttótonn', num(s.bruttotonn, 2))
          + fS('Skráningarlengd', s.lengd != null ? num(s.lengd, 2) + ' m' : null)
          + fS('Smíðaár', s.smidaar)
          + fS('Smíðastöð', s.smidastod)
          + (s.opinnBatur != null ? fS('Bátsgerð', s.opinnBatur ? 'Opinn bátur' : 'Þilfarsskip') : '')
          + '</div>'
          + ownersHtml(s.eigendur)
          + (s.skipaskrarnumer != null ? '<a class="sk-fisk" href="/atvinnuvegir/sjavarutvegur/">Aflamark & aflahlutdeild → sjávarútvegur</a>' : '')
          + '</div>';
      };
      const showShip = (s, fromList) => {
        out.innerHTML = (fromList ? '<button class="sk-back" type="button">← Til baka í niðurstöður</button>' : '') + cardHtml(s);
        if (s.skipaskrarnumer != null) setUrl('&q=' + encodeURIComponent(s.skipaskrarnumer));
      };
      const showList = (ships, alls) => {
        skState = ships;
        const rows = ships.map((s, i) =>
          '<button class="sk-row" type="button" data-idx="' + i + '">'
          + '<span class="sk-row-nm">' + esc(s.nafn || '—') + '</span>'
          + (s.skipaskrarnumer != null ? '<span class="sk-row-reg">#' + esc(s.skipaskrarnumer) + '</span>' : '')
          + '<span class="sk-row-meta">' + esc([s.tegund, s.heimahofn].filter(Boolean).join(' · ')) + '</span>'
          + '</button>').join('');
        out.innerHTML = '<p class="sk-list-h">' + ships.length + ' skip fundust' + (alls && alls > ships.length ? ' (sýni ' + ships.length + ' af ' + alls + ')' : '') + ' — smelltu til að sjá nánar:</p>' + rows;
      };
      const renderSkip = (d) => {
        if (d.error === 'q') { out.innerHTML = '<div class="os-msg">Sláðu inn skipaskrárnúmer eða nafn (a.m.k. 2 stafi).</div>'; return; }
        if (d.error === 'kvoti') { out.innerHTML = '<div class="os-msg">⏳ Of margar flettingar í bili — reyndu aftur síðar.</div>'; return; }
        const ships = d.ships || [];
        if (!ships.length) { out.innerHTML = '<div class="os-msg">🔍 Ekkert skip fannst fyrir <b>' + esc(d.qs || '') + '</b>. Athugaðu stafsetningu — leita má eftir númeri eða (hluta úr) nafni.</div>'; return; }
        if (ships.length === 1) { showShip(ships[0], false); return; }
        showList(ships, d.alls);
      };

      // ── Loftfar-render (leit eftir TF-númeri/nafni; listi → spjald eins og skip) ──
      let loftState = [];
      const loftOwners = (a) => {
        if (!a.eigendur || !a.eigendur.length) return '';
        const rows = a.eigendur.map((o) => (o.erFyrirtaeki && o.kt) ? '<li><a href="/fyrirtaeki/?q=' + encodeURIComponent(o.kt) + '">' + esc(o.nafn) + '</a></li>' : '<li>' + esc(o.nafn) + '</li>').join('');
        return '<div class="sk-own"><div class="l">Skráðir eigendur</div><ul>' + rows + '</ul></div>';
      };
      const loftCard = (a) => '<div class="sk-card">'
        + '<div class="sk-h"><h2>' + esc(a.skrnr || 'Loftfar') + '</h2>' + (a.afskrad ? '<span class="sk-reg">afskráð</span>' : '') + '</div>'
        + '<p class="sk-sub">' + esc(a.tegund || '—') + '</p>'
        + '<div class="sk-grid">' + fS('Árgerð', a.argerd) + fS('Hámarksþyngd', a.hamth != null ? num(a.hamth) + ' kg' : null) + fS('Raðnúmer', a.radnr) + fS('Rekandi', a.rekandi ? a.rekandi.nafn : null) + '</div>'
        + loftOwners(a) + '</div>';
      const showLoftList = (acs) => {
        loftState = acs;
        const rows = acs.map((a, i) =>
          '<button class="sk-row" type="button" data-lidx="' + i + '"><span class="sk-row-nm">' + esc(a.skrnr || '—') + '</span>'
          + '<span class="sk-row-reg">' + esc((a.tegund || '').slice(0, 22)) + '</span>'
          + '<span class="sk-row-meta">' + esc((a.eigendur[0] && a.eigendur[0].nafn) || (a.argerd ? 'árg. ' + a.argerd : '')) + '</span></button>').join('');
        out.innerHTML = '<p class="sk-list-h">' + acs.length + ' loftför fundust — smelltu til að sjá nánar:</p>' + rows;
      };
      const renderLoft = (d) => {
        if (d.error === 'q') { out.innerHTML = '<div class="os-msg">Sláðu inn TF-númer eða nafn (a.m.k. 2 stafi).</div>'; return; }
        const acs = d.loftfor || [];
        if (!acs.length) { out.innerHTML = '<div class="os-msg">🔍 Ekkert loftfar fannst fyrir <b>' + esc(d.q || '') + '</b>. Athugaðu stafsetningu — leita má eftir TF-númeri eða (hluta úr) nafni/eiganda.</div>'; return; }
        if (acs.length === 1) { out.innerHTML = loftCard(acs[0]); return; }
        showLoftList(acs);
      };

      // ── URL-sync ──
      const setUrl = (extra) => { try { history.replaceState(null, '', '/okutaeki-skip/?t=' + mode + (extra || '')); } catch (e) {} };

      // ── Mode-skipti ──
      const applyMode = (m, keepVal) => {
        mode = m;
        const M = MODES[m];
        tabs.forEach((t) => { const on = t.dataset.mode === m; t.classList.toggle('on', on); t.setAttribute('aria-selected', on ? 'true' : 'false'); });
        titleEl.textContent = M.title;
        leadEl.innerHTML = M.lead;
        lockEl.innerHTML = M.lock;
        footEl.innerHTML = M.foot;
        inp.placeholder = M.placeholder;
        inp.maxLength = M.maxlen;
        inp.classList.toggle('plate', M.plate);
        if (!keepVal) { inp.value = ''; out.innerHTML = ''; skState = []; }
      };

      const go = async () => {
        const q = (inp.value || '').trim();
        if (q.length < 2) { inp.focus(); return; }
        btn.disabled = true; out.innerHTML = '<div class="os-msg">Leita…</div>';
        try {
          if (mode === 'oku') {
            const d = await fetch('/api/okutaeki?numer=' + encodeURIComponent(q)).then((r) => r.json());
            renderOku(d);
            setUrl('&n=' + encodeURIComponent(q.toUpperCase()));
          } else if (mode === 'skip') {
            const d = await fetch('/api/skip?q=' + encodeURIComponent(q)).then((r) => r.json());
            renderSkip(d);
            if (!(d.ships && d.ships.length === 1)) setUrl('&q=' + encodeURIComponent(q));
          } else {
            const d = await fetch('/api/loftfor?q=' + encodeURIComponent(q)).then((r) => r.json());
            renderLoft(d);
            setUrl('&q=' + encodeURIComponent(q));
          }
        } catch (e) { out.innerHTML = '<div class="os-msg">Villa við uppflettingu — reyndu aftur.</div>'; }
        btn.disabled = false;
      };

      // Listi/til-baka smellir (aðeins í skip-ham)
      out.addEventListener('click', (e) => {
        const row = e.target.closest('.sk-row');
        if (mode === 'skip') {
          if (row && skState[+row.dataset.idx]) { showShip(skState[+row.dataset.idx], true); return; }
          if (e.target.closest('.sk-back')) { showList(skState); setUrl(''); }
        } else if (mode === 'loft') {
          if (row && loftState[+row.dataset.lidx]) { out.innerHTML = '<button class="sk-back" type="button">← Til baka í niðurstöður</button>' + loftCard(loftState[+row.dataset.lidx]); return; }
          if (e.target.closest('.sk-back')) { showLoftList(loftState); }
        }
      });

      form.addEventListener('submit', (e) => { e.preventDefault(); go(); });
      inp.addEventListener('input', () => { if (mode === 'oku') inp.value = inp.value.toUpperCase().replace(/[^A-Z0-9ÁÐÉÍÓÚÝÞÆÖ]/g, ''); });
      tabs.forEach((t) => t.addEventListener('click', () => { if (t.dataset.mode !== mode) { applyMode(t.dataset.mode); setUrl(''); inp.focus(); } }));

      // ── Byrjunarstaða úr slóð (?t=oku|skip, +?n=/?q=) ──
      const params = new URLSearchParams(location.search);
      const startMode = params.get('t') === 'skip' ? 'skip' : params.get('t') === 'loft' ? 'loft' : 'oku';
      applyMode(startMode, true);
      const preset = startMode === 'oku' ? params.get('n') : params.get('q');
      if (preset) { inp.value = startMode === 'oku' ? preset.toUpperCase() : preset; go(); }
      inp.focus();
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="okuskip"]')) initOkuSkip(); });
  </script>
</Layout>
