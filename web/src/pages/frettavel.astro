---
// ─────────────────────────────────────────────────────────────
// 🗞️ FRÉTTAVÉL KARP — sjálfvirk gagnablaðamennska (forsíða/straumur).
// build_frettavel.js finnur atburði vélrænt í opinberu gögnunum og skrifar örfrétt.
// Kort eru smellanleg → sér-fréttasíða (/frettavel/<id>/) fyrir SEO + tilvísun.
// Flokka-skilgreining (mynd/litur/merki) deilt úr ../lib/frettavel.mjs.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import FV from '@gogn/frettavel.json';
import { catOf, artHref, imgPath, spark, dIS } from '../lib/frettavel.mjs';
const items = FV.items || [];
const updated = (FV.updated || '').slice(0, 10);
// Hópa eftir degi (nýjast efst — items koma þegar raðaðar nýjast fyrst)
const byDate = [];
for (const it of items) { const last = byDate[byDate.length - 1]; if (last && last.d === it.date) last.list.push(it); else byDate.push({ d: it.date, list: [it] }); }
const desc = `Fréttavél Karp — sjálfvirkar fréttir skrifaðar úr opinberum gögnum: atkvæði þingmanna, fylgismet, fasteignamet, ríkisgreiðslur, útboð, gjaldþrot, dómar, styrkir, vextir og verðbólga. Hver frétt tengir á frumgögnin.`;
---

<Layout title="🗞️ Fréttavélin | Karp" description={desc} canonical="https://karp.is/frettavel/" ogTitle="Fréttavél Karp">
  <main data-pg="frettavel">
    <p class="kicker">Karp · Fréttavélin</p>
    <h1>🗞️ Fréttavélin</h1>
    <p>Fréttir sem gögnin skrifa sjálf: vél Karp vaktar opinberu gögnin — Alþingi, kannanir, kaupskrá HMS, reikninga ríkisins, útboð, Lögbirtingablaðið, dóma, styrki, vexti og verðbólgu — og birtir frétt þegar eitthvað fréttnæmt gerist í tölunum. <a href="/frettavel.xml">RSS-veita ↗</a></p>
    <div class="disclosure">🤖 <b>Gagnsæi:</b> Atburðirnir eru fundnir vélrænt eftir föstum reglum (t.d. „þingmaður kýs gegn ≥75% eigin þingflokks") og textinn er skrifaður af gervigreind <i>eingöngu</i> úr reiknuðu staðreyndunum — eða af sniðmáti úr sömu tölum. Engin mannleg ritstjórn. Smelltu á frétt fyrir fulla útgáfu, aðferð og frumgögn.</div>

    {byDate.length === 0 && <p class="empty">Engar fréttir enn — vélin keyrir daglega og birtir um leið og gögnin hreyfast fréttnæmt.</p>}
    {byDate.map((g) => (
      <section>
        <h2>{dIS(g.d)}</h2>
        <div class="fv-list">
          {g.list.map((it) => { const cat = catOf(it.type); const c = cat.color; const sp = spark(it.spark); return (
            <article class="fv-card" id={it.id} style={`--c:${c}`}>
              <a class="fv-card-link" href={artHref(it.id)}>
                <div class="fv-thumb"><span class="fv-thumb-emoji">{cat.emoji}</span><img src={imgPath(it.type)} alt="" loading="lazy" onerror="this.remove()" /></div>
                <div class="fv-card-body">
                  <div class="fv-top">
                    <span class="fv-badge" style={`color:${c};border-color:${c}55;background:${c}1a`}>{cat.emoji} {cat.label}</span>
                    {sp && (
                      <svg class="fv-spark" viewBox={`0 0 ${sp.w} ${sp.h}`} width={sp.w} height={sp.h} aria-hidden="true" style={`color:${c}`}>
                        <polyline points={sp.area} fill="currentColor" opacity="0.13" stroke="none" />
                        <polyline points={sp.pts} fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round" />
                        <circle cx={sp.ex} cy={sp.ey} r="2.4" fill="currentColor" />
                      </svg>
                    )}
                  </div>
                  <h3>{it.title}</h3>
                  <p class="fv-text">{it.text}</p>
                </div>
              </a>
              <div class="fv-foot">
                <a class="fv-src" href={it.url}>Skoða frumgögnin →</a>
                <span class="fv-ai">{it.ai ? '🤖 vélskrifað' : '⚙️ sniðmát'}</span>
              </div>
            </article>
          ); })}
        </div>
      </section>
    ))}

    <p class="foot">Forþjónað (SSG). Vélin keyrir daglega kl. 06 UTC (build_frettavel.js) — atburðareglur og heimildir í hverri frétt. Uppfært {updated}. Ábendingar: <a href="mailto:aron@sgdal.is">aron@sgdal.is</a>.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; }
    p { color: var(--ink); } p a { color: var(--gold); }
    .disclosure { background: rgba(58,160,255,.06); border: 1px solid rgba(58,160,255,.28); border-radius: 12px; padding: 12px 16px; font-size: 13px; color: var(--muted); line-height: 1.55; margin: 14px 0 6px; }
    .disclosure b { color: var(--ink); }
    h2 { font-size: 13px; color: var(--faint); text-transform: uppercase; letter-spacing: .06em; margin: 26px 0 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; }
    .fv-list { display: flex; flex-direction: column; gap: 12px; }
    .fv-card { --c: #8fa0b8; background: var(--panel); border: 1px solid var(--line); border-left: 3px solid var(--c); border-radius: 13px; padding: 13px 15px; scroll-margin-top: 80px; }
    .fv-card-link { display: flex; gap: 13px; text-decoration: none; }
    .fv-thumb { position: relative; flex: none; width: 104px; height: 80px; border-radius: 9px; overflow: hidden; align-self: flex-start; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, color-mix(in srgb, var(--c) 34%, var(--panel)), var(--panel)); border: 1px solid var(--line); }
    .fv-thumb-emoji { font-size: 30px; opacity: .55; }
    .fv-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .fv-card-body { min-width: 0; flex: 1; }
    .fv-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .fv-badge { display: inline-block; font-size: 10.5px; font-weight: 700; border-radius: 999px; padding: 3px 10px; border: 1px solid var(--line); white-space: nowrap; }
    .fv-spark { flex: none; height: 26px; width: auto; }
    .fv-card h3 { font-size: 16px; color: var(--ink); margin: 8px 0 5px; line-height: 1.32; }
    .fv-card-link:hover h3 { color: var(--c); }
    .fv-text { font-size: 13px; line-height: 1.55; margin: 0; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .fv-foot { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 10px; padding-top: 9px; border-top: 1px solid var(--line); }
    .fv-src { font-size: 12px; color: var(--gold); text-decoration: none; font-weight: 600; }
    .fv-src:hover { text-decoration: underline; }
    .fv-ai { font-size: 11px; color: var(--faint); }
    .empty { color: var(--faint); margin-top: 20px; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 30px; border-top: 1px solid var(--line); padding-top: 14px; }
    .foot a { color: var(--muted); }
    @media (max-width: 520px) { .fv-thumb { width: 76px; height: 62px; } .fv-thumb-emoji { font-size: 24px; } }
  </style>
</Layout>
