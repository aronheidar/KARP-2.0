---
// Furðuhagfræði (#2 LOTA 8) — „hvað kaupir klukkustund af vinnu?" Portað úr
// gamla (FURDU: wageIdx+hpm+items → numbeo-verð, bökuð á byggingartíma). 🏃 Launakapphlaupið
// (Hagstofa) kemur nú úr daglegu snapshot-i: skriptur/build_furduhagfraedi.mjs → gogn/furduhagfraedi.json.
import Layout from '../layouts/Layout.astro';
import FURDU from '../data/furdu.json';
import NUMBEO from '@gogn/numbeo.json';
import DATA from '@gogn/furduhagfraedi.json';
import { fmtNum, groupThousands } from '@lib/format.mjs';

const { RACE, updated } = DATA;

const rvk = (NUMBEO.prices || {}).Reykjavik || [];
const cph = (NUMBEO.prices || {}).Copenhagen || [];
const itemsMeta = NUMBEO.items || [];
const wage = rvk[FURDU.wageIdx] || null;           // meðalnettólaun á mánuði (kr)
const hourly = wage ? wage / (FURDU.hpm || 160) : null; // tímakaup

const rows = (FURDU.items || []).map((it) => {
  const p = rvk[it.idx], pc = cph[it.idx];
  if (p == null || !hourly) return null;
  return {
    e: it.e, l: it.l || (itemsMeta[it.idx] || {}).is || '',
    price: p,
    perHour: Math.round((hourly / p) * 10) / 10,
    mins: Math.round((p / hourly) * 60),
    minsCph: pc != null && cph[FURDU.wageIdx] ? Math.round((pc / (cph[FURDU.wageIdx] / (FURDU.hpm || 160))) * 60) : null,
  };
}).filter(Boolean).sort((a, b) => a.mins - b.mins);

const f1 = (v) => String(v).replace('.', ',');
const desc = `Furðuhagfræði — hvað kaupir klukkustund af íslenskri vinnu? Tímakaupið (${hourly ? groupThousands(Math.round(hourly)) : '—'} kr) mælt í bjórum, kaffibollum og bíómiðum${RACE ? `, og Launakapphlaupið: frá ${RACE.baseY} hafa laun ${f1(RACE.fW)}-faldast en húsnæðisverð ${f1(RACE.fH)}-faldast` : ''}.`;
---

<Layout title="Furðuhagfræði — hvað kaupir tímakaupið? | Karp" description={desc} canonical="https://karp.is/furduhagfraedi/" ogTitle="Furðuhagfræði">
  <main data-pg="furduhagfraedi">
    <p class="kicker">Hagvísir Íslands · Efnahagur</p>
    <h1>Furðuhagfræði 🤪</h1>
    <p>Gleymdu vísitölum — mælum kaupmáttinn í <strong>bjórum og kaffibollum</strong>. Meðalnettólaun í Reykjavík eru {wage ? groupThousands(wage) : '—'} kr/mán ≈ <strong>{hourly ? groupThousands(Math.round(hourly)) : '—'} kr á klukkustund</strong>.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Furðuhagfræðin: verð frá Numbeo (hópöflun) og opinber verð; vísitölurnar reiknar Karp til gamans og fróðleiks — ekki hagspá.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="sal">
      <label for="mysal">💰 Eða settu inn <strong>þín útborguðu laun</strong> og sjáðu hvað tímakaupið þitt kaupir:</label>
      <div class="sal-row">
        <div class="sal-in"><input id="mysal" type="number" min="0" step="10000" placeholder={wage ? String(wage) : '450000'} inputmode="numeric" /><span>kr/mán</span></div>
        <span class="sal-note" id="sal-note"></span>
      </div>
    </div>

    <div class="grid">
      {rows.map((r) => (
        <div class="c" data-price={r.price}>
          <div class="c-e">{r.e}</div>
          <div class="c-l">{r.l}</div>
          <div class="c-v"><span class="c-v-num">{fmtNum(r.perHour, 1)}</span> <span>á klst vinnu</span></div>
          <div class="c-m">⏱️ <span class="c-m-mins">{r.mins}</span> mín að vinna fyrir einum{r.minsCph != null ? ` · KBH: ${r.minsCph} mín` : ''}</div>
          <div class="c-p">{groupThousands(Math.round(r.price))} kr stk</div>
        </div>
      ))}
    </div>

    {RACE && (
      <>
        <h2>🏃 Launakapphlaupið</h2>
        <p class="race-sub">Hvað hefur hækkað mest frá {RACE.baseY}? Laun, almennt verðlag og húsnæðisverð — allt sett á 100 í {RACE.baseY}. Heimild: Hagstofa.</p>
        <div id="c-race"></div>
        <div class="race-insight">
          Frá {RACE.baseY} hafa <b style="color:#46e08a">launin</b> {f1(RACE.fW)}-faldast, <b style="color:#f6b13b">húsnæðisverð</b> {f1(RACE.fH)}-faldast og <b style="color:#9fb0c8">almennt verðlag</b> {f1(RACE.fC)}-faldast.
          {RACE.fH > RACE.fW ? ' Húsnæðisverð hefur hækkað meira en launin — íbúð kostar fleiri mánaðarlaun nú en þá.' : ' Launin hafa haldið í við húsnæðisverðið.'}
        </div>
      </>
    )}

    <p class="note">ⓘ Verð frá Numbeo (samfélagslega söfnuð), laun = meðalnettólaun. Fylgni er ekki orsök og bjór er ekki fjárfestingarráðgjöf. 🍺</p>
    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Sama fyrirbæri og gamla mælaborðið — tímakaups-hagfræðin. #2.</p>
  </main>

  <style>
    main { max-width: 820px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: var(--ink); }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 16px; }
    .c { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 13px; padding: 14px 16px; }
    .c-e { font-size: 28px; }
    .c-l { font-weight: 700; font-size: 13.5px; margin: 4px 0 6px; }
    .c-v { font-size: 24px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
    .c-v span { font-size: 11px; color: var(--faint); font-weight: 500; }
    .c-m { font-size: 11.5px; color: var(--muted); margin-top: 5px; }
    .c-p { font-size: 11px; color: var(--faint); margin-top: 2px; }
    .note { font-size: 13px; color: var(--muted); background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 18px 0 0; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 22px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .sal { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.25); border-radius: 12px; padding: 12px 16px; margin: 14px 0 4px; }
    .sal label { font-size: 13px; color: var(--ink); display: block; margin-bottom: 8px; }
    .sal-row { display: flex; flex-wrap: wrap; gap: 8px 16px; align-items: center; }
    .sal-in { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 9px; padding: 6px 12px; }
    .sal-in input { width: 130px; background: none; border: 0; color: var(--ink); font-size: 16px; font-weight: 700; font-variant-numeric: tabular-nums; outline: none; }
    .sal-in span { font-size: 12px; color: var(--faint); }
    .sal-note { font-size: 12.5px; color: #f6b13b; font-weight: 600; }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 4px; }
    .race-sub { font-size: 13px; color: var(--muted); margin: 0 0 6px; }
    #c-race { width: 100%; height: 310px; }
    .race-insight { font-size: 13.5px; color: var(--ink); background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 11px 14px; margin-top: 8px; line-height: 1.55; }
  </style>

  <!-- Eyja: 🏃 Launakapphlaupið (LOTA 13g) -->
  <script define:vars={{ RACE }}>
    function initRace() {
      const el = document.getElementById('c-race');
      if (!el || !RACE) return;
      const go = () => {
        if (window.echarts.getInstanceByDom(el)) return;
        const c = window.echarts.init(el);
        c.setOption({
          backgroundColor: 'transparent',
          legend: { data: ['Laun', 'Húsnæðisverð', 'Verðlag'], top: 0, textStyle: { color: '#cdd6e6', fontSize: 12 }, icon: 'roundRect', itemWidth: 14, itemHeight: 8 },
          grid: { left: 8, right: 16, top: 32, bottom: 6, containLabel: true },
          tooltip: { trigger: 'axis', backgroundColor: 'rgba(9,14,26,.94)', borderColor: 'rgba(255,255,255,.12)', textStyle: { color: '#eaf1fb', fontSize: 12.5 }, valueFormatter: (v) => (v == null ? '–' : String(Math.round(v))) },
          xAxis: { type: 'category', boundaryGap: false, data: RACE.labels, axisTick: { show: false }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } }, axisLabel: { color: '#7e8ca6', fontSize: 11, hideOverlap: true, formatter: (v) => String(v).slice(0, 4) } },
          yAxis: { type: 'value', scale: true, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } }, axisLabel: { color: '#7e8ca6', fontSize: 11 } },
          series: [
            { name: 'Laun', type: 'line', data: RACE.wage, smooth: true, symbol: 'none', lineStyle: { color: '#46e08a', width: 2.4 }, itemStyle: { color: '#46e08a' } },
            { name: 'Húsnæðisverð', type: 'line', data: RACE.house, smooth: true, symbol: 'none', lineStyle: { color: '#f6b13b', width: 2.4 }, itemStyle: { color: '#f6b13b' } },
            { name: 'Verðlag', type: 'line', data: RACE.cpi, smooth: true, symbol: 'none', lineStyle: { color: '#9fb0c8', width: 2, type: 'dashed' }, itemStyle: { color: '#9fb0c8' } },
          ],
        });
        window.addEventListener('resize', () => c.resize());
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="furduhagfraedi"]')) initRace(); });
  </script>

  <!-- Eyja: „launin þín" — endurreiknar spjöldin í vafra (LOTA 12) -->
  <script define:vars={{ WAGE: wage, HPM: FURDU.hpm || 160 }}>
    function initFurdu() {
      const inp = document.getElementById('mysal');
      if (!inp || inp.dataset.done) return;
      inp.dataset.done = '1';
      const gt = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      const note = document.getElementById('sal-note');
      const cards = [...document.querySelectorAll('.c[data-price]')];
      const paint = () => {
        const sal = +inp.value > 0 ? +inp.value : WAGE;
        if (!sal) return;
        const hourly = sal / HPM;
        if (note) note.textContent = +inp.value > 0 ? `Tímakaupið þitt: ${gt(hourly)} kr/klst` : `Meðaltal: ${gt(WAGE / HPM)} kr/klst`;
        cards.forEach((c) => {
          const p = +c.dataset.price;
          if (!p) return;
          const v = c.querySelector('.c-v-num'), m = c.querySelector('.c-m-mins');
          if (v) v.textContent = String(Math.round((hourly / p) * 10) / 10).replace('.', ',');
          if (m) m.textContent = Math.round((p / hourly) * 60);
        });
      };
      inp.addEventListener('input', paint);
      paint();
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="furduhagfraedi"]')) initFurdu(); });
  </script>
</Layout>
