---
// Furðuhagfræði (#2 LOTA 8) — „hvað kaupir klukkustund af vinnu?" Portað úr
// gamla (FURDU: wageIdx+hpm+items → numbeo-verð). Allt reiknað á BYGGINGARTÍMA.
import Layout from '../layouts/Layout.astro';
import FURDU from '../data/furdu.json';
import NUMBEO from '@gogn/numbeo.json';
import { fmtNum, groupThousands } from '@lib/format.mjs';

const rvk = (NUMBEO.prices || {}).Reykjavik || [];
const cph = (NUMBEO.prices || {}).Copenhagen || [];
const itemsMeta = NUMBEO.items || [];
const wage = rvk[FURDU.wageIdx] || null;           // meðalnettólaun á mánuði (kr)
const hourly = wage ? wage / (FURDU.hpm || 160) : null; // tímakaup

const rows = (FURDU.items || []).map((it) => {
  const p = rvk[it.idx], pc = cph[it.idx];
  if (p == null || !hourly) return null;
  return {
    e: it.e, l: it.l || (itemsMeta[it.idx] || {}).is || '',
    price: p,
    perHour: Math.round((hourly / p) * 10) / 10,
    mins: Math.round((p / hourly) * 60),
    minsCph: pc != null && cph[FURDU.wageIdx] ? Math.round((pc / (cph[FURDU.wageIdx] / (FURDU.hpm || 160))) * 60) : null,
  };
}).filter(Boolean).sort((a, b) => a.mins - b.mins);

const updated = '2026-07-02';
const desc = `Furðuhagfræði — hvað kaupir klukkustund af íslenskri vinnu? Tímakaupið (${hourly ? groupThousands(Math.round(hourly)) : '—'} kr) mælt í bjórum, kaffibollum og bíómiðum — og borið saman við Kaupmannahöfn.`;
---

<Layout title="Furðuhagfræði — hvað kaupir tímakaupið? | Karp" description={desc} canonical="https://app.karp.is/furduhagfraedi/" ogTitle="Furðuhagfræði">
  <main data-pg="furduhagfraedi">
    <p class="kicker">Hagvísir Íslands · Efnahagur</p>
    <h1>Furðuhagfræði 🤪</h1>
    <p>Gleymdu vísitölum — mælum kaupmáttinn í <strong>bjórum og kaffibollum</strong>. Meðalnettólaun í Reykjavík eru {wage ? groupThousands(wage) : '—'} kr/mán ≈ <strong>{hourly ? groupThousands(Math.round(hourly)) : '—'} kr á klukkustund</strong>.</p>

    <div class="sal">
      <label for="mysal">💰 Eða settu inn <strong>þín útborguðu laun</strong> og sjáðu hvað tímakaupið þitt kaupir:</label>
      <div class="sal-row">
        <div class="sal-in"><input id="mysal" type="number" min="0" step="10000" placeholder={wage ? String(wage) : '450000'} inputmode="numeric" /><span>kr/mán</span></div>
        <span class="sal-note" id="sal-note"></span>
      </div>
    </div>

    <div class="grid">
      {rows.map((r) => (
        <div class="c" data-price={r.price}>
          <div class="c-e">{r.e}</div>
          <div class="c-l">{r.l}</div>
          <div class="c-v"><span class="c-v-num">{fmtNum(r.perHour, 1)}</span> <span>á klst vinnu</span></div>
          <div class="c-m">⏱️ <span class="c-m-mins">{r.mins}</span> mín að vinna fyrir einum{r.minsCph != null ? ` · KBH: ${r.minsCph} mín` : ''}</div>
          <div class="c-p">{groupThousands(Math.round(r.price))} kr stk</div>
        </div>
      ))}
    </div>

    <p class="note">ⓘ Verð frá Numbeo (samfélagslega söfnuð), laun = meðalnettólaun. Fylgni er ekki orsök og bjór er ekki fjárfestingarráðgjöf. 🍺</p>
    <p class="foot">Forþjónað (SSG) {updated}. Sama fyrirbæri og gamla mælaborðið — tímakaups-hagfræðin. #2.</p>
  </main>

  <style>
    main { max-width: 820px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 16px; }
    .c { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 13px; padding: 14px 16px; }
    .c-e { font-size: 28px; }
    .c-l { font-weight: 700; font-size: 13.5px; margin: 4px 0 6px; }
    .c-v { font-size: 24px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
    .c-v span { font-size: 11px; color: #7e8ca6; font-weight: 500; }
    .c-m { font-size: 11.5px; color: #9fb0c8; margin-top: 5px; }
    .c-p { font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 18px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 22px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .sal { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.25); border-radius: 12px; padding: 12px 16px; margin: 14px 0 4px; }
    .sal label { font-size: 13px; color: #cdd6e6; display: block; margin-bottom: 8px; }
    .sal-row { display: flex; flex-wrap: wrap; gap: 8px 16px; align-items: center; }
    .sal-in { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 9px; padding: 6px 12px; }
    .sal-in input { width: 130px; background: none; border: 0; color: #eaf1fb; font-size: 16px; font-weight: 700; font-variant-numeric: tabular-nums; outline: none; }
    .sal-in span { font-size: 12px; color: #7e8ca6; }
    .sal-note { font-size: 12.5px; color: #f6b13b; font-weight: 600; }
  </style>

  <!-- Eyja: „launin þín" — endurreiknar spjöldin í vafra (LOTA 12) -->
  <script define:vars={{ WAGE: wage, HPM: FURDU.hpm || 160 }}>
    function initFurdu() {
      const inp = document.getElementById('mysal');
      if (!inp || inp.dataset.done) return;
      inp.dataset.done = '1';
      const gt = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      const note = document.getElementById('sal-note');
      const cards = [...document.querySelectorAll('.c[data-price]')];
      const paint = () => {
        const sal = +inp.value > 0 ? +inp.value : WAGE;
        if (!sal) return;
        const hourly = sal / HPM;
        if (note) note.textContent = +inp.value > 0 ? `Tímakaupið þitt: ${gt(hourly)} kr/klst` : `Meðaltal: ${gt(WAGE / HPM)} kr/klst`;
        cards.forEach((c) => {
          const p = +c.dataset.price;
          if (!p) return;
          const v = c.querySelector('.c-v-num'), m = c.querySelector('.c-m-mins');
          if (v) v.textContent = String(Math.round((hourly / p) * 10) / 10).replace('.', ',');
          if (m) m.textContent = Math.round((p / hourly) * 60);
        });
      };
      inp.addEventListener('input', paint);
      paint();
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="furduhagfraedi"]')) initFurdu(); });
  </script>
</Layout>
