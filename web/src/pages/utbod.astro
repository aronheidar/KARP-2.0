    .tw-n { font-size: 13px; color: #eaf1fb; font-weight: 600; }
    .tw-v { font-size: 12.5px; color: #9fb0c8; } .tw-v b { color: #f6b13b; }
    .tw-g { color: #42d086; }
    .op-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 10px; }
    .op-card { display: block; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 12px 14px; text-decoration: none; }
    .op-card:hover { border-color: rgba(246,177,59,.45); }
    .op-card b { display: block; font-size: 13px; color: #eaf1fb; margin-bottom: 4px; line-height: 1.35; }
