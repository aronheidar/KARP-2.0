    .foot a { color: #9fb0c8; }
  </style>
  <style is:global>
    /* runtime-DOM útboðslisti → global */
    .ut-list { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
    @media (max-width: 820px) { .ut-list { grid-template-columns: 1fr; } }
    .ut-it { display: block; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 11px; padding: 11px 13px; text-decoration: none; }
    .ut-it:hover { border-color: rgba(246,177,59,.45); }
    .ut-it.hit { border-left: 3px solid #f6b13b; background: rgba(246,177,59,.05); }
    .ut-it .cat { font-size: 15px; margin-right: 4px; }
    .ut-t { display: block; font-size: 13.5px; color: #eaf1fb; line-height: 1.35; }
    .ut-m { display: block; font-size: 11px; color: #7e8ca6; margin-top: 5px; }
    .ut-m .by { color: #9fb0c8; }
    .ut-badge { display: inline-block; font-size: 10px; font-weight: 700; border-radius: 6px; padding: 1px 7px; margin-right: 6px; vertical-align: 1px; }
    .ut-badge.rk { background: rgba(66,208,134,.14); color: #42d086; }
    .ut-badge.ted { background: rgba(58,160,255,.14); color: #3aa0ff; }
    .ut-badge.fax { background: rgba(124,92,255,.14); color: #9d86ff; }
    .ut-badge.lv { background: rgba(246,177,59,.14); color: #f6b13b; }
    .ut-badge.rvk { background: rgba(224,101,95,.14); color: #e0655f; }
    .ut-new { color: #f6b13b; font-weight: 700; }
    .ut-soon { color: #ff8a3d; font-weight: 700; }
    .ut-past { color: #e0655f; }
    /* 🔔 Mín útboðsvakt — formið er runtime-DOM → verður að vera global (Astro-scope nær ekki innerHTML) */
    .uv { margin: 18px 0 6px; background: linear-gradient(180deg, rgba(246,177,59,.09), rgba(246,177,59,.03)); border: 1px solid rgba(246,177,59,.35); border-radius: 14px; padding: 16px 18px; }
    .uv-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .uv-title { font-size: 16px; font-weight: 800; color: #f6b13b; }
    .uv-desc { font-size: 12.5px; color: #9fb0c8; margin-top: 3px; }
    .uv-pill { font-size: 11px; font-weight: 700; border-radius: 999px; padding: 4px 12px; background: rgba(255,255,255,.06); color: #8fa0ba; border: 1px solid rgba(255,255,255,.14); white-space: nowrap; }
    .uv-pill.on { background: rgba(66,208,134,.14); color: #42d086; border-color: rgba(66,208,134,.4); }
    #uv-body { margin-top: 12px; font-size: 13.5px; color: #cdd6e6; }
    #uv-body a { color: #f6b13b; }
    .uv-sec { background: rgba(10,14,20,.35); border: 1px solid rgba(255,255,255,.07); border-radius: 11px; padding: 11px 13px; margin-bottom: 10px; }
    .uv-lbl { font-size: 11px; font-weight: 700; color: #8fa0ba; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .uv-lbl .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: #6f7b8d; }
    .uv-cats { display: flex; flex-wrap: wrap; gap: 6px; }
    .uv-cat { font-size: 12px; color: #9fb0c8; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 999px; padding: 5px 11px; cursor: pointer; user-select: none; transition: border-color .15s; }
    .uv-cat:hover { border-color: rgba(246,177,59,.4); }
    .uv-cat.on { background: rgba(246,177,59,.16); border-color: rgba(246,177,59,.55); color: #f6b13b; font-weight: 600; }
    #uv-words { width: 100%; box-sizing: border-box; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 12px; color: #eaf1fb; font-size: 13px; }
    #uv-words:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .uv-foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 2px; }
    .uv-toggle { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: #cdd6e6; cursor: pointer; }
    .uv-save { display: inline-block; background: #f6b13b; color: #131a29; border: 0; border-radius: 10px; padding: 10px 24px; font-weight: 800; font-size: 13.5px; cursor: pointer; text-decoration: none; }
    .uv-save:hover { filter: brightness(1.08); }
    .uv-save:disabled { opacity: .6; }
    .uv-msg { font-size: 12.5px; margin-top: 9px; color: #42d086; }
    .uv-gate { display: flex; justify-content: space-between; align-items: center; gap: 14px; flex-wrap: wrap; }
  </style>

  <script>
    import UTBOD_DATA from '@gogn/utbod.json';
    import { loadUser, karpGet, karpPost, loginHref } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    const daysTo = (d) => { if (!d) return null; const t = Date.parse(d + 'T23:59:59'); if (isNaN(t)) return null; return Math.ceil((t - Date.now()) / 86400000); };

    function initUtbod() {
      const list = document.getElementById('ut-list');
      if (!list || list.dataset.done) return;
      list.dataset.done = '1';
      const CATS = UTBOD_DATA.cats || {};
      let ITEMS = (UTBOD_DATA.tenders || []).slice();
      let cat = '', sort = 'new';
      const lvWords = () => { try { return JSON.parse(localStorage.getItem('karp-leitvakt') || '[]').map((w) => String(w).toLowerCase()).filter(Boolean); } catch (e) { return []; } };
      const todayStr = new Date().toISOString().slice(0, 10);

      // Lifandi ferskleiki: /api/utbod (Útboðsvefur) ofan á bakaða safnið — merkja NÝTT
      fetch('/api/utbod').then((r) => (r.ok ? r.json() : null)).then((posts) => {
        if (!Array.isArray(posts)) return;
        const have = new Set(ITEMS.filter((x) => x.src === 'rk').map((x) => x.t.toLowerCase().slice(0, 50)));
        const fresh = posts.map((p) => ({ src: 'rk', buyer: 'Ríkiskaup / Útboðsvefur', t: ((p.title || {}).rendered || '').replace(/&#(\d+);/g, (m, c) => String.fromCharCode(+c)).replace(/&amp;/g, '&'), u: p.link, d: (p.date || '').slice(0, 10), deadline: null, cat: 'annad' }))
          .filter((x) => x.t && !have.has(x.t.toLowerCase().slice(0, 50)));
        if (fresh.length) { ITEMS = fresh.concat(ITEMS); paint(); }
      }).catch(() => {});

      const stat = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
      const refreshStats = () => {
        stat('us-soon', ITEMS.filter((x) => { const dt = daysTo(x.deadline); return dt != null && dt >= 0 && dt <= 14; }).length || '0');
        stat('us-new', ITEMS.filter((x) => (x.d || '') === todayStr).length || '0');
        stat('us-n', ITEMS.length);
      };

      function paint() {
        refreshStats();
        const q = (document.getElementById('ut-q').value || '').toLowerCase().trim();
        const on = {}; document.querySelectorAll('#ut-srcs input').forEach((c) => { on[c.dataset.src] = c.checked; });
        const words = lvWords();
        let rows = ITEMS.filter((x) => on[x.src] !== false && (!cat || x.cat === cat) && (!q || (x.t + ' ' + (x.buyer || '')).toLowerCase().includes(q)));
        if (sort === 'deadline') {
          rows = rows.slice().sort((a, b) => { const da = daysTo(a.deadline), db = daysTo(b.deadline); if (da == null && db == null) return 0; if (da == null) return 1; if (db == null) return -1; return da - db; });
        }
        document.getElementById('ut-count').textContent = rows.length + ' útboð' + (cat ? ` · ${(CATS[cat] || [cat])[0]}` : '') + (q ? ` · leit: „${q}“` : '') + (words.length ? ` · ${words.length} leitarorð þín upplýst` : '');
        list.innerHTML = rows.length ? rows.map((x) => {
          const hit = words.some((w) => (x.t + ' ' + (x.buyer || '')).toLowerCase().includes(w));
          const isNew = (x.d || '') === todayStr;
          const dt = daysTo(x.deadline);
          let dl = '';
          if (x.deadline) {
            if (dt != null && dt < 0) dl = `<span class="ut-past">frestur liðinn (${dIS(x.deadline)})</span>`;
            else if (dt != null && dt <= 14) dl = `<span class="ut-soon">⏳ lokar eftir ${dt} d (${dIS(x.deadline)})</span>`;
            else dl = `frestur ${dIS(x.deadline)}`;
          }
          const cm = CATS[x.cat] || ['', '📦'];
          const parts = [isNew ? '<span class="ut-new">NÝTT Í DAG</span>' : '', dl, x.buyer ? `<span class="by">${esc(x.buyer)}</span>` : '', x.d && !dl ? 'birt ' + dIS(x.d) : ''].filter(Boolean);
          return `<a class="ut-it${hit ? ' hit' : ''}" href="${safe(x.u)}" target="_blank" rel="noopener"><span class="ut-t"><span class="ut-badge ${x.src}">${esc((({rk:'Útboðsvefur',ted:'TED',rvk:'Reykjavík',fax:'Faxafl.',lv:'Landsv.'})[x.src]) || x.src)}</span><span class="cat" title="${esc(cm[0])}">${cm[1]}</span>${esc(x.t)}</span><span class="ut-m">${parts.join(' · ')}</span></a>`;
        }).join('') : '<div style="grid-column:1/-1;color:#7e8ca6">Ekkert útboð passar við leitina — prófaðu annan flokk eða leitarorð.</div>';
      }

      document.getElementById('ut-q').addEventListener('input', paint);
      document.getElementById('ut-sort').addEventListener('change', (e) => { sort = e.target.value; paint(); });
      document.querySelectorAll('#ut-srcs input').forEach((c) => c.addEventListener('change', paint));
      document.querySelectorAll('#ut-cats .uc').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('#ut-cats .uc').forEach((x) => x.classList.toggle('on', x === b));
        cat = b.dataset.c || ''; paint();
      }));
      paint();
    }
    // 🔔 Mín útboðsvakt (LOTA 26): innskráðir velja flokka + leitarorð → daglegur póstur
    function initUtbodVakt() {
      const body = document.getElementById('uv-body');
      if (!body || body.dataset.done) return;
      body.dataset.done = '1';
      const CATS = UTBOD_DATA.cats || {};
      const pill = document.getElementById('uv-status');
      const setPill = (on) => { if (!pill) return; pill.hidden = false; pill.textContent = on ? '● Vakt virk' : 'Óvirk'; pill.classList.toggle('on', !!on); };
      loadUser().then((u) => {
        if (!u || !u.loggedIn) {
          body.innerHTML = '<div class="uv-gate"><span>⭐ Veldu útboðsflokka og leitarorð — Karp sendir þér póst um leið og nýtt útboð fellur að þinni verktöku. Ókeypis hluti af <a href="/karp-pro/">Karp+</a>.</span><a class="uv-save" href="' + esc(loginHref()) + '">Skrá inn</a></div>';
          return;
        }
        karpGet('/utbodvakt').then((v) => {
          v = v || { on: false, cats: [], words: [] };
          setPill(v.on);
          const sel = new Set(v.cats || []);
          const catBtns = Object.keys(CATS).map((k) => `<span class="uv-cat${sel.has(k) ? ' on' : ''}" data-c="${k}">${CATS[k][1]} ${esc(CATS[k][0])}</span>`).join('');
          body.innerHTML =
            `<div class="uv-sec"><div class="uv-lbl">1 · Flokkarnir mínir</div><div class="uv-cats">${catBtns}</div></div>`
            + `<div class="uv-sec"><div class="uv-lbl">2 · Leitarorð <span class="opt">— valfrjálst, þrengir valið (kommu-aðskilin)</span></div><input id="uv-words" type="text" value="${esc((v.words || []).join(', '))}" placeholder="t.d. malbik, raflagnir, gröftur"></div>`
            + `<div class="uv-foot"><label class="uv-toggle"><input type="checkbox" id="uv-on"${v.on ? ' checked' : ''}> 📧 Daglegur tölvupóstur</label><button class="uv-save" id="uv-save">Vista vakt</button></div>`
            + '<div class="uv-msg" id="uv-msg"></div>';
          body.querySelectorAll('.uv-cat').forEach((b) => b.addEventListener('click', () => b.classList.toggle('on')));
          document.getElementById('uv-save').addEventListener('click', () => {
            const cats = [...body.querySelectorAll('.uv-cat.on')].map((b) => b.dataset.c);
            const words = (document.getElementById('uv-words').value || '').split(',').map((w) => w.trim()).filter((w) => w.length >= 2).slice(0, 12);
            const on = document.getElementById('uv-on').checked;
            const btn = document.getElementById('uv-save'); btn.disabled = true; btn.textContent = 'Vista…';
            const msg = document.getElementById('uv-msg');
            if (on && !cats.length && !words.length) { msg.style.color = '#e0655f'; msg.textContent = 'Veldu a.m.k. einn flokk eða eitt leitarorð til að kveikja á vaktinni.'; btn.disabled = false; btn.textContent = 'Vista vakt'; return; }
            karpPost('/utbodvakt', { on, cats, words }).then((r) => {
              setPill(r && r.on);
              msg.style.color = '#42d086';
              msg.textContent = (r && r.on) ? `✓ Vakt virk — þú færð póst um ný útboð í ${cats.length} ${cats.length === 1 ? 'flokki' : 'flokkum'}${words.length ? ' og ' + words.length + ' leitarorð' : ''}.` : '✓ Vistað — vaktin er slökkt.';
              btn.disabled = false; btn.textContent = 'Vista vakt';
            }).catch(() => { msg.style.color = '#e0655f'; msg.textContent = 'Náði ekki að vista — reyndu aftur.'; btn.disabled = false; btn.textContent = 'Vista vakt'; });
          });
        }).catch(() => { body.innerHTML = '<span class="dim">Náði ekki í vaktarstillingar.</span>'; });
      }).catch(() => {});
    }
    // 🏆 Leit í niðurstöðum (SSG-raðir, togglar [hidden] — global !important reglan sér um felun)
    function initUrslitLeit() {
      const q = document.getElementById('aw-q');
      if (!q || q.dataset.done) return;
      q.dataset.done = '1';
      const rows = [...document.querySelectorAll('#aw-list .aw-row')];
      q.addEventListener('input', () => {
        const s = q.value.toLowerCase().trim();
        let n = 0;
        rows.forEach((r) => { const hit = !s || (r.dataset.s || '').includes(s); r.hidden = !hit; if (hit) n++; });
        const cnt = document.querySelector('.aw-n');
        if (cnt) cnt.textContent = s ? n + ' passa' : rows.length + ' niðurstöður';
      });
      // 🥊 Samkeppnisprófíll (LOTA 57): smellur á samningshafa síar úrslitin á hann —
      // öll útboð hans, kaupendur og verðmæti á einum stað. Sama leit og handvirka.
      document.querySelectorAll('.tw-list .tw-row').forEach((r) => {
        const nameEl = r.querySelector('.tw-n');
        if (!nameEl) return;
        r.style.cursor = 'pointer';
        r.title = 'Smelltu til að sjá öll útboð sem ' + nameEl.textContent + ' vann — kaupendur og verðmæti';
        r.addEventListener('click', () => {
          // lengsta orðið úr nafninu: þolir mun á viðskeytum/bilum milli topplista og raða
          const ord = nameEl.textContent.trim().replace(/[.,()]/g, ' ').split(/\s+/).filter((w) => w.length >= 3 && !/^(hf|ehf|ohf|og|amp|co|kg|se)$/i.test(w));
          q.value = (ord.sort((a, b) => b.length - a.length)[0] || nameEl.textContent.trim()).toLowerCase();
          q.dispatchEvent(new Event('input'));
          document.getElementById('aw-list').scrollIntoView({ behavior: 'smooth', block: 'start' });
          q.focus();
        });
      });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="utbod"]')) { initUtbod(); initUtbodVakt(); initUrslitLeit(); } });
  </script>
  <script>
    // 🔒 Karp+ gátt (LOTA 94) — læsir Útboðsvaktina AÐEINS ef greiðsluveggir eru VIRKIR (KARP_USER.paywall; slökkt sjálfgefið).
    import { loadUser, locked, plusGate } from '../lib/auth.js';
    document.addEventListener('astro:page-load', () => {
      const m = document.querySelector('main[data-pg="utbod"]');
      if (!m) return;
      loadUser().then(() => {
        if (!locked() || document.getElementById('plus-gate-box')) return;
        [...m.children].forEach((c) => { c.style.display = 'none'; });
        const g = document.createElement('div'); g.id = 'plus-gate-box'; m.appendChild(g);
        plusGate(g, { title: 'Útboðsvaktin er hluti af Karp+', blurb: 'Fylgstu með opinberum útboðum og innkaupum — nýjustu útboð, úrslit og vaktir eftir leitarorðum á einum stað. Fyrsti mánuðurinn er frír.', price: 'áskrift' });
      });
    });
  </script>
</Layout>
