---
// ─────────────────────────────────────────────────────────────
// 📋 ÚTBOÐSGÁTT KARP (LOTA 25) — allsherjar útboðssíða fyrir verktaka.
// Grunngögn: gogn/utbod.json (build_utbod.js scrape-ar allar gáttir daglega:
// Útboðsvefur+TED+Reykjavík+Faxaflóahafnir+Landsvirkjun, normaliserað & flokkað).
// Ofan á það sækir eyjan lifandi /api/utbod fyrir sama-dags ferskleika. Leit, flokka-
// og veitusíur, röðun eftir fresti, dagsetningasíur (ný í dag / loka innan 14 daga),
// útboð sem passa útboðsvakt notandans raðast EFST (vakt-samsvörun), 🎯 fit-einkunn
// (verktaka-prófíll: vottorð/tæki + vakt-flokkar + frestur), 🔮 forauglýsingar (TED PIN)
// og 📅 ICS-dagatal á fresti.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import UTBOD from '@gogn/utbod.json';
import URSLIT from '@gogn/utbod_urslit.json';
const krM = (v) => (v >= 1e9 ? (Math.round(v / 1e8) / 10).toString().replace('.', ',') + ' ma.kr.' : Math.round(v / 1e6).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' m.kr.');
const dIS2 = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
const AWARDS = (URSLIT.awards || []).slice(0, 80);
const TOPW = Object.values(URSLIT.byWinner || {}).filter((w) => w.isk > 0).sort((a, b) => b.isk - a.isk).slice(0, 12);
const updated = (UTBOD.updated || '').slice(0, 10);
const nSrc = Object.keys(UTBOD.sources || {}).length;
// 🔮 Forauglýsingar & markaðskannanir (TED PIN/RFI) — verk sem eru VÆNTANLEG í útboð
const PINS = (UTBOD.pins || []).slice(0, 25);
// 🥊 Samkeppnisvísar: meðaltal tilboða í opnunum (Landsvirkjun) + virkustu kaupendur safnsins
const AVGBIDS = (() => { const ns = (URSLIT.opnanir || []).map((x) => (x.bids || []).length).filter((n) => n > 0); return ns.length ? Math.round(10 * ns.reduce((a, b) => a + b, 0) / ns.length) / 10 : null; })();
const TOPBUYERS = Object.entries((UTBOD.tenders || []).reduce((a, x) => { if (x.buyer) a[x.buyer] = (a[x.buyer] || 0) + 1; return a; }, {})).sort((a, b) => b[1] - a[1]).slice(0, 3);
const desc = `Útboðsgátt Karp — ${UTBOD.n} opinber útboð frá öllum helstu gáttum á einum stað: Útboðsvefur Ríkiskaupa, TED (EES), Reykjavíkurborg, Faxaflóahafnir og Landsvirkjun. Leit, flokkar, frestir og tölvupósts-vakt fyrir verktaka.`;
// Flokkalisti raðaður eftir fjölda (build skilar cats-heitum + byCat-talningu)
const catList = Object.entries(UTBOD.byCat || {}).sort((a, b) => b[1] - a[1])
  .map(([k, n]) => ({ k, n, label: (UTBOD.cats[k] || [k])[0], e: (UTBOD.cats[k] || ['', '📦'])[1] }));
const SRCMETA = { rk: ['Útboðsvefur', '🇮🇸'], ted: ['TED (EES)', '🇪🇺'], rvk: ['Reykjavíkurborg', '🏙️'], fax: ['Faxaflóahafnir', '⚓'], lv: ['Landsvirkjun', '⚡'] };
---

<Layout title="📋 Útboðsgátt — öll útboð á einum stað | Karp" description={desc} canonical="https://karp.is/utbod/" ogTitle="Útboðsgátt Karp">
  <main data-pg="utbod">
    <p class="kicker">Karp+ · Útboð</p>
    <h1>📋 Útboðsgátt</h1>
    <p>Öll opinber útboð frá öllum helstu gáttum — á einum stað, fyrir verktaka og birgja. Leitaðu, síaðu eftir flokki og láttu <a href="/vaktir/">leitarorðavaktina</a> senda þér póst um leið og nýtt útboð passar við þína verktöku.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Grunngögnin eru sótt daglega kl. 6 af öllum gáttum sem Karp nær í: Útboðsvefur Ríkiskaupa (API), TED — EES-útboð á Íslandi (API), Reykjavíkurborg, Faxaflóahafnir og Landsvirkjun (vef-scrape) — og Útboðsvefurinn er auk þess sóttur lifandi í hverri heimsókn. Flokkun er vélræn: TED eftir CPV-innkaupakóðum, annað eftir lykilorðum í heiti. Fit-einkunnin er reiknuð í vafranum þínum úr vaktinni þinni og verktaka-prófílnum. 📋 Hæfiskröfur EES-útboða eru dregnar út úr tilkynningunum með gervigreind — leiðbeinandi, sannreyndu alltaf í útboðsgögnunum sjálfum.">ⓘ</i> Um gögnin á síðunni</p>

    <div id="uv-panel" class="uv">
      <div class="uv-head">
        <div>
          <div class="uv-title">🔔 Mín útboðsvakt</div>
          <div class="uv-desc">Ný útboð sem passa þína verktöku — beint í tölvupóstinn, á hverjum morgni.</div>
        </div>
        <span id="uv-status" class="uv-pill" hidden>Óvirk</span>
      </div>
      <div id="uv-body"><span class="dim">Hleð…</span></div>
    </div>

    <div class="ut-stats">
      <div class="us-c"><b id="us-n">{UTBOD.n}</b><span>útboð í safni</span></div>
      <div class="us-c"><b>{nSrc}</b><span>lifandi gáttir</span></div>
      <button class="us-c us-f" id="us-soon-c" type="button" title="Sía listann: aðeins útboð sem loka innan 14 daga"><b id="us-soon">—</b><span>loka innan 14 daga</span></button>
      <button class="us-c us-f" id="us-new-c" type="button" title="Sía listann: aðeins útboð birt í dag"><b id="us-new">—</b><span>ný í dag</span></button>
    </div>

    {(AVGBIDS || TOPBUYERS.length > 0) && <p class="ut-comp">🥊 Samkeppnin: {AVGBIDS ? `meðaltal ${String(AVGBIDS).replace('.', ',')} tilboð í opnun` : ''}{AVGBIDS && TOPBUYERS.length ? ' · ' : ''}{TOPBUYERS.length ? 'virkustu kaupendur: ' + TOPBUYERS.map(([b, n]) => `${b} (${n})`).join(' · ') : ''}</p>}

    <div class="ut-bar">
      <input id="ut-q" type="search" placeholder="Leita í útboðum… (t.d. „malbik“, „raflagnir“, „ræsting“)" autocomplete="off" />
      <select id="ut-sort" aria-label="Röðun">
        <option value="new">Nýjast fyrst</option>
        <option value="deadline">Frestur styst í</option>
        <option value="fit">🎯 Fit — passar best</option>
      </select>
    </div>

    <div class="ut-cats" id="ut-cats">
      <button class="uc on" data-c="">Allir flokkar · {UTBOD.n}</button>
      {catList.map((c) => <button class="uc" data-c={c.k}>{c.e} {c.label} · {c.n}</button>)}
    </div>

    <div class="ut-srcs" id="ut-srcs">
      <span class="us-l">Gáttir:</span>
      {Object.keys(SRCMETA).map((s) => (UTBOD.bySrc && UTBOD.bySrc[s] ? <label class="ut-src"><input type="checkbox" data-src={s} checked /> {SRCMETA[s][1]} {SRCMETA[s][0]} ({UTBOD.bySrc[s]})</label> : null))}
    </div>

    <div id="ut-count" class="ut-count"></div>
    <div id="ut-list" class="ut-list">Raða útboðum…</div>

    {PINS.length > 0 && <>
      <h2>🔮 Væntanleg útboð — forauglýsingar & markaðskannanir <i class="tip" tabindex="0" data-tip="Forauglýsingar (PIN) og markaðskannanir (RFI) úr TED — verk sem opinberir kaupendur eru að undirbúa en hafa EKKI enn boðið út. Forskotið: þú sérð verkefnin á undan öðrum og getur svarað markaðskönnun til að hafa áhrif á útboðslýsinguna áður en hún er skrifuð.">ⓘ</i></h2>
      <div class="op-list">
        {PINS.map((p) => (
          <a class="op-card" href={p.u} target="_blank" rel="noopener">
            <b>{p.t.replace(/^Iceland – /, '')}</b>
            <span>{p.d ? dIS2(p.d) + ' · ' : ''}{p.buyer}</span>
          </a>
        ))}
      </div>
    </>}

    <h2>🏆 Hver vann? — niðurstöður útboða <i class="tip" tabindex="0" data-tip="Samningstilkynningar (contract award notices) úr TED, opna útboðasafni ESB — hver vann íslensk útboð og á hvaða samningsverðmæti. Verðmæti eru heildarvirði samnings (rammasamningar geta spannað ár) og birtast aðeins þegar þau eru skráð í íslenskum krónum. Uppfært daglega.">ⓘ</i></h2>
    <div class="aw-bar"><input id="aw-q" type="search" placeholder="Leita í niðurstöðum… (fyrirtæki, kaupandi, verk)" autocomplete="off" /><span class="aw-n">{URSLIT.nAwards} niðurstöður</span></div>
    <div class="aw-list" id="aw-list">
      {AWARDS.map((a) => (
        <a class="aw-row" href={a.u} target="_blank" rel="noopener" data-s={(a.t + ' ' + a.buyer + ' ' + a.winners.join(' ')).toLowerCase()}>
          <span class="aw-t">{a.t.replace(/^Iceland – /, '')}</span>
          <span class="aw-m">{dIS2(a.d)} · {a.buyer} → <b>{a.winners.slice(0, 3).join(', ')}{a.winners.length > 3 ? ` +${a.winners.length - 3}` : ''}</b>{a.cur === 'ISK' && a.value ? ` · ${krM(a.value)}` : ''}</span>
        </a>
      ))}
    </div>

    <h2>Stærstu samningshafar ríkisins <i class="tip" tabindex="0" data-tip="Samanlagt samningsverðmæti (ISK) hvers fyrirtækis úr TED-niðurstöðunum hér að ofan — og til samanburðar RAUNGREIÐSLUR ríkisins til sama fyrirtækis síðustu 12 mánuði úr opnum reikningum ríkisins (opnirreikningar.is). Nöfn eru pöruð nákvæmlega (ehf/hf strípað) — engin ágiskun; vantar greiðslutala þýðir að fyrirtækið er ekki meðal 200 stærstu birgja tímabilsins. Samningar spanna oft lengri tíma en 12 mánuði.">ⓘ</i></h2>
    <div class="tw-list">
      {TOPW.map((w) => (
        <div class="tw-row">
          <span class="tw-n">{w.nafn}</span>
          <span class="tw-v"><b>{krM(w.isk)}</b> · {w.n} {w.n === 1 ? 'útboð' : 'útboð'}{w.greidslur12m != null ? <span class="tw-g"> · greiðslur 12 mán: {krM(w.greidslur12m)}</span> : ''}</span>
        </div>
      ))}
    </div>

    {URSLIT.opnanir && URSLIT.opnanir.length > 0 && <>
      <h2>Tilboð opnuð <i class="tip" tabindex="0" data-tip="Opnunarfundargerðir Landsvirkjunar — hvaða fyrirtæki buðu og á hvaða verði (án VSK, með fyrirvara um villur eins og kaupandi birtir). Lægsta boð er ekki sjálfkrafa það sem verður valið.">ⓘ</i></h2>
      <div class="op-list">
        {URSLIT.opnanir.map((o) => (
          <a class="op-card" href={o.u} target="_blank" rel="noopener">
            <b>{o.t}</b>
            <span>{o.d ? dIS2(o.d) + ' · ' : ''}{o.bids.length} tilboð · lægst: {o.laegst.n} — {krM(o.laegst.isk)}</span>
          </a>
        ))}
      </div>
    </>}

    <h2>🏗️ Á undan útboðunum</h2>
    <p class="ut-bygg"><a href="/byggingarvakt/">Byggingarvaktin</a> sýnir afgreiðslur byggingarfulltrúa Reykjavíkur — samþykkt byggingaráform og útgefin leyfi eftir heimilisföngum. Þar sérðu hvar framkvæmdir einkaaðila eru að fara af stað, áður en nokkuð er boðið út.</p>

    <p class="foot">Forþjónað (SSG). Útboðasafn uppfært daglega {updated}. Grunngögn: utbodsvefur.is (Ríkiskaup), api.ted.europa.eu (útboð + forauglýsingar, CPV-flokkað), reykjavik.is, faxafloahafnir.is, landsvirkjun.is — sótt af build_utbod.js. Ábendingar um fleiri gáttir: <a href="mailto:aron@sgdal.is">aron@sgdal.is</a>. #1 LOTA 25.</p>
  </main>

  <style>
    main { max-width: 1000px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .ut-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 16px 0 4px; }
    @media (max-width: 640px) { .ut-stats { grid-template-columns: 1fr 1fr; } }
    .us-c { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 11px; padding: 11px 13px; text-align: center; }
    .us-c b { display: block; font-size: 24px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
    .us-c span { font-size: 11px; color: #7e8ca6; }
    /* Smellanlegar dagsetningasíur (ný í dag / loka innan 14 daga) */
    button.us-f { font: inherit; cursor: pointer; transition: border-color .15s; }
    button.us-f:hover { border-color: rgba(246,177,59,.45); }
    button.us-f.on { background: rgba(246,177,59,.12); border-color: rgba(246,177,59,.6); }
    button.us-f.on span { color: #f6b13b; font-weight: 700; }
    .ut-bar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 14px; }
    #ut-q { flex: 1; min-width: 220px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 11px; padding: 10px 14px; color: #eaf1fb; font-size: 14px; }
    #ut-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #ut-sort { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 11px; padding: 10px 12px; color: #cdd6e6; font-size: 13px; }
    .ut-cats { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
    .uc { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 4px 11px; font-size: 11.5px; cursor: pointer; }
    .uc.on { background: rgba(246,177,59,.14); border-color: rgba(246,177,59,.5); color: #f6b13b; font-weight: 600; }
    .ut-srcs { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 10px; }
    .us-l { font-size: 11px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .04em; }
    .ut-src { font-size: 12.5px; color: #cdd6e6; display: inline-flex; gap: 5px; align-items: center; cursor: pointer; }
    .ut-count { font-size: 12px; color: #7e8ca6; margin: 12px 0 6px; }
    .ut-comp { font-size: 12px; color: #8fa0ba; margin: 10px 0 0; }
    .ut-bygg { font-size: 13.5px; }
    .ut-bygg a { color: #f6b13b; }
    /* 🏆 Niðurstöður (SSG-efni → scoped í lagi; leitin togglar bara [hidden]) */
    .aw-bar { display: flex; gap: 10px; align-items: center; margin: 4px 0 10px; }
    #aw-q { flex: 1; min-width: 200px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 13px; color: #eaf1fb; font-size: 13px; }
    #aw-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .aw-n { font-size: 12px; color: #7e8ca6; white-space: nowrap; }
    .aw-list { max-height: 430px; overflow-y: auto; border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 4px 10px; }
    .aw-row { display: block; padding: 9px 4px; border-bottom: 1px solid rgba(255,255,255,.06); text-decoration: none; }
    .aw-row:last-child { border-bottom: 0; }
    .aw-row:hover .aw-t { color: #f6b13b; }
    .aw-t { display: block; font-size: 13px; color: #eaf1fb; line-height: 1.35; }
    .aw-m { display: block; font-size: 11.5px; color: #7e8ca6; margin-top: 3px; }
    .aw-m b { color: #42d086; font-weight: 600; }
    .tw-list { border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 4px 12px; }
    .tw-row { display: flex; justify-content: space-between; gap: 12px; padding: 8px 2px; border-bottom: 1px solid rgba(255,255,255,.06); flex-wrap: wrap; }
    .tw-row:last-child { border-bottom: 0; }
    .tw-n { font-size: 13px; color: #eaf1fb; font-weight: 600; }
    .tw-v { font-size: 12.5px; color: #9fb0c8; } .tw-v b { color: #f6b13b; }
    .tw-g { color: #42d086; }
    .op-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 10px; }
    .op-card { display: block; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 12px 14px; text-decoration: none; }
    .op-card:hover { border-color: rgba(246,177,59,.45); }
    .op-card b { display: block; font-size: 13px; color: #eaf1fb; margin-bottom: 4px; line-height: 1.35; }
    .op-card span { font-size: 12px; color: #9fb0c8; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .foot a { color: #9fb0c8; }
  </style>
  <style is:global>
    /* runtime-DOM útboðslisti → global */
    .ut-list { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
    @media (max-width: 820px) { .ut-list { grid-template-columns: 1fr; } }
    .ut-it { display: block; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 11px; padding: 11px 13px; text-decoration: none; }
    .ut-it:hover { border-color: rgba(246,177,59,.45); }
    .ut-it.hit { border-left: 3px solid #f6b13b; background: rgba(246,177,59,.05); }
    .ut-it .cat { font-size: 15px; margin-right: 4px; }
    .ut-t { display: block; font-size: 13.5px; color: #eaf1fb; line-height: 1.35; }
    .ut-m { display: block; font-size: 11px; color: #7e8ca6; margin-top: 5px; }
    .ut-m .by { color: #9fb0c8; }
    .ut-badge { display: inline-block; font-size: 10px; font-weight: 700; border-radius: 6px; padding: 1px 7px; margin-right: 6px; vertical-align: 1px; }
    .ut-badge.rk { background: rgba(66,208,134,.14); color: #42d086; }
    .ut-badge.ted { background: rgba(58,160,255,.14); color: #3aa0ff; }
    .ut-badge.fax { background: rgba(124,92,255,.14); color: #9d86ff; }
    .ut-badge.lv { background: rgba(246,177,59,.14); color: #f6b13b; }
    .ut-badge.rvk { background: rgba(224,101,95,.14); color: #e0655f; }
    .ut-badge.vakt { background: rgba(246,177,59,.22); color: #f6b13b; border: 1px solid rgba(246,177,59,.5); }
    .ut-new { color: #f6b13b; font-weight: 700; }
    .ut-soon { color: #ff8a3d; font-weight: 700; }
    .ut-past { color: #e0655f; }
    /* 🎯 Fit-einkunn + 📅 ICS-dagatal (runtime-DOM) */
    .ut-fit { display: inline-block; font-size: 10.5px; font-weight: 800; border-radius: 6px; padding: 1px 7px; }
    .ut-fit.hi { background: rgba(66,208,134,.16); color: #42d086; }
    .ut-fit.mid { background: rgba(246,177,59,.16); color: #f6b13b; }
    .ut-fit.lo { background: rgba(255,255,255,.07); color: #8fa0ba; }
    .ut-ics { color: #9fb0c8; cursor: pointer; text-decoration: underline dotted; }
    .ut-ics:hover { color: #f6b13b; }
    /* 📋 Hæfiskröfur (GG-þáttun) — tooltip með kröfulistanum; litur eftir prófíl-mátun */
    .ut-haefi { color: #9fb0c8; text-decoration: underline dotted; cursor: help; }
    .ut-haefi.ok { color: #42d086; font-weight: 700; }
    .ut-haefi.mid { color: #f6b13b; font-weight: 700; }
    .ut-haefi.nei { color: #e0655f; font-weight: 700; }
    /* 🎯 Verktaka-prófíll (runtime-DOM í uv-panel) */
    .uv-prof { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 12px; }
    @media (max-width: 640px) { .uv-prof { grid-template-columns: 1fr; } }
    .uv-prof label { display: block; font-size: 11.5px; color: #8fa0ba; font-weight: 600; }
    .uv-prof label.wide { grid-column: 1 / -1; }
    .uv-prof label .opt { font-weight: 400; color: #6f7b8d; }
    .uv-prof input { display: block; width: 100%; box-sizing: border-box; margin-top: 4px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 8px 11px; color: #eaf1fb; font-size: 13px; }
    .uv-prof input:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .vp-note { font-size: 11.5px; color: #6f7b8d; max-width: 420px; }
    /* 🔔 Mín útboðsvakt — formið er runtime-DOM → verður að vera global (Astro-scope nær ekki innerHTML) */
    .uv { margin: 18px 0 6px; background: linear-gradient(180deg, rgba(246,177,59,.09), rgba(246,177,59,.03)); border: 1px solid rgba(246,177,59,.35); border-radius: 14px; padding: 16px 18px; }
    .uv-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .uv-title { font-size: 16px; font-weight: 800; color: #f6b13b; }
    .uv-desc { font-size: 12.5px; color: #9fb0c8; margin-top: 3px; }
    .uv-pill { font-size: 11px; font-weight: 700; border-radius: 999px; padding: 4px 12px; background: rgba(255,255,255,.06); color: #8fa0ba; border: 1px solid rgba(255,255,255,.14); white-space: nowrap; }
    .uv-pill.on { background: rgba(66,208,134,.14); color: #42d086; border-color: rgba(66,208,134,.4); }
    #uv-body { margin-top: 12px; font-size: 13.5px; color: #cdd6e6; }
    #uv-body a { color: #f6b13b; }
    .uv-sec { background: rgba(10,14,20,.35); border: 1px solid rgba(255,255,255,.07); border-radius: 11px; padding: 11px 13px; margin-bottom: 10px; }
    .uv-lbl { font-size: 11px; font-weight: 700; color: #8fa0ba; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .uv-lbl .opt { font-weight: 400; text-transform: none; letter-spacing: 0; color: #6f7b8d; }
    .uv-cats { display: flex; flex-wrap: wrap; gap: 6px; }
    .uv-cat { font-size: 12px; color: #9fb0c8; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 999px; padding: 5px 11px; cursor: pointer; user-select: none; transition: border-color .15s; }
    .uv-cat:hover { border-color: rgba(246,177,59,.4); }
    .uv-cat.on { background: rgba(246,177,59,.16); border-color: rgba(246,177,59,.55); color: #f6b13b; font-weight: 600; }
    #uv-words { width: 100%; box-sizing: border-box; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 12px; color: #eaf1fb; font-size: 13px; }
    #uv-words:focus { outline: none; border-color: rgba(246,177,59,.55); }
    .uv-foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 2px; }
    .uv-toggle { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: #cdd6e6; cursor: pointer; }
    .uv-save { display: inline-block; background: #f6b13b; color: #131a29; border: 0; border-radius: 10px; padding: 10px 24px; font-weight: 800; font-size: 13.5px; cursor: pointer; text-decoration: none; }
    .uv-save:hover { filter: brightness(1.08); }
    .uv-save:disabled { opacity: .6; }
    .uv-msg { font-size: 12.5px; margin-top: 9px; color: #42d086; }
    .uv-gate { display: flex; justify-content: space-between; align-items: center; gap: 14px; flex-wrap: wrap; }
  </style>

  <script>
    import UTBOD_DATA from '@gogn/utbod.json';
    import { loadUser, karpGet, karpPost, loginHref } from '../lib/auth.js';
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const safe = (u) => (/^https?:/i.test(String(u || '')) ? String(u) : '#');
    const dIS = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
    const daysTo = (d) => { if (!d) return null; const t = Date.parse(d + 'T23:59:59'); if (isNaN(t)) return null; return Math.ceil((t - Date.now()) / 86400000); };

    // 🔔 Vakt-samsvörun: útboð sem falla að útboðsvakt notandans (flokkar + leitarorð úr
    // /utbodvakt) raðast EFST í listann. Deilt milli initUtbod (paint) og initUtbodVakt (hleðsla/vistun).
    let VAKT = null;          // { cats:Set, words:[lágstafir] } eða null (útskráð/engin vakt)
    let repaint = () => {};   // paint() úr initUtbod — kallað þegar vaktin hleðst eða vistast
    const setVakt = (cats, words) => {
      cats = cats || []; words = (words || []).map((w) => String(w).toLowerCase()).filter(Boolean);
      VAKT = (cats.length || words.length) ? { cats: new Set(cats), words } : null;
      repaint();
    };
    const vaktMatch = (x) => {
      if (!VAKT) return false;
      if (VAKT.cats.has(x.cat)) return true;
      const s = (x.t + ' ' + (x.buyer || '')).toLowerCase();
      return VAKT.words.some((w) => s.includes(w));
    };

    // 🎯 Fit-einkunn (þrep 2): hve vel passar útboð við verktakann? Reglubundið og gegnsætt —
    // vakt-flokkar (50) + leitarorð (20) + vottorð/tæki úr verktaka-prófílnum (15) + frestur (15).
    // Aðeins þættir sem GÖGN eru til um telja (score = hlutfall af mögulegu). Prófíll: /verkprofil.
    let PROFIL = null;   // { velta, menn, vottord:[], taeki:[] } — sett af initUtbodVakt
    const profTokens = () => PROFIL ? [...(PROFIL.vottord || []), ...(PROFIL.taeki || [])].map((w) => String(w).toLowerCase()).filter((w) => w.length >= 3) : [];
    const showFit = () => !!((VAKT && (VAKT.cats.size || VAKT.words.length)) || profTokens().length);

    // 📋 Hæfiskröfur (þrep 3): gervigreindar-þáttaðar kröfur EES-útboða úr gogn/utbod_haefi.json
    // (build_utbod_haefi.mjs). Mátaðar við verktaka-prófílinn: veltukrafa vs árvelta, vottorð vs vottorð.
    let HAEFI = null;   // { [slóð]: { krofur:[{flokkur,texti}], lagmarksvelta_isk, vottord:[], reynsla_ar, tryggingar } | { engar:true } }
    const haefiCheck = (h) => {   // → { passed, total } — aðeins kröfur sem HÆGT er að máta við prófílinn
      if (!h || !h.krofur || !h.krofur.length || !PROFIL) return null;
      let passed = 0, total = 0;
      if (h.lagmarksvelta_isk > 0 && PROFIL.velta > 0) { total++; if (PROFIL.velta >= h.lagmarksvelta_isk) passed++; }
      for (const v of h.vottord || []) {
        const vl = String(v).toLowerCase(); total++;
        if ((PROFIL.vottord || []).some((p) => { const pl = String(p).toLowerCase(); return pl.includes(vl) || vl.includes(pl); })) passed++;
      }
      return total ? { passed, total } : null;
    };
    const fitInfo = (x, dtFn) => {
      const parts = []; let earned = 0, max = 0;
      const hay = (x.t + ' ' + (x.buyer || '')).toLowerCase();
      if (VAKT && VAKT.cats.size) { max += 50; const ok = VAKT.cats.has(x.cat); if (ok) earned += 50; parts.push('flokkur ' + (ok ? '✓' : '✗')); }
      if (VAKT && VAKT.words.length) { max += 20; const ok = VAKT.words.some((w) => hay.includes(w)); if (ok) earned += 20; parts.push('leitarorð ' + (ok ? '✓' : '✗')); }
      const tok = profTokens();
      if (tok.length) { max += 15; const ok = tok.some((w) => hay.includes(w)); if (ok) earned += 15; parts.push('vottorð/tæki ' + (ok ? '✓' : '✗')); }
      if (x.deadline) {
        const dt = dtFn(x.deadline);
        if (dt != null) { max += 15; const p = dt >= 14 ? 15 : dt >= 7 ? 10 : dt >= 3 ? 5 : 0; earned += p; parts.push('frestur ' + p + '/15'); }
      }
      // Hæfiskröfur mátaðar við prófílinn (þrep 3) — vega þyngst þegar þær eru til
      const hc = HAEFI ? haefiCheck(HAEFI[x.u]) : null;
      if (hc) { max += 25; earned += Math.round(25 * hc.passed / hc.total); parts.push('hæfi ' + hc.passed + '/' + hc.total); }
      if (!max) return null;
      return { score: Math.round(100 * earned / max), tip: parts.join(' · ') };
    };

    function initUtbod() {
      const list = document.getElementById('ut-list');
      if (!list || list.dataset.done) return;
      list.dataset.done = '1';
      const CATS = UTBOD_DATA.cats || {};
      let ITEMS = (UTBOD_DATA.tenders || []).slice();
      let cat = '', sort = 'new', dfilter = '';   // dfilter: '' | 'new' (birt í dag) | 'soon' (loka ≤14 d)
      const lvWords = () => { try { return JSON.parse(localStorage.getItem('karp-leitvakt') || '[]').map((w) => String(w).toLowerCase()).filter(Boolean); } catch (e) { return []; } };
      const todayStr = new Date().toISOString().slice(0, 10);

      // 📋 Hæfiskröfur (þrep 3): valfrjálst gagnasafn — 404 þar til fyrsta Claude-keyrslan hefur bakað það
      fetch('/gogn/utbod_haefi.json').then((r) => (r.ok ? r.json() : null)).then((j) => {
        if (j && j.haefi && Object.keys(j.haefi).length) { HAEFI = j.haefi; paint(); }
      }).catch(() => {});

      // Lifandi ferskleiki: /api/utbod (Útboðsvefur) ofan á bakaða safnið — merkja NÝTT
      fetch('/api/utbod').then((r) => (r.ok ? r.json() : null)).then((posts) => {
        if (!Array.isArray(posts)) return;
        const have = new Set(ITEMS.filter((x) => x.src === 'rk').map((x) => x.t.toLowerCase().slice(0, 50)));
        const fresh = posts.map((p) => ({ src: 'rk', buyer: 'Ríkiskaup / Útboðsvefur', t: ((p.title || {}).rendered || '').replace(/&#(\d+);/g, (m, c) => String.fromCharCode(+c)).replace(/&amp;/g, '&'), u: p.link, d: (p.date || '').slice(0, 10), deadline: null, cat: 'annad' }))
          .filter((x) => x.t && !have.has(x.t.toLowerCase().slice(0, 50)));
        if (fresh.length) { ITEMS = fresh.concat(ITEMS); paint(); }
      }).catch(() => {});

      const stat = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
      const refreshStats = () => {
        stat('us-soon', ITEMS.filter((x) => { const dt = daysTo(x.deadline); return dt != null && dt >= 0 && dt <= 14; }).length || '0');
        stat('us-new', ITEMS.filter((x) => (x.d || '') === todayStr).length || '0');
        stat('us-n', ITEMS.length);
      };

      // Dagsetningasía: 'new' = birt í dag, 'soon' = frestur rennur út innan 14 daga
      const dOK = (x) => {
        if (!dfilter) return true;
        if (dfilter === 'new') return (x.d || '') === todayStr;
        const dt = daysTo(x.deadline); return dt != null && dt >= 0 && dt <= 14;
      };

      function paint() {
        refreshStats();
        const q = (document.getElementById('ut-q').value || '').toLowerCase().trim();
        const on = {}; document.querySelectorAll('#ut-srcs input').forEach((c) => { on[c.dataset.src] = c.checked; });
        const words = lvWords();
        let rows = ITEMS.filter((x) => on[x.src] !== false && (!cat || x.cat === cat) && dOK(x) && (!q || (x.t + ' ' + (x.buyer || '')).toLowerCase().includes(q)));
        if (sort === 'deadline') {
          rows = rows.slice().sort((a, b) => { const da = daysTo(a.deadline), db = daysTo(b.deadline); if (da == null && db == null) return 0; if (da == null) return 1; if (db == null) return -1; return da - db; });
        }
        // 🎯 Fit-einkunnir (þegar vakt/prófíll er til) — fit-röðun raðar eftir þeim
        const fits = showFit() ? new Map(rows.map((x) => [x, fitInfo(x, daysTo)])) : null;
        if (sort === 'fit' && fits) rows = rows.slice().sort((a, b) => (((fits.get(b) || {}).score ?? -1)) - (((fits.get(a) || {}).score ?? -1)));
        // Vakt-samsvörun efst: stöðug röðun (innbyrðis röð helst) — sleppt í fit-röðun (fit nær yfir hana)
        let nVakt = 0;
        if (VAKT && sort !== 'fit') { const top = [], rest = []; rows.forEach((x) => (vaktMatch(x) ? top : rest).push(x)); nVakt = top.length; rows = top.concat(rest); }
        document.getElementById('ut-count').textContent = rows.length + ' útboð'
          + (dfilter === 'new' ? ' · ný í dag' : dfilter === 'soon' ? ' · loka innan 14 daga' : '')
          + (cat ? ` · ${(CATS[cat] || [cat])[0]}` : '') + (q ? ` · leit: „${q}“` : '')
          + (sort === 'fit' && fits ? ' · 🎯 raðað eftir fit-einkunn' : '')
          + (nVakt ? ` · 🔔 ${nVakt} passa vaktina þína (efst)` : '')
          + (words.length ? ` · ${words.length} leitarorð þín upplýst` : '');
        list.innerHTML = rows.length ? rows.map((x) => {
          const vhit = vaktMatch(x);
          const hit = vhit || words.some((w) => (x.t + ' ' + (x.buyer || '')).toLowerCase().includes(w));
          const isNew = (x.d || '') === todayStr;
          const dt = daysTo(x.deadline);
          let dl = '';
          if (x.deadline) {
            if (dt != null && dt < 0) dl = `<span class="ut-past">frestur liðinn (${dIS(x.deadline)})</span>`;
            else if (dt != null && dt <= 14) dl = `<span class="ut-soon">⏳ lokar eftir ${dt} d (${dIS(x.deadline)})</span>`;
            else dl = `frestur ${dIS(x.deadline)}`;
          }
          const fi = fits ? fits.get(x) : null;
          const fitB = fi ? `<span class="ut-fit ${fi.score >= 70 ? 'hi' : fi.score >= 40 ? 'mid' : 'lo'}" title="${esc('Fit ' + fi.score + '% — ' + fi.tip)}">🎯 ${fi.score}%</span>` : '';
          // 📋 Hæfiskröfur: merki með kröfulistanum í tooltip; með prófíl → x/y uppfyllt (mátanlegar kröfur)
          const hx = HAEFI ? HAEFI[x.u] : null;
          const hc = hx ? haefiCheck(hx) : null;
          const haefiB = hx && hx.krofur && hx.krofur.length
            ? `<span class="ut-haefi${hc ? (hc.passed === hc.total ? ' ok' : hc.passed === 0 ? ' nei' : ' mid') : ''}" title="${esc(hx.krofur.map((k) => '• ' + k.texti).join('\n').slice(0, 900) + '\n(GG-þáttun — sannreyndu í útboðsgögnum)')}">📋 ${hc ? `uppfyllir ${hc.passed}/${hc.total}` : hx.krofur.length + ' hæfiskröfur'}</span>` : '';
          const ics = (x.deadline && dt != null && dt >= 0) ? `<span class="ut-ics" role="button" tabindex="0" title="Setja frestinn í dagatalið (.ics)" data-t="${esc(x.t.slice(0, 90))}" data-dl="${esc(x.deadline)}" data-u="${safe(x.u)}">📅 dagatal</span>` : '';
          const cm = CATS[x.cat] || ['', '📦'];
          const parts = [fitB, haefiB, isNew ? '<span class="ut-new">NÝTT Í DAG</span>' : '', dl, ics, x.buyer ? `<span class="by">${esc(x.buyer)}</span>` : '', x.d && !dl ? 'birt ' + dIS(x.d) : ''].filter(Boolean);
          return `<a class="ut-it${hit ? ' hit' : ''}" href="${safe(x.u)}" target="_blank" rel="noopener"><span class="ut-t">${vhit ? '<span class="ut-badge vakt" title="Passar við útboðsvaktina þína">🔔 VAKTIN</span>' : ''}<span class="ut-badge ${x.src}">${esc((({rk:'Útboðsvefur',ted:'TED',rvk:'Reykjavík',fax:'Faxafl.',lv:'Landsv.'})[x.src]) || x.src)}</span><span class="cat" title="${esc(cm[0])}">${cm[1]}</span>${esc(x.t)}</span><span class="ut-m">${parts.join(' · ')}</span></a>`;
        }).join('') : '<div style="grid-column:1/-1;color:#7e8ca6">Ekkert útboð passar við leitina — prófaðu annan flokk, síu eða leitarorð.</div>';
      }

      // 📅 ICS-dagatal: smellt á „dagatal" á færslu → .ics skrá með frest-degi + 2ja daga áminningu.
      // Delegated handler (raðirnar eru endurteiknaðar) — stöðvar kortið sjálft (hlekkinn).
      list.addEventListener('click', (e) => {
        const b = e.target.closest('.ut-ics');
        if (!b) return;
        e.preventDefault(); e.stopPropagation();
        const dl = b.dataset.dl || '', t = b.dataset.t || 'Útboð', u = b.dataset.u || '';
        const ics = ['BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//Karp//utbod//IS', 'BEGIN:VEVENT',
          'UID:utbod-' + dl + '-' + Math.abs([...t].reduce((a, c) => (a * 31 + c.charCodeAt(0)) | 0, 7)) + '@karp.is',
          'DTSTAMP:' + new Date().toISOString().replace(/[-:.]/g, '').slice(0, 15) + 'Z',
          'DTSTART;VALUE=DATE:' + dl.replace(/-/g, ''),
          'SUMMARY:' + ('Frestur útboðs: ' + t).replace(/[\r\n,;]/g, ' '),
          'DESCRIPTION:' + ('Skilafrestur. ' + u).replace(/[\r\n,;]/g, ' '),
          'URL:' + u,
          'BEGIN:VALARM', 'TRIGGER:-P2D', 'ACTION:DISPLAY', 'DESCRIPTION:Útboðsfrestur eftir 2 daga', 'END:VALARM',
          'END:VEVENT', 'END:VCALENDAR'].join('\r\n');
        const a = document.createElement('a');
        a.href = 'data:text/calendar;charset=utf-8,' + encodeURIComponent(ics);
        a.download = 'utbod-frestur-' + dl + '.ics';
        document.body.appendChild(a); a.click(); a.remove();
      });

      document.getElementById('ut-q').addEventListener('input', paint);
      document.getElementById('ut-sort').addEventListener('change', (e) => { sort = e.target.value; paint(); });
      document.querySelectorAll('#ut-srcs input').forEach((c) => c.addEventListener('change', paint));
      document.querySelectorAll('#ut-cats .uc').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('#ut-cats .uc').forEach((x) => x.classList.toggle('on', x === b));
        cat = b.dataset.c || ''; paint();
      }));
      // Stats-flísarnar tvær eru toggle-síur (einkvæmar): smellur kveikir, annar smellur slekkur
      const fBtn = { soon: document.getElementById('us-soon-c'), new: document.getElementById('us-new-c') };
      const setDf = (f) => {
        dfilter = dfilter === f ? '' : f;
        if (fBtn.soon) fBtn.soon.classList.toggle('on', dfilter === 'soon');
        if (fBtn.new) fBtn.new.classList.toggle('on', dfilter === 'new');
        if (dfilter === 'soon' && sort !== 'deadline') { sort = 'deadline'; const s = document.getElementById('ut-sort'); if (s) s.value = 'deadline'; }
        paint();
      };
      if (fBtn.soon) fBtn.soon.addEventListener('click', () => setDf('soon'));
      if (fBtn.new) fBtn.new.addEventListener('click', () => setDf('new'));
      repaint = paint;
      paint();
    }
    // 🔔 Mín útboðsvakt (LOTA 26): innskráðir velja flokka + leitarorð → daglegur póstur
    function initUtbodVakt() {
      const body = document.getElementById('uv-body');
      if (!body || body.dataset.done) return;
      body.dataset.done = '1';
      const CATS = UTBOD_DATA.cats || {};
      const pill = document.getElementById('uv-status');
      const setPill = (on) => { if (!pill) return; pill.hidden = false; pill.textContent = on ? '● Vakt virk' : 'Óvirk'; pill.classList.toggle('on', !!on); };
      loadUser().then((u) => {
        if (!u || !u.loggedIn) {
          body.innerHTML = '<div class="uv-gate"><span>⭐ Veldu útboðsflokka og leitarorð — Karp sendir þér póst um leið og nýtt útboð fellur að þinni verktöku, og útboðin þín raðast efst á síðunni. Hluti af <a href="/karp-pro/">Karp+</a> — eða sér áskrift á 1.900 kr./mán., 30 daga frítt.</span><a class="uv-save" href="' + esc(loginHref()) + '">Skrá inn</a></div>';
          return;
        }
        karpGet('/utbodvakt').then((v) => {
          v = v || { on: false, cats: [], words: [] };
          setPill(v.on);
          setVakt(v.cats, v.words);   // vakt-samsvörun í listanum (efst) — óháð póst-rofanum
          const sel = new Set(v.cats || []);
          const catBtns = Object.keys(CATS).map((k) => `<span class="uv-cat${sel.has(k) ? ' on' : ''}" data-c="${k}">${CATS[k][1]} ${esc(CATS[k][0])}</span>`).join('');
          body.innerHTML =
            `<div class="uv-sec"><div class="uv-lbl">1 · Flokkarnir mínir</div><div class="uv-cats">${catBtns}</div></div>`
            + `<div class="uv-sec"><div class="uv-lbl">2 · Leitarorð <span class="opt">— valfrjálst, þrengir valið (kommu-aðskilin)</span></div><input id="uv-words" type="text" value="${esc((v.words || []).join(', '))}" placeholder="t.d. malbik, raflagnir, gröftur"></div>`
            + `<div class="uv-foot"><label class="uv-toggle"><input type="checkbox" id="uv-on"${v.on ? ' checked' : ''}> 📧 Daglegur tölvupóstur</label><button class="uv-save" id="uv-save">Vista vakt</button></div>`
            + '<div class="uv-msg" id="uv-msg"></div>';
          body.querySelectorAll('.uv-cat').forEach((b) => b.addEventListener('click', () => b.classList.toggle('on')));
          document.getElementById('uv-save').addEventListener('click', () => {
            const cats = [...body.querySelectorAll('.uv-cat.on')].map((b) => b.dataset.c);
            const words = (document.getElementById('uv-words').value || '').split(',').map((w) => w.trim()).filter((w) => w.length >= 2).slice(0, 12);
            const on = document.getElementById('uv-on').checked;
            const btn = document.getElementById('uv-save'); btn.disabled = true; btn.textContent = 'Vista…';
            const msg = document.getElementById('uv-msg');
            if (on && !cats.length && !words.length) { msg.style.color = '#e0655f'; msg.textContent = 'Veldu a.m.k. einn flokk eða eitt leitarorð til að kveikja á vaktinni.'; btn.disabled = false; btn.textContent = 'Vista vakt'; return; }
            karpPost('/utbodvakt', { on, cats, words }).then((r) => {
              setPill(r && r.on);
              setVakt(cats, words);   // listinn endurraðast strax eftir vistun
              msg.style.color = '#42d086';
              msg.textContent = (r && r.on) ? `✓ Vakt virk — þú færð póst um ný útboð í ${cats.length} ${cats.length === 1 ? 'flokki' : 'flokkum'}${words.length ? ' og ' + words.length + ' leitarorð' : ''}.` : '✓ Vistað — vaktin er slökkt.';
              btn.disabled = false; btn.textContent = 'Vista vakt';
            }).catch(() => { msg.style.color = '#e0655f'; msg.textContent = 'Náði ekki að vista — reyndu aftur.'; btn.disabled = false; btn.textContent = 'Vista vakt'; });
          });
          initVerkprofil(body);   // 🎯 þrep 3 í forminu: verktaka-prófíllinn (fit-einkunn)
        }).catch(() => { body.innerHTML = '<span class="dim">Náði ekki í vaktarstillingar.</span>'; });
      }).catch(() => {});
    }
    // 🎯 Verktaka-prófíll (fit): velta, mannafli, vottorð/leyfi, tæki/sérhæfing → /verkprofil (karp-vaktpro.php).
    // Skilar sjálfgildum þegar endapunkturinn er lifandi; null (404) = WPCode-líming ókomin → sleppa hljóðlega.
    function initVerkprofil(body) {
      karpGet('/verkprofil').then((pr) => {
        if (!pr || typeof pr.velta === 'undefined' || document.getElementById('uv-profil')) return;
        PROFIL = { velta: +pr.velta || 0, menn: +pr.menn || 0, vottord: pr.vottord || [], taeki: pr.taeki || [] };
        const sec = document.createElement('div');
        sec.className = 'uv-sec'; sec.id = 'uv-profil';
        sec.innerHTML = '<div class="uv-lbl">3 · Verktaka-prófíllinn minn <span class="opt">— gefur útboðunum 🎯 fit-einkunn (sjá líka röðunina „Fit — passar best")</span></div>'
          + '<div class="uv-prof">'
          + '<label>Árvelta (m.kr.)<input id="vp-velta" type="number" min="0" inputmode="numeric" value="' + (PROFIL.velta ? Math.round(PROFIL.velta / 1e6) : '') + '"></label>'
          + '<label>Starfsmenn<input id="vp-menn" type="number" min="0" inputmode="numeric" value="' + (PROFIL.menn || '') + '"></label>'
          + '<label class="wide">Vottorð & leyfi <span class="opt">(kommu-aðskilin, t.d. ISO 9001, rafverktakaleyfi)</span><input id="vp-vottord" type="text" value="' + esc(PROFIL.vottord.join(', ')) + '" placeholder="t.d. ISO 9001, öryggisstjórnunarkerfi"></label>'
          + '<label class="wide">Tæki & sérhæfing <span class="opt">(t.d. krani, malbik, gröfur — orðin lýsa því sem þú getur boðið í)</span><input id="vp-taeki" type="text" value="' + esc(PROFIL.taeki.join(', ')) + '" placeholder="t.d. gröfur, krani, malbikun"></label>'
          + '</div>'
          + '<div class="uv-foot"><span class="vp-note">Velta og mannafli nýtast þegar hæfiskröfur útboðsgagna verða þáttaðar sjálfkrafa (í vinnslu).</span><button class="uv-save" id="vp-save">Vista prófíl</button></div>'
          + '<div class="uv-msg" id="vp-msg"></div>';
        body.appendChild(sec);
        repaint();   // fit-merkin birtast strax með vistaða prófílnum
        const splitL = (id) => (document.getElementById(id).value || '').split(',').map((w) => w.trim()).filter((w) => w.length >= 2).slice(0, 20);
        document.getElementById('vp-save').addEventListener('click', () => {
          const btn = document.getElementById('vp-save'), msg = document.getElementById('vp-msg');
          btn.disabled = true; btn.textContent = 'Vista…';
          const payload = {
            velta: Math.max(0, Math.round(+document.getElementById('vp-velta').value || 0)) * 1e6,
            menn: Math.max(0, Math.round(+document.getElementById('vp-menn').value || 0)),
            vottord: splitL('vp-vottord'), taeki: splitL('vp-taeki'),
          };
          karpPost('/verkprofil', payload).then((r) => {
            if (!r || !r.ok) throw new Error('save');
            PROFIL = { velta: +r.velta || 0, menn: +r.menn || 0, vottord: r.vottord || [], taeki: r.taeki || [] };
            msg.style.color = '#42d086';
            msg.textContent = '✓ Prófíll vistaður — fit-einkunnir uppfærðar á listanum.';
            btn.disabled = false; btn.textContent = 'Vista prófíl';
            repaint();
          }).catch(() => { msg.style.color = '#e0655f'; msg.textContent = 'Náði ekki að vista prófílinn — reyndu aftur.'; btn.disabled = false; btn.textContent = 'Vista prófíl'; });
        });
      }).catch(() => {});
    }
    // 🏆 Leit í niðurstöðum (SSG-raðir, togglar [hidden] — global !important reglan sér um felun)
    function initUrslitLeit() {
      const q = document.getElementById('aw-q');
      if (!q || q.dataset.done) return;
      q.dataset.done = '1';
      const rows = [...document.querySelectorAll('#aw-list .aw-row')];
      q.addEventListener('input', () => {
        const s = q.value.toLowerCase().trim();
        let n = 0;
        rows.forEach((r) => { const hit = !s || (r.dataset.s || '').includes(s); r.hidden = !hit; if (hit) n++; });
        const cnt = document.querySelector('.aw-n');
        if (cnt) cnt.textContent = s ? n + ' passa' : rows.length + ' niðurstöður';
      });
      // 🥊 Samkeppnisprófíll (LOTA 57): smellur á samningshafa síar úrslitin á hann —
      // öll útboð hans, kaupendur og verðmæti á einum stað. Sama leit og handvirka.
      document.querySelectorAll('.tw-list .tw-row').forEach((r) => {
        const nameEl = r.querySelector('.tw-n');
        if (!nameEl) return;
        r.style.cursor = 'pointer';
        r.title = 'Smelltu til að sjá öll útboð sem ' + nameEl.textContent + ' vann — kaupendur og verðmæti';
        r.addEventListener('click', () => {
          // lengsta orðið úr nafninu: þolir mun á viðskeytum/bilum milli topplista og raða
          const ord = nameEl.textContent.trim().replace(/[.,()]/g, ' ').split(/\s+/).filter((w) => w.length >= 3 && !/^(hf|ehf|ohf|og|amp|co|kg|se)$/i.test(w));
          q.value = (ord.sort((a, b) => b.length - a.length)[0] || nameEl.textContent.trim()).toLowerCase();
          q.dispatchEvent(new Event('input'));
          document.getElementById('aw-list').scrollIntoView({ behavior: 'smooth', block: 'start' });
          q.focus();
        });
      });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="utbod"]')) { initUtbod(); initUtbodVakt(); initUrslitLeit(); } });
  </script>
  <script>
    // 🔒 Aðgangsgátt (LOTA 94 + sér-áskrift) — læsir Útboðsvaktina AÐEINS ef greiðsluveggir eru VIRKIR
    // (KARP_USER.paywall; slökkt sjálfgefið). Aðgangur: Karp+ þrep 1+ EÐA sér-áskriftin 'utbod' (1.900 kr./mán.).
    import { loadUser, hasSub, subGate, isAdmin } from '../lib/auth.js';
    document.addEventListener('astro:page-load', () => {
      const m = document.querySelector('main[data-pg="utbod"]');
      if (!m) return;
      loadUser().then((u) => {
        // Útboðsvaktin er SÉRLAUSN — aðgangur AÐEINS með 'utbod'-áskrift (ekki innifalin í þrepunum).
        // Gátt birtist þegar greiðsluveggur er á og notandinn hvorki með áskriftina né admin.
        if (isAdmin() || hasSub('utbod') || !(u && u.paywall === true) || document.getElementById('plus-gate-box')) return;
        [...m.children].forEach((c) => { c.style.display = 'none'; });
        const g = document.createElement('div'); g.id = 'plus-gate-box'; m.appendChild(g);
        subGate(g, { service: 'utbod', price: 1900, trialDays: 30, title: 'Útboðsvaktin', blurb: 'Öll opinber útboð á einum stað — leit, flokkar, frestir, úrslit og dagleg tölvupósts-vakt sniðin að þinni verktöku.' });
      });
    });
  </script>
  <style is:global>
    /* 👁️ Sýnishorn fyrir útskráða (?syni=1) — kynningarborði + dæmi-útboð (runtime-DOM → is:global) */
    .syni-wrap { margin: 4px 0 18px; }
    .syni-banner { background: linear-gradient(180deg, rgba(246,177,59,.13), rgba(246,177,59,.04)); border: 1px solid rgba(246,177,59,.5); border-radius: 14px; padding: 16px 18px; margin: 0 0 14px; }
    .syni-banner .syni-t { font-size: 15.5px; font-weight: 800; color: #f6b13b; margin-bottom: 6px; line-height: 1.35; }
    .syni-banner p { font-size: 13px; color: #cdd6e6; margin: 0 0 12px; line-height: 1.5; }
    .syni-btns { display: flex; gap: 8px; flex-wrap: wrap; }
    .syni-main { background: #f6b13b; color: #131a29; font-weight: 800; padding: 9px 20px; border-radius: 9px; text-decoration: none; font-size: 13.5px; }
    .syni-main:hover { filter: brightness(1.07); }
    .syni-sec { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.18); color: #eaf1fb; padding: 9px 18px; border-radius: 9px; text-decoration: none; font-size: 13.5px; }
    .syni-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09); border-radius: 13px; padding: 15px 16px; margin: 0 0 14px; }
    .syni-lbl { font-size: 11px; font-weight: 700; color: #8fa0ba; text-transform: uppercase; letter-spacing: .05em; margin: 0 0 10px; }
  </style>
  <script>
    // 👁️ Sýnishorn — útskráðir gestir sjá dæmi um útboð + útboðsvakt áður en þeir skrá sig / gerast áskrifendur.
    // ?syni=1 → fullt sýnishorn (opið öllum, tilbúin gögn, engin PII). Annars: kynningarspjald efst fyrir útskráða.
    // Sama mynstur og fasteignavakt (renderDemoValuation) og fyrirtaeki (demoFyrirtaeki).
    import { loadUser, loginHref } from '../lib/auth.js';
    function utbodSampleHtml(full) {
      // Tilbúin (EKKI raunveruleg) útboð — kaupendur eru opinberir aðilar, engin persónugögn.
      const items = [
        { badge: 'rk', bl: 'Útboðsvefur', emoji: '🚧', t: 'Malbikun stofnbrauta og gatnagerð 2026', by: 'Kópavogsbær', vakt: true, fit: 92, dl: '⏳ lokar eftir 9 d (21.7.2026)', dlc: 'ut-soon' },
        { badge: 'rvk', bl: 'Reykjavík', emoji: '⚡', t: 'Endurnýjun raflagna í grunnskóla', by: 'Reykjavíkurborg', fit: 78, haefi: 5, dl: 'frestur 22.7.2026' },
        { badge: 'rk', bl: 'Útboðsvefur', emoji: '❄️', t: 'Snjómokstur og hálkuvörn — rammasamningur', by: 'Vegagerðin', vakt: true, fit: 85, isNew: true },
        { badge: 'ted', bl: 'TED', emoji: '🧹', t: 'Ræstingar á heilbrigðisstofnun', by: 'Ríkiskaup', fit: 64, dl: 'frestur 30.7.2026' },
        { badge: 'rk', bl: 'Útboðsvefur', emoji: '🏗️', t: 'Byggingarstjórn — viðbygging leikskóla', by: 'Akureyrarbær', fit: 71, haefi: 3, dl: '⏳ lokar eftir 12 d (24.7.2026)', dlc: 'ut-soon' },
      ];
      const row = (x) => {
        const fc = x.fit >= 70 ? 'hi' : x.fit >= 40 ? 'mid' : 'lo';
        const parts = [`<span class="ut-fit ${fc}">🎯 ${x.fit}%</span>`, x.haefi ? `<span class="ut-haefi">📋 ${x.haefi} hæfiskröfur</span>` : '', x.isNew ? '<span class="ut-new">NÝTT Í DAG</span>' : '', x.dl ? `<span class="${x.dlc || ''}">${x.dl}</span>` : '', `<span class="by">${x.by}</span>`].filter(Boolean);
        return `<div class="ut-it${x.vakt ? ' hit' : ''}" style="cursor:default"><span class="ut-t">${x.vakt ? '<span class="ut-badge vakt">🔔 VAKTIN</span>' : ''}<span class="ut-badge ${x.badge}">${x.bl}</span><span class="cat">${x.emoji}</span>${x.t}</span><span class="ut-m">${parts.join(' · ')}</span></div>`;
      };
      const rows = items.slice(0, full ? 5 : 3).map(row).join('');
      const chips = ['🚧 Framkvæmdir', '⚡ Raflagnir', '❄️ Vetrarþjónusta'].map((c) => `<span class="uv-cat on">${c}</span>`).join('');
      const cta = `<div class="syni-btns"><a class="syni-main" href="${loginHref()}">Skráðu þig inn</a><a class="syni-sec" href="/karp-pro/">Áskrift — 1.900 kr./mán. →</a></div>`;
      return `<div class="syni-banner"><div class="syni-t">⭐ Þetta er sýnishorn — svona raðast útboðin sem passa þína verktöku efst</div>`
        + `<p>Tilbúin dæmigögn. Með Útboðsvaktinni færðu 🎯 fit-einkunn, 📋 hæfiskröfur og 🔔 vakt-röðun — og daglegan tölvupóst um leið og nýtt útboð fellur að þinni verktöku. <b>Skráðu þig inn eða gerstu áskrifandi til að sjá allt.</b></p>${cta}</div>`
        + `<div class="ut-list" style="grid-template-columns:1fr">${rows}</div>`
        + `<div class="syni-card" style="margin-top:14px"><div class="syni-lbl">🔔 Mín útboðsvakt (sýnishorn)</div><div class="uv-cats" style="margin-bottom:10px">${chips}</div><div style="font-size:12.5px;color:#8fa0ba">📧 Daglegur tölvupóstur um ný útboð sem passa — <b style="color:#42d086">virkur</b> í sýnishorni. Skráðu þig inn til að stilla þína eigin vakt og verktaka-prófíl.</div></div>`
        + (full
          ? `<div class="syni-banner" style="margin-top:14px"><div class="syni-t">Tilbúinn að fá þín útboð efst?</div><p>Þetta sýnishorn notar tilbúin gögn. Skráðu þig inn eða gerstu áskrifandi til að fá alvöru útboð, fit-einkunnir og daglega vakt.</p>${cta}</div>`
          : `<p style="font-size:12.5px;color:#8fa0ba;margin:10px 0 0"><a href="/utbod/?syni=1" style="color:#f6b13b">👁️ Sjá fullt sýnishorn →</a> · öll opnu útboðin eru aðgengileg hér að neðan.</p>`);
    }
    document.addEventListener('astro:page-load', () => {
      const m = document.querySelector('main[data-pg="utbod"]');
      if (!m) return;
      const sp = new URLSearchParams(location.search);
      if (sp.get('syni') === '1' || sp.get('demo') === 'utbod') {
        if (m.querySelector('#syni-full')) return;
        [...m.children].forEach((c) => { c.style.display = 'none'; });
        const host = document.createElement('div'); host.id = 'syni-full'; host.className = 'syni-wrap';
        host.innerHTML = utbodSampleHtml(true);
        m.insertBefore(host, m.firstChild);
        return;
      }
      loadUser().then((u) => {
        if (u && u.loggedIn) return;               // aðeins útskráðir gestir sjá kynningarspjaldið
        if (m.querySelector('#syni-inline')) return;
        const host = document.createElement('div'); host.id = 'syni-inline'; host.className = 'syni-wrap';
        host.innerHTML = utbodSampleHtml(false);
        const anchor = m.querySelector('#uv-panel');
        m.insertBefore(host, anchor || m.firstChild);
      });
    });
  </script>
</Layout>
