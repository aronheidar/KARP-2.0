---
// ─────────────────────────────────────────────────────────────
// 📋 ÚTBOÐSGÁTT KARP (LOTA 25) — allsherjar útboðssíða fyrir verktaka.
// Grunngögn: gogn/utbod.json (build_utbod.js scrape-ar allar gáttir daglega:
// Útboðsvefur+TED+Faxaflóahafnir+Landsvirkjun, normaliserað & flokkað). Ofan á
// það sækir eyjan lifandi /api/utbod fyrir sama-dags ferskleika. Leit, flokka-
// og veitusíur, röðun eftir fresti, „lokar brátt"/„nýtt", leitarorða-highlight.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import UTBOD from '@gogn/utbod.json';
import URSLIT from '@gogn/utbod_urslit.json';
const krM = (v) => (v >= 1e9 ? (Math.round(v / 1e8) / 10).toString().replace('.', ',') + ' ma.kr.' : Math.round(v / 1e6).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ' m.kr.');
const dIS2 = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
const AWARDS = (URSLIT.awards || []).slice(0, 80);
const TOPW = Object.values(URSLIT.byWinner || {}).filter((w) => w.isk > 0).sort((a, b) => b.isk - a.isk).slice(0, 12);
const updated = (UTBOD.updated || '').slice(0, 10);
const nSrc = Object.keys(UTBOD.sources || {}).length;
const desc = `Útboðsgátt Karp — ${UTBOD.n} opinber útboð frá öllum helstu gáttum á einum stað: Útboðsvefur Ríkiskaupa, TED (EES), Faxaflóahafnir og Landsvirkjun. Leit, flokkar, frestir og tölvupósts-vakt fyrir verktaka.`;
// Flokkalisti raðaður eftir fjölda (build skilar cats-heitum + byCat-talningu)
const catList = Object.entries(UTBOD.byCat || {}).sort((a, b) => b[1] - a[1])
  .map(([k, n]) => ({ k, n, label: (UTBOD.cats[k] || [k])[0], e: (UTBOD.cats[k] || ['', '📦'])[1] }));
const SRCMETA = { rk: ['Útboðsvefur', '🇮🇸'], ted: ['TED (EES)', '🇪🇺'], rvk: ['Reykjavíkurborg', '🏙️'], fax: ['Faxaflóahafnir', '⚓'], lv: ['Landsvirkjun', '⚡'] };
---

<Layout title="📋 Útboðsgátt — öll útboð á einum stað | Karp" description={desc} canonical="https://karp.is/utbod/" ogTitle="Útboðsgátt Karp">
  <main data-pg="utbod">
    <p class="kicker">Karp+ · Útboð</p>
    <h1>📋 Útboðsgátt</h1>
    <p>Öll opinber útboð frá öllum helstu gáttum — á einum stað, fyrir verktaka og birgja. Leitaðu, síaðu eftir flokki og láttu <a href="/vaktir/">leitarorðavaktina</a> senda þér póst um leið og nýtt útboð passar við þína verktöku.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Grunngögnin eru sótt daglega af öllum gáttum sem Karp nær í: Útboðsvefur Ríkiskaupa (API), TED — EES-útboð á Íslandi (API), Faxaflóahafnir og Landsvirkjun (vef-scrape). Flokkun er vélræn eftir lykilorðum í heiti. Reykjavík (In-Tend) er bot-varið → beinn hlekkur neðst. Leit og síur vinna í vafranum þínum.">ⓘ</i> Um gögnin á síðunni</p>

    <div id="uv-panel" class="uv">
      <div class="uv-head">
        <div>
          <div class="uv-title">🔔 Mín útboðsvakt</div>
          <div class="uv-desc">Ný útboð sem passa þína verktöku — beint í tölvupóstinn, á hverjum morgni.</div>
        </div>
        <span id="uv-status" class="uv-pill" hidden>Óvirk</span>
      </div>
      <div id="uv-body"><span class="dim">Hleð…</span></div>
    </div>

    <div class="ut-stats">
      <div class="us-c"><b id="us-n">{UTBOD.n}</b><span>útboð í safni</span></div>
      <div class="us-c"><b>{nSrc}</b><span>lifandi gáttir</span></div>
      <div class="us-c"><b id="us-soon">—</b><span>loka innan 14 daga</span></div>
      <div class="us-c"><b id="us-new">—</b><span>ný í dag</span></div>
    </div>

    <div class="ut-bar">
      <input id="ut-q" type="search" placeholder="Leita í útboðum… (t.d. „malbik“, „raflagnir“, „ræsting“)" autocomplete="off" />
      <select id="ut-sort" aria-label="Röðun">
        <option value="new">Nýjast fyrst</option>
        <option value="deadline">Frestur styst í</option>
      </select>
    </div>

    <div class="ut-cats" id="ut-cats">
      <button class="uc on" data-c="">Allir flokkar · {UTBOD.n}</button>
      {catList.map((c) => <button class="uc" data-c={c.k}>{c.e} {c.label} · {c.n}</button>)}
    </div>

    <div class="ut-srcs" id="ut-srcs">
      <span class="us-l">Gáttir:</span>
      {Object.keys(SRCMETA).map((s) => (UTBOD.bySrc && UTBOD.bySrc[s] ? <label class="ut-src"><input type="checkbox" data-src={s} checked /> {SRCMETA[s][1]} {SRCMETA[s][0]} ({UTBOD.bySrc[s]})</label> : null))}
    </div>

    <div id="ut-count" class="ut-count"></div>
    <div id="ut-list" class="ut-list">Raða útboðum…</div>

    <h2>🏆 Hver vann? — niðurstöður útboða <i class="tip" tabindex="0" data-tip="Samningstilkynningar (contract award notices) úr TED, opna útboðasafni ESB — hver vann íslensk útboð og á hvaða samningsverðmæti. Verðmæti eru heildarvirði samnings (rammasamningar geta spannað ár) og birtast aðeins þegar þau eru skráð í íslenskum krónum. Uppfært daglega.">ⓘ</i></h2>
    <div class="aw-bar"><input id="aw-q" type="search" placeholder="Leita í niðurstöðum… (fyrirtæki, kaupandi, verk)" autocomplete="off" /><span class="aw-n">{URSLIT.nAwards} niðurstöður</span></div>
    <div class="aw-list" id="aw-list">
      {AWARDS.map((a) => (
        <a class="aw-row" href={a.u} target="_blank" rel="noopener" data-s={(a.t + ' ' + a.buyer + ' ' + a.winners.join(' ')).toLowerCase()}>
          <span class="aw-t">{a.t.replace(/^Iceland – /, '')}</span>
          <span class="aw-m">{dIS2(a.d)} · {a.buyer} → <b>{a.winners.slice(0, 3).join(', ')}{a.winners.length > 3 ? ` +${a.winners.length - 3}` : ''}</b>{a.cur === 'ISK' && a.value ? ` · ${krM(a.value)}` : ''}</span>
        </a>
      ))}
    </div>

    <h2>Stærstu samningshafar ríkisins <i class="tip" tabindex="0" data-tip="Samanlagt samningsverðmæti (ISK) hvers fyrirtækis úr TED-niðurstöðunum hér að ofan — og til samanburðar RAUNGREIÐSLUR ríkisins til sama fyrirtækis síðustu 12 mánuði úr opnum reikningum ríkisins (opnirreikningar.is). Nöfn eru pöruð nákvæmlega (ehf/hf strípað) — engin ágiskun; vantar greiðslutala þýðir að fyrirtækið er ekki meðal 200 stærstu birgja tímabilsins. Samningar spanna oft lengri tíma en 12 mánuði.">ⓘ</i></h2>
    <div class="tw-list">
      {TOPW.map((w) => (
        <div class="tw-row">
          <span class="tw-n">{w.nafn}</span>
          <span class="tw-v"><b>{krM(w.isk)}</b> · {w.n} {w.n === 1 ? 'útboð' : 'útboð'}{w.greidslur12m != null ? <span class="tw-g"> · greiðslur 12 mán: {krM(w.greidslur12m)}</span> : ''}</span>
        </div>
      ))}
    </div>

    {URSLIT.opnanir && URSLIT.opnanir.length > 0 && <>
      <h2>Tilboð opnuð <i class="tip" tabindex="0" data-tip="Opnunarfundargerðir Landsvirkjunar — hvaða fyrirtæki buðu og á hvaða verði (án VSK, með fyrirvara um villur eins og kaupandi birtir). Lægsta boð er ekki sjálfkrafa það sem verður valið.">ⓘ</i></h2>
      <div class="op-list">
        {URSLIT.opnanir.map((o) => (
          <a class="op-card" href={o.u} target="_blank" rel="noopener">
            <b>{o.t}</b>
            <span>{o.d ? dIS2(o.d) + ' · ' : ''}{o.bids.length} tilboð · lægst: {o.laegst.n} — {krM(o.laegst.isk)}</span>
          </a>
        ))}
      </div>
    </>}

    <h2>Aðrar útboðsgáttir <i class="tip" tabindex="0" data-tip="Þessar gáttir reka eigin kerfi sem Karp nær ekki að sækja sjálfvirkt (bot-varnir eða lokuð kerfi) — en mörg þeirra auglýsa líka á Útboðsvefnum sem er hér að ofan. Beinir hlekkir svo þú missir ekki af neinu.">ⓘ</i></h2>
    <div class="ut-more">
      <a class="um-card" href="https://utbod.reykjavik.is/aspx/Tenders/Current" target="_blank" rel="noopener"><b>🏙️ Reykjavík — útboðskerfið</b><span>Auglýst útboð borgarinnar eru komin í safnið hér að ofan. Þessi hlekkur opnar sjálft útboðskerfið (In-Tend) þar sem gögn eru sótt og tilboð gerð.</span></a>
      <a class="um-card" href="https://www.vegagerdin.is/verkefnin/" target="_blank" rel="noopener"><b>🛣️ Vegagerðin</b><span>Vega-, brúa- og jarðvinnuframkvæmdir — oftast líka auglýstar á Útboðsvefnum hér að ofan.</span></a>
      <a class="um-card" href="https://www.or.is/um-or/utbod/" target="_blank" rel="noopener"><b>💧 Orkuveitan (OR)</b><span>Veitu-, orku- og fráveituframkvæmdir OR-samstæðunnar (Veitur, ON, Ljósleiðarinn).</span></a>
      <a class="um-card" href="https://www.kopavogur.is/" target="_blank" rel="noopener"><b>🏘️ Kópavogsbær</b><span>Útboð næststærsta sveitarfélags landsins.</span></a>
      <a class="um-card" href="https://www.hafnarfjordur.is/stjornsysla/stjornkerfi/utbod/" target="_blank" rel="noopener"><b>🏘️ Hafnarfjörður</b><span>Útboð Hafnarfjarðarkaupstaðar.</span></a>
      <a class="um-card" href="https://ted.europa.eu/en/search/result?place-of-performance=ISL" target="_blank" rel="noopener"><b>🇪🇺 TED — öll skjöl</b><span>Fullt viðmót ESB-safnsins: forauglýsingar, niðurstöður og samningar, ekki bara virk útboð.</span></a>
    </div>

    <p class="foot">Forþjónað (SSG). Útboðasafn uppfært daglega {updated}. Grunngögn: utbodsvefur.is (Ríkiskaup), api.ted.europa.eu, faxafloahafnir.is, landsvirkjun.is — sótt af build_utbod.js. Ábendingar um fleiri gáttir: <a href="mailto:aron@sgdal.is">aron@sgdal.is</a>. #1 LOTA 25.</p>
  </main>

  <style>
