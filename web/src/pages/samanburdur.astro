---
// ─────────────────────────────────────────────────────────────
// ÍSLAND Í SAMANBURÐI (LOTA 13) — IMF WEO (hagvöxtur + verðbólga, spár til
// 2031) og Our World in Data (orka + CO₂ á mann, Ísland sem útlagi).
// Allt sótt á BYGGINGARTÍMA (þolir bilun). Í app-skelinni. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum } from '@lib/format.mjs';

const PEERS = { ISL: 'Ísland', NOR: 'Noregur', DNK: 'Danmörk', SWE: 'Svíþjóð', FIN: 'Finnland' };
const PCOL = { ISL: '#f6b13b', NOR: '#3a8dff', DNK: '#ff6d7a', SWE: '#19d3c5', FIN: '#7c5cf7' };

// IMF DataMapper: skilar öllum löndum — síum okkar. Ár 2000 → spá.
async function imf(ind) {
  try {
    const j = await (await fetch(`https://www.imf.org/external/datamapper/api/v1/${ind}`)).json();
    const all = (j.values || {})[ind] || {};
    const out = {};
    Object.keys(PEERS).forEach((c) => { if (all[c]) out[c] = all[c]; });
    return Object.keys(out).length ? out : null;
  } catch (e) { return null; }
}
const GROWTH = await imf('NGDP_RPCH');   // raunhagvöxtur %
const INFL = await imf('PCPIPCH');       // verðbólga %
const imfYears = GROWTH ? Object.keys(GROWTH.ISL || {}).map(Number).filter((y) => y >= 2005 && y <= 2031).sort((a, b) => a - b) : [];
const FORECAST_FROM = 2026;

// OWID grapher-CSV: öll lönd → sía + heimsröðun Íslands.
async function owid(slug, col) {
  try {
    const t = await (await fetch(`https://ourworldindata.org/grapher/${slug}.csv`)).text();
    const lines = t.split('\n');
    const head = lines[0].split(',');
    const ci = head.findIndex((h) => h.toLowerCase().includes(col));
    if (ci < 0) return null;
    const byCode = {};
    for (const ln of lines.slice(1)) {
      const p = ln.split(',');
      const code = p[1], yr = +p[2], v = parseFloat(p[ci]);
      if (!code || code.length !== 3 || isNaN(v)) continue; // aðeins lönd (ekki svæði)
      if (!byCode[code] || byCode[code].yr < yr) byCode[code] = { yr, v };
    }
    return byCode;
  } catch (e) { return null; }
}
const ENERGY = await owid('per-capita-energy-use', 'energy');
const CO2 = await owid('co-emissions-per-capita', 'emissions');
const rankOf = (byCode) => {
  if (!byCode || !byCode.ISL) return null;
  const vals = Object.entries(byCode).sort((a, b) => b[1].v - a[1].v);
  return { rank: vals.findIndex(([c]) => c === 'ISL') + 1, total: vals.length, v: byCode.ISL.v, yr: byCode.ISL.yr };
};
const eRank = rankOf(ENERGY);
const cRank = rankOf(CO2);
const barData = (byCode) => (byCode ? Object.keys(PEERS).filter((c) => byCode[c]).map((c) => ({ c, n: PEERS[c], v: Math.round(byCode[c].v) })) : []);
const E_BARS = barData(ENERGY);
const C_BARS = ENERGY ? Object.keys(PEERS).filter((c) => CO2 && CO2[c]).map((c) => ({ c, n: PEERS[c], v: Math.round((CO2[c].v) * 10) / 10 })) : [];

const updated = '2026-07-02';
const desc = `Ísland í alþjóðlegum samanburði — hagvöxtur og verðbólga (IMF-spár til 2031) og orku- og kolefnisnotkun á mann${eRank ? ` þar sem Ísland er nr. ${eRank.rank} af ${eRank.total} í orkunotkun á mann` : ''}. Samanburður við Norðurlöndin.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Ísland í alþjóðlegum samanburði', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland' };
---

<Layout title="Ísland í samanburði — Norðurlöndin & heimurinn | Karp" description={desc} canonical="https://app.karp.is/samanburdur/" jsonLd={jsonLd} ogTitle="Ísland í samanburði">
  <main data-pg="samanburdur">
    <p class="kicker">Hagvísir Íslands · Efnahagur</p>
    <h1>Ísland í samanburði 🌍</h1>
    <p>Hvar sker Ísland sig úr? Hagvöxtur og verðbólga borin saman við Norðurlöndin (með <strong>IMF-spám til 2031</strong>) — og orkunotkun þar sem Ísland er heimsmethafi.</p>

    <div class="kpis">
      {eRank && <div class="kpi"><div class="k-l">⚡ Orkunotkun á mann</div><div class="k-v">{eRank.rank}. sæti</div><div class="k-s">af {eRank.total} löndum heims ({eRank.yr})</div></div>}
      {cRank && <div class="kpi"><div class="k-l">🏭 CO₂ á mann</div><div class="k-v">{cRank.rank}. sæti</div><div class="k-s">af {cRank.total} löndum ({cRank.yr})</div></div>}
      {GROWTH && GROWTH.ISL && GROWTH.ISL[FORECAST_FROM] != null && <div class="kpi"><div class="k-l">📈 IMF-spá {FORECAST_FROM}</div><div class="k-v">{fmtNum(GROWTH.ISL[FORECAST_FROM], 1)}%</div><div class="k-s">hagvöxtur Íslands</div></div>}
    </div>

    {GROWTH && (
      <div class="ppair">
        <div><h2>Hagvöxtur — Ísland vs. Norðurlöndin</h2><div id="ch-growth" class="cmp-chart"></div></div>
        <div><h2>Verðbólga — Ísland sker sig úr</h2><div id="ch-infl" class="cmp-chart"></div></div>
      </div>
    )}
    <p class="src">Heilar línur = raun, brotalínur frá {FORECAST_FROM} = spá Alþjóðagjaldeyrissjóðsins (WEO).</p>

    {E_BARS.length > 1 && (
      <div class="ppair">
        <div><h2>Orkunotkun á mann (kWh/ári)</h2><div id="ch-energy" class="cmp-chart"></div></div>
        <div><h2>CO₂-losun á mann (tonn/ári)</h2><div id="ch-co2" class="cmp-chart"></div></div>
      </div>
    )}
    <p class="note">ⓘ Orkumetið skýrist af stóriðju og jarðvarma — raforkan er nær öll endurnýjanleg, en heildarnotkunin (öll orka, líka eldsneyti) á mann er sú mesta í heimi. CO₂-talan telur losun innanlands (án landnotkunar og alþjóðaflugs).</p>
    <p class="foot">Forþjónað (SSG) {updated}. Heimildir: IMF World Economic Outlook (DataMapper API) · Our World in Data (Energy Institute/GCB). #2 LOTA 13.</p>
  </main>

  <style>
    main { max-width: 900px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }
    .cmp-chart { width: 100%; height: 290px; }
    .src { font-size: 12px; color: #7e8ca6; margin: 4px 0 0; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <script define:vars={{ GROWTH, INFL, imfYears, FORECAST_FROM, PEERS, PCOL, E_BARS, C_BARS }}>
    function initCmp() {
      const first = document.getElementById('ch-growth') || document.getElementById('ch-energy');
      if (!first) return;
      const go = () => {
        const mkLines = (id, data) => {
          const el = document.getElementById(id);
          if (!el || !data || window.echarts.getInstanceByDom(el)) return;
          const c = window.echarts.init(el);
          const series = Object.keys(PEERS).filter((k) => data[k]).flatMap((k) => {
            const real = imfYears.map((y) => (y < FORECAST_FROM ? (data[k][y] ?? null) : null));
            const fc = imfYears.map((y) => (y >= FORECAST_FROM - 1 ? (data[k][y] ?? null) : null));
            const base = { name: PEERS[k], type: 'line', smooth: true, symbol: 'none', itemStyle: { color: PCOL[k] } };
            return [
              { ...base, data: real, lineStyle: { width: k === 'ISL' ? 3.2 : 1.6, color: PCOL[k] } },
              { ...base, data: fc, lineStyle: { width: k === 'ISL' ? 3.2 : 1.6, color: PCOL[k], type: 'dashed' }, legendHoverLink: false, tooltip: { show: false }, silent: true, name: PEERS[k], showSymbol: false, emphasis: { disabled: true }, z: 1, legend: undefined, id: id + '-fc-' + k },
            ];
          });
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: Object.keys(PEERS).filter((k) => data[k]).map((k) => PEERS[k]), textStyle: { color: '#9fb0c8', fontSize: 10.5 }, top: 0, type: 'scroll' },
            grid: { left: 34, right: 12, top: 30, bottom: 22 },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : Number(v).toFixed(1).replace('.', ',') + '%') },
            xAxis: { type: 'category', data: imfYears, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            series,
          });
          window.addEventListener('resize', () => c.resize());
        };
        mkLines('ch-growth', GROWTH);
        mkLines('ch-infl', INFL);
        const mkBars = (id, bars, unit) => {
          const el = document.getElementById(id);
          if (!el || !bars || !bars.length || window.echarts.getInstanceByDom(el)) return;
          const c = window.echarts.init(el);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 70, right: 40, top: 10, bottom: 22 },
            tooltip: { trigger: 'axis', valueFormatter: (v) => String(v).replace('.', ',') + ' ' + unit },
            xAxis: { type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 10 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            yAxis: { type: 'category', inverse: true, data: bars.map((b) => b.n), axisLabel: { color: '#cdd6e6', fontSize: 11.5 }, axisLine: { show: false }, axisTick: { show: false } },
            series: [{ type: 'bar', barMaxWidth: 22, data: bars.map((b) => ({ value: b.v, itemStyle: { color: PCOL[b.c] || '#42506a', borderRadius: [0, 5, 5, 0] } })), label: { show: true, position: 'right', color: '#9fb0c8', fontSize: 10.5, formatter: (p) => String(p.value).replace('.', ',') } }],
          });
          window.addEventListener('resize', () => c.resize());
        };
        mkBars('ch-energy', [...E_BARS].sort((a, b) => b.v - a.v), 'kWh');
        mkBars('ch-co2', [...C_BARS].sort((a, b) => b.v - a.v), 't');
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="samanburdur"]')) initCmp(); });
  </script>
</Layout>
