---
// /skip/ — SAMEINUÐ við ökutækjaleit (Verk 1) → /okutaeki-skip/ (rofi á „Skip").
// Beinum áfram og höldum ?q= fyrirspurninni svo gamlir tenglar/bókamerki virki.
// is:inline → klassísk skrifta sem keyrir SAMSTUNDIS við þáttun (á undan meta-refresh)
// og heldur fyrirspurninni; meta-refresh er varafall fyrir JS-lausa vafra.
---
<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        try {
          var q = new URLSearchParams(location.search).get('q');
          location.replace('/okutaeki-skip/?t=skip' + (q ? '&q=' + encodeURIComponent(q) : ''));
        } catch (e) {}
      })();
    </script>
    <meta http-equiv="refresh" content="0; url=/okutaeki-skip/?t=skip" />
    <link rel="canonical" href="https://karp.is/okutaeki-skip/" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Skipaleit — áfram á Karp</title>
  </head>
  <body>
    <p>Skipaleitin er nú hluti af <a href="/okutaeki-skip/?t=skip">Ökutækja- &amp; skipaleit</a>…</p>
  </body>
</html>
