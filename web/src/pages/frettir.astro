---
// Umfjöllun / Vöktun (#2 LOTA 8) — tveir flipar eins og gamla: „Eftir málefni"
// (lifandi fyrirsagnir /frettir) + „Eftir fyrirtæki" (35 félög: lifandi
// umfjöllun /frettir?q= + BAKAÐ viðhorf (sentiment.json) + kennitölur).
import Layout from '../layouts/Layout.astro';
import FYRIRTAEKI from '../data/fyrirtaeki.json';
import SENTIMENT from '@gogn/sentiment.json';
import RAUNVIRDI from '@gogn/raunvirdi.json';

const SENT = SENTIMENT.companies || {};
const RV = RAUNVIRDI.companies || {};
const COS = FYRIRTAEKI.map((c) => ({ n: c.n, a: c.a && c.a.length ? c.a : [c.n], t: c.t || null, sent: SENT[c.n] ? { idx: SENT[c.n].idx, n: SENT[c.n].n } : null, rv: c.t && RV[c.t] ? { pe: RV[c.t].pe, pb: RV[c.t].pb, mcap: RV[c.t].mcap } : null }));
const updated = '2026-07-02';
const desc = 'Fjölmiðlavöktun Karp — lifandi fyrirsagnir eftir málefnum og umfjöllun um 35 íslensk fyrirtæki með vélrænu viðhorfsmati og verðkennitölum.';
---

<Layout title="Vöktun — fjölmiðlaumfjöllun | Karp" description={desc} canonical="https://app.karp.is/frettir/" ogTitle="Fjölmiðlavöktun Karp">
  <main>
    <p class="kicker">Hagvísir Íslands · Umfjöllun</p>
    <h1>Vöktun</h1>
    <div class="tabs"><button class="tab on" data-t="mal">📰 Eftir málefni</button><button class="tab" data-t="fyr">🏢 Eftir fyrirtæki</button></div>

    <section id="p-mal">
      <p>Nýjustu fyrirsagnir íslenskra miðla — uppfærast stöðugt. Aðeins fyrirsagnir og hlekkir; efnið er hjá miðlunum.</p>
      <div id="live-list" class="live">Sæki fyrirsagnir…</div>
    </section>

    <section id="p-fyr" hidden>
      <p>Smelltu á félag fyrir lifandi umfjöllun{Object.keys(SENT).length ? ', vélrænt viðhorfsmat' : ''} og kennitölur.</p>
      <div class="cos">
        {COS.map((c, i) => (
          <button class="co" data-i={i}>
            <span class="co-n">{c.n}</span>
            {c.sent && <span class={`co-s ${c.sent.idx > 15 ? 'up' : c.sent.idx < -15 ? 'dn' : ''}`}>{c.sent.idx > 0 ? '+' : ''}{c.sent.idx}</span>}
          </button>
        ))}
      </div>
      <div id="co-detail" hidden></div>
    </section>

    <p class="foot">Forþjónað (SSG) {updated}. Fyrirsagnir gegnum <code>/frettir</code>-endapunkt karp.is (birtast á app.karp.is); viðhorf = vélrænt mat (Claude) á fyrirsögnum, ekki dómur. #2.</p>
  </main>

  <script type="application/json" id="d-cos" set:html={JSON.stringify(COS)}></script>

  <style>
    main { max-width: 780px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 12px; } p { color: #cdd6e6; }
    .tabs { display: flex; gap: 6px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 16px; }
    .tab { background: none; border: 0; color: #9fb0c8; font-size: 15px; font-weight: 700; padding: 10px 14px; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .tab.on { color: #f6b13b; border-bottom-color: #f6b13b; }
    .cos { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 8px; margin-top: 10px; }
    .co { display: flex; justify-content: space-between; align-items: center; gap: 8px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 10px 12px; color: #eaf1fb; font-size: 13px; font-weight: 600; cursor: pointer; text-align: left; }
    .co:hover { border-color: #f6b13b; }
    .co-s { font-size: 11px; font-weight: 800; color: #9fb0c8; }
    .co-s.up { color: #46e08a; } .co-s.dn { color: #ff6d7a; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    .live .it, #co-detail .it { display: block; padding: 9px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    .live .it .t, #co-detail .it .t { display: block; font-size: 14px; color: #eaf1fb; line-height: 1.35; }
    .live .it:hover .t, #co-detail .it:hover .t { color: #f6b13b; }
    .live .it .s, #co-detail .it .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .live-empty { font-size: 13.5px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 12px 14px; border-radius: 0 8px 8px 0; }
    #co-detail { margin-top: 16px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 16px 18px; }
    #co-detail .d-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    #co-detail .d-n { font-size: 19px; font-weight: 800; color: #f6b13b; }
    #co-detail .d-tiles { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0; }
    #co-detail .d-t { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 9px; padding: 7px 11px; font-size: 12px; color: #9fb0c8; }
    #co-detail .d-t b { color: #eaf1fb; font-size: 14px; }
    #co-detail .d-t b.up { color: #46e08a; } #co-detail .d-t b.dn { color: #ff6d7a; }
  </style>

  <!-- Eyja: lifandi fyrirsagnir + fyrirtækja-detail. #2 -->
  <script>
    const esc9 = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    // Öryggi: aðeins http(s)-hlekkir úr RSS-veitunum (javascript:/data: blokkað).
    const safe9 = (u) => (/^https?:\/\//i.test(String(u || '')) ? String(u) : '#');
    const paint = (el, items, emptyMsg) => {
      const arr = Array.isArray(items) ? items : [];
      el.innerHTML = arr.length
        ? arr.slice(0, 30).map((it) => `<a class="it" href="${esc9(safe9(it.link))}" target="_blank" rel="noopener"><span class="t">${esc9(it.title)}</span><span class="s">${esc9(it.source || '')}${it.date ? ' · ' + esc9(it.date) : ''}</span></a>`).join('')
        : `<div class="live-empty">${emptyMsg}</div>`;
    };
    const OFFLINE = 'Fyrirsagnir birtast á app.karp.is (CORS-varinn endapunktur).';
    function initFrettir() {
      const list = document.getElementById('live-list');
      if (!list || list.dataset.done) return;
      list.dataset.done = '1';
      fetch('https://karp.is/wp-json/karp/v1/frettir').then((r) => (r.ok ? r.json() : [])).then((d) => paint(list, d, 'Engar fyrirsagnir í augnablikinu.')).catch(() => paint(list, [], OFFLINE));
      // Flipar
      document.querySelectorAll('.tab').forEach((t) => {
        t.onclick = () => {
          document.querySelectorAll('.tab').forEach((x) => x.classList.toggle('on', x === t));
          document.getElementById('p-mal').hidden = t.dataset.t !== 'mal';
          document.getElementById('p-fyr').hidden = t.dataset.t !== 'fyr';
        };
      });
      // Fyrirtæki
      const COS = JSON.parse(document.getElementById('d-cos').textContent);
      const det = document.getElementById('co-detail');
      const th = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      document.querySelectorAll('.co[data-i]').forEach((b) => {
        b.onclick = () => {
          const c = COS[+b.dataset.i];
          det.hidden = false;
          const tiles = [];
          if (c.sent) tiles.push(`<span class="d-t">Viðhorf: <b class="${c.sent.idx > 15 ? 'up' : c.sent.idx < -15 ? 'dn' : ''}">${c.sent.idx > 0 ? '+' : ''}${c.sent.idx}</b> · ${c.sent.n} fyrirsagnir</span>`);
          if (c.rv) { if (c.rv.mcap) tiles.push(`<span class="d-t">Markaðsvirði: <b>${th(c.rv.mcap / 1e9)} ma</b></span>`); if (c.rv.pe != null) tiles.push(`<span class="d-t">V/H: <b>${String(c.rv.pe).replace('.', ',')}</b></span>`); if (c.rv.pb != null) tiles.push(`<span class="d-t">V/I: <b>${String(c.rv.pb).replace('.', ',')}</b></span>`); }
          det.innerHTML = `<div class="d-h"><span class="d-n">${esc9(c.n)}</span>${c.t ? `<a href="/markadir/" style="font-size:12px;color:#9fb0c8">${esc9(c.t)} á Mörkuðum →</a>` : ''}</div><div class="d-tiles">${tiles.join('')}</div><div class="d-list">Sæki umfjöllun…</div>`;
          det.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          const dl = det.querySelector('.d-list');
          fetch('https://karp.is/wp-json/karp/v1/frettir?q=' + encodeURIComponent(c.a.join(',')))
            .then((r) => (r.ok ? r.json() : [])).then((d) => paint(dl, d, 'Engin nýleg umfjöllun fannst.')).catch(() => paint(dl, [], OFFLINE));
        };
      });
    }
    document.addEventListener('astro:page-load', initFrettir);
  </script>
</Layout>
