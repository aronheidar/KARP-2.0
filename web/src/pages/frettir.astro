---
// Umfjöllun / Vöktun (#2 LOTA 8) — tveir flipar eins og gamla: „Eftir málefni"
// (lifandi fyrirsagnir /frettir) + „Eftir fyrirtæki" (35 félög: lifandi
// umfjöllun /frettir?q= + BAKAÐ viðhorf (sentiment.json) + kennitölur).
import Layout from '../layouts/Layout.astro';
import FYRIRTAEKI from '../data/fyrirtaeki.json';
import SENTIMENT from '@gogn/sentiment.json';
import RAUNVIRDI from '@gogn/raunvirdi.json';
import PSTANCE from '../data/pstance.json';
import CABINET from '@gogn/cabinet.json';
import STOFNANIR from '../data/stofnanir_umf.json';

// Fleiri aðila-hópar (LOTA 13b): stjórnmálaflokkar + ráðherrar — sama /firma-greining.
const PARTIES = Object.keys(PSTANCE).map((n) => ({ n, a: [n] }));
const MINS = CABINET.map((c) => ({ n: c.nafn, a: [c.nafn], sub: (c.emb || [])[0] || 'ráðherra' }));
const INST = STOFNANIR.map((x) => ({ n: x.n, a: x.a && x.a.length ? x.a : [x.n] }));

// Tengdir aðilar per málefni (LOTA 14): birtast sem flýtihnappar yfir fréttalistanum
const relOf = (names) => names.map((n) => INST.find((x) => x.n === n)).filter(Boolean).map((x) => ({ n: x.n, al: x.a.join(',') }));
const RELB = {
  efnahagur: relOf(['Seðlabankinn', 'Skatturinn', 'HMS', 'Samkeppniseftirlitið']),
  stjornmal: relOf(['Ríkisstjórnin', 'Alþingi', 'Hæstiréttur']),
  sveitarfelog: relOf(['Vegagerðin', 'HMS']),
  althjoda: relOf(['Landhelgisgæslan']),
  samfelag: relOf(['Landspítalinn', 'RÚV', 'Vinnumálastofnun', 'Þjóðkirkjan']),
};

const SENT = SENTIMENT.companies || {};
const RV = RAUNVIRDI.companies || {};
const COS = FYRIRTAEKI.map((c) => {
  const rv = c.t && RV[c.t] ? RV[c.t] : null;
  return {
    n: c.n, a: c.a && c.a.length ? c.a : [c.n], t: c.t || null,
    sent: SENT[c.n] ? { idx: SENT[c.n].idx, n: SENT[c.n].n } : null,
    rv: rv ? { pe: rv.pe, pb: rv.pb, mcap: rv.mcap } : null,
    rvFull: rv ? { mcap: rv.mcap, pe: rv.pe, pb: rv.pb, roe: rv.roe, ni: rv.ni, ccy: rv.ccy } : null,
  };
});
// SoV-samanburðurinn (LOTA 34C): allir aðilar sem hægt er að bera saman
const SOVENTS = [...COS.map((c) => ({ n: c.n, a: c.a })), ...INST, ...PARTIES, ...MINS.map((m) => ({ n: m.n, a: m.a }))];
const updated = '2026-07-04';
const desc = 'Fjölmiðlavöktun Karp — lifandi fyrirsagnir eftir málefnum og umfjöllun um 35 íslensk fyrirtæki með vélrænu viðhorfsmati og verðkennitölum.';
---

<Layout title="Vöktun — fjölmiðlaumfjöllun | Karp" description={desc} canonical="https://karp.is/frettir/" ogTitle="Fjölmiðlavöktun Karp">
  <main data-pg="frettir">
    <p class="kicker">Hagvísir Íslands · Umfjöllun</p>
    <h1>Vöktun</h1>
    <p>Nýjustu fyrirsagnir íslenskra miðla eftir málefnum — og premium-greining á hvaða aðila sem er. Leitin er alltaf opin.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Fréttavöktunin birtir aðeins fyrirsagnir og tengla úr opnum RSS-veitum íslenskra miðla (og Bing News fyrir erlenda umfjöllun um Ísland). Tónn og viðhorf eru vélrænt mat á fyrirsögnum — nálgun, ekki ritstjórnarmat.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="fy-search">
      <input id="fy-q" type="text" placeholder="🔍 Leitaðu að hvaða fyrirtæki, stofnun eða einstaklingi sem er…" autocomplete="off" />
      <button id="fy-go" type="button">Greina</button>
    </div>

    <!-- SAMEINAÐUR flipi (LOTA 14): málefni OG aðila-hópar í einni röð -->
    <div class="chips" id="u-chips">
      <button class="chip on" data-e="">🗞️ Allt</button>
      <button class="chip" data-e="efnahagur">💹 Efnahagur</button>
      <button class="chip" data-e="stjornmal">🏛️ Stjórnmál &amp; Alþingi</button>
      <button class="chip" data-e="sveitarfelog">🏘️ Sveitarfélög</button>
      <button class="chip" data-e="althjoda">🌍 Alþjóða</button>
      <button class="chip" data-e="samfelag">👥 Samfélag</button>
      <button class="chip" data-e="__erlent">🌍 Erlendir miðlar</button>
      <span class="chip-sep"></span>
      <button class="chip" data-g="fyr">🏢 Fyrirtæki</button>
      <button class="chip" data-g="stofnanir">🏦 Stofnanir</button>
      <button class="chip" data-g="flokkar">🚩 Flokkar</button>
      <button class="chip" data-g="radherrar">🧑‍⚖️ Ráðherrar</button>
    </div>

    <div id="rel" class="rel" hidden></div>
    <p class="rail-hint">🗞️ Fyrirsagnirnar birtast í <b>fréttastikunni hægra megin</b> og fylgja valinu hér að ofan — og reyndar síðunni sem þú ert á hverju sinni. <span class="more-link" style="display:inline">Dýpri greining: <a href="#greining">Fjölmiðlagreiningin neðar á síðunni</a>.</span></p>
    <div id="live-wrap">
      <div id="live-list" class="live">Sæki fyrirsagnir…</div>
    </div>

    <div class="cos" id="g-stofnanir" hidden>
        {INST.map((x) => <button class="co co-ent" data-name={x.n} data-al={x.a.join(',')}><span class="co-n">{x.n}</span></button>)}
      </div>
      <div class="cos" id="g-flokkar" hidden>
        {PARTIES.map((p) => <button class="co co-ent" data-name={p.n}><span class="co-n">{p.n}</span></button>)}
      </div>
      <div class="cos" id="g-radherrar" hidden>
        {MINS.map((m) => <button class="co co-ent" data-name={m.n}><span class="co-n">{m.n}</span><span class="co-s">{m.sub}</span></button>)}
      </div>
      <div class="cos" id="g-fyr" hidden>
        {COS.map((c, i) => (
          <button class="co" data-i={i}>
            <span class="co-n">{c.n}</span>
            {c.sent && <span class={`co-s ${c.sent.idx > 15 ? 'up' : c.sent.idx < -15 ? 'dn' : ''}`}>{c.sent.idx > 0 ? '+' : ''}{c.sent.idx}</span>}
          </button>
        ))}
      </div>
      <div id="co-detail" hidden></div>

    <!-- ── 📊 FJÖLMIÐLAGREININGIN (LOTA 34B — sameinuð hingað úr /greining/) ──
         Sjálfgefið: heildarsafnið. Við val á aðila að ofan AÐLAGAST allt:
         KPI, gröfin, Fjölmiðlavogin og tengslanetið. -->
    <section id="greining">
      <h2 class="fg-h">📊 Fjölmiðlagreining <i class="tip" tabindex="0" data-tip="Fréttasafn Karp greint: umfang, tónn og dreifing. Sjálfgefið sést heildarsafnið (50þ+ fyrirsagnir) — veldu aðila að ofan og öll gröfin, vogin og tengslanetið laga sig að valinu. Tónn er vélrænt mat, ekki ritstjórnardómur.">ⓘ</i> <span id="fg-selname"></span></h2>
      <div id="fg-kpis">Sæki greiningu…</div>
      <div class="fg-pair">
        <div><h3 class="fg-sh" id="fg-months-h">Umfjöllun &amp; tónn eftir mánuðum</h3><div id="fg-months"></div></div>
        <div><h3 class="fg-sh" id="fg-src-h">Hlutdeild miðlanna</h3><div id="fg-src"></div></div>
      </div>

      <h3 class="fg-sh">📊 Fjölmiðlavogin <i class="tip" tabindex="0" data-tip="Tónn PER MIÐIL um valið málefni eða aðila — veldu flís, sláðu inn eigið efni, eða veldu aðila að ofan og vogin keyrir sjálfkrafa.">ⓘ</i></h3>
      <div class="chips" id="fg-vogchips">
        <button class="chip" data-q="verðbólga,verðbólgu">Verðbólga</button>
        <button class="chip" data-q="vextir,vaxta,stýrivextir,stýrivaxta">Vextir</button>
        <button class="chip" data-q="Ríkisstjórnin,Ríkisstjórnarinnar,Ríkisstjórn">Ríkisstjórnin</button>
        <button class="chip" data-q="húsnæði,húsnæðis,fasteigna,leigumarkað">Húsnæðismál</button>
        <button class="chip" data-q="útlendinga,hælisleitend,innflytjend">Útlendingamál</button>
        <button class="chip" data-q="kjarasamning,verkfall,kjaradeil">Kjaramál</button>
      </div>
      <div id="fg-vog">Veldu málefni — eða aðila að ofan — til að vega miðlana.</div>

      <h3 class="fg-sh">⚖️ Samanburður aðila — hlutdeild umfjöllunar <i class="tip" tabindex="0" data-tip="Share of voice: veldu tvo aðila og sjáðu hvor á meira af umfjölluninni (sl. 12 mánuði), tón hvors um sig og þróunina viku fyrir viku á sama grafi. Klassísk PR-greining.">ⓘ</i></h3>
      <div class="sov-row">
        <input id="sov-a" list="sov-list" placeholder="Aðili A — t.d. Icelandair" autocomplete="off" />
        <span class="sov-vs">vs</span>
        <input id="sov-b" list="sov-list" placeholder="Aðili B — t.d. Play" autocomplete="off" />
        <button id="sov-go" type="button">Bera saman</button>
      </div>
      <datalist id="sov-list">{SOVENTS.map((e) => <option value={e.n} />)}</datalist>
      <div id="sov-out"></div>

      <h3 class="fg-sh">🕸️ Tengslanet umfjöllunar <i class="tip" tabindex="0" data-tip="Hverjir koma saman fyrir í fréttum? Hnútur = aðili (stærð = fjöldi frétta sl. 180 daga), brún = sameiginlegar fyrirsagnir. Netið FYLGIR VALINU efst á síðunni: Fyrirtæki-flipinn sýnir fyrirtækjanetið, Flokkar flokkanetið o.s.frv. — og valinn aðili lýsist upp.">ⓘ</i> <span class="fg-follow">fylgir valinu efst</span></h3>
      <div id="tn-graph"></div>
      <div id="tn-note" class="tn-note"></div>
      <div id="tn-pairs"></div>
    </section>

    <!-- 📰 Nýjasta umfjöllunin — NEÐST, fyrir neðan greininguna (ósk notanda) -->
    <div id="btm-news" hidden>
      <div class="d-sec" id="btm-sec">Nýjasta umfjöllunin</div>
      <div class="d-list" id="btm-list"></div>
    </div>

    <p class="foot">Forþjónað (SSG) {updated}. Fyrirsagnir gegnum <code>/frettir</code>-endapunkt karp.is (birtast á karp.is); viðhorf = vélrænt mat (Claude) á fyrirsögnum, ekki dómur. Greiningarnar keyra lifandi á fréttasafninu (/yearreview + /firma + /firmagraph). #2 + LOTA 34.</p>
  </main>

  <script type="application/json" id="d-cos" set:html={JSON.stringify(COS)}></script>
  <script type="application/json" id="d-sovents" set:html={JSON.stringify(SOVENTS)}></script>
  <script type="application/json" id="d-rel" set:html={JSON.stringify(RELB)}></script>

  <style>
    main { max-width: 980px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 12px; } p { color: #cdd6e6; }
    .chip-sep { width: 1px; align-self: stretch; background: rgba(255,255,255,.14); margin: 0 4px; }
    .rel { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin: 2px 0 8px; }
    .rel-l { font-size: 11.5px; color: #7e8ca6; }
    .rel-b { background: rgba(25,211,197,.08); border: 1px solid rgba(25,211,197,.35); color: #19d3c5; border-radius: 999px; padding: 3px 11px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .rel-b:hover { background: rgba(25,211,197,.18); }
    .cos { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 8px; margin-top: 10px; }
    .co { display: flex; justify-content: space-between; align-items: center; gap: 8px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 10px 12px; color: #eaf1fb; font-size: 13px; font-weight: 600; cursor: pointer; text-align: left; }
    .co:hover { border-color: #f6b13b; }
    .co-s { font-size: 11px; font-weight: 800; color: #9fb0c8; }
    .co-ent .co-s { font-weight: 400; font-size: 10.5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fy-search { display: flex; gap: 8px; margin: 10px 0 12px; }
    .fy-search input { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #eaf1fb; border-radius: 10px; padding: 10px 14px; font-size: 14px; outline: none; }
    .fy-search input:focus { border-color: #f6b13b; }
    .fy-search button { background: #f6b13b; color: #06121a; border: 0; border-radius: 10px; padding: 10px 18px; font-size: 13.5px; font-weight: 800; cursor: pointer; }
    .fy-search button:hover { filter: brightness(1.1); }
    .co-fl { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.16); color: #cdd6e6; border-radius: 999px; padding: 4px 14px; font-size: 12px; font-weight: 700; cursor: pointer; }
    .co-fl.on { background: rgba(70,224,138,.14); border-color: rgba(70,224,138,.5); color: #46e08a; }
    .co-s.up { color: #46e08a; } .co-s.dn { color: #ff6d7a; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .more-link { font-size: 12.5px; color: #9fb0c8; margin-top: 14px; }
    .more-link a { color: #f6b13b; }
  </style>
  <style is:global>
    /* 2 dálkar á fréttalistanum (LOTA 14) — minna skrun */
    .live { column-count: 2; column-gap: 26px; }
    @media (max-width: 760px) { .live { column-count: 1; } }
    /* LOTA 21: fyrirsagnalistinn fer af síðunni á breiðum skjá (stikan sér um hann)
       — helst sem fallback á mjóum skjá þar sem stikan er falin (<1000px). */
    .rail-hint { font-size: 13px; color: #9fb0c8; margin: 10px 0 4px; }
    @media (min-width: 1000.1px) { #live-wrap { display: none; } }
    @media (max-width: 1000px) { .rail-hint { display: none; } }
    .live .it { break-inside: avoid; }
    .live .it, #co-detail .it { display: block; padding: 9px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    .live .it .t, #co-detail .it .t { display: block; font-size: 14px; color: #eaf1fb; line-height: 1.35; }
    .live .it:hover .t, #co-detail .it:hover .t { color: #f6b13b; }
    .live .it .s, #co-detail .it .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .live-empty { font-size: 13.5px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 12px 14px; border-radius: 0 8px 8px 0; }
    #co-detail { margin-top: 16px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 16px 18px; }
    #co-detail .d-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    #co-detail .d-n { font-size: 19px; font-weight: 800; color: #f6b13b; }
    #co-detail .d-tiles { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0; }
    #co-detail .d-t { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 9px; padding: 7px 11px; font-size: 12px; color: #9fb0c8; }
    #co-detail .d-t b { color: #eaf1fb; font-size: 14px; }
    #co-detail .d-t b.up { color: #46e08a; } #co-detail .d-t b.dn { color: #ff6d7a; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 12px; }
    .chip { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 5px 13px; font-size: 12.5px; font-weight: 600; cursor: pointer; }
    .chip:hover { color: #f6b13b; border-color: #f6b13b; }
    .chip.on { color: #06121a; background: #f6b13b; border-color: #f6b13b; }
    #co-detail .d-sec { font-size: 11px; font-weight: 800; color: #19d3c5; text-transform: uppercase; letter-spacing: .05em; margin: 14px 0 4px; }
    #co-detail #d-tl { width: 100%; height: 190px; }
    #co-detail .d-cloud { display: flex; flex-wrap: wrap; gap: 4px 10px; align-items: baseline; padding: 4px 0; }
    #co-detail .d-w { color: #cdd6e6; }
    #co-detail .d-w:nth-child(3n) { color: #f6b13b; } #co-detail .d-w:nth-child(3n+1) { color: #19d3c5; }
    /* Premium-spjöldin (LOTA 13, eins og gamla) */
    .se-card { background: rgba(255,255,255,.035); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 12px 14px; margin: 10px 0; }
    /* LOTA 20: spjaldið í tvo dálka á breiðum skjá — LOTA 35: ÞRJÁ á mjög breiðum */
    @media (min-width: 900px) {
      .d-more { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: start; }
      .d-more .se-card { margin: 0; }
      .d-more .fy-health, .d-more .se-card:has(#d-tl), .d-more .pro-tease { grid-column: 1 / -1; }
    }
    @media (min-width: 1150px) {
      .d-more { grid-template-columns: 1fr 1fr 1fr; }
    }
    .fg-follow { font-size: 11px; font-weight: 400; color: #7e8ca6; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 999px; padding: 2px 9px; margin-left: 6px; text-transform: none; letter-spacing: 0; }
    #btm-news { margin-top: 26px; border-top: 1px solid rgba(255,255,255,.1); padding-top: 6px; }
    /* ⭐ Pro-kynningin í spjaldinu (runtime-DOM) */
    .pro-tease { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.35); border-radius: 13px; padding: 16px 18px; }
    .pt-t { font-size: 15px; font-weight: 800; color: #f6b13b; margin-bottom: 6px; }
    .pro-tease p { font-size: 13px; color: #cdd6e6; margin: 0 0 12px; }
    .pt-btns { display: flex; gap: 8px; flex-wrap: wrap; }
    .pt-main { background: #f6b13b; color: #131a29; font-weight: 800; padding: 8px 18px; border-radius: 9px; text-decoration: none; font-size: 13px; }
    .pt-sec { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.18); color: #eaf1fb; padding: 8px 16px; border-radius: 9px; text-decoration: none; font-size: 13px; }
    .se-card .se-l { font-size: 13px; font-weight: 800; color: #eaf1fb; }
    .se-sub { font-size: 11px; color: #7e8ca6; font-weight: 400; margin-left: 6px; }
    .se-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
    .se-idx { font-size: 30px; font-weight: 800; line-height: 1; text-align: right; font-variant-numeric: tabular-nums; }
    .se-idx small { display: block; font-size: 10.5px; font-weight: 600; letter-spacing: .04em; }
    .se-pos { color: #46e08a; } .se-neg { color: #ff6d7a; } .se-neu { color: #9fb0c8; }
    .se-bar { display: flex; height: 10px; border-radius: 5px; overflow: hidden; margin: 10px 0 6px; }
    .se-bar i { display: block; height: 100%; }
    .se-bneg { background: #ff6d7a; } .se-bneu { background: #5a6678; } .se-bpos { background: #46e08a; }
    .se-leg { display: flex; gap: 14px; font-size: 11.5px; flex-wrap: wrap; }
    .se-note { font-size: 11px; color: #7e8ca6; margin-top: 8px; line-height: 1.45; }
    .rv-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(118px, 1fr)); gap: 8px; margin-top: 10px; }
    .rv-tile { background: rgba(255,255,255,.045); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 9px 11px; }
    .rv-tile.good { border-color: rgba(70,224,138,.4); } .rv-tile.warn { border-color: rgba(246,177,59,.4); } .rv-tile.bad { border-color: rgba(255,109,122,.4); }
    .rv-v { font-size: 17px; font-weight: 800; color: #eaf1fb; font-variant-numeric: tabular-nums; }
    .rv-tile.good .rv-v { color: #46e08a; } .rv-tile.warn .rv-v { color: #f6b13b; } .rv-tile.bad .rv-v { color: #ff6d7a; }
    .rv-l { font-size: 10.5px; color: #8fa0ba; margin-top: 2px; }
    .rv-l span { color: #7e8ca6; font-size: 10px; }
    .fy-srcrows, .fy-dist { margin-top: 10px; }
    .fy-srcrow { display: grid; grid-template-columns: 110px 1fr 44px 52px; gap: 8px; align-items: center; padding: 3px 0; }
    .fy-srcn { font-size: 11.5px; color: #cdd6e6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fy-srcbar { height: 9px; background: rgba(255,255,255,.05); border-radius: 5px; overflow: hidden; }
    .fy-srcbar i { display: block; height: 100%; border-radius: 5px; }
