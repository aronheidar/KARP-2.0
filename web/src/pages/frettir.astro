    }
    function tnPairs(d) {
      const el = document.getElementById('tn-pairs');
      if (!el) return;
      const top = (d.links || []).slice().sort((a, b) => b.value - a.value).slice(0, 12);
      el.innerHTML = top.length ? '<div class="tn-pairs-h">Sterkustu tengslin</div>' + top.map((l) => `<div class="tn-pair"><span class="tn-pair-n"><b>${esc9(l.source)}</b> ↔ <b>${esc9(l.target)}</b></span><span class="tn-pair-v">${l.value} fréttir</span></div>`).join('') : '';
    }
    // ── KPI + gröf: heild (yearreview) eða valinn aðili (/firma-svarið) ──
    let FG_GLOBAL = null;
    const mISF = (m) => ['jan', 'feb', 'mar', 'apr', 'maí', 'jún', 'júl', 'ágú', 'sep', 'okt', 'nóv', 'des'][+String(m).slice(5, 7) - 1] || m;
    function fgChart(id, opt) { withEcharts(() => { const el = document.getElementById(id); if (!el) return; const c = window.echarts.getInstanceByDom(el) || window.echarts.init(el); c.setOption(opt, true); window.addEventListener('resize', () => c.resize()); }); }
    function fgGlobal() {
      const kp = document.getElementById('fg-kpis');
      document.getElementById('fg-selname').innerHTML = '';
      document.getElementById('fg-months-h').textContent = 'Umfjöllun & tónn eftir mánuðum';
      document.getElementById('fg-src-h').textContent = 'Hlutdeild miðlanna';
      const paint = (d) => {
        const tone = (i) => (i > 15 ? ['jákvæður', '#46e08a'] : i < -15 ? ['neikvæður', '#ff6d7a'] : ['hlutlaus', '#9fb0c8']);
        const totN = d.months.reduce((a, m) => a + m.n, 0) || 1;
        const avgIdx = Math.round(d.months.reduce((a, m) => a + (m.idx || 0) * m.n, 0) / totN);
        kp.innerHTML = `<div class="kpis">
          <div class="kpi"><div class="k-l">🗞️ Fréttir í safni ${d.year}</div><div class="k-v">${thF(d.total)}</div><div class="k-s">${thF(d.scored)} tón-greindar</div></div>
          <div class="kpi"><div class="k-l">🤖 Meðaltónn ársins</div><div class="k-v" style="color:${tone(avgIdx)[1]}">${avgIdx > 0 ? '+' : ''}${avgIdx}</div><div class="k-s">${tone(avgIdx)[0]} · −100…+100</div></div>
          ${d.best ? `<div class="kpi"><div class="k-l">☀️ Jákvæðasti mánuður</div><div class="k-v" style="color:#46e08a">${mISF(d.best.m)}</div><div class="k-s">tónn +${d.best.idx}</div></div>` : ''}
          ${d.worst ? `<div class="kpi"><div class="k-l">🌧️ Neikvæðasti mánuður</div><div class="k-v" style="color:#ff6d7a">${mISF(d.worst.m)}</div><div class="k-s">tónn ${d.worst.idx}</div></div>` : ''}
        </div>`;
        fgChart('fg-months', {
          backgroundColor: 'transparent', legend: { data: ['Fréttir', 'Tónn'], textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0 },
          grid: { left: 44, right: 40, top: 30, bottom: 22 }, tooltip: { trigger: 'axis' },
          xAxis: { type: 'category', data: d.months.map((x) => mISF(x.m)), axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
          yAxis: [{ type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 10, formatter: (v) => (v >= 1000 ? v / 1000 + 'þ' : v) }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } }, { type: 'value', min: -50, max: 50, axisLabel: { color: '#9fb0c8', fontSize: 10 }, splitLine: { show: false } }],
          series: [{ name: 'Fréttir', type: 'bar', data: d.months.map((x) => x.n), barMaxWidth: 26, itemStyle: { color: 'rgba(58,141,255,.45)', borderRadius: [4, 4, 0, 0] } }, { name: 'Tónn', type: 'line', yAxisIndex: 1, data: d.months.map((x) => x.idx), smooth: true, symbol: 'circle', symbolSize: 5, lineStyle: { color: '#f6b13b', width: 3 }, itemStyle: { color: '#f6b13b' } }],
        });
        if (d.bySource && d.bySource.length) fgChart('fg-src', {
          backgroundColor: 'transparent', tooltip: { trigger: 'item', valueFormatter: (v) => thF(v) + ' fréttir' },
          series: [{ type: 'pie', radius: ['42%', '72%'], center: ['50%', '52%'], label: { color: '#cdd6e6', fontSize: 11, formatter: '{b}\n{d}%' }, labelLine: { lineStyle: { color: 'rgba(255,255,255,.2)' } }, itemStyle: { borderColor: '#0b1220', borderWidth: 2 }, data: d.bySource.slice(0, 8).map((x) => ({ name: x.s, value: x.n })) }],
        });
      };
      if (FG_GLOBAL) { paint(FG_GLOBAL); return; }
      fetch(API + '/yearreview').then((r) => (r.ok ? r.json() : null)).then((d) => {
        if (!d || !d.ready) { kp.innerHTML = '<div class="empty">Heildargreiningin er ekki tilbúin í augnablikinu.</div>'; return; }
        FG_GLOBAL = d; paint(d);
      }).catch(() => { kp.innerHTML = '<div class="empty">Greiningin birtist á karp.is (CORS-varinn endapunktur).</div>'; });
    }
    function fgSetSel(c, f) {
      const kp = document.getElementById('fg-kpis');
      if (!kp) return;
      FG_SEL = { c, f };
      document.getElementById('fg-selname').innerHTML = '— valið: <b>' + esc9(c.n) + '</b> <button type="button" class="fg-btn" id="fg-pdf" title="Prentvæn skýrsla (vista sem PDF í prentglugganum)">🖨️ PDF-skýrsla</button> <button type="button" id="fg-clear" title="Aftur í heildina">✕ heildin</button>';
      document.getElementById('fg-clear').onclick = () => { FG_SEL = null; fgGlobal(); };
      document.getElementById('fg-pdf').onclick = fgReport;
      document.getElementById('fg-months-h').textContent = 'Umfjöllun um ' + c.n + ' (vikur)';
      document.getElementById('fg-src-h').textContent = 'Miðlar sem fjalla um ' + c.n;
      const se = f.sentiment || {}, st = f.stats || {};
      kp.innerHTML = `<div class="kpis">
        <div class="kpi"><div class="k-l">🗞️ Fréttir sl. 6 mán</div><div class="k-v">${thF(f.total)}</div><div class="k-s">${st.perDay != null ? String(st.perDay).replace('.', ',') + ' á dag' : ''}</div></div>
        <div class="kpi"><div class="k-l">🤖 Tónn umfjöllunar</div><div class="k-v" style="color:${se.idx > 15 ? '#46e08a' : se.idx < -15 ? '#ff6d7a' : '#9fb0c8'}">${se.idx > 0 ? '+' : ''}${se.idx ?? '—'}</div><div class="k-s">${se.scored || 0} tón-greindar</div></div>
        <div class="kpi"><div class="k-l">📰 Miðlar</div><div class="k-v">${(st.sources || []).length}</div><div class="k-s">fjalla um aðilann</div></div>
      </div>`;
      const tl = f.timeline || [];
      if (tl.length > 2) fgChart('fg-months', {
        backgroundColor: 'transparent', grid: { left: 34, right: 10, top: 12, bottom: 22 },
        tooltip: { trigger: 'axis', formatter: (ps) => { const p = ps[0]; const t = tl[p.dataIndex]; return `vika ${p.name}<br><b>${t.n}</b> fréttir${t.scored ? ` · tónn ${t.idx > 0 ? '+' : ''}${t.idx}` : ''}`; } },
        xAxis: { type: 'category', data: tl.map((t) => t.d.slice(5)), axisLabel: { color: '#7e8ca6', fontSize: 9 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 9 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        series: [{ type: 'bar', data: tl.map((t) => ({ value: t.n, itemStyle: { color: t.scored ? (t.idx > 15 ? '#46e08a' : t.idx < -15 ? '#ff6d7a' : '#5a6678') : '#42506a', borderRadius: [3, 3, 0, 0] } })), barMaxWidth: 18 }],
      });
      if (st.sources && st.sources.length) fgChart('fg-src', {
        backgroundColor: 'transparent', tooltip: { trigger: 'item', valueFormatter: (v) => v + ' fréttir' },
        series: [{ type: 'pie', radius: ['42%', '72%'], center: ['50%', '52%'], label: { color: '#cdd6e6', fontSize: 11, formatter: '{b}\n{d}%' }, labelLine: { lineStyle: { color: 'rgba(255,255,255,.2)' } }, itemStyle: { borderColor: '#0b1220', borderWidth: 2 }, data: st.sources.slice(0, 8).map((x) => ({ name: x.s, value: x.n })) }],
      });
      runFgVog(c.a.join(','), c.n);
      if (GRAFSECT[c.n] != null) { if (TN_CAT !== 'fyrirtaeki') tnLoad('fyrirtaeki', c.n); else tnFocus(c.n); }
      else tnFocus(c.n);
    }
    // ── Fjölmiðlavogin ──
    function runFgVog(q, label) {
      const vog = document.getElementById('fg-vog');
      if (!vog) return;
      vog.innerHTML = 'Veg miðlana fyrir „' + esc9(label) + '“…';
      fetch(API + '/firma?q=' + encodeURIComponent(q) + '&days=365')
        .then((r) => (r.ok ? r.json() : null))
        .then((f) => {
          const bs = f && f.sentiment && f.sentiment.bySource;
          if (!f || !f.ready || !bs || bs.length < 2) { vog.innerHTML = '<div class="empty">Of lítil umfjöllun um „' + esc9(label) + '“ til að vega miðlana.</div>'; return; }
          const cl = (i) => (i > 12 ? 'pos' : i < -12 ? 'neg' : 'neu');
          const mx = Math.max(...bs.map((x) => x.n), 1);
          vog.innerHTML = bs.map((x) => `<div class="fy-srcrow"><span class="fy-srcn">${esc9(x.s)}</span><span class="fy-srcbar"><i class="st-${cl(x.idx)}" style="width:${Math.max(6, (x.n / mx) * 100).toFixed(0)}%"></i></span><span class="fy-srcidx st-${cl(x.idx)}">${x.idx > 0 ? '+' : ''}${x.idx}</span><span class="fy-srcc">${x.n}</span></div>`).join('')
            + `<div class="vog-note">${thF(f.total)} fréttir um efnið sl. 12 mánuði · tónn −100…+100 per miðil · breidd = fjöldi frétta miðilsins.</div>`;
        })
        .catch(() => { vog.innerHTML = '<div class="empty">Vogin birtist á karp.is.</div>'; });
    }
    // ── ⚖️ SoV-samanburður tveggja aðila (LOTA 34C) ──
    const SOVENTS9 = (() => { try { return JSON.parse(document.getElementById('d-sovents').textContent); } catch (e) { return []; } })();
    const sovAlias = (name) => { const e = SOVENTS9.find((x) => x.n.toLowerCase() === name.toLowerCase()); return e ? e.a : [name]; };
    function sovRun() {
      const a = (document.getElementById('sov-a').value || '').trim();
      const b = (document.getElementById('sov-b').value || '').trim();
      const out = document.getElementById('sov-out');
      if (a.length < 2 || b.length < 2) { out.innerHTML = '<div class="empty">Veldu tvo aðila til að bera saman — hvaða nafn sem er gengur.</div>'; return; }
      out.innerHTML = 'Ber saman „' + esc9(a) + '“ og „' + esc9(b) + '“…';
      Promise.all([a, b].map((n) => fetch(API + '/firma?q=' + encodeURIComponent(sovAlias(n).join(',')) + '&days=365').then((r) => (r.ok ? r.json() : null)).catch(() => null)))
        .then(([fa, fb]) => {
          if (!fa || !fa.ready || !fb || !fb.ready) { out.innerHTML = '<div class="empty">Samanburðurinn birtist á karp.is (CORS-varinn endapunktur).</div>'; return; }
          const tot = (fa.total || 0) + (fb.total || 0);
          if (!tot) { out.innerHTML = '<div class="empty">Engin umfjöllun fannst um hvorugan aðilann.</div>'; return; }
          const pa = Math.round((fa.total || 0) / tot * 100);
          const tone = (f) => (f.sentiment && f.sentiment.scored ? (f.sentiment.idx > 0 ? '+' : '') + f.sentiment.idx : '—');
          out.innerHTML =
            `<div class="sov-bar"><span class="sov-a" style="width:${Math.max(6, pa)}%">${esc9(a)} · ${pa}%</span><span class="sov-b" style="width:${Math.max(6, 100 - pa)}%">${esc9(b)} · ${100 - pa}%</span></div>`
            + `<div class="sov-kpis"><span><b>${esc9(a)}</b>: ${thF(fa.total)} fréttir · tónn ${tone(fa)}</span><span><b>${esc9(b)}</b>: ${thF(fb.total)} fréttir · tónn ${tone(fb)}</span></div>`
            + '<div id="sov-tl"></div><div class="vog-note">Hlutdeild umfjöllunar (share of voice) sl. 12 mánuði úr fréttasafni Karp · línurnar sýna fréttir á viku.</div>';
          const map = {};
          (fa.timeline || []).forEach((t) => { (map[t.d] = map[t.d] || {}).a = t.n; });
          (fb.timeline || []).forEach((t) => { (map[t.d] = map[t.d] || {}).b = t.n; });
          const weeks = Object.keys(map).sort();
          if (weeks.length > 2) fgChart('sov-tl', {
            backgroundColor: 'transparent', legend: { data: [a, b], textStyle: { color: '#9fb0c8', fontSize: 11 }, top: 0 },
            grid: { left: 34, right: 10, top: 28, bottom: 22 }, tooltip: { trigger: 'axis' },
            xAxis: { type: 'category', data: weeks.map((w) => w.slice(5)), axisLabel: { color: '#7e8ca6', fontSize: 9 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 9 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            series: [
              { name: a, type: 'line', smooth: true, symbol: 'none', data: weeks.map((w) => map[w].a || 0), lineStyle: { color: '#f6b13b', width: 3 }, itemStyle: { color: '#f6b13b' } },
              { name: b, type: 'line', smooth: true, symbol: 'none', data: weeks.map((w) => map[w].b || 0), lineStyle: { color: '#3aa0ff', width: 3 }, itemStyle: { color: '#3aa0ff' } },
            ],
          });
        });
    }
    // ── 🖨️ PDF-skýrslan (prentvæn útgáfa af greiningunni fyrir valinn aðila) ──
    let FG_SEL = null;
    function fgReport() {
      if (!FG_SEL) return;
      const { c, f } = FG_SEL;
      let rep = document.getElementById('fg-report');
      if (!rep) { rep = document.createElement('div'); rep.id = 'fg-report'; document.body.appendChild(rep); }
      const img = (id) => { const el = document.getElementById(id); const ch = el && window.echarts && window.echarts.getInstanceByDom(el); return ch ? '<img src="' + ch.getDataURL({ pixelRatio: 2, backgroundColor: '#0e1420' }) + '">' : ''; };
      const se = f.sentiment || {}, st = f.stats || {};
      const dnow = new Date().toISOString().slice(0, 10);
      rep.innerHTML = `
        <div class="rep-h"><span class="rep-logo">🐟 KARP</span><span class="rep-t">Fjölmiðlaskýrsla — ${esc9(c.n)}</span><span class="rep-d">${dnow} · sl. 6 mánuðir</span></div>
        <div class="rep-kpis"><div><b>${thF(f.total)}</b>fréttir</div><div><b>${se.idx > 0 ? '+' : ''}${se.idx ?? '—'}</b>tónn (−100…+100)</div><div><b>${(st.sources || []).length}</b>miðlar</div><div><b>${st.perDay != null ? String(st.perDay).replace('.', ',') : '—'}</b>á dag</div></div>
        <h4>Umfjöllun eftir vikum</h4>${img('fg-months')}
        <h4>Dreifing miðla</h4>${img('fg-src')}
        <h4>Nýjustu fyrirsagnir</h4><ol>${(f.items || []).slice(0, 12).map((it) => '<li>' + esc9(it.title || it.t || '') + ' <span>(' + esc9(it.source || it.s || '') + ')</span></li>').join('')}</ol>
        <div class="rep-f">Unnið sjálfvirkt úr fréttasafni Karp · karp.is · tónn er vélrænt mat á fyrirsögnum, ekki ritstjórnardómur · ${dnow}</div>`;
      window.print();
    }
    function initFjolmidlagreining() {
      const sec = document.getElementById('greining');
      if (!sec || sec.dataset.done) return;
      sec.dataset.done = '1';
      document.querySelectorAll('#fg-vogchips .chip').forEach((ch) => {
        ch.onclick = () => { document.querySelectorAll('#fg-vogchips .chip').forEach((x) => x.classList.toggle('on', x === ch)); runFgVog(ch.dataset.q, ch.textContent); };
      });
      const sgo = document.getElementById('sov-go');
      if (sgo) sgo.onclick = sovRun;
      ['sov-a', 'sov-b'].forEach((id) => { const el = document.getElementById(id); if (el) el.onkeydown = (e) => { if (e.key === 'Enter') sovRun(); }; });
      fgGlobal();
      tnLoad('stofnanir');
    }
    window.__fgSetSel = fgSetSel;
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="frettir"]')) { initFrettir(); initFjolmidlagreining(); } });
  </script>
</Layout>
