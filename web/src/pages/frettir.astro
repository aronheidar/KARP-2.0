---
// Umfjöllun / Vöktun (#2 LOTA 8) — tveir flipar eins og gamla: „Eftir málefni"
// (lifandi fyrirsagnir /frettir) + „Eftir fyrirtæki" (35 félög: lifandi
// umfjöllun /frettir?q= + BAKAÐ viðhorf (sentiment.json) + kennitölur).
import Layout from '../layouts/Layout.astro';
import FYRIRTAEKI from '../data/fyrirtaeki.json';
import SENTIMENT from '@gogn/sentiment.json';
import RAUNVIRDI from '@gogn/raunvirdi.json';
import PSTANCE from '../data/pstance.json';
import CABINET from '@gogn/cabinet.json';
import STOFNANIR from '../data/stofnanir_umf.json';

// Fleiri aðila-hópar (LOTA 13b): stjórnmálaflokkar + ráðherrar — sama /firma-greining.
const PARTIES = Object.keys(PSTANCE).map((n) => ({ n, a: [n] }));
const MINS = CABINET.map((c) => ({ n: c.nafn, a: [c.nafn], sub: (c.emb || [])[0] || 'ráðherra' }));
const INST = STOFNANIR.map((x) => ({ n: x.n, a: x.a && x.a.length ? x.a : [x.n] }));

// Tengdir aðilar per málefni (LOTA 14): birtast sem flýtihnappar yfir fréttalistanum
const relOf = (names) => names.map((n) => INST.find((x) => x.n === n)).filter(Boolean).map((x) => ({ n: x.n, al: x.a.join(',') }));
const RELB = {
  efnahagur: relOf(['Seðlabankinn', 'Skatturinn', 'HMS', 'Samkeppniseftirlitið']),
  stjornmal: relOf(['Ríkisstjórnin', 'Alþingi', 'Hæstiréttur']),
  sveitarfelog: relOf(['Vegagerðin', 'HMS']),
  althjoda: relOf(['Landhelgisgæslan']),
  samfelag: relOf(['Landspítalinn', 'RÚV', 'Vinnumálastofnun', 'Þjóðkirkjan']),
};

const SENT = SENTIMENT.companies || {};
const RV = RAUNVIRDI.companies || {};
const COS = FYRIRTAEKI.map((c) => {
  const rv = c.t && RV[c.t] ? RV[c.t] : null;
  return {
    n: c.n, a: c.a && c.a.length ? c.a : [c.n], t: c.t || null,
    sent: SENT[c.n] ? { idx: SENT[c.n].idx, n: SENT[c.n].n } : null,
    rv: rv ? { pe: rv.pe, pb: rv.pb, mcap: rv.mcap } : null,
    rvFull: rv ? { mcap: rv.mcap, pe: rv.pe, pb: rv.pb, roe: rv.roe, ni: rv.ni, ccy: rv.ccy } : null,
  };
});
const updated = '2026-07-02';
const desc = 'Fjölmiðlavöktun Karp — lifandi fyrirsagnir eftir málefnum og umfjöllun um 35 íslensk fyrirtæki með vélrænu viðhorfsmati og verðkennitölum.';
---

<Layout title="Vöktun — fjölmiðlaumfjöllun | Karp" description={desc} canonical="https://karp.is/frettir/" ogTitle="Fjölmiðlavöktun Karp">
  <main data-pg="frettir">
    <p class="kicker">Hagvísir Íslands · Umfjöllun</p>
    <h1>Vöktun</h1>
    <p>Nýjustu fyrirsagnir íslenskra miðla eftir málefnum — og premium-greining á hvaða aðila sem er. Leitin er alltaf opin.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Fréttavöktunin birtir aðeins fyrirsagnir og tengla úr opnum RSS-veitum íslenskra miðla (og Bing News fyrir erlenda umfjöllun um Ísland). Tónn og viðhorf eru vélrænt mat á fyrirsögnum — nálgun, ekki ritstjórnarmat.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="fy-search">
      <input id="fy-q" type="text" placeholder="🔍 Leitaðu að hvaða fyrirtæki, stofnun eða einstaklingi sem er…" autocomplete="off" />
      <button id="fy-go" type="button">Greina</button>
    </div>

    <!-- SAMEINAÐUR flipi (LOTA 14): málefni OG aðila-hópar í einni röð -->
    <div class="chips" id="u-chips">
      <button class="chip on" data-e="">🗞️ Allt</button>
      <button class="chip" data-e="efnahagur">💹 Efnahagur</button>
      <button class="chip" data-e="stjornmal">🏛️ Stjórnmál &amp; Alþingi</button>
      <button class="chip" data-e="sveitarfelog">🏘️ Sveitarfélög</button>
      <button class="chip" data-e="althjoda">🌍 Alþjóða</button>
      <button class="chip" data-e="samfelag">👥 Samfélag</button>
      <button class="chip" data-e="__erlent">🌍 Erlendir miðlar</button>
      <span class="chip-sep"></span>
      <button class="chip" data-g="fyr">🏢 Fyrirtæki</button>
      <button class="chip" data-g="stofnanir">🏦 Stofnanir</button>
      <button class="chip" data-g="flokkar">🚩 Flokkar</button>
      <button class="chip" data-g="radherrar">🧑‍⚖️ Ráðherrar</button>
    </div>

    <div id="rel" class="rel" hidden></div>
    <p class="rail-hint">🗞️ Fyrirsagnirnar birtast í <b>fréttastikunni hægra megin</b> og fylgja valinu hér að ofan — og reyndar síðunni sem þú ert á hverju sinni. <span class="more-link" style="display:inline">Dýpri greining: <a href="/greining/">Fjölmiðlagreiningin</a>.</span></p>
    <div id="live-wrap">
      <div id="live-list" class="live">Sæki fyrirsagnir…</div>
    </div>

    <div class="cos" id="g-stofnanir" hidden>
        {INST.map((x) => <button class="co co-ent" data-name={x.n} data-al={x.a.join(',')}><span class="co-n">{x.n}</span></button>)}
      </div>
      <div class="cos" id="g-flokkar" hidden>
        {PARTIES.map((p) => <button class="co co-ent" data-name={p.n}><span class="co-n">{p.n}</span></button>)}
      </div>
      <div class="cos" id="g-radherrar" hidden>
        {MINS.map((m) => <button class="co co-ent" data-name={m.n}><span class="co-n">{m.n}</span><span class="co-s">{m.sub}</span></button>)}
      </div>
      <div class="cos" id="g-fyr" hidden>
        {COS.map((c, i) => (
          <button class="co" data-i={i}>
            <span class="co-n">{c.n}</span>
            {c.sent && <span class={`co-s ${c.sent.idx > 15 ? 'up' : c.sent.idx < -15 ? 'dn' : ''}`}>{c.sent.idx > 0 ? '+' : ''}{c.sent.idx}</span>}
          </button>
        ))}
      </div>
      <div id="co-detail" hidden></div>

    <p class="foot">Forþjónað (SSG) {updated}. Fyrirsagnir gegnum <code>/frettir</code>-endapunkt karp.is (birtast á karp.is); viðhorf = vélrænt mat (Claude) á fyrirsögnum, ekki dómur. #2.</p>
  </main>

  <script type="application/json" id="d-cos" set:html={JSON.stringify(COS)}></script>
  <script type="application/json" id="d-rel" set:html={JSON.stringify(RELB)}></script>

  <style>
    main { max-width: 980px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 12px; } p { color: #cdd6e6; }
    .chip-sep { width: 1px; align-self: stretch; background: rgba(255,255,255,.14); margin: 0 4px; }
    .rel { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin: 2px 0 8px; }
    .rel-l { font-size: 11.5px; color: #7e8ca6; }
    .rel-b { background: rgba(25,211,197,.08); border: 1px solid rgba(25,211,197,.35); color: #19d3c5; border-radius: 999px; padding: 3px 11px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .rel-b:hover { background: rgba(25,211,197,.18); }
    .cos { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 8px; margin-top: 10px; }
    .co { display: flex; justify-content: space-between; align-items: center; gap: 8px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 10px 12px; color: #eaf1fb; font-size: 13px; font-weight: 600; cursor: pointer; text-align: left; }
    .co:hover { border-color: #f6b13b; }
    .co-s { font-size: 11px; font-weight: 800; color: #9fb0c8; }
    .co-ent .co-s { font-weight: 400; font-size: 10.5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fy-search { display: flex; gap: 8px; margin: 10px 0 12px; }
    .fy-search input { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); color: #eaf1fb; border-radius: 10px; padding: 10px 14px; font-size: 14px; outline: none; }
    .fy-search input:focus { border-color: #f6b13b; }
    .fy-search button { background: #f6b13b; color: #06121a; border: 0; border-radius: 10px; padding: 10px 18px; font-size: 13.5px; font-weight: 800; cursor: pointer; }
    .fy-search button:hover { filter: brightness(1.1); }
    .co-fl { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.16); color: #cdd6e6; border-radius: 999px; padding: 4px 14px; font-size: 12px; font-weight: 700; cursor: pointer; }
    .co-fl.on { background: rgba(70,224,138,.14); border-color: rgba(70,224,138,.5); color: #46e08a; }
    .co-s.up { color: #46e08a; } .co-s.dn { color: #ff6d7a; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .more-link { font-size: 12.5px; color: #9fb0c8; margin-top: 14px; }
    .more-link a { color: #f6b13b; }
  </style>
  <style is:global>
    /* 2 dálkar á fréttalistanum (LOTA 14) — minna skrun */
    .live { column-count: 2; column-gap: 26px; }
    @media (max-width: 760px) { .live { column-count: 1; } }
    /* LOTA 21: fyrirsagnalistinn fer af síðunni á breiðum skjá (stikan sér um hann)
       — helst sem fallback á mjóum skjá þar sem stikan er falin (<1000px). */
    .rail-hint { font-size: 13px; color: #9fb0c8; margin: 10px 0 4px; }
    @media (min-width: 1000.1px) { #live-wrap { display: none; } }
    @media (max-width: 1000px) { .rail-hint { display: none; } }
    .live .it { break-inside: avoid; }
    .live .it, #co-detail .it { display: block; padding: 9px 2px; border-bottom: 1px solid rgba(255,255,255,.07); text-decoration: none; }
    .live .it .t, #co-detail .it .t { display: block; font-size: 14px; color: #eaf1fb; line-height: 1.35; }
    .live .it:hover .t, #co-detail .it:hover .t { color: #f6b13b; }
    .live .it .s, #co-detail .it .s { display: block; font-size: 11px; color: #7e8ca6; margin-top: 2px; }
    .live-empty { font-size: 13.5px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 12px 14px; border-radius: 0 8px 8px 0; }
    #co-detail { margin-top: 16px; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 16px 18px; }
    #co-detail .d-h { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    #co-detail .d-n { font-size: 19px; font-weight: 800; color: #f6b13b; }
    #co-detail .d-tiles { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0; }
    #co-detail .d-t { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 9px; padding: 7px 11px; font-size: 12px; color: #9fb0c8; }
    #co-detail .d-t b { color: #eaf1fb; font-size: 14px; }
    #co-detail .d-t b.up { color: #46e08a; } #co-detail .d-t b.dn { color: #ff6d7a; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 12px; }
    .chip { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 5px 13px; font-size: 12.5px; font-weight: 600; cursor: pointer; }
    .chip:hover { color: #f6b13b; border-color: #f6b13b; }
    .chip.on { color: #06121a; background: #f6b13b; border-color: #f6b13b; }
    #co-detail .d-sec { font-size: 11px; font-weight: 800; color: #19d3c5; text-transform: uppercase; letter-spacing: .05em; margin: 14px 0 4px; }
    #co-detail #d-tl { width: 100%; height: 190px; }
    #co-detail .d-cloud { display: flex; flex-wrap: wrap; gap: 4px 10px; align-items: baseline; padding: 4px 0; }
    #co-detail .d-w { color: #cdd6e6; }
    #co-detail .d-w:nth-child(3n) { color: #f6b13b; } #co-detail .d-w:nth-child(3n+1) { color: #19d3c5; }
    /* Premium-spjöldin (LOTA 13, eins og gamla) */
    .se-card { background: rgba(255,255,255,.035); border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 12px 14px; margin: 10px 0; }
    /* LOTA 20: spjaldið í tvo dálka á breiðum skjá — minna skrun */
    @media (min-width: 900px) {
      .d-more { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: start; }
      .d-more .se-card { margin: 0; }
      .d-more .fy-health, .d-more .se-card:has(#d-tl), .d-more .d-sec, .d-more .pro-tease { grid-column: 1 / -1; }
    }
    /* ⭐ Pro-kynningin í spjaldinu (runtime-DOM) */
    .pro-tease { background: rgba(246,177,59,.06); border: 1px solid rgba(246,177,59,.35); border-radius: 13px; padding: 16px 18px; }
    .pt-t { font-size: 15px; font-weight: 800; color: #f6b13b; margin-bottom: 6px; }
    .pro-tease p { font-size: 13px; color: #cdd6e6; margin: 0 0 12px; }
    .pt-btns { display: flex; gap: 8px; flex-wrap: wrap; }
    .pt-main { background: #f6b13b; color: #131a29; font-weight: 800; padding: 8px 18px; border-radius: 9px; text-decoration: none; font-size: 13px; }
    .pt-sec { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.18); color: #eaf1fb; padding: 8px 16px; border-radius: 9px; text-decoration: none; font-size: 13px; }
    .se-card .se-l { font-size: 13px; font-weight: 800; color: #eaf1fb; }
    .se-sub { font-size: 11px; color: #7e8ca6; font-weight: 400; margin-left: 6px; }
    .se-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
    .se-idx { font-size: 30px; font-weight: 800; line-height: 1; text-align: right; font-variant-numeric: tabular-nums; }
    .se-idx small { display: block; font-size: 10.5px; font-weight: 600; letter-spacing: .04em; }
    .se-pos { color: #46e08a; } .se-neg { color: #ff6d7a; } .se-neu { color: #9fb0c8; }
    .se-bar { display: flex; height: 10px; border-radius: 5px; overflow: hidden; margin: 10px 0 6px; }
    .se-bar i { display: block; height: 100%; }
    .se-bneg { background: #ff6d7a; } .se-bneu { background: #5a6678; } .se-bpos { background: #46e08a; }
    .se-leg { display: flex; gap: 14px; font-size: 11.5px; flex-wrap: wrap; }
    .se-note { font-size: 11px; color: #7e8ca6; margin-top: 8px; line-height: 1.45; }
    .rv-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(118px, 1fr)); gap: 8px; margin-top: 10px; }
    .rv-tile { background: rgba(255,255,255,.045); border: 1px solid rgba(255,255,255,.09); border-radius: 10px; padding: 9px 11px; }
    .rv-tile.good { border-color: rgba(70,224,138,.4); } .rv-tile.warn { border-color: rgba(246,177,59,.4); } .rv-tile.bad { border-color: rgba(255,109,122,.4); }
    .rv-v { font-size: 17px; font-weight: 800; color: #eaf1fb; font-variant-numeric: tabular-nums; }
    .rv-tile.good .rv-v { color: #46e08a; } .rv-tile.warn .rv-v { color: #f6b13b; } .rv-tile.bad .rv-v { color: #ff6d7a; }
    .rv-l { font-size: 10.5px; color: #8fa0ba; margin-top: 2px; }
    .rv-l span { color: #7e8ca6; font-size: 10px; }
    .fy-srcrows, .fy-dist { margin-top: 10px; }
    .fy-srcrow { display: grid; grid-template-columns: 110px 1fr 44px 52px; gap: 8px; align-items: center; padding: 3px 0; }
    .fy-srcn { font-size: 11.5px; color: #cdd6e6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fy-srcbar { height: 9px; background: rgba(255,255,255,.05); border-radius: 5px; overflow: hidden; }
    .fy-srcbar i { display: block; height: 100%; border-radius: 5px; }
    .st-pos { background: #46e08a; color: #46e08a; } .st-neg { background: #ff6d7a; color: #ff6d7a; } .st-neu { background: #8892a6; color: #9fb0c8; }
    .fy-srcidx { font-size: 11.5px; font-weight: 800; text-align: right; background: none !important; font-variant-numeric: tabular-nums; }
    .fy-srcc { font-size: 10.5px; color: #7e8ca6; text-align: right; font-variant-numeric: tabular-nums; }
    .fy-d0 { background: #3a8dff; } .fy-d1 { background: #19d3c5; } .fy-d2 { background: #7c5cf7; } .fy-d3 { background: #f6b13b; }
    .fy-health { display: flex; gap: 10px; align-items: baseline; flex-wrap: wrap; border-radius: 10px; padding: 9px 13px; margin: 10px 0; font-size: 12.5px; }
    .fy-hb { font-weight: 800; white-space: nowrap; }
    .fy-ht { color: #cdd6e6; }
    .fy-h-hi { background: rgba(255,109,122,.1); border: 1px solid rgba(255,109,122,.35); }
    .fy-h-mid { background: rgba(246,177,59,.1); border: 1px solid rgba(246,177,59,.35); }
    .fy-h-lo { background: rgba(58,141,255,.08); border: 1px solid rgba(58,141,255,.3); }
    .fy-h-ok { background: rgba(70,224,138,.07); border: 1px solid rgba(70,224,138,.25); }
  </style>

  <!-- Eyja: lifandi fyrirsagnir + fyrirtækja-detail. #2 -->
  <script>
    import { loadUser, karpPost } from '../lib/auth.js';
    const esc9 = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    // Öryggi: aðeins http(s)-hlekkir úr RSS-veitunum (javascript:/data: blokkað).
    const safe9 = (u) => (/^https?:\/\//i.test(String(u || '')) ? String(u) : '#');
    const paint = (el, items, emptyMsg) => {
      // /frettir skilar {efni, cached, items:[...]} — normalísera í fylki.
      const arr = Array.isArray(items) ? items : (items && items.items) || [];
      el.innerHTML = arr.length
        ? arr.slice(0, 30).map((it) => `<a class="it" href="${esc9(safe9(it.link))}" target="_blank" rel="noopener"><span class="t">${esc9(it.title)}</span><span class="s">${esc9(it.source || '')}${it.date ? ' · ' + esc9(it.date) : ''}</span></a>`).join('')
        : `<div class="live-empty">${emptyMsg}</div>`;
    };
    const OFFLINE = 'Fyrirsagnir birtast á karp.is (CORS-varinn endapunktur).';
    const API = 'https://wp.karp.is/wp-json/karp/v1';
    function withEcharts(fn) {
      if (window.echarts) { fn(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', fn, { once: true });
    }
    function initFrettir() {
      const list = document.getElementById('live-list');
      if (!list || list.dataset.done) return;
      list.dataset.done = '1';
      // Málefnis-flísar: /frettir?efni=X (LOTA 12)
      const loadMal = (efni) => {
        list.innerHTML = 'Sæki fyrirsagnir…';
        if (efni === '__erlent') {
          // 🌍 Ísland í erlendum miðlum (Google News RSS um worker-proxy)
          fetch('/api/erlent')
            .then((r) => (r.ok ? r.text() : null))
            .then((xml) => {
              if (!xml || xml[0] === '{') { paint(list, [], 'Erlendi straumurinn birtist þegar veitan er komin í loftið.'); return; }
              const doc = new DOMParser().parseFromString(xml, 'text/xml');
              const items = [...doc.querySelectorAll('item')].map((it) => ({
                title: (it.querySelector('title') || {}).textContent || '',
                link: (it.querySelector('link') || {}).textContent || '',
                source: (it.querySelector('source') || {}).textContent || (((it.querySelector('link') || {}).textContent || '').split('//')[1] || '').split('/')[0].replace('www.', ''),
                date: ((it.querySelector('pubDate') || {}).textContent || '').slice(0, 16),
              }));
              paint(list, items, 'Engar erlendar fréttir í augnablikinu.');
            })
            .catch(() => paint(list, [], OFFLINE));
          return;
        }
        fetch(API + '/frettir' + (efni ? '?efni=' + encodeURIComponent(efni) : ''))
          .then((r) => (r.ok ? r.json() : [])).then((d) => paint(list, d, 'Engar fyrirsagnir í þessum flokki í augnablikinu.')).catch(() => paint(list, [], OFFLINE));
      };
      // SAMEINAÐA chips-röðin (LOTA 14): málefni → fréttir + tengdir aðilar; hópur → aðilagrind
      const RELB = JSON.parse(document.getElementById('d-rel').textContent || '{}');
      const relEl = document.getElementById('rel');
      const wrap = document.getElementById('live-wrap');
      const GRIDS = ['fyr', 'stofnanir', 'flokkar', 'radherrar'];
      const showGrids = (g) => GRIDS.forEach((k) => { const el = document.getElementById('g-' + k); if (el) el.hidden = k !== g; });
      const paintRel = (e) => {
        const rel = RELB[e] || [];
        if (!relEl) return;
        relEl.hidden = !rel.length;
        relEl.innerHTML = rel.length ? '<span class="rel-l">Greina aðila:</span>' + rel.map((x) => `<button class="rel-b" data-name="${esc9(x.n)}" data-al="${esc9(x.al)}">${esc9(x.n)}</button>`).join('') : '';
        relEl.querySelectorAll('.rel-b').forEach((b) => { b.onclick = () => openCo({ n: b.dataset.name, a: b.dataset.al.split(',') }); });
      };
      document.querySelectorAll('#u-chips .chip').forEach((ch) => {
        ch.onclick = () => {
          document.querySelectorAll('#u-chips .chip').forEach((x) => x.classList.toggle('on', x === ch));
          if (ch.dataset.g) { if (wrap) wrap.hidden = true; showGrids(ch.dataset.g); }
          else {
            if (wrap) wrap.hidden = false;
            showGrids(null); paintRel(ch.dataset.e); loadMal(ch.dataset.e);
            // LOTA 21: valið stýrir líka fréttastikunni hægra megin (eins og gamla kerfið)
            if (window.karpSetRailEfni) window.karpSetRailEfni(ch.dataset.e, true);
          }
        };
      });
      loadMal('');
      // Fyrirtæki: /firma → viðhorf + tímalína + orðaský + skjalasafn (LOTA 12)
      const COS = JSON.parse(document.getElementById('d-cos').textContent);
      const det = document.getElementById('co-detail');
      const th = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      // ── PREMIUM fyrirtækjaspjaldið (LOTA 13, eins og gamla + betra) ──
      const f1 = (v) => (v == null ? '—' : String(Math.round(v * 10) / 10).replace('.', ','));
      const rvCard = (rv, ccy) => {
        if (!rv || rv.mcap == null) return '';
        const ma = (v) => (v != null ? th(v / 1e9) + ' ma.kr' : '—');
        const peCls = rv.pe == null ? '' : rv.pe < 10 ? 'good' : rv.pe > 22 ? 'bad' : 'warn';
        const pbCls = rv.pb == null ? '' : rv.pb < 1 ? 'good' : rv.pb > 2.5 ? 'bad' : 'warn';
        const pbSub = rv.pb == null ? '' : rv.pb < 1 ? 'undir bókfærðu virði' : 'yfir bókfærðu virði';
        const tile = (l, v, sub, cls) => `<div class="rv-tile ${cls || ''}"><div class="rv-v">${v}</div><div class="rv-l">${l}${sub ? `<br><span>${esc9(sub)}</span>` : ''}</div></div>`;
        return `<div class="se-card"><div class="se-l">📊 Verðkennitölur — markaðsvirði og afkoma</div><div class="rv-grid">`
          + tile('Markaðsvirði', ma(rv.mcap), ccy && ccy !== 'ISK' ? 'uppgjör í ' + ccy : '')
          + tile('V/H', rv.pe != null ? f1(rv.pe) : '—', 'verð ÷ hagnaður', peCls)
          + tile('V/I', rv.pb != null ? f1(rv.pb) : '—', pbSub, pbCls)
          + tile('Arðsemi eigin fjár', rv.roe != null ? f1(rv.roe) + '%' : '—', 'ROE')
          + (rv.ni != null ? tile('Hagnaður', ma(rv.ni), 'síðasta uppgjörsár') : '')
          + `</div><div class="se-note"><b>V/I</b> = markaðsvirði ÷ bókfært eigið fé; <b>V/H</b> = verð ÷ hagnaður. Lágt V/I getur þýtt að markaðurinn meti félagið undir bókfærðu virði. Ekki fjárfestingarráðgjöf. Heimild: Yahoo Finance + uppgjör félaga.</div></div>`;
      };
      const sentCard = (s) => {
        if (!s || !s.scored) return '';
        const cls = s.idx > 15 ? 'pos' : s.idx < -15 ? 'neg' : 'neu';
        const label = s.idx > 15 ? 'Jákvætt' : s.idx < -15 ? 'Neikvætt' : 'Hlutlaust';
        const tot = (s.pos + s.neu + s.neg) || 1;
        return `<div class="se-card"><div class="se-head"><div class="se-l">🤖 Viðhorf umfjöllunar <span class="se-sub">${s.scored} fyrirsagnir · gervigreind metur tón</span></div>`
          + `<div class="se-idx se-${cls}">${s.idx > 0 ? '+' : ''}${s.idx}<small>${label}</small></div></div>`
          + `<div class="se-bar"><i class="se-bneg" style="width:${((s.neg / tot) * 100).toFixed(1)}%"></i><i class="se-bneu" style="width:${((s.neu / tot) * 100).toFixed(1)}%"></i><i class="se-bpos" style="width:${((s.pos / tot) * 100).toFixed(1)}%"></i></div>`
          + `<div class="se-leg"><span class="se-neg">▼ ${s.neg} neikvæðar</span><span class="se-neu">● ${s.neu} hlutlausar</span><span class="se-pos">▲ ${s.pos} jákvæðar</span></div>`
          + `<div class="se-note">Vísitala −100…+100 — hver fyrirsögn er metin vélrænt (jákvætt/hlutlaust/neikvætt). Til vöktunar — ekki staðfest greining.</div></div>`;
      };
      const srcToneCard = (bs) => {
        if (!bs || bs.length < 2) return '';
        const cl = (idx) => (idx > 12 ? 'pos' : idx < -12 ? 'neg' : 'neu');
        const mx = Math.max(...bs.map((x) => x.n), 1);
        return `<div class="se-card"><div class="se-l">📰 Tónn eftir fréttamiðli <span class="se-sub">hvernig hver miðill fjallar um félagið</span></div><div class="fy-srcrows">`
          + bs.map((x) => `<div class="fy-srcrow"><span class="fy-srcn">${esc9(x.s)}</span><span class="fy-srcbar"><i class="st-${cl(x.idx)}" style="width:${Math.max(6, (x.n / mx) * 100).toFixed(0)}%"></i></span><span class="fy-srcidx st-${cl(x.idx)}">${x.idx > 0 ? '+' : ''}${x.idx}</span><span class="fy-srcc">${x.n}</span></div>`).join('')
          + `</div><div class="se-note">Vísitala −100…+100 per miðli. Vélrænt mat á tóni — ekki ritstjórnardómur um hlutdrægni.</div></div>`;
      };
      const distCard = (sources, total) => {
        if (!sources || sources.length < 2) return '';
        const tot = total || sources.reduce((a, x) => a + x.n, 0) || 1;
        return `<div class="se-card"><div class="se-l">🗞️ Dreifing milli fréttamiðla <span class="se-sub">hver fjallar mest um félagið</span></div><div class="fy-dist">`
          + sources.slice(0, 8).map((x, i) => `<div class="fy-srcrow"><span class="fy-srcn">${esc9(x.s)}</span><span class="fy-srcbar"><i class="fy-d${i % 4}" style="width:${Math.max(4, (x.n / (sources[0].n || 1)) * 100).toFixed(0)}%"></i></span><span class="fy-srcc">${x.n} · ${Math.round((x.n / tot) * 100)}%</span></div>`).join('')
          + `</div></div>`;
      };
      const healthBanner = (f) => {
        const tl = (f.timeline || []).filter((p) => p && p.d);
        if (tl.length < 6 || (f.total || 0) < 12) return '';
        const vols = tl.map((p) => p.n || 0), nWk = vols.length, recN = nWk >= 14 ? 2 : 1;
        const hist = vols.slice(0, nWk - recN), rec = vols.slice(nWk - recN);
        const mean = hist.reduce((a, b) => a + b, 0) / hist.length;
        const sd = Math.sqrt(hist.reduce((a, b) => a + (b - mean) * (b - mean), 0) / hist.length) || 1;
        const recAvg = rec.reduce((a, b) => a + b, 0) / rec.length;
        const z = (recAvg - mean) / sd, ratio = mean > 0.3 ? recAvg / mean : recAvg > 1 ? 3 : 1;
        const sIdx = f.sentiment && f.sentiment.scored ? f.sentiment.idx : null;
        let level, icon, label;
        if (recAvg >= 2.5 && (z >= 2.5 || ratio >= 3)) { level = 'hi'; icon = '🔴'; label = 'Mikið frávik'; }
        else if (recAvg >= 1.8 && (z >= 1.4 || ratio >= 1.8)) { level = 'mid'; icon = '🟠'; label = 'Aukin umfjöllun'; }
        else if (recAvg < mean * 0.5 && mean > 1) { level = 'lo'; icon = '🔵'; label = 'Hljóðlátt'; }
        else { level = 'ok'; icon = '🟢'; label = 'Eðlilegt'; }
        const parts = [];
        if (level === 'hi' || level === 'mid') parts.push('Umfjöllun nýlega ' + f1(ratio) + '× yfir meðallagi síðustu mánaða');
        else if (level === 'lo') parts.push('Umfjöllun undir venju');
        else parts.push('Umfjöllun í takt við venju');
        if (sIdx != null) { if (sIdx <= -25 && level !== 'ok' && level !== 'lo') parts.push('og heildartónn neikvæður (' + sIdx + ') — fylgstu með'); else parts.push('heildartónn ' + (sIdx > 0 ? '+' : '') + sIdx); }
        return `<div class="fy-health fy-h-${level}"><span class="fy-hb">${icon} ${label}</span><span class="fy-ht">${parts.join(' · ')}.</span></div>`;
      };
      function openCo(c) {
          det.hidden = false;
          det.innerHTML = `<div class="d-h"><span class="d-n">${esc9(c.n)}</span><button class="co-fl" id="co-follow" hidden></button>${c.t ? `<a href="/markadir/" style="font-size:12px;color:#9fb0c8">${esc9(c.t)} á Mörkuðum →</a>` : ''}</div><div class="d-more"><span class="se-sub">Sæki og greini umfjöllun…</span></div><div class="d-list"></div>`;
          det.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          const dl = det.querySelector('.d-list'), dm = det.querySelector('.d-more');
          // ⭐ Umfjöllunar-spjaldið er Karp Pro (LOTA 20) — kynning í stað greiningar óinnskráð
          loadUser().then((uNow) => {
          if (!uNow || !uNow.loggedIn) {
            dm.innerHTML = `<div class="pro-tease"><div class="pt-t">⭐ Umfjöllunargreiningin er hluti af Karp Pro</div><p>Heilsumerki umfjöllunar, tónn yfir tíma, verðkennitölur, orðaský og miðladreifing fyrir <b>${esc9(c.n)}</b> — með ókeypis aðgangi.</p><div class="pt-btns"><a class="pt-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="pt-sec" href="${(uNow && uNow.loginUrl) || 'https://wp.karp.is/login/'}">Innskráning</a></div></div>`;
            dl.innerHTML = '';
            return;
          }
          fetch(API + '/firma?q=' + encodeURIComponent(c.a.join(',')) + '&days=180')
            .then((r) => (r.ok ? r.json() : null))
            .then((f) => {
              if (!f || !f.ready) { dm.innerHTML = rvCard(c.rv && { ...c.rv }, null); paint(dl, [], 'Engin nýleg umfjöllun fannst.'); return; }
              const se = f.sentiment || {};
              let mh = healthBanner(f);
              mh += rvCard(c.rvFull || c.rv, c.rvFull && c.rvFull.ccy);
              mh += sentCard(se);
              if (f.timeline && f.timeline.length > 2) mh += '<div class="se-card"><div class="se-l">📈 Umfjöllun &amp; tónn yfir tíma <span class="se-sub">vikur · litur = tónn</span></div><div id="d-tl"></div></div>';
              mh += srcToneCard(se.bySource);
              if (f.words && f.words.length) {
                const ws = f.words.slice(0, 28), mx = ws[0].n || 1;
                mh += '<div class="se-card"><div class="se-l">💬 Algengustu orð í umfjöllun</div><div class="d-cloud">' + ws.map((w) => `<span class="d-w" style="font-size:${Math.round(11 + (w.n / mx) * 16)}px;opacity:${0.55 + (w.n / mx) * 0.45}">${esc9(w.w)}</span>`).join('') + '</div></div>';
              }
              mh += distCard(f.stats && f.stats.sources, f.total);
              mh += `<div class="d-sec">Nýjasta umfjöllunin · ${f.total} fréttir sl. 6 mán${f.stats && f.stats.perDay != null ? ' · ' + String(f.stats.perDay).replace('.', ',') + ' á dag' : ''}</div>`;
              dm.innerHTML = mh;
              paint(dl, f.items || [], 'Engin nýleg umfjöllun fannst.');
              if (f.timeline && f.timeline.length > 2) withEcharts(() => {
                const el = document.getElementById('d-tl');
                if (!el || window.echarts.getInstanceByDom(el)) return;
                const ch = window.echarts.init(el);
                ch.setOption({
                  backgroundColor: 'transparent', grid: { left: 30, right: 8, top: 8, bottom: 20 },
                  tooltip: { trigger: 'axis', formatter: (ps) => { const p = ps[0]; const t = f.timeline[p.dataIndex]; return `vika ${p.name}<br><b>${t.n}</b> fréttir${t.scored ? ` · tónn ${t.idx > 0 ? '+' : ''}${t.idx}` : ''}`; } },
                  xAxis: { type: 'category', data: f.timeline.map((t) => t.d.slice(5)), axisLabel: { color: '#7e8ca6', fontSize: 9 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
                  yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', fontSize: 9 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
                  series: [{ type: 'bar', data: f.timeline.map((t) => ({ value: t.n, itemStyle: { color: t.scored ? (t.idx > 15 ? '#46e08a' : t.idx < -15 ? '#ff6d7a' : '#5a6678') : '#42506a', borderRadius: [3, 3, 0, 0] } })), barMaxWidth: 18 }],
                });
              });
            })
            .catch(() => paint(dl, [], OFFLINE));
          });
          // + Fylgja (co:-lykill í follows, sami og gamla) — LOTA 13c
          loadUser().then((u) => {
            const fb = document.getElementById('co-follow');
            if (!fb || !u || !u.loggedIn) return;
            const key = 'co:' + c.n;
            const paintF = () => { const on = (window.KARP_USER.follows || []).includes(key); fb.textContent = on ? '✓ Fylgist með' : '+ Fylgja'; fb.classList.toggle('on', on); };
            fb.hidden = false;
            paintF();
            fb.onclick = async () => {
              fb.disabled = true;
              const cur = window.KARP_USER.follows || [];
              const next = cur.includes(key) ? cur.filter((x) => x !== key) : [...cur, key];
              const res = await karpPost('/follows', { follows: next });
              window.KARP_USER.follows = (res && res.follows) ? res.follows : next;
              fb.disabled = false;
              paintF();
            };
          }).catch(() => {});
      }
      document.querySelectorAll('.co[data-i]').forEach((b) => { b.onclick = () => openCo(COS[+b.dataset.i]); });
      // Flokkar/ráðherrar + FRJÁLS LEIT (LOTA 13b) — sama premium-greining fyrir hvaða aðila sem er
      document.querySelectorAll('.co-ent[data-name]').forEach((b) => { b.onclick = () => openCo({ n: b.dataset.name, a: b.dataset.al ? b.dataset.al.split(',') : [b.dataset.name] }); });
      document.querySelectorAll('#ent-chips .chip').forEach((ch) => {
        ch.onclick = () => {
          document.querySelectorAll('#ent-chips .chip').forEach((x) => x.classList.toggle('on', x === ch));
          ['fyr', 'stofnanir', 'flokkar', 'radherrar'].forEach((g) => { const el = document.getElementById('g-' + g); if (el) el.hidden = g !== ch.dataset.g; });
        };
      });
      const q = document.getElementById('fy-q'), go = document.getElementById('fy-go');
      const doSearch = () => { const v = (q.value || '').trim(); if (v.length > 2) openCo({ n: v, a: [v] }); };
      if (go) go.onclick = doSearch;
      if (q) q.onkeydown = (e) => { if (e.key === 'Enter') doSearch(); };
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="frettir"]')) initFrettir(); });
  </script>
</Layout>
