---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Umferð: farþegar um Keflavíkurflugvöll (Hagstofa) + LIFANDI
// vegaumferð (Vegagerðin gegnum karp-umferd.php proxy, felst á localhost/CORS-bilun)
// + flug (OpenSky). Í app-skelinni.
// Gögn: daglegt snapshot úr skriptur/build_umferd.mjs → gogn/umferd.json
// (áður sótt beint á Hagstofu í frontmatter á hverri byggingu → seigla + saga).
// ⚠ Lifandi vegaumferð/flug eru áfram sótt á keyrslutíma í <script>-eyjum — ekki í snapshot. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';
import DATA from '@gogn/umferd.json';

const { KEF, updated } = DATA;
const desc = `Umferð á Íslandi — ${KEF ? groupThousands(KEF.now) + ' farþegar um Keflavíkurflugvöll í ' + KEF.nowLbl + (KEF.yoy != null ? ' (' + (KEF.yoy > 0 ? '+' : '') + fmtNum(KEF.yoy, 1) + '% frá fyrra ári)' : '') : 'flugfarþegar og vegaumferð'} auk lifandi vegaumferðar frá teljurum Vegagerðarinnar.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Umferð á Íslandi', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Farþegar um Keflavíkurflugvöll' };
---

<Layout title="Umferð — flug & vegir | Karp" description={desc} canonical="https://karp.is/umferd/" jsonLd={jsonLd} ogTitle="Umferð á Íslandi">
  <main data-pg="umferd">
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Umferð</h1>
    <p>Farþegar um Keflavíkurflugvöll (allir farþegar, mánaðarlega) og lifandi vegaumferð af teljurum Vegagerðarinnar. Heimildir: Hagstofa, Vegagerðin.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Umferðartölur: teljarar Vegagerðarinnar (um veitu Karp) og farþegatölur um Keflavíkurflugvöll frá Hagstofu.">ⓘ</i> Um gögnin á síðunni</p>

    {KEF && (
      <div class="kpis">
        <div class="kpi"><div class="k-l">✈️ Farþegar um KEF</div><div class="k-v">{groupThousands(KEF.now)}</div><div class="k-s">{KEF.nowLbl}</div></div>
        {KEF.yoy != null && <div class="kpi"><div class="k-l">📈 Breyting</div><div class={`k-v ${KEF.yoy >= 0 ? 'up' : 'dn'}`}>{KEF.yoy > 0 ? '+' : ''}{fmtNum(KEF.yoy, 1)}%</div><div class="k-s">frá sama mánuði í fyrra</div></div>}
      </div>
    )}

    <div id="veg-live" hidden>
      <h2>🚗 Vegaumferð núna</h2>
      <div class="kpis" id="veg-live-row"></div>
      <div id="veg-roads" class="roads"></div>
      <p class="srcnote">Lifandi gögn frá teljurum Vegagerðarinnar (15 mín) — birtast aðeins á karp.is.</p>
    </div>

    <div id="flug-live" hidden>
      <h2>✈️ Flug yfir Íslandi — núna</h2>
      <div class="kpis" id="flug-row"></div>
      <div id="flug-list" class="roads"></div>
      <p class="srcnote">Lifandi ratsjárgögn (ADS-B) frá OpenSky Network, uppfært á ~5 mín fresti. Sýnir loftför innan svæðisins 62,5–67,5°N.</p>
    </div>

    {KEF && (
      <>
        <h2>Farþegar um Keflavíkurflugvöll — 20 ár</h2>
        <div id="chart-kef"></div>
        <p class="srcnote">COVID-hrunið 2020–21 og endurreisnin sjást vel. Allir farþegar (brottför + koma + tenging).</p>
      </>
    )}

    <p class="foot">Forþjónað (SSG, daglegt gagna-snapshot) {updated}. Heimildir: Hagstofa (SAM02001), Vegagerðin (lifandi teljarar). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: var(--ink); }
    h2 { font-size: 15px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: var(--muted); }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-v.up { color: #46e08a; } .k-v.dn { color: #ff6d7a; }
    .k-s { font-size: 11px; color: var(--faint); }
    #chart-kef { width: 100%; height: 320px; }
    .roads { display: flex; flex-direction: column; gap: 4px; margin-top: 8px; }
    .srcnote { font-size: 12px; color: var(--faint); margin: 4px 0 0; }
    .foot { font-size: 12px; color: var(--faint); margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Vegalisti fyllist á keyrslutíma → global. */
    #veg-roads .rd { display: flex; justify-content: space-between; gap: 10px; font-size: 13px; padding: 6px 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 8px; }
    #veg-roads .rd b { color: var(--ink); font-weight: 600; }
    #veg-roads .rd span { color: var(--muted); font-variant-numeric: tabular-nums; }
  </style>

  <!-- Eyja: KEF-línurit. astro:page-load. #2 -->
  <script define:vars={{ KEF }}>
    function initKef() {
      const el = document.getElementById('chart-kef');
      if (!el || !KEF) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initKef, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const c = window.echarts.init(el);
      c.setOption({
        backgroundColor: 'transparent', grid: { left: 52, right: 14, top: 14, bottom: 40 },
        xAxis: { type: 'category', data: KEF.labels, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: 23 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: (v) => v / 1000 + 'þ' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        dataZoom: [{ type: 'inside' }, { type: 'slider', bottom: 4, height: 16, borderColor: 'rgba(255,255,255,.1)', textStyle: { color: '#7e8ca6' } }],
        tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.')) },
        series: [{ type: 'line', data: KEF.vals, symbol: 'none', lineStyle: { width: 2, color: '#f6b13b' }, areaStyle: { opacity: 0.12, color: '#f6b13b' } }],
      });
      window.addEventListener('resize', () => c.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="umferd"]')) initKef(); });
  </script>

  <!-- Eyja: lifandi vegaumferð (proxy). Felst ef ekki tiltækt. #2 -->
  <script>
    function initVeg() {
      const box = document.getElementById('veg-live');
      if (!box || box.dataset.done) return;
      fetch('/api/umferd')
        .then((r) => (r.ok ? r.json() : Promise.reject()))
        .then((d) => {
          const th = (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
          // Öryggi: vegaheiti úr lifandi veitu HTML-varin fyrir innsetningu.
          const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
          const tiles = [];
          if (d.total_today != null) tiles.push({ l: '🚗 Bílar í dag', v: th(d.total_today), s: 'samanlagt á teljurum' });
          if (d.counters != null) tiles.push({ l: '📡 Teljarar', v: th(d.counters), s: 'virkir' });
          if (!tiles.length) return;
          document.getElementById('veg-live-row').innerHTML = tiles.map((t) => `<div class="kpi"><div class="k-l">${t.l}</div><div class="k-v">${t.v}</div><div class="k-s">${t.s}</div></div>`).join('');
          const roads = Array.isArray(d.fjolfornustu) ? d.fjolfornustu.slice(0, 6) : [];
          document.getElementById('veg-roads').innerHTML = roads.map((r) => `<div class="rd"><b>${esc(String(r.nafn || r.NAFN || '').slice(0, 60))}</b><span>${th(r.umf || r.v || r.UMF_I_DAG || 0)} bílar í dag</span></div>`).join('');
          box.hidden = false;
          box.dataset.done = '1';
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="umferd"]')) initVeg(); });
  </script>

  <!-- Eyja: ✈️ lifandi flug yfir Íslandi (OpenSky um /api/flug Worker-proxy). LOTA 13 -->
  <script>
    function initFlug() {
      const wrap = document.getElementById('flug-live');
      if (!wrap || wrap.dataset.done) return;
      wrap.dataset.done = '1';
      const esc = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      fetch('/api/flug')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const states = (d && d.states) || [];
          if (!states.length) return; // proxy ekki virkur enn eða ekkert flug — fela hljóðlega
          const planes = states.map((s) => ({ cs: (s[1] || '').trim(), land: s[2] || '', alt: s[13] ?? s[7], spd: s[9], onGround: s[8] }))
            .filter((p) => p.cs && !p.onGround)
            .sort((a, b) => (b.alt || 0) - (a.alt || 0));
          const icel = planes.filter((p) => /^ICE|^FXI|^NLC/.test(p.cs)).length;
          wrap.hidden = false;
          document.getElementById('flug-row').innerHTML =
            `<div class="kpi"><div class="k-l">✈️ Á lofti yfir svæðinu</div><div class="k-v">${planes.length}</div><div class="k-s">loftför núna</div></div>`
            + `<div class="kpi"><div class="k-l">🇮🇸 Íslensk flugfélög</div><div class="k-v">${icel}</div><div class="k-s">ICE/FXI/NLC kallmerki</div></div>`;
          document.getElementById('flug-list').innerHTML = planes.slice(0, 10).map((p) =>
            `<div class="road"><span class="r-n">${esc(p.cs)}</span><span class="r-v">${p.alt ? Math.round(p.alt) + ' m' : '—'}${p.spd ? ' · ' + Math.round(p.spd * 3.6) + ' km/klst' : ''}</span><span class="r-s">${esc(p.land)}</span></div>`
          ).join('');
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="umferd"]')) initFlug(); });
  </script>
</Layout>
