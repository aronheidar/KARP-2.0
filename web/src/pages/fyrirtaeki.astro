    // Fjárhagsheilsa: vegin einkunn (0-100 + A-E) úr 4 stoðum (arðsemi/skuldsetning/lausafé/vöxtur)
    function fsHealthScore(k) {
      const nz = (v, lo, hi) => (v == null ? null : Math.max(0, Math.min(100, (v - lo) / (hi - lo) * 100)));
      const avg = (arr) => { const f = arr.filter((x) => x != null); return f.length ? f.reduce((a, b) => a + b, 0) / f.length : null; };
      const ard = avg([nz(k.hagnhlutf, -0.02, 0.12), nz(k.roe, 0, 0.2)]);
      const skuld = avg([nz(k.eiginfjarhlutf, 0.1, 0.55), nz(3 - Math.min(k.de == null ? 3 : k.de, 4), 0, 2.5)]);
      const laus = nz(k.veltufjar, 0.7, 1.8);
      const voxt = nz(k.tekjuvoxtur, -0.05, 0.15);
      let t = 0, w = 0;
      [[ard, 0.3], [skuld, 0.3], [laus, 0.2], [voxt, 0.2]].forEach((p) => { if (p[0] != null) { t += p[0] * p[1]; w += p[1]; } });
      const score = w ? Math.round(t / w) : null;
      const grade = score == null ? '–' : score >= 80 ? 'A' : score >= 65 ? 'B' : score >= 50 ? 'C' : score >= 35 ? 'D' : 'E';
      const color = score == null ? '#6b7688' : score >= 65 ? '#42d086' : score >= 50 ? '#e8b84b' : '#ef6a6a';
      return { score, grade, color, pillars: { ard, skuld, laus, voxt } };
    }
    // 💪 Heilsu-stoðir: 4 míni-súlur á bak við hringinn (arðsemi/skuldsetning/lausafé/vöxtur, 0-100)
    function fsHealthBars(hs) {
      const p = (hs && hs.pillars) || {};
      const rows = [['Arðsemi', p.ard], ['Skuldsetning', p.skuld], ['Lausafé', p.laus], ['Vöxtur', p.voxt]].filter((r) => r[1] != null);
      if (!rows.length) return '';
      const col = (v) => v >= 65 ? '#42d086' : v >= 45 ? '#e8b84b' : '#ef6a6a';
      return '<div class="kpi-pillars">' + rows.map((r) => '<div class="kpi-pil"><span class="kpi-pil-l">' + r[0] + '</span><span class="kpi-pil-t"><i style="width:' + Math.round(r[1]) + '%;background:' + col(r[1]) + '"></i></span></div>').join('') + '</div>';
    }
    // ═══ 🎯 KARP lánshæfismat (v2) ═══════════════════════════════════════════════════════════════
    // Samsett, leiðbeinandi vísbending: fjárhagsheilsa (grunnur 0–100) ± áhættuþættir úr opinberum
    // gögnum (starfsaldur, ársreikningaskil/vanskil, Lögbirtingablaðið, atvinnugreinar-viðmið F2,
    // gjaldþrota-tengsl F8, refsilista-skimun F9). EKKI formlegt lánshæfismat skv. lögum nr. 33/2005.
    // Ein einkunn per skýrsla — kemur í stað gömlu „Fjárhagsheilsa"-hringsins (fsKpiHtml) og -raðar (KYC).
    let _lh = null;
    const FS_LH_ORDER = ['fjarhagur', 'aldur', 'skil', 'vanskil', 'logbirting', 'sector', 'flakk', 'sanction'];
    const FS_LH_SKALI = 'Einkunnaskali 0–100: A 80–100 mjög sterk · B 65–79 sterk · C 50–64 í meðallagi · D 35–49 veik · E 0–34 mjög veik. Grunnurinn er fjárhagsheilsa úr ársreikningi (arðsemi, skuldsetning, lausafé, vöxtur); áhættuþættir hnika henni upp eða niður.';
    function fsLhGrade(s) { return s == null ? '–' : s >= 80 ? 'A' : s >= 65 ? 'B' : s >= 50 ? 'C' : s >= 35 ? 'D' : 'E'; }
    function fsLhColor(s) { return s == null ? '#6b7688' : s >= 65 ? '#42d086' : s >= 50 ? '#e8b84b' : '#ef6a6a'; }
    function fsLhScore() {
      if (!_lh || _lh.base == null) return null;
      let s = _lh.base, cap = 100;
      for (const k in _lh.factors) { const f = _lh.factors[k]; s += (f.delta || 0); if (f.cap != null) cap = Math.min(cap, f.cap); }
      return Math.max(0, Math.min(cap, Math.round(s)));   // þak: alvarleg merki (þrot/refsilistar) tryggja lágan flokk óháð sterkum fjárhag
    }
    function fsLhSet(key, o) { if (_lh) _lh.factors[key] = o; }
    // Aldur félags í árum úr skráningardegi (dd.mm.yyyy) — null ef óþekkt.
    function fsLhAldur(skrad) { const m = String(skrad || '').match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/); return m ? Math.floor((Date.now() - new Date(+m[3], +m[2] - 1, +m[1]).getTime()) / (365.25 * 864e5)) : null; }
    // Sein ársreikningaskil? (sama 31.8-frestur og fsSkilaSaga) — null ef engin skil skráð.
    function fsLhSkilLate(f) {
      const ars = (f.arsreikningar || []).filter((a) => a.ar && a.skil).slice(0, 6);
      if (!ars.length) return null;
      const pd = (s) => { const m = String(s || '').match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/); return m ? new Date(+m[3], +m[2] - 1, +m[1]) : null; };
      return ars.some((a) => { const yr = parseInt(a.ar, 10), d = pd(a.skil); return d && d >= new Date(yr + 1, 8, 1); });
    }
    // Grunnstilling matsins úr félaginu (samstundis: fjárhagsheilsa + aldur + skil).
    function fsLhReset(f) {
      const k0 = f.fjarhagur && f.fjarhagur.length ? (f.fjarhagur[0]._kpi || fsKpiCalc(f.fjarhagur[0], f.fjarhagur[1])) : null;
      const hs = k0 ? fsHealthScore(k0) : null;
      _lh = { base: hs && hs.score != null ? hs.score : null, factors: {} };
      fsLhSet('fjarhagur', hs && hs.score != null
        ? { icon: '📊', label: 'Fjárhagsheilsa', txt: hs.score + '/100 · ' + hs.grade, base: true, status: hs.score >= 65 ? 'g' : hs.score >= 50 ? 'o' : 'b', tip: 'Grunnur matsins: vegin einkunn úr ársreikningi — arðsemi (30%), skuldsetning (30%), lausafé (20%), vöxtur (20%). ' + FS_LH_SKALI }
        : { icon: '📊', label: 'Fjárhagsheilsa', txt: 'Enginn ársreikningur', base: true, status: 'n', tip: 'Enginn ársreikningur skráður — ekki hægt að reikna fjárhagslega einkunn; áhættuþættir birtast eftir sem áður. ' + FS_LH_SKALI });
      const yrs = fsLhAldur(f.skrad);
      if (yrs != null) fsLhSet('aldur', { icon: '🏛️', label: 'Starfsaldur', txt: yrs + ' ára' + (yrs >= 10 ? ' · rótgróið' : yrs < 2 ? ' · nýtt félag' : ''), delta: yrs >= 10 ? 4 : yrs >= 3 ? 2 : yrs < 2 ? -4 : 0, status: yrs >= 3 ? 'g' : yrs < 2 ? 'o' : 'n', tip: 'Starfsaldur frá skráningu í fyrirtækjaskrá. Rótgróin félög (10+ ára) +4, meðal (3–10) +2, ný (<2 ára) −4 — eldri rekstur er að jafnaði stöðugri.' });
      const late = fsLhSkilLate(f);
      if (late != null) fsLhSet('skil', { icon: '📅', label: 'Ársreikningaskil', txt: late ? 'Sein skil' : 'Skilað á réttum tíma', delta: late ? -5 : 2, status: late ? 'o' : 'g', tip: 'Voru ársreikningar skilaðir fyrir lögbundinn frest (31. ágúst árið eftir reikningsár)? Í tíma +2, sein skil −5 — mælikvarði á rekstrar-aga.' });
    }
    // Innmatur kortsins (hrein fall af _lh): hringur + einkunn + þátta-listi + fyrirvari.
    function fsLhBody() {
      if (!_lh) return '';
      const s = fsLhScore(), grade = fsLhGrade(s), color = fsLhColor(s);
      const band = s == null ? 'Ófullnægjandi fjárhagsgögn' : s >= 65 ? 'Sterk staða' : s >= 50 ? 'Í meðallagi' : 'Veik staða';
      const c = 163.4, off = s == null ? c : c * (1 - s / 100);
      const ring = '<svg viewBox="0 0 64 64" width="84" height="84" aria-hidden="true">'
