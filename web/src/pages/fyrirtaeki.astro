    // Vefur KYC-kortið: PEP-skimun (#fs-ar-pep) + Lögbirtingablaðið (#fs-ar-log merki + #fs-logbirting listi
    // þegar hólfin eru til staðar). Kallað BÆÐI í fullri skýrslu (fyllir aðeins #fs-logbirting; KYC-hólf
    // fjarverandi → no-op) OG í áreiðanleika-view (fyllir KYC-hólfin). Öll element-uppfærsla er null-vörðuð.
    function fsWireKyc(felag) {
      fsWirePep(felag);   // ⚖️ PEP-skimun eigenda/forráðamanna → áreiðanleiki-kort (#fs-ar-pep)
      fsWireMedia(felag);      // 📰 F7 fjölmiðlaumfjöllun
      fsWireFlakk(felag);      // 🔁 F8 gjaldþrota-tengsl
      fsWireSanction(felag);   // 🌐 F9 þvingunaraðgerða-skimun
      fsWireAreidStig();       // 🛡️ Auðgun 14 — samsett stöðumerkja-yfirlit
      fetch('/api/logbirting?kt=' + encodeURIComponent(felag.kt || '')).then((r) => (r.ok ? r.json() : null)).then((l) => {
        // → áreiðanleiki: Lögbirtingablaðs-merki (gjaldþrot/innköllun = rautt)
        const lc = document.getElementById('fs-ar-log');
        if (lc) { const lv = lc.querySelector('.fs-ar-v'); const nt = (l && l.tilkynningar) || []; const mx = nt.reduce((m, n) => Math.max(m, n.alvarleiki || 0), 0);
          if (!l || !l.holdur || !nt.length) { lc.className = 'fs-ar g'; if (lv) lv.textContent = 'Engar tilkynningar'; }
          else if (mx >= 2) { lc.className = 'fs-ar b'; if (lv) lv.textContent = 'Gjaldþrot/innköllun'; }
          else { lc.className = 'fs-ar o'; if (lv) lv.textContent = nt.length + ' tilkynning' + (nt.length > 1 ? 'ar' : ''); } }
        const el = document.getElementById('fs-logbirting');
