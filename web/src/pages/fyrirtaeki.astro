---
// ─────────────────────────────────────────────────────────────
// 🏢 FYRIRTÆKJASKRÁ (LOTA 57b) — ókeypis uppfletting félaga
// Lifandi leit í fyrirtækjaskrá Skattsins um /api/fyrirtaeki (worker-proxy,
// 24 klst skyndiminni). Prófílkortið tengir áfram í Karp-gögnin: Umfjöllun
// (Vöktun), Greiðslur frá ríkinu (samsvörun í gogn/birgjar.json) og Útboð.
// Allt UI-ið er runtime-DOM → stílar í is:global (Astro-gildran: scoped CSS
// tree-shakast ef klasinn er bara í innerHTML).
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import '../styles/ubo.css';
const desc = 'Flettu upp íslensku félagi í fyrirtækjaskrá — ókeypis: nafn, kennitala, heimilisfang, rekstrarform, ÍSAT-atvinnugrein, VSK-númer og skil ársreikninga, ásamt umfjöllun fjölmiðla, greiðslum frá ríkinu og útboðum.';
---

<Layout title="🏢 Fyrirtækjaskrá — ókeypis uppfletting | Karp" description={desc} canonical="https://karp.is/fyrirtaeki/" ogTitle="Fyrirtækjaskrá — ókeypis uppfletting félaga">
  <main data-pg="fyrirtaeki">
    <p class="kicker">Karp+ · Atvinnulíf</p>
    <h1>🏢 Fyrirtækjaskrá</h1>
    <p>Flettu upp hvaða íslenska félagi sem er — beint úr opinberri fyrirtækjaskrá Skattsins. <a href="/lausnir/fyrirtaekjaskyrsla/" style="color:#f6b13b">Um Fyrirtækjaskýrsluna →</a></p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Lifandi uppfletting í opinberri fyrirtækjaskrá Skattsins (skatturinn.is) — engin gögn geymd hjá Karp, hver leit sótt beint (24 klst skyndiminni). Sýnir skráð grunngögn: heiti, kennitölu, heimilisfang, rekstrarform, ÍSAT-atvinnugrein, VSK-númer og skil ársreikninga. Staðfest vottorð fást hjá Skattinum.">ⓘ</i> Um gögnin á síðunni</p>

    <form id="fs-form" autocomplete="off">
      <input id="fs-q" type="search" placeholder="Nafn félags eða kennitala…" autocomplete="off" aria-label="Leit í fyrirtækjaskrá" />
      <button id="fs-btn" type="submit">Fletta upp</button>
    </form>
    <div id="fs-out" aria-live="polite"></div>

    <p class="note">ⓘ Uppflettingin notar opinberu fyrirtækjaskrána og er ókeypis — sambærileg grunnuppfletting kostar áskrift annars staðar. Fyrir stærstu birgja ríkisins er stokkið beint í <a href="/birgjar/">Birgja ríkisins</a>, umfjöllun fjölmiðla er í <a href="/frettir/">Vöktun</a> og opinber innkaup í <a href="/utbod/">Útboðum</a>.</p>
    <p class="foot">Lifandi uppfletting: fyrirtækjaskrá Skattsins (skatturinn.is) um /api/fyrirtaeki — 24 klst skyndiminni. LOTA 57b.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    #fs-form { display: flex; gap: 8px; margin: 18px 0 14px; }
    #fs-q { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 11px 14px; color: #eaf1fb; font-size: 15px; }
    #fs-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #fs-btn { background: #f6b13b; color: #101623; border: 0; border-radius: 10px; padding: 0 18px; font-size: 14px; font-weight: 700; cursor: pointer; }
    #fs-btn:hover { filter: brightness(1.08); }
    .note { font-size: 12.5px; color: #8fa0b8; margin-top: 22px; } .note a { color: #f6b13b; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 14px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 12px; }
  </style>

  <style is:global>
    /* fyrirtækjaskrá — runtime-DOM (innerHTML) → verður að vera global */
    .fs-empty { color: #7e8ca6; font-size: 13.5px; padding: 14px 2px; }
    .fs-hits { border: 1px solid rgba(255,255,255,.08); border-radius: 12px; overflow: hidden; }
    .fs-hit { display: flex; gap: 12px; align-items: baseline; padding: 9px 13px; border-bottom: 1px solid rgba(255,255,255,.06); cursor: pointer; font-size: 13.5px; }
    .fs-hit:last-child { border-bottom: 0; }
    .fs-hit:hover, .fs-hit:focus-visible { background: rgba(246,177,59,.07); outline: none; }
    .fs-hit .kt { font-variant-numeric: tabular-nums; color: #7e8ca6; font-size: 12px; white-space: nowrap; }
    .fs-hit .n { color: #eaf1fb; font-weight: 600; flex: 1; }
    .fs-hit .h { color: #9fb0c8; font-size: 12px; text-align: right; }
    .fs-hit.af .n { color: #8fa0b8; font-weight: 400; }
    .fs-badge { font-size: 10.5px; color: #e78284; border: 1px solid rgba(231,130,132,.4); border-radius: 6px; padding: 1px 6px; white-space: nowrap; vertical-align: 2px; }
    .fs-more { color: #7e8ca6; font-size: 12px; padding: 8px 2px; }
    .fs-card { border: 1px solid rgba(246,177,59,.35); border-radius: 14px; padding: 18px 20px; background: rgba(255,255,255,.02); }
    .fs-card h2 { font-size: 21px; margin: 0; color: #eaf1fb; display: inline; }
    .fs-card .kt { color: #7e8ca6; font-size: 13px; margin-left: 10px; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .fs-back { background: none; border: 0; color: #f6b13b; font-size: 12.5px; cursor: pointer; padding: 0; margin: 0 0 10px; }
    .fs-back:hover { text-decoration: underline; }
    .fs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 8px 18px; margin: 14px 0 4px; }
    .fs-f { font-size: 13px; }
    .fs-f .l { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; display: block; }
    .fs-f .v { color: #cdd6e6; }
    .fs-sub { font-size: 11.5px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .05em; margin: 14px 0 6px; }
    .fs-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .fs-chip { font-size: 12px; color: #cdd6e6; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 9px; padding: 3px 9px; }
    .fs-chip b { color: #f6b13b; font-weight: 600; }
    .fs-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-top: 16px; }
    .fs-link { display: block; text-decoration: none; border: 1px solid rgba(255,255,255,.12); border-radius: 11px; padding: 10px 13px; background: rgba(255,255,255,.03); }
    .fs-link:hover { border-color: rgba(246,177,59,.5); }
    .fs-link .t { color: #eaf1fb; font-size: 13.5px; font-weight: 600; }
    .fs-link .s { color: #8fa0b8; font-size: 11.5px; margin-top: 2px; }
    .fs-link.on { border-color: rgba(246,177,59,.45); background: rgba(246,177,59,.06); }
    .fs-link.on .s { color: #f6b13b; }
    /* Pro-gátt (LOTA 63) */
    .fs-tease { background: rgba(255,255,255,.04); border: 1px solid rgba(246,177,59,.35); border-radius: 13px; padding: 16px 18px; font-size: 14px; color: #dfe7f4; line-height: 1.55; }
    .fs-tease b { color: #f6b13b; }
    .fs-tease-btns { display: flex; gap: 8px; margin-top: 12px; }
    .fs-tease-main { background: #f6b13b; color: #131a29; font-weight: 800; font-size: 13px; text-decoration: none; padding: 9px 15px; border-radius: 9px; }
    .fs-tease-sec { border: 1px solid rgba(255,255,255,.2); color: #cdd6e6; font-size: 13px; text-decoration: none; padding: 9px 15px; border-radius: 9px; }
    /* Vanskilamerki + firmavakt (LOTA 73) */
