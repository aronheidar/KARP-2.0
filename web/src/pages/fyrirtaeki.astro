    body.fs-printing #fs-report .fs-vm-n { color: #111 !important; }
    .fs-eftirlit { margin-top: 10px; }
    .fs-ef-row { display: flex; align-items: center; gap: 10px; padding: 7px 0; border-top: 1px solid rgba(255,255,255,.06); }
