          const meta = [n.domstoll, n.dagsThinghald && ('þinghald ' + n.dagsThinghald), n.frestur && ('kröfulýsingarfrestur ' + n.frestur)].filter(Boolean).map(escF).join(' · ');
          return `<div class="fs-lb-row"><span class="fs-lb-b ${sc(n.alvarleiki)}" title="Alvarleiki ${n.alvarleiki}/2">⚖</span>`
            + `<span class="fs-lb-t"><b>${escF(n.tegundHeiti)}</b>${meta ? '<br><span class="fs-lb-l">' + meta + '</span>' : ''}</span>`
            + `<span class="fs-lb-d">${escF(n.dagsetning || '')}${n.hlekkur ? '<br><a href="' + escF(n.hlekkur) + '" target="_blank" rel="noopener">tölublað' + (n.tolublad ? ' ' + escF(n.tolublad) : '') + ' ↗</a>' : ''}</span></div>`;
        }).join('');
        el.innerHTML = `<div class="fs-sub">⚖️ Lögbirtingablaðið — opinberar tilkynningar${l.count > 8 ? ' · nýjustu 8 af ' + l.count : ''}</div>${rows}`
          + `<div class="fs-kv-src">Opinber lögbirting (lög nr. 15/2005): gjaldþrotaskipti, innkallanir, skiptalok og félagsslit lögaðila · <a href="https://www.logbirtingablad.is" target="_blank" rel="noopener">logbirtingablad.is</a></div>`;
      }).catch(() => {});
    }
    // ── 🕸️ Tengslakort (task #25) — eignarhaldsnet á prófílnum ─────────────────
    // Byggir á f.eigendur (skráðir raunverulegir eigendur RSK: nafn + fæðingarár, ÁN kt).
    // Lögaðili (nafn/tegund bendir til félags) → smellur flettir því félagi upp (leita).
    // Einstaklingur → smellur opnar „möguleg tengsl" — ÖNNUR uppflett félög í þessari lotu
    // þar sem sama nafn+fæðingarár birtist (best-effort, ekki tæmandi; engin ný RSK-köll).
    const tkPct = (h) => { if (!h) return null; const m = String(h).replace(',', '.').match(/([\d.]+)/); return m ? Math.min(100, parseFloat(m[1])) : null; };
    const tkShort = (s) => { s = String(s || ''); return s.length > 28 ? s.slice(0, 26) + '…' : s; };
    const tkNorm = (s) => String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-zðþæ0-9\s]/g, ' ').replace(/\s+/g, ' ').trim();
    function tkErFelag(o) {
      if (o.faeding) return false;                       // einstaklingar hafa fæðingarár, lögaðilar ekki
      const n = String(o.nafn || ''), t = String(o.tegund || '').toLowerCase();
      if (/(^|\s)(ehf|hf|ohf|slhf|slf|sf|svf|bs)\.?\s*$/i.test(n)) return true;   // félagsform í enda nafns
      if (/félag|lögaðil|gegnum félag/.test(t)) return true;
      return false;                                      // óvíst án fæðingarárs → sýnt sem einstaklingur (varfærið)
    }
    // Lotu-vísitala uppflettra félaga (sessionStorage) — grunnur „möguleg tengsl". EKKI viðvarandi DB;
    // aðeins félög sem NOTANDI hefur flett upp í þessum vafra/lotu. Persónuvernd: aðeins nafn+fæðingarár.
    const FS_SEEN_KEY = 'karp_fs_seen_v1';
    function fsSeenLoad() { try { const r = sessionStorage.getItem(FS_SEEN_KEY); return r ? JSON.parse(r) : []; } catch (e) { return []; } }
    function fsRemember(f) {
      if (!f || !f.kt || f.demo) return;
      if (!((f.eigendur && f.eigendur.length) || f.eigendurTomt)) return;
      try {
        const list = fsSeenLoad().filter((x) => x && x.kt !== f.kt);
        list.push({ kt: f.kt, nafn: f.nafn || '', e: (f.eigendur || []).map((o) => ({ n: o.nafn || '', f: o.faeding || null })) });
        sessionStorage.setItem(FS_SEEN_KEY, JSON.stringify(list.slice(-80)));
      } catch (e) {}
    }
    function fsTengslLeit(owner, selfKt) {
      if (!owner.nafn) return [];
      const key = tkNorm(owner.nafn) + '|' + (owner.faeding || '');
      const out = [];
      for (const c of fsSeenLoad()) {
        if (!c || c.kt === selfKt) continue;
        if ((c.e || []).some((o) => tkNorm(o.n) + '|' + (o.f || '') === key)) out.push({ kt: c.kt, nafn: c.nafn });
      }
      return out;
    }
    function fsTengsl(f) {
      const has = !!(f.eigendur && f.eigendur.length);
      if (!has && !f.eigendurTomt) return '';           // ekki flett upp → ekkert kort
      const n = has ? f.eigendur.length : 0;
      const sub = '<div class="fs-sub">🕸️ Tengslakort — skráð eignarhald' + (n ? ' · ' + n + (n === 1 ? ' eigandi' : ' eigendur') : '') + '</div>';
      const empty = (!has && f.eigendurTomt) ? '<div class="tk-empty">Enginn einstaklingur skráður með raunverulegt eignarhald yfir 25% — dæmigert fyrir dreift eða skráð eignarhald. Kortið sýnir félagið sjálft.</div>' : '';
      const legend = has ? '<div class="tk-legend"><span class="tk-lg"><i class="co"></i> Félagið</span><span class="tk-lg"><i class="pe"></i> 👤 Einstaklingur — möguleg tengsl</span><span class="tk-lg"><i class="fe"></i> 🏢 Lögaðili — opna fyrirtækjaskrá</span><span class="tk-lg">Línubreidd ≈ eignarhlutur</span></div>' : '';
      const src = '<div class="tk-src">ⓘ Byggt á skráðum <b>raunverulegum eigendum</b> (>25% eða yfirráð) í fyrirtækjaskrá Skattsins. Einstaklingar birtast eins og skráin birtir þá (nafn + fæðingarár, án kennitölu). Tengsl eru <b>skráð eða möguleg</b> — ekki fullyrðing. Hvorki lánshæfismat né vanskilaskrá.</div>';
      return '<div class="tk-sec">' + sub + '<div class="tk-wrap" id="tk-wrap" role="group" aria-label="Tengslakort: skráð eignarhald félagsins"></div>' + empty + '<div class="tk-detail" id="tk-detail" hidden></div>' + legend + src + '</div>';
    }
    // Teiknar netið inn í #tk-wrap og tengir smelli. nav(q) = fletta upp félagi (kt eða nafn) í síðunni.
    function fsWireTengsl(f, nav) {
      const wrap = document.getElementById('tk-wrap');
      if (!wrap || wrap.dataset.done) return;
      wrap.dataset.done = '1';
      fsRemember(f);                                     // skrá núverandi félag í lotu-vísitölu (ekki demo)
      const owners = (f.eigendur || []).slice(0, 16).map((o, i) => ({
        i, nafn: o.nafn || '—', hlutur: o.hlutur || null, pct: tkPct(o.hlutur),
        faeding: o.faeding || null, buseta: o.buseta || null, rikisfang: o.rikisfang || null,
        tegund: o.tegund || null, felag: tkErFelag(o), pep: false,
      }));
      let lastW = -1;
      function paint(force) {
        const W = Math.max(260, Math.round(wrap.clientWidth || 640));
        if (!force && W === lastW) return;   // aðeins endurteikna þegar breidd breytist → engin ResizeObserver-lykkja
        lastW = W;
        const mob = W < 460;
        const NW = mob ? 132 : 158, NH = 48, GAP = mob ? 12 : 18;
        const CW = Math.min(W - 12, mob ? 208 : 244), CH = 58;
        const VGAP = mob ? 50 : 62, RGAP = 24;
        const N = owners.length, cx = W / 2;
        let cols = N ? Math.max(1, Math.floor((W + GAP) / (NW + GAP))) : 1;
        cols = Math.min(cols, N || 1, mob ? 2 : 4);
        const rows = N ? Math.ceil(N / cols) : 0;
        const H = CH + (N ? VGAP + rows * NH + (rows - 1) * RGAP : 0) + 4;
        let edges = '', nodes = '', chips = '';
        nodes += '<div class="tk-node tk-co" style="left:' + ((W - CW) / 2).toFixed(1) + 'px;top:0;width:' + CW + 'px;height:' + CH + 'px" title="' + escF(f.nafn || '') + '">'
          + '<span class="tk-row"><span class="tk-ic">🏢</span><span class="tk-nm tk-nm-co">' + escF(f.nafn || '—') + '</span></span>'
          + '<span class="tk-meta">kt. ' + escF(ktFmt(f.kt)) + '</span></div>';
        owners.forEach((o, k) => {
          const r = Math.floor(k / cols);
          const inRow = (r < rows - 1) ? cols : (N - cols * (rows - 1));
          const x = (W - (inRow * NW + (inRow - 1) * GAP)) / 2 + (k - r * cols) * (NW + GAP);
          const y = CH + VGAP + r * (NH + RGAP), ox = x + NW / 2, dy = y - CH;
          const sw = o.pct != null ? (1.3 + Math.min(o.pct, 100) / 100 * 2.4).toFixed(2) : '1.4';
          edges += '<path class="tk-edge" data-i="' + o.i + '" d="M' + cx.toFixed(1) + ' ' + CH + ' C' + cx.toFixed(1) + ' ' + (CH + dy * 0.45).toFixed(1)
            + ',' + ox.toFixed(1) + ' ' + (y - dy * 0.45).toFixed(1) + ',' + ox.toFixed(1) + ' ' + y.toFixed(1) + '" style="stroke-width:' + sw + 'px"'
            + (o.pct == null ? ' stroke-dasharray="4 5"' : '') + '/>';
          if (o.hlutur) chips += '<span class="tk-pct" style="left:' + ((cx + ox) / 2).toFixed(1) + 'px;top:' + ((CH + y) / 2).toFixed(1) + 'px">' + escF(o.hlutur) + '</span>';
          const meta = o.felag ? (o.tegund ? escF(tkShort(o.tegund)) : 'Lögaðili') + ' <span class="tk-open">opna ↗</span>'
                               : (o.faeding ? 'f. ' + escF(o.faeding) : 'Einstaklingur') + (o.buseta ? ' · ' + escF(o.buseta) : '');
          const al = (o.felag ? 'Lögaðili: ' : 'Einstaklingur: ') + escF(o.nafn) + (o.hlutur ? ', ' + escF(o.hlutur) : '') + (o.felag ? ' — opna fyrirtækjaskrá' : ' — sjá möguleg tengsl');
          nodes += '<button type="button" class="tk-node tk-owner ' + (o.felag ? 'tk-felag' : 'tk-person') + (o.pep ? ' tk-pep' : '')
            + '" data-i="' + o.i + '" style="left:' + x.toFixed(1) + 'px;top:' + y + 'px;width:' + NW + 'px;height:' + NH + 'px;animation-delay:' + (k * 45) + 'ms" title="' + escF(o.nafn) + '" aria-label="' + al + '">'
            + '<span class="tk-row"><span class="tk-ic">' + (o.felag ? '🏢' : '👤') + '</span><span class="tk-nm">' + escF(o.nafn) + '</span>' + (o.pep ? '<span class="tk-pepm" title="Möguleg stjórnmálatengsl (PEP)">⚖️</span>' : '') + '</span>'
            + '<span class="tk-meta">' + meta + '</span></button>';
        });
