    .fs-mailopt input { accent-color: var(--gold); cursor: pointer; margin: 0; }
    .fs-vakta { background: none; border: 1px solid rgba(246,177,59,.5); color: #f6b13b; font-size: 12.5px; font-weight: 700; border-radius: 9px; padding: 6px 12px; cursor: pointer; margin: 0 0 10px; }
    .fs-vakta:hover { background: rgba(246,177,59,.1); }
    .fs-vakta.on { background: rgba(66,208,134,.12); border-color: rgba(66,208,134,.5); color: #42d086; }
    .fs-vakta:disabled { opacity: .6; cursor: default; }
    .fs-vanskil { margin-top: 12px; font-size: 12.5px; }
    .fs-kvoti { margin-top: 8px; }
    .fs-kv-ti { font-size: 13px; color: #cdd6e6; background: rgba(58,141,255,.08); border: 1px solid rgba(58,141,255,.28); border-radius: 9px; padding: 8px 12px; }
    .fs-kv-ti b { color: #eaf1fb; } .fs-kv-ti b.pos { color: #42d086; } .fs-kv-ti b.neg { color: #e78284; }
    .fs-kv-src { font-size: 10.5px; color: #6b7688; margin-top: 5px; font-style: italic; }
    .fs-leyfi-af { color: #d9a0e6; font-size: 12px; font-weight: 600; }
    .fs-leyfi-loc { color: #8fa0b8; font-size: 11px; }
    body.fs-printing #fs-report .fs-kv-ti { background: #eef4ff !important; border-color: #b9cdf0 !important; color: #123 !important; }
    body.fs-printing #fs-report .fs-kv-ti b { color: #111 !important; } body.fs-printing #fs-report .fs-kv-src { color: #555 !important; }
    .fs-vorumerki { margin-top: 10px; }
    .fs-vms { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px; }
    .fs-vm { display: inline-flex; align-items: center; gap: 8px; max-width: 320px; border: 1px solid rgba(246,177,59,.30); border-radius: 10px; padding: 5px 9px 5px 6px; background: rgba(255,255,255,.02); text-decoration: none; color: #eaf1fb; }
    .fs-vm:hover { border-color: rgba(246,177,59,.65); }
    .fs-vm-i { width: 30px; height: 30px; flex: 0 0 30px; border-radius: 6px; object-fit: contain; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 15px; }
    .fs-vm-ph { background: rgba(246,177,59,.14); color: #f6b13b; }
    .fs-vm-n { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 190px; }
    .fs-vm-s { font-size: 11px; padding: 1px 6px; border-radius: 999px; white-space: nowrap; }
    .fs-vm-s.ok { background: rgba(70,190,120,.18); color: #6fd39b; }
    .fs-vm-s.bad { background: rgba(231,130,132,.16); color: #e78284; }
    .fs-vm-s.mid { background: rgba(126,140,166,.18); color: #9fb0c8; }
