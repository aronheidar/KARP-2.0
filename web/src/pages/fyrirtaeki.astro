    .tk-rel:hover { background: rgba(246,177,59,.12); border-color: rgba(246,177,59,.5); }
    .tk-rel .tk-nm2 { flex: 1; min-width: 0; font-size: 12.5px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tk-rel .kt { color: #8fa0b8; font-size: 11px; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .tk-relempty { font-size: 12px; color: #8fa0b8; line-height: 1.55; }
    .tk-demohint { font-size: 12.5px; color: #f0c674; line-height: 1.55; padding-right: 24px; }
    .tk-det-note { font-size: 10.5px; color: #7e8ca6; margin-top: 10px; line-height: 1.55; font-style: italic; }
    /* hreyfing: viðbót ofan á sýnilegt sjálfgefið ástand (öruggt fyrir headless/prent) */
    @media (prefers-reduced-motion: no-preference) {
      .tk-anim .tk-node { animation: tkNodeIn .5s cubic-bezier(.22,1,.36,1) both; }
      .tk-anim .tk-edge { animation: tkEdgeIn .55s ease-out both; }
    }
    @keyframes tkNodeIn { from { opacity: 0; transform: translateY(7px) scale(.97); } to { opacity: 1; transform: none; } }
    @keyframes tkEdgeIn { from { opacity: 0; } to { opacity: 1; } }
    @media (max-width: 460px) { .tk-nm { font-size: 11.5px; } .tk-nm-co { font-size: 13px; } .tk-pct { font-size: 9.5px; padding: 1px 5px; } }
    /* prent: læsilegt á hvítum pappír (kortið er innan #fs-report) */
    body.fs-printing #fs-report .tk-node { background: #fff !important; border-color: #cfd8e6 !important; box-shadow: none !important; }
    body.fs-printing #fs-report .tk-co { background: #fbf0d8 !important; border-color: #d9b871 !important; }
    body.fs-printing #fs-report .tk-nm, body.fs-printing #fs-report .tk-nm-co { color: #111 !important; }
    body.fs-printing #fs-report .tk-meta, body.fs-printing #fs-report .tk-co .tk-meta { color: #555 !important; }
    body.fs-printing #fs-report .tk-edge { stroke: #c69a4e !important; }
    body.fs-printing #fs-report .tk-pct { background: #fff !important; color: #7a5900 !important; border-color: #d9b871 !important; }
    body.fs-printing #fs-report .tk-src, body.fs-printing #fs-report .tk-legend { color: #555 !important; }
    body.fs-printing #fs-report .tk-src b { color: #222 !important; }
    /* 🎯 KARP lánshæfismat (v2) — samsett vísbending úr opinberum gögnum, EKKI formlegt lánshæfismat */
    .fs-lh { margin: 2px 0 16px; }
    .fs-lh-card { border: 1px solid rgba(246,177,59,.4); border-radius: 12px; padding: 14px 16px; background: linear-gradient(180deg, rgba(246,177,59,.07), rgba(255,255,255,.015)); }
    .fs-lh-main { display: flex; align-items: center; gap: 14px; }
    .fs-lh-ring { flex: 0 0 auto; line-height: 0; }
    .fs-lh-head { min-width: 0; }
    .fs-lh-t { font-size: 12px; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; color: #f6b13b; }
    .fs-lh-band { font-size: 16px; font-weight: 800; margin-top: 2px; line-height: 1.1; }
    .fs-lh-sub { font-size: 11.5px; color: #9fb0c8; margin-top: 3px; line-height: 1.4; }
    .fs-lh-factors { display: flex; flex-direction: column; gap: 5px; margin-top: 13px; }
    .fs-lh-f { display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 8px; background: rgba(255,255,255,.03); border-left: 3px solid #6b7688; }
    .fs-lh-f.s-g { border-left-color: #42d086; } .fs-lh-f.s-o { border-left-color: #e8b84b; } .fs-lh-f.s-b { border-left-color: #ef6a6a; } .fs-lh-f.s-n { border-left-color: #6b7688; }
    .fs-lh-fi { font-size: 14px; flex: 0 0 auto; }
    .fs-lh-fl { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; line-height: 1.25; color: #9fb0c8; font-size: 11px; }
    .fs-lh-fl b { color: #eaf1fb; font-weight: 700; font-size: 12.5px; }
    .fs-lh-fd { flex: 0 0 auto; font-variant-numeric: tabular-nums; font-weight: 800; font-size: 12.5px; color: #9fb0c8; }
    .fs-lh-f.s-g .fs-lh-fd { color: #42d086; } .fs-lh-f.s-o .fs-lh-fd { color: #e8b84b; } .fs-lh-f.s-b .fs-lh-fd { color: #ef6a6a; }
    .fs-lh-note { font-size: 11px; color: #7e8ca6; margin-top: 11px; line-height: 1.45; border-top: 1px solid rgba(255,255,255,.07); padding-top: 8px; }
    @media (max-width: 520px) { .fs-lh-main { gap: 11px; } .fs-lh-band { font-size: 15px; } }
    body.fs-printing #fs-report .fs-lh-card { background: #fff !important; border: 1px solid #ccc !important; }
    body.fs-printing #fs-report .fs-lh-f { background: #f6f8fb !important; }
    body.fs-printing #fs-report .fs-lh-t { color: #a9791a !important; }
    body.fs-printing #fs-report .fs-lh-fl b { color: #111 !important; }
    body.fs-printing #fs-report .fs-lh-sub, body.fs-printing #fs-report .fs-lh-note, body.fs-printing #fs-report .fs-lh-fl { color: #555 !important; }
    /* 🔗 .eig-* stílar fluttir í web/src/styles/ubo.css (LOTA 112) */
  </style>

  <script>
    import { loadUser, loginHref, karpGet, karpPost, isAdmin, hasReport, karpCheckout, karpWarmReports } from '../lib/auth.js';
    import { mountUboReport, renderUboSample } from '../lib/ubo-report.js';
    let FS_USER = null;
    const fsTease = () => `<div class="fs-tease"><b>⭐ Fyrirtækjaskráin er hluti af Karp+</b> — ókeypis aðgangur sem tekur mínútu. Flettu upp hvaða félagi sem er og sjáðu samtenginguna sem enginn annar birtir: umfjöllun fjölmiðla, greiðslur frá ríkinu og útboð á einum stað.<div class="fs-tease-btns"><a class="fs-tease-main" href="/karp-pro/">Hvað er Karp+?</a><a class="fs-tease-sec" href="${loginHref()}">Innskráning</a></div></div>`;
    const escF = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const ktFmt = (kt) => (kt && kt.length === 10 ? kt.slice(0, 6) + '-' + kt.slice(6) : kt || '');
    const mkrF = (v) => String(Math.round(v / 1e6)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    // birgjar.json ber 200 stærstu birgja ríkisins — nöfn þar eru STYTT (~30 stafir)
    // svo samsvörunin er normaliseruð forskeytis-samsvörun, ekki jafngildi.
    let FS_BIRGJAR = null;
    const fsBirgjar = () => FS_BIRGJAR ? Promise.resolve(FS_BIRGJAR) : fetch('/gogn/birgjar.json').then((r) => (r.ok ? r.json() : null)).then((d) => (FS_BIRGJAR = d)).catch(() => null);
    const fsNorm = (s) => String(s || '').toLowerCase().replace(/\(félag afskráð\)/g, '').replace(/[.,]/g, '').replace(/\s+(ehf|hf|slhf|ohf|sf|slf|svf|bs)$/i, '').replace(/\s+/g, ' ').trim();
    // almenn normaliseruð samsvörun (jafngildi eða forskeyti ≥10 stafir) — birgjar, útboðsvinnendur o.fl.
    function fsMatch(nafn, items, get) {
      const b = fsNorm(nafn);
      if (!b) return null;
      for (const it of items || []) {
        const a = fsNorm(get(it));
        if (!a) continue;
        if (a === b || (a.length >= 10 && b.startsWith(a)) || (b.length >= 10 && a.startsWith(b))) return it;
      }
      return null;
    }
    const fsFinnaBirgja = (vendors, nafn) => fsMatch(nafn, vendors, (v) => v.n);
    // stutt heiti án félagsforms fyrir frjálsa textaleit (fjölmiðlar, Nasdaq)
    const fsStutt = (nafn) => String(nafn || '').replace(/\s*\(félag afskráð\)/gi, '').replace(/\s+(ehf|hf|slhf|ohf|sf|slf|svf|bs)\.?$/i, '').trim();
    // ── Áreiðanleiki (KYC) + PEP-skimun (LOTA 109) ─────────────────────────────
    // PEP = stjórnmálalega tengdir aðilar. Client-hlið skimun eigenda/forráðamanna gegn
    // /gogn/pep.json (þingmenn + ráðherrar + sveitarstjórar). Fornafn+eftirnafn samsvörun →
    // „MÖGULEG tengsl" (EKKI fullyrðing: sama nafn ≠ sami einstaklingur → notandi staðfestir).
    let _pepP = null;
    function fsPep() { if (!_pepP) _pepP = fetch('/gogn/pep.json').then((r) => (r.ok ? r.json() : null)).then((j) => (j && j.folk) || []).catch(() => []); return _pepP; }
    function pepNorm(s) { return String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-zðþæ\s]/g, ' ').replace(/\s+/g, ' ').trim(); }
    function pepMatch(name, folk) {
      const t = pepNorm(name).split(' ').filter(Boolean);
      if (t.length < 2) return null;
      const first = t[0], last = t[t.length - 1];
      for (const p of folk) { const pt = (p.n || '').split(' ').filter(Boolean); if (pt.length >= 2 && pt[0] === first && pt[pt.length - 1] === last) return p; }
      return null;
    }
    async function fsPepScreen(f) {
      const folk = await fsPep();
      if (!folk.length) return [];
      const hits = [], seen = new Set();
      const chk = (rawName, role) => {
        const nm = String(rawName || '').split(' - ')[0].trim();   // "Nafn - hlutverk" → nafn
        if (!nm) return; const p = pepMatch(nm, folk);
        if (p && !seen.has(p.n)) { seen.add(p.n); hits.push({ nafn: nm, felagshlutverk: role, pep: p }); }
      };
      for (const e of (f.eigendur || [])) chk(e.nafn, 'raunv. eigandi' + (e.hlutur ? ' ' + e.hlutur : ''));
      for (const r of (f.radamenn || [])) { const parts = String(r).split(' - '); chk(parts[0], (parts[1] || 'forráðamaður').toLowerCase()); }
      return hits;
    }
    async function fsWirePep(f) {
      const chip = document.getElementById('fs-ar-pep'); if (!chip) return;
      const v = chip.querySelector('.fs-ar-v');
      const hits = await fsPepScreen(f);
      if (!hits.length) { chip.className = 'fs-ar g'; if (v) v.textContent = 'Engin þekkt'; return; }
      chip.className = 'fs-ar o';
      if (v) v.textContent = hits.length + ' möguleg';
      const d = document.getElementById('fs-ar-pep-detail');
      if (d) d.innerHTML = '⚠️ <b>Möguleg stjórnmálatengsl (PEP)</b> — nafnasamsvörun, staðfestu auðkenni: '
        + hits.map((h) => escF(h.nafn) + ' <span class="fs-ar-role">' + escF(h.felagshlutverk) + ' → ' + escF(h.pep.hlutverk) + '</span>').join('; ');
    }
    // Áreiðanleika-samantekt (KYC) — opinber stöðumerki, EKKI lánshæfismat.
    function fsAr(icon, l, v, st) { return '<div class="fs-ar ' + (st || 'n') + '"><span class="fs-ar-i">' + icon + '</span><div class="fs-ar-tx"><span class="fs-ar-l">' + l + '</span><span class="fs-ar-v">' + v + '</span></div></div>'; }
    // Aldur félags úr skráningardegi (traustmerki: eldra = rótgrónara).
    function fsSkradAldur(skrad) {
      const m = String(skrad || '').match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/);
      if (!m) return skrad || '—';
      const yrs = Math.floor((Date.now() - new Date(+m[3], +m[2] - 1, +m[1]).getTime()) / (365.25 * 864e5));
      return (skrad || '—') + (yrs >= 1 ? ' · ' + yrs + ' ára' : '');
    }
    // 📅 Ársreikningaskila-fylgni: skilaði félagið á réttum tíma? (áætluð skiladagsetn. 31.8 árið eftir).
    function fsSkilaSaga(f) {
      const ars = (f.arsreikningar || []).filter((a) => a.ar).slice(0, 6);
      if (!ars.length) return '';
      const parseD = (s) => { const m = String(s || '').match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/); return m ? new Date(+m[3], +m[2] - 1, +m[1]) : null; };
      let anyLate = false;
      const cells = ars.map((a) => {
        const yr = parseInt(a.ar, 10), d = parseD(a.skil), late = d && d >= new Date(yr + 1, 8, 1);   // 1.9 = eftir 31.8-fresti
        if (late) anyLate = true;
        const st = !a.skil ? 'n' : late ? 'o' : 'g';
        return '<span class="fs-skil ' + st + '"><b>' + escF(a.ar) + '</b><span>' + (a.skil ? escF(a.skil) + (late ? ' · seint' : ' ✓') : 'óskráð') + '</span></span>';
      }).join('');
      return '<div class="fs-sub">📅 Ársreikningaskil — tímanleiki' + (anyLate ? ' <span class="fs-skil-warn">⚠ sein skil</span>' : '') + '</div><div class="fs-skil-row">' + cells + '</div>'
        + '<div class="fs-ph-src">Grænt = skilað fyrir áætlaðan frest (31. ágúst árið eftir reikningsár, 8 mán.); gult = eftir fresti. Byggt á skráðum skiladögum RSK.</div>';
    }
    function fsAreidanleiki(f) {
      const nowY = new Date().getFullYear();
      const skra = f.afskrad ? fsAr('🏢', 'Skráning', 'Afskráð', 'b') : fsAr('🏢', 'Skráning', 'Virkt' + (f.form ? ' · ' + f.form.replace(/\s*\(.*/, '').trim() : ''), 'g');
      const arY = (f.arsreikningar || []).map((a) => parseInt(a.ar, 10)).filter(Boolean).sort((a, b) => b - a)[0];
      const skil = arY ? fsAr('📄', 'Ársreikningsskil', 'Síðast ' + arY, arY >= nowY - 2 ? 'g' : 'o') : fsAr('📄', 'Ársreikningsskil', 'Engin skráð', 'o');
      // 🎯 KARP lánshæfismat lifir í fullri skýrslunni (fsLanshaefi) — KYC-yfirlitið vísar á það og sýnir enga sér-einkunn.
      const heilsa = fsAr('🎯', 'KARP lánshæfismat', 'Í fullri fyrirtækjaskýrslu →', 'n');
      const eign = (f.eigendur && f.eigendur.length) ? fsAr('👥', 'Eignarhald', 'Gagnsætt · ' + f.eigendur.length + ' skráð', 'g') : (f.eigendurTomt ? fsAr('👥', 'Eignarhald', 'Dreift (<25%)', 'o') : fsAr('👥', 'Eignarhald', 'Óskráð', 'n'));
      return '<div class="fs-sub">🛡️ Áreiðanleiki — yfirlit (KYC)</div>'
        + '<div id="fs-ar-stig" class="fs-ar-stig n"></div>'
        + '<div class="fs-argrid">' + skra + skil + heilsa + eign
        + '<div id="fs-ar-pep" class="fs-ar n"><span class="fs-ar-i">⚖️</span><div class="fs-ar-tx"><span class="fs-ar-l">Stjórnmálatengsl (PEP)</span><span class="fs-ar-v">skima…</span></div></div>'
        + '<div id="fs-ar-log" class="fs-ar n"><span class="fs-ar-i">📜</span><div class="fs-ar-tx"><span class="fs-ar-l">Lögbirtingablaðið</span><span class="fs-ar-v">athuga…</span></div></div>'
        + '<div id="fs-ar-media" class="fs-ar n"><span class="fs-ar-i">📰</span><div class="fs-ar-tx"><span class="fs-ar-l">Fjölmiðlaumfjöllun</span><span class="fs-ar-v">athuga…</span></div></div>'
        + '<div id="fs-ar-flakk" class="fs-ar n"><span class="fs-ar-i">🔁</span><div class="fs-ar-tx"><span class="fs-ar-l">Gjaldþrota-tengsl</span><span class="fs-ar-v">athuga…</span></div></div>'
        + '<div id="fs-ar-sanction" class="fs-ar n"><span class="fs-ar-i">🌐</span><div class="fs-ar-tx"><span class="fs-ar-l">Þvingunaraðgerðir</span><span class="fs-ar-v">skima…</span></div></div>'
        + '</div>'
        + '<div id="fs-ar-pep-detail" class="fs-ar-detail"></div>'
        + '<div id="fs-ar-media-detail" class="fs-ar-detail"></div>'
        + '<div id="fs-ar-flakk-detail" class="fs-ar-detail"></div>'
        + '<div id="fs-ar-sanction-detail" class="fs-ar-detail"></div>'
        + '<div class="fs-ar-note">Samantekt á opinberum stöðumerkjum til áreiðanleikakönnunar — <b>ekki lánshæfismat</b>. Karp birtir hvorki lánshæfiseinkunn né vanskilaskrá (leyfisskyld starfsemi).</div>';
    }
    // Sjálfstæð Áreiðanleikamats-skýrsla (VERK B, ?vidmot=areidanleiki): slim haus (heiti+kt) + AÐEINS
    // KYC-kortið + Lögbirtinga-listi. Endurnýtir fsAreidanleiki/fsWireKyc — fulla skýrslan er án KYC.
    function fsAreidView(f, rsk) {
      const badge = f.afskrad ? ' <span class="fs-badge">Félag afskráð</span>' : '';
      const rskLink = rsk ? `<a class="fs-link" style="margin-top:14px" href="${escF(rsk)}" target="_blank" rel="noopener"><span class="t">🏛️ Skoða hjá Skattinum</span><div class="s">frumskráning og staðfest vottorð</div></a>` : '';
      return `<div class="fs-topbtns"><button class="fs-back" type="button">← Ný leit</button><button class="fs-vakta" id="fs-areid-print" type="button" title="Prenta eða vista áreiðanleikamatið sem PDF">🖨️ Prenta / PDF</button></div>
        <div id="fs-report">
        <div class="fs-rephead" hidden><b>🛡️ KARP — Áreiðanleikamat (KYC)</b><span>${escF(f.nafn)} · kt. ${escF(ktFmt(f.kt))} · skýrsla gerð ${new Date().toLocaleDateString('is-IS')} · karp.is/areidanleiki · heimildir: fyrirtækjaskrá og ársreikningaskrá Skattsins, Lögbirtingablaðið, PEP-listi (þing/ráðherrar/sveitarstjórnir)</span></div>
        <div class="fs-card">
          <h2>${escF(f.nafn)}</h2><span class="kt">kt. ${escF(ktFmt(f.kt))}</span>${badge}
          ${fsAreidanleiki(f)}
          <div id="fs-logbirting" class="fs-logbirting" hidden></div>
          ${rskLink}
          <div class="eig-related"><a class="eig-fulllink" href="/fyrirtaeki/?q=${escF(f.kt)}">🏢 Full fyrirtækjaskýrsla →</a><a class="eig-fulllink" href="/eigendur/?q=${escF(f.kt)}">🔗 Endanlegir eigendur →</a></div>
          <div class="fs-note2">ⓘ Áreiðanleikamat byggir á opinberum stöðumerkjum úr fyrirtækjaskrá og ársreikningaskrá Skattsins, Lögbirtingablaðinu og PEP-skimun (nafnasamsvörun — staðfestu auðkenni). <b>Hvorki lánshæfismat né vanskilaskrá</b> — slík starfsemi er leyfisskyld. Full fyrirtækjaskýrsla með fjárhagsmælaborði, eigendaneti, greiðslum og fleiru er á <a href="/fyrirtaeki/?q=${escF(f.kt)}">fyrirtækjaskránni</a>.</div>
        </div>
        </div>`;
    }
    // F7 — Fjölmiðlaumfjöllun (adverse media): endurnýtir /firma (fjölmiðlavakt Karp), félagsnafn aðal.
    // Chart 2 — vikuleg umfjöllun/tónn súlurit (/firma timeline: grænt=jákvætt, rautt=neikvætt).
    function fsMediaTimeline(tl) {
      const weeks = (tl || []).filter((w) => w && w.n > 0).slice(-26);
      if (weeks.length < 2) return '';
      const mx = Math.max.apply(null, weeks.map((w) => w.n)) || 1, bw = 8, gap = 3, h = 40;
      const bars = weeks.map((w, i) => {
        const bh = Math.max(2, Math.round(w.n / mx * (h - 6)));
        const col = w.idx == null ? '#6b7688' : w.idx > 15 ? '#42d086' : w.idx < -15 ? '#ef6a6a' : '#e8b84b';
        return '<rect x="' + (i * (bw + gap)) + '" y="' + (h - bh) + '" width="' + bw + '" height="' + bh + '" rx="2" fill="' + col + '"><title>' + escF(w.d) + ': ' + w.n + ' greinar' + (w.idx != null ? ' · tónn ' + w.idx : '') + '</title></rect>';
      }).join('');
      const wd = weeks.length * (bw + gap);
      return '<div class="fs-media-tl"><div class="fs-media-tl-h">📊 Umfjöllun eftir vikum <span>grænt = jákvætt · rautt = neikvætt</span></div><svg viewBox="0 0 ' + wd + ' ' + h + '" width="100%" style="max-width:' + Math.max(160, wd) + 'px;height:' + h + 'px" preserveAspectRatio="none">' + bars + '</svg></div>';
    }
    async function fsWireMedia(f) {
      const chip = document.getElementById('fs-ar-media'); if (!chip) return;
      const v = chip.querySelector('.fs-ar-v');
      try {
        const fj = await fetch('https://wp.karp.is/wp-json/karp/v1/firma?q=' + encodeURIComponent(fsStutt(f.nafn)) + '&days=365').then((r) => (r.ok ? r.json() : null));
        if (!fj || !fj.ready) { chip.className = 'fs-ar n'; if (v) v.textContent = 'Ekki í boði'; return; }
        const se = fj.sentiment || {}, tot = fj.total || 0;
        if (!tot) { chip.className = 'fs-ar g'; if (v) v.textContent = 'Engin umfjöllun'; return; }
        const idx = se.idx || 0, bad = se.scored && (idx < -15 || (se.neg || 0) > (se.pos || 0));
        chip.className = 'fs-ar ' + (bad ? 'o' : 'g');
        if (v) v.textContent = tot + ' grein' + (tot > 1 ? 'ar' : '') + (se.scored ? ' · tónn ' + (idx > 0 ? '+' : '') + idx : '');
