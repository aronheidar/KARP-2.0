    // Auðgun 14 — samsett áreiðanleika-yfirlit: telur opinber stöðumerki (grænt/gult/rautt). EKKI lánshæfismat.
    function fsWireAreidStig() {
      const host = document.getElementById('fs-ar-stig'); if (!host) return;
      let n = 0;
      const tick = () => {
        const chips = [].slice.call(document.querySelectorAll('.fs-argrid .fs-ar'));
        if (!chips.length) return true;
        const c = { g: 0, o: 0, b: 0, u: 0 };
        chips.forEach((el) => { const m = String(el.className).match(/fs-ar (g|o|b)\b/); c[m ? m[1] : 'u']++; });
        const done = c.u === 0, lvl = c.b ? 'b' : c.o ? 'o' : 'g';
        const lbl = c.b ? 'Alvarleg stöðumerki' : c.o >= 2 ? 'Nokkur athugunarefni' : c.o ? 'Minniháttar athugunarefni' : 'Engin neikvæð stöðumerki';
        host.className = 'fs-ar-stig ' + lvl;
        host.innerHTML = '<div class="fs-ar-stig-b">' + (c.b ? '🔴' : c.o ? '🟡' : '🟢') + '</div>'
          + '<div class="fs-ar-stig-tx"><b>' + lbl + '</b>'
          + '<span>' + (chips.length - c.u) + '/' + chips.length + ' opinberar athuganir' + (done ? '' : ' (í vinnslu…)') + ' · ' + '🟢'.repeat(c.g) + '🟡'.repeat(c.o) + '🔴'.repeat(c.b) + '</span>'
          + '<span class="fs-ar-stig-n">Samantekt á opinberum stöðumerkjum — <b>ekki lánshæfismat</b>.</span></div>';
        return done || n++ > 24;
      };
      const iv = setInterval(() => { if (tick()) clearInterval(iv); }, 700);
      tick();
