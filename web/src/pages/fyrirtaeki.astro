        wrap.innerHTML = '<svg class="tk-edges" width="' + W + '" height="' + H + '" viewBox="0 0 ' + W + ' ' + H + '" aria-hidden="true">' + edges + '</svg>' + nodes + chips;
      }
      if (!wrap.dataset.animated) { wrap.classList.add('tk-anim'); wrap.dataset.animated = '1'; setTimeout(() => { if (wrap) wrap.classList.remove('tk-anim'); }, 950); }
      paint(true);
      // PEP-skimun (endurnýtir fsPepScreen) → merkir eigenda-hnúta ⚖️ og teiknar aftur
      fsPepScreen(f).then((hits) => {
        if (!hits || !hits.length) return;
        const set = new Set(hits.map((h) => tkNorm(h.nafn)));
        let ch = false;
        owners.forEach((o) => { if (set.has(tkNorm(o.nafn))) { o.pep = true; ch = true; } });
        if (ch) paint(true);
      }).catch(() => {});
      // smellur / lyklaborð (delegað — helst þótt render() endurbyggi)
      wrap.addEventListener('click', (e) => {
        const node = e.target.closest && e.target.closest('.tk-owner'); if (!node) return;
        const o = owners[+node.dataset.i]; if (!o) return;
        o.felag ? openFelag(o) : openPerson(o);
      });
      const hot = (on) => (e) => { const nd = e.target.closest && e.target.closest('.tk-owner'); if (!nd) return; const p = wrap.querySelector('.tk-edge[data-i="' + nd.dataset.i + '"]'); if (p) p.classList.toggle('hot', on); };
      wrap.addEventListener('mouseover', hot(true)); wrap.addEventListener('mouseout', hot(false));
      wrap.addEventListener('focusin', hot(true)); wrap.addEventListener('focusout', hot(false));
      let rt = 0;
      const relayout = () => { clearTimeout(rt); rt = setTimeout(() => paint(false), 80); };   // debounce (setTimeout, ekki rAF)
      if (window.ResizeObserver) { try { new ResizeObserver(relayout).observe(wrap); } catch (e) {} }
      window.addEventListener('resize', relayout);   // + gluggabreidd → nær snúningi/stærðarbreytingu í raunvöfrum
      function facts(o) {
        const F = [];
        if (o.hlutur) F.push('<span class="tk-fct">Hlutur <b>' + escF(o.hlutur) + '</b></span>');
        if (o.faeding) F.push('<span class="tk-fct">Fæðingarár <b>' + escF(o.faeding) + '</b></span>');
        if (o.buseta) F.push('<span class="tk-fct">Búseta <b>' + escF(o.buseta) + '</b></span>');
        if (o.rikisfang) F.push('<span class="tk-fct">Ríkisfang <b>' + escF(o.rikisfang) + '</b></span>');
        if (o.tegund) F.push('<span class="tk-fct">' + escF(o.tegund) + '</span>');
        return F.join('');
      }
      function openPerson(o) {
        const det = document.getElementById('tk-detail'); if (!det) return;
        const hits = fsTengslLeit(o, f.kt);
