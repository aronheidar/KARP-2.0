    .fs-ef-b { flex: 0 0 28px; width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 15px; color: #10151f; }
    .fs-ef-b.r5 { background: #3fb950; } .fs-ef-b.r4 { background: #6fd39b; } .fs-ef-b.r3 { background: #f6b13b; } .fs-ef-b.r2 { background: #f0883e; } .fs-ef-b.r1 { background: #f85149; color: #fff; } .fs-ef-b.r0 { background: #d1242f; color: #fff; }
    .fs-ef-t { flex: 1 1 auto; font-size: 12.5px; color: #cdd6e6; min-width: 0; line-height: 1.4; }
    .fs-ef-t b { color: #eaf1fb; }
    .fs-ef-l { color: #9fb0c8; font-size: 11.5px; }
    .fs-ef-d { flex: 0 0 auto; font-size: 11px; color: #7e8ca6; white-space: nowrap; text-align: right; line-height: 1.4; }
    .fs-ef-d a { color: #f6b13b; }
    @media (max-width: 560px) { .fs-ef-d { display: none; } }
    body.fs-printing #fs-report .fs-ef-t, body.fs-printing #fs-report .fs-ef-t b { color: #123 !important; }
    body.fs-printing #fs-report .fs-ef-l { color: #445 !important; }
    .fs-styrkir { margin-top: 10px; }
    .fs-st-sum { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 6px; }
    .fs-st-chip { font-size: 11px; padding: 2px 8px; border-radius: 999px; background: rgba(246,177,59,.12); color: #f6b13b; border: 1px solid rgba(246,177,59,.28); white-space: nowrap; }
    .fs-st-row { display: flex; align-items: baseline; gap: 10px; padding: 7px 0; border-top: 1px solid rgba(255,255,255,.06); }
    .fs-st-row:first-of-type { border-top: 0; }
    .fs-st-y { flex: 0 0 40px; font-size: 12px; font-weight: 700; color: #f6b13b; }
    .fs-st-t { flex: 1 1 auto; font-size: 12.5px; color: #cdd6e6; min-width: 0; line-height: 1.4; }
    .fs-st-t b { color: #eaf1fb; }
    .fs-st-s { color: #9fb0c8; font-size: 11.5px; }
    .fs-st-a { flex: 0 0 auto; font-size: 12.5px; font-weight: 700; color: #42d086; white-space: nowrap; text-align: right; }
    .fs-st-vil { font-size: 10px; color: #f0883e; border: 1px solid rgba(240,136,62,.4); border-radius: 999px; padding: 0 5px; margin-left: 6px; vertical-align: middle; }
    body.fs-printing #fs-report .fs-st-t, body.fs-printing #fs-report .fs-st-t b { color: #123 !important; }
    body.fs-printing #fs-report .fs-st-s { color: #445 !important; }
    body.fs-printing #fs-report .fs-st-a { color: #137333 !important; }
    body.fs-printing #fs-report .fs-st-chip { color: #7a5900 !important; border-color: #d9c089 !important; background: #fbf3df !important; }
    /* Lögbirtingablaðið (LOTA 95): lögform. tilkynningar, litað eftir alvarleika (þrot=rautt) */
    .fs-logbirting { margin-top: 10px; }
    .fs-lb-row { display: flex; align-items: flex-start; gap: 10px; padding: 7px 0; border-top: 1px solid rgba(255,255,255,.06); }
    .fs-lb-row:first-of-type { border-top: 0; }
    .fs-lb-b { flex: 0 0 26px; width: 26px; height: 26px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    .fs-lb-b.s2 { background: rgba(248,81,73,.18); color: #f7776f; border: 1px solid rgba(248,81,73,.42); }
    .fs-lb-b.s1 { background: rgba(240,136,62,.16); color: #f0a35e; border: 1px solid rgba(240,136,62,.38); }
    .fs-lb-b.s0 { background: rgba(126,140,166,.16); color: #9fb0c8; border: 1px solid rgba(126,140,166,.32); }
    .fs-lb-t { flex: 1 1 auto; font-size: 12.5px; color: #cdd6e6; min-width: 0; line-height: 1.4; }
    .fs-lb-t b { color: #eaf1fb; }
    .fs-lb-l { color: #9fb0c8; font-size: 11.5px; }
    .fs-lb-d { flex: 0 0 auto; font-size: 11px; color: #7e8ca6; white-space: nowrap; text-align: right; line-height: 1.4; }
    .fs-lb-d a { color: #f6b13b; }
    @media (max-width: 560px) { .fs-lb-d { display: none; } }
    body.fs-printing #fs-report .fs-lb-t, body.fs-printing #fs-report .fs-lb-t b { color: #123 !important; }
    body.fs-printing #fs-report .fs-lb-l { color: #445 !important; }
    body.fs-printing #fs-report .fs-lb-b.s2 { color: #b3261e !important; border-color: #b3261e !important; background: #fdf0ef !important; }
    body.fs-printing #fs-report .fs-lb-b.s1 { color: #8a5000 !important; border-color: #d9a05a !important; background: #fdf5ec !important; }
    .fs-van { display: inline-block; border-radius: 8px; padding: 4px 10px; font-weight: 700; }
    .fs-van.bad { background: rgba(231,130,132,.12); border: 1px solid rgba(231,130,132,.45); color: #e78284; }
    .fs-van.ok { background: rgba(66,208,134,.1); border: 1px solid rgba(66,208,134,.35); color: #42d086; }
    .fs-vansub { color: #7e8ca6; font-size: 11.5px; }
    /* Fyrirtækjaskýrslan (LOTA 69): grind-hólf + kaupa-röð + prentútgáfa */
    .fs-rephead b { display: block; font-size: 15px; letter-spacing: .04em; }
