    // F8 — Gjaldþrota-tengsl / kennitöluflakks-vísbendingar: sama kjarna-nafn (án félagsforms), önnur kt,
    // nýlega slitið/gjaldþrota í Lögbirtingablaðinu. VÍSBENDING, ekki staðfesting.
    let _lbAll = null;
    function fsLogbirtingAll() { if (!_lbAll) _lbAll = fetch('/gogn/logbirting.json').then((r) => (r.ok ? r.json() : null)).catch(() => null); return _lbAll; }
    function fsCoreName(s) { return String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/\b(ehf|hf|slhf|ohf|sf|slf|svf|bs)\b\.?/g, '').replace(/[^a-z0-9]+/g, ' ').replace(/\s+/g, ' ').trim(); }
    async function fsWireFlakk(f) {
      const chip = document.getElementById('fs-ar-flakk'); if (!chip) return;
