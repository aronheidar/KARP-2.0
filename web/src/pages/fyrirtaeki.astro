---
// ─────────────────────────────────────────────────────────────
// 🏢 FYRIRTÆKJASKRÁ (LOTA 57b) — ókeypis uppfletting félaga
// Lifandi leit í fyrirtækjaskrá Skattsins um /api/fyrirtaeki (worker-proxy,
// 24 klst skyndiminni). Prófílkortið tengir áfram í Karp-gögnin: Umfjöllun
// (Vöktun), Greiðslur frá ríkinu (samsvörun í gogn/birgjar.json) og Útboð.
// Allt UI-ið er runtime-DOM → stílar í is:global (Astro-gildran: scoped CSS
// tree-shakast ef klasinn er bara í innerHTML).
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
const desc = 'Flettu upp íslensku félagi í fyrirtækjaskrá — ókeypis: nafn, kennitala, heimilisfang, rekstrarform, ÍSAT-atvinnugrein, VSK-númer og skil ársreikninga, ásamt umfjöllun fjölmiðla, greiðslum frá ríkinu og útboðum.';
---

<Layout title="🏢 Fyrirtækjaskrá — ókeypis uppfletting | Karp" description={desc} canonical="https://karp.is/fyrirtaeki/" ogTitle="Fyrirtækjaskrá — ókeypis uppfletting félaga">
  <main data-pg="fyrirtaeki">
    <p class="kicker">Karp Pro · Atvinnulíf</p>
    <h1>🏢 Fyrirtækjaskrá</h1>
    <p>Flettu upp hvaða íslenska félagi sem er — beint úr opinberri fyrirtækjaskrá Skattsins. Hluti af <a href="/karp-pro/" style="color:#f6b13b">Karp Pro</a> (ókeypis aðgangur). Kortið tengir svo áfram í það sem Karp veit: umfjöllun fjölmiðla, greiðslur frá ríkinu og opinber útboð.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Lifandi uppfletting í opinberri fyrirtækjaskrá Skattsins (skatturinn.is) — engin gögn geymd hjá Karp, hver leit sótt beint (24 klst skyndiminni). Sýnir skráð grunngögn: heiti, kennitölu, heimilisfang, rekstrarform, ÍSAT-atvinnugrein, VSK-númer og skil ársreikninga. Staðfest vottorð fást hjá Skattinum.">ⓘ</i> Um gögnin á síðunni</p>

    <form id="fs-form" autocomplete="off">
      <input id="fs-q" type="search" placeholder="Nafn félags eða kennitala…" autocomplete="off" aria-label="Leit í fyrirtækjaskrá" />
      <button id="fs-btn" type="submit">Fletta upp</button>
    </form>
    <div id="fs-out" aria-live="polite"></div>

    <p class="note">ⓘ Uppflettingin notar opinberu fyrirtækjaskrána og er ókeypis — sambærileg grunnuppfletting kostar áskrift annars staðar. Fyrir stærstu birgja ríkisins er stokkið beint í <a href="/birgjar/">Birgja ríkisins</a>, umfjöllun fjölmiðla er í <a href="/frettir/">Vöktun</a> og opinber innkaup í <a href="/utbod/">Útboðum</a>.</p>
    <p class="foot">Lifandi uppfletting: fyrirtækjaskrá Skattsins (skatturinn.is) um /api/fyrirtaeki — 24 klst skyndiminni. LOTA 57b.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; margin: 0 0 10px; } p { color: #cdd6e6; }
    #fs-form { display: flex; gap: 8px; margin: 18px 0 14px; }
    #fs-q { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 11px 14px; color: #eaf1fb; font-size: 15px; }
    #fs-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
    #fs-btn { background: #f6b13b; color: #101623; border: 0; border-radius: 10px; padding: 0 18px; font-size: 14px; font-weight: 700; cursor: pointer; }
    #fs-btn:hover { filter: brightness(1.08); }
    .note { font-size: 12.5px; color: #8fa0b8; margin-top: 22px; } .note a { color: #f6b13b; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 14px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 12px; }
  </style>

  <style is:global>
    /* fyrirtækjaskrá — runtime-DOM (innerHTML) → verður að vera global */
    .fs-empty { color: #7e8ca6; font-size: 13.5px; padding: 14px 2px; }
    .fs-hits { border: 1px solid rgba(255,255,255,.08); border-radius: 12px; overflow: hidden; }
    .fs-hit { display: flex; gap: 12px; align-items: baseline; padding: 9px 13px; border-bottom: 1px solid rgba(255,255,255,.06); cursor: pointer; font-size: 13.5px; }
    .fs-hit:last-child { border-bottom: 0; }
    .fs-hit:hover, .fs-hit:focus-visible { background: rgba(246,177,59,.07); outline: none; }
    .fs-hit .kt { font-variant-numeric: tabular-nums; color: #7e8ca6; font-size: 12px; white-space: nowrap; }
    .fs-hit .n { color: #eaf1fb; font-weight: 600; flex: 1; }
    .fs-hit .h { color: #9fb0c8; font-size: 12px; text-align: right; }
    .fs-hit.af .n { color: #8fa0b8; font-weight: 400; }
    .fs-badge { font-size: 10.5px; color: #e78284; border: 1px solid rgba(231,130,132,.4); border-radius: 6px; padding: 1px 6px; white-space: nowrap; vertical-align: 2px; }
    .fs-more { color: #7e8ca6; font-size: 12px; padding: 8px 2px; }
    .fs-card { border: 1px solid rgba(246,177,59,.35); border-radius: 14px; padding: 18px 20px; background: rgba(255,255,255,.02); }
    .fs-card h2 { font-size: 21px; margin: 0; color: #eaf1fb; display: inline; }
    .fs-card .kt { color: #7e8ca6; font-size: 13px; margin-left: 10px; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .fs-back { background: none; border: 0; color: #f6b13b; font-size: 12.5px; cursor: pointer; padding: 0; margin: 0 0 10px; }
    .fs-back:hover { text-decoration: underline; }
    .fs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 8px 18px; margin: 14px 0 4px; }
    .fs-f { font-size: 13px; }
    .fs-f .l { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; display: block; }
    .fs-f .v { color: #cdd6e6; }
    .fs-sub { font-size: 11.5px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .05em; margin: 14px 0 6px; }
    .fs-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .fs-chip { font-size: 12px; color: #cdd6e6; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 9px; padding: 3px 9px; }
    .fs-chip b { color: #f6b13b; font-weight: 600; }
    .fs-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-top: 16px; }
    .fs-link { display: block; text-decoration: none; border: 1px solid rgba(255,255,255,.12); border-radius: 11px; padding: 10px 13px; background: rgba(255,255,255,.03); }
    .fs-link:hover { border-color: rgba(246,177,59,.5); }
    .fs-link .t { color: #eaf1fb; font-size: 13.5px; font-weight: 600; }
    .fs-link .s { color: #8fa0b8; font-size: 11.5px; margin-top: 2px; }
    .fs-link.on { border-color: rgba(246,177,59,.45); background: rgba(246,177,59,.06); }
    .fs-link.on .s { color: #f6b13b; }
    /* Pro-gátt (LOTA 63) */
    .fs-tease { background: rgba(255,255,255,.04); border: 1px solid rgba(246,177,59,.35); border-radius: 13px; padding: 16px 18px; font-size: 14px; color: #dfe7f4; line-height: 1.55; }
    .fs-tease b { color: #f6b13b; }
    .fs-tease-btns { display: flex; gap: 8px; margin-top: 12px; }
    .fs-tease-main { background: #f6b13b; color: #131a29; font-weight: 800; font-size: 13px; text-decoration: none; padding: 9px 15px; border-radius: 9px; }
    .fs-tease-sec { border: 1px solid rgba(255,255,255,.2); color: #cdd6e6; font-size: 13px; text-decoration: none; padding: 9px 15px; border-radius: 9px; }
    /* Vanskilamerki + firmavakt (LOTA 73) */
    .fs-topbtns { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
    .fs-vakta { background: none; border: 1px solid rgba(246,177,59,.5); color: #f6b13b; font-size: 12.5px; font-weight: 700; border-radius: 9px; padding: 6px 12px; cursor: pointer; margin: 0 0 10px; }
    .fs-vakta:hover { background: rgba(246,177,59,.1); }
    .fs-vakta.on { background: rgba(66,208,134,.12); border-color: rgba(66,208,134,.5); color: #42d086; }
    .fs-vakta:disabled { opacity: .6; cursor: default; }
    .fs-vanskil { margin-top: 12px; font-size: 12.5px; }
    .fs-van { display: inline-block; border-radius: 8px; padding: 4px 10px; font-weight: 700; }
    .fs-van.bad { background: rgba(231,130,132,.12); border: 1px solid rgba(231,130,132,.45); color: #e78284; }
    .fs-van.ok { background: rgba(66,208,134,.1); border: 1px solid rgba(66,208,134,.35); color: #42d086; }
    .fs-vansub { color: #7e8ca6; font-size: 11.5px; }
    /* Fyrirtækjaskýrslan (LOTA 69): grind-hólf + kaupa-röð + prentútgáfa */
    .fs-rephead b { display: block; font-size: 15px; letter-spacing: .04em; }
    .fs-rephead span { display: block; font-size: 11px; margin: 2px 0 10px; line-height: 1.5; }
    .fs-ph-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
    .fs-ph { border: 1.5px dashed rgba(255,255,255,.22); border-radius: 11px; padding: 11px 13px; background: rgba(255,255,255,.02); }
    .fs-ph b { display: block; color: #9fb0c8; font-size: 13px; margin-bottom: 4px; }
    .fs-ph span { color: #7e8ca6; font-size: 11.5px; line-height: 1.5; }
    .fs-ph a { color: #f6b13b; }
    .fs-ph.filled { border-style: solid; border-color: rgba(66,208,134,.32); background: rgba(66,208,134,.05); }
    .fs-ph.filled b { color: #eaf1fb; }
    .fs-eig { font-size: 12.5px; color: #cdd6e6; padding: 5px 0; border-top: 1px solid rgba(255,255,255,.06); }
    .fs-eig:first-of-type { border-top: none; }
    .fs-eig > b { display: inline; color: #eaf1fb; font-size: 13px; }
    .fs-eig-h { color: #f6b13b; font-weight: 700; }
    .fs-eig-s { display: block; color: #7e8ca6; font-size: 11px; margin-top: 1px; }
    .fs-ph-src { display: block; color: #6b7688; font-size: 10.5px; margin-top: 8px; font-style: italic; }
    body.fs-printing #fs-report .fs-ph.filled { border-color: #9ad9b5 !important; background: #f2fbf6 !important; }
    body.fs-printing #fs-report .fs-eig, body.fs-printing #fs-report .fs-eig > b { color: #222 !important; }
    body.fs-printing #fs-report .fs-eig-s, body.fs-printing #fs-report .fs-ph-src { color: #555 !important; }
    .fs-note2 { font-size: 11.5px; color: #7e8ca6; margin-top: 14px; line-height: 1.5; border-top: 1px solid rgba(255,255,255,.07); padding-top: 10px; }
    .fs-buyrow { display: flex; align-items: center; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
    .fs-buy { background: #f6b13b; color: #131a29; border: 0; border-radius: 10px; padding: 10px 16px; font-size: 13.5px; font-weight: 800; cursor: pointer; }
    .fs-buy:hover { filter: brightness(1.08); } .fs-buy:disabled { opacity: .7; cursor: default; }
    .fs-buynote { font-size: 11px; color: #7e8ca6; }
    @media print {
      body.fs-printing * { visibility: hidden; }
      body.fs-printing #fs-report, body.fs-printing #fs-report * { visibility: visible; }
      body.fs-printing #fs-report { position: absolute; left: 0; top: 0; width: 100%; background: #fff !important; color: #111; }
      body.fs-printing #fs-report .fs-rephead { display: block !important; visibility: visible; color: #111; }
      body.fs-printing #fs-report .fs-rephead[hidden] { display: block !important; }
      body.fs-printing #fs-report .fs-card { border: 1px solid #ccc !important; background: #fff !important; }
      body.fs-printing #fs-report .fs-card h2 { color: #111 !important; }
      body.fs-printing #fs-report .fs-f .v, body.fs-printing #fs-report .fs-chip { color: #222 !important; }
      body.fs-printing #fs-report .fs-f .l, body.fs-printing #fs-report .fs-sub, body.fs-printing #fs-report .kt { color: #555 !important; }
      body.fs-printing #fs-report .fs-chip { background: #f4f6f9 !important; border-color: #ddd !important; }
      body.fs-printing #fs-report .fs-chip b { color: #b07500 !important; }
      body.fs-printing #fs-report .fs-link { border-color: #ddd !important; background: #fff !important; }
      body.fs-printing #fs-report .fs-link .t { color: #111 !important; }
      body.fs-printing #fs-report .fs-link .s { color: #444 !important; }
      body.fs-printing #fs-report .fs-link.on { border-color: #b07500 !important; background: #fdf8ec !important; }
      body.fs-printing #fs-report .fs-link.on .s { color: #b07500 !important; }
      body.fs-printing #fs-report .fs-ph { border-color: #ccc !important; background: #fafbfc !important; }
      body.fs-printing #fs-report .fs-ph b { color: #444 !important; }
      body.fs-printing #fs-report .fs-ph span, body.fs-printing #fs-report .fs-note2 { color: #555 !important; }
      body.fs-printing #fs-report .fs-badge { color: #b3261e !important; border-color: #b3261e !important; }
      body.fs-printing #fs-report .fs-van.bad { color: #b3261e !important; border-color: #b3261e !important; background: #fdf0ef !important; }
      body.fs-printing #fs-report .fs-van.ok { color: #0a7a43 !important; border-color: #0a7a43 !important; background: #effaf3 !important; }
      body.fs-printing #fs-report .fs-vansub { color: #555 !important; }
    }
  </style>

  <script>
    import { loadUser, loginHref, karpGet, karpPost } from '../lib/auth.js';
    let FS_USER = null;
    const fsTease = () => `<div class="fs-tease"><b>⭐ Fyrirtækjaskráin er hluti af Karp Pro</b> — ókeypis aðgangur sem tekur mínútu. Flettu upp hvaða félagi sem er og sjáðu samtenginguna sem enginn annar birtir: umfjöllun fjölmiðla, greiðslur frá ríkinu og útboð á einum stað.<div class="fs-tease-btns"><a class="fs-tease-main" href="/karp-pro/">Hvað er Karp Pro?</a><a class="fs-tease-sec" href="${loginHref()}">Innskráning</a></div></div>`;
    const escF = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const ktFmt = (kt) => (kt && kt.length === 10 ? kt.slice(0, 6) + '-' + kt.slice(6) : kt || '');
    const mkrF = (v) => String(Math.round(v / 1e6)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    // birgjar.json ber 200 stærstu birgja ríkisins — nöfn þar eru STYTT (~30 stafir)
    // svo samsvörunin er normaliseruð forskeytis-samsvörun, ekki jafngildi.
    let FS_BIRGJAR = null;
    const fsBirgjar = () => FS_BIRGJAR ? Promise.resolve(FS_BIRGJAR) : fetch('/gogn/birgjar.json').then((r) => (r.ok ? r.json() : null)).then((d) => (FS_BIRGJAR = d)).catch(() => null);
    const fsNorm = (s) => String(s || '').toLowerCase().replace(/\(félag afskráð\)/g, '').replace(/[.,]/g, '').replace(/\s+(ehf|hf|slhf|ohf|sf|slf|svf|bs)$/i, '').replace(/\s+/g, ' ').trim();
    // almenn normaliseruð samsvörun (jafngildi eða forskeyti ≥10 stafir) — birgjar, útboðsvinnendur o.fl.
    function fsMatch(nafn, items, get) {
      const b = fsNorm(nafn);
      if (!b) return null;
      for (const it of items || []) {
        const a = fsNorm(get(it));
        if (!a) continue;
        if (a === b || (a.length >= 10 && b.startsWith(a)) || (b.length >= 10 && a.startsWith(b))) return it;
      }
      return null;
    }
    const fsFinnaBirgja = (vendors, nafn) => fsMatch(nafn, vendors, (v) => v.n);
    // stutt heiti án félagsforms fyrir frjálsa textaleit (fjölmiðlar, Nasdaq)
    const fsStutt = (nafn) => String(nafn || '').replace(/\s*\(félag afskráð\)/gi, '').replace(/\s+(ehf|hf|slhf|ohf|sf|slf|svf|bs)\.?$/i, '').trim();
    function fsKort(felag, rsk) {
      const f = felag;
      const rod = (l, v) => (v ? `<div class="fs-f"><span class="l">${l}</span><span class="v">${escF(v)}</span></div>` : '');
      const badge = f.afskrad ? ' <span class="fs-badge">Félag afskráð</span>' : '';
      const isat = (f.isat || []).map((x) => `<span class="fs-chip">${escF(x)}</span>`).join('');
      const vsk = (f.vsk || []).map((v) => `<span class="fs-chip"><b>${escF(v.nr)}</b> skráð ${escF(v.skrad || '–')}${v.afskrad ? ' · afskráð ' + escF(v.afskrad) : ''}</span>`).join('');
      const ars = (f.arsreikningar || []).slice(0, 5).map((a) => `<span class="fs-chip"><b>${escF(a.ar)}</b>${a.skil ? ' skilað ' + escF(a.skil) : ''}</span>`).join('');
      // LOTA 74: raunverulegir eigendur eru OPNIR á RSK-detail-síðunni — fyllum eigenda-hólfið
      const eig = (f.eigendur || []).map((e) => `<div class="fs-eig"><b>${escF(e.nafn)}</b>${e.hlutur ? ' <span class="fs-eig-h">' + escF(e.hlutur) + '</span>' : ''}<span class="fs-eig-s">${[e.faeding, e.buseta, e.tegund].filter(Boolean).map(escF).join(' · ')}</span></div>`).join('');
      // LOTA 69: prófílkortið er um leið FYRIRTÆKJASKÝRSLA — Karp-samtengingin fyllist lifandi
      // og grind-hólfin (ársreikningar/eigendur/stjórn) standa tilbúin fyrir API Skattsins.
      return `<div class="fs-topbtns"><button class="fs-back" type="button">← Ný leit</button><button class="fs-vakta" id="fs-vakta" type="button" data-kt="${escF(f.kt)}" data-nafn="${escF(f.nafn)}">🔔 Vakta félagið</button></div>
        <div id="fs-report">
        <div class="fs-rephead" hidden><b>🐟 KARP — Fyrirtækjaskýrsla</b><span>${escF(f.nafn)} · kt. ${escF(ktFmt(f.kt))} · skýrsla gerð ${new Date().toLocaleDateString('is-IS')} · karp.is/fyrirtaeki · heimildir: fyrirtækjaskrá Skattsins, opnirreikningar.is, TED/útboðsvefir, Nasdaq-kauphallartilkynningar, fjölmiðlavakt Karp</span></div>
        <div class="fs-card">
          <h2>${escF(f.nafn)}</h2><span class="kt">kt. ${escF(ktFmt(f.kt))}</span>${badge}
          <div class="fs-grid">
            ${rod('Skráð', f.skrad)}${rod('Rekstrarform', f.form)}${rod('Lögheimili', f.logheimili)}
            ${rod('Póstfang', f.postfang !== f.logheimili ? f.postfang : '')}${rod('Sveitarfélag', f.svf)}
            ${rod('Forráðamaður', (f.radamenn || []).join(' · '))}${rod('Eldri heiti', (f.heiti || []).join(' · '))}
          </div>
          ${isat ? '<div class="fs-sub">ÍSAT atvinnugrein</div><div class="fs-chips">' + isat + '</div>' : ''}
          ${vsk ? '<div class="fs-sub">VSK-númer</div><div class="fs-chips">' + vsk + '</div>' : ''}
          ${ars ? '<div class="fs-sub">Ársreikningar (skil)</div><div class="fs-chips">' + ars + '</div>' : ''}
          <div id="fs-vanskil" class="fs-vanskil" hidden></div>
          <div class="fs-sub">Karp-samtengingin — umfjöllun, ríkisviðskipti og útboð á einum stað</div>
          <div class="fs-links">
            <a class="fs-link" id="fs-umfj" href="/frettir/"><span class="t">📰 Umfjöllun fjölmiðla</span><div class="s">tel fyrirsagnir í fjölmiðlavaktinni…</div></a>
            <a class="fs-link" id="fs-birgir" href="/birgjar/"><span class="t">💸 Greiðslur frá ríkinu</span><div class="s">athuga birgjaskrána…</div></a>
            <a class="fs-link" id="fs-utb" href="/utbod/"><span class="t">🏆 Útboð unnin</span><div class="s">athuga úrslitaskrána…</div></a>
            <a class="fs-link" id="fs-tilk" href="/frettir/"><span class="t">📣 Kauphallartilkynningar</span><div class="s">athuga Nasdaq-veituna…</div></a>
            ${rsk ? `<a class="fs-link" href="${escF(rsk)}" target="_blank" rel="noopener"><span class="t">🏛️ Skoða hjá Skattinum</span><div class="s">frumskráning og staðfest vottorð</div></a>` : ''}
          </div>
          <div class="fs-sub">Eigendur, fjárhagur og stjórn</div>
          <div class="fs-ph-grid">
            ${eig
              ? `<div class="fs-ph filled"><b>👥 Raunverulegir eigendur</b>${eig}<span class="fs-ph-src">Skráðir raunverulegir eigendur (>25% eða yfirráð) — fyrirtækjaskrá Skattsins</span></div>`
              : (f.eigendurTomt
                ? `<div class="fs-ph filled"><b>👥 Raunverulegir eigendur</b><span>Enginn einstaklingur skráður með raunverulegt eignarhald yfir 25% — dæmigert fyrir skráð félög og dreift eignarhald.</span></div>`
                : `<div class="fs-ph"><b>👥 Eigendur</b><span>Raunverulegir eigendur birtast hér þegar þeir eru skráðir í fyrirtækjaskrá.</span></div>`)}
            <div class="fs-ph"><b>📊 Ársreikningar í tölum</b><span>Tekjur, afkoma og eigið fé — Skatturinn birtir ársreikningana á rafrænu formi án endurgjalds${rsk ? `; <a href="${escF(rsk)}" target="_blank" rel="noopener">sæktu þá hjá Skattinum</a>` : ''}. Sjálfvirkur lykiltölu-lestur bíður API-aðgangs.</span></div>
            <div class="fs-ph"><b>🪑 Stjórn & prókúra</b><span>${(f.radamenn || []).length ? 'Forráðamaður: <b style="color:#cdd6e6">' + escF((f.radamenn || []).join(' · ')) + '</b>. ' : ''}Fullur stjórnarlisti og prókúruhafar bíða API-aðgangs að hlutafélagaskrá.</span></div>
          </div>
          <div class="fs-note2">ⓘ Skýrslan byggir á opinberum gögnum (fyrirtækjaskrá og ársreikningaskrá Skattsins — þ.m.t. skráðir raunverulegir eigendur, opnirreikningar.is, TED/útboðsvefir, Nasdaq) og fjölmiðlavakt Karp. Karp birtir hvorki lánshæfismat né vanskilaskrá — slík starfsemi er leyfisskyld. Staðfest vottorð fást hjá Skattinum.</div>
        </div>
        </div>
        <div class="fs-buyrow"><button id="fs-buy" class="fs-buy" type="button">🛒 Kaupa skýrslu — 0 kr.</button><span class="fs-buynote">Kynningarverð · opnast sem PDF til að vista eða prenta</span></div>`;
    }
    function initFs() {
      const form = document.getElementById('fs-form');
      const inp = document.getElementById('fs-q');
      const out = document.getElementById('fs-out');
      if (!form || form.dataset.done) return;
      form.dataset.done = '1';
      const skila = (html) => { out.innerHTML = html; };
      function leita(q, fraSmell) {
        q = String(q || '').trim();
        if (q.length < 2) { skila('<div class="fs-empty">Sláðu inn a.m.k. 2 stafi — nafn félags eða kennitölu.</div>'); return; }
        if (fraSmell) inp.value = q;
        try { history.replaceState(null, '', '/fyrirtaeki/?q=' + encodeURIComponent(q)); } catch (e) {}
        skila('<div class="fs-empty">Fletti upp í fyrirtækjaskrá…</div>');
        fetch('/api/fyrirtaeki?q=' + encodeURIComponent(q))
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            if (!d || d.error) { skila('<div class="fs-empty">Ekki náðist í fyrirtækjaskrána í augnablikinu — reyndu aftur eftir andartak.</div>'); return; }
            if (d.felag) {
              skila(fsKort(d.felag, d.rsk));
              out.querySelector('.fs-back').onclick = () => { skila(''); inp.value = ''; inp.focus(); try { history.replaceState(null, '', '/fyrirtaeki/'); } catch (e) {} };
              // 💸 er félagið meðal 200 stærstu birgja ríkisins?
              fsBirgjar().then((b) => {
                const el = document.getElementById('fs-birgir');
                if (!el) return;
                const v = b && fsFinnaBirgja(b.vendors, d.felag.nafn);
                el.querySelector('.s').textContent = v
                  ? mkrF(v.t) + ' m.kr frá ríkinu sl. 12 mán' + (v.o ? ' — mest frá ' + v.o : '')
                  : 'ekki meðal 200 stærstu birgja ríkisins';
                if (v) el.classList.add('on');
              });
              // 🏆 útboðsúrslit (TED-awards + LV-opnanir, LOTA 69)
              fetch('/gogn/utbod_urslit.json').then((r) => (r.ok ? r.json() : null)).then((uu) => {
                const el = document.getElementById('fs-utb');
                if (!el || !uu) return;
                const w = fsMatch(d.felag.nafn, Object.values(uu.byWinner || {}), (x) => x.nafn);
                el.querySelector('.s').textContent = w
                  ? w.n + (w.n === 1 ? ' útboð unnið' : ' útboð unnin') + ' · ' + mkrF(w.isk) + ' m.kr samtals (TED/LV-vakt)'
                  : 'engin skráð útboðsúrslit í TED/LV-vaktinni';
                if (w) el.classList.add('on');
              }).catch(() => {});
              // 📰 umfjöllun fjölmiðla (fjölmiðlavakt Karp, sl. 180 dagar) — fallback ef veitan svarar ekki
              fetch('https://wp.karp.is/wp-json/karp/v1/firma?q=' + encodeURIComponent(fsStutt(d.felag.nafn)) + '&days=180').then((r) => (r.ok ? r.json() : null)).then((fj) => {
                const el = document.getElementById('fs-umfj');
                if (!el) return;
                const se = fj && fj.ready && fj.sentiment;
                el.querySelector('.s').textContent = se && se.scored
                  ? se.scored + ' fyrirsagnir sl. 180 daga · viðhorf ' + (se.idx > 0 ? '+' : '') + se.idx + ' (' + (se.idx > 15 ? 'jákvætt' : se.idx < -15 ? 'neikvætt' : 'hlutlaust') + ')'
                  : 'engin nýleg umfjöllun í fjölmiðlavaktinni';
                if (se && se.scored) el.classList.add('on');
              }).catch(() => { const el = document.getElementById('fs-umfj'); if (el) el.querySelector('.s').textContent = 'fréttir, tónn og tímalínur í fjölmiðlavaktinni →'; });
              // 📣 kauphallartilkynningar (Nasdaq) — freeText nær líka í ÖNNUR félög sem nefna
              // nafnið í meginmáli → sía á útgefandann sjálfan (annars birtist t.d. Reitir undir Origo)
              fetch('/api/tilkynningar?co=' + encodeURIComponent(fsStutt(d.felag.nafn))).then((r) => (r.ok ? r.json() : null)).then((tk) => {
                const el = document.getElementById('fs-tilk');
                if (!el) return;
                const b = fsNorm(fsStutt(d.felag.nafn));
                const items = ((tk && tk.items) || []).filter((x) => { const a = fsNorm(x.co); return a && b && (a === b || a.startsWith(b) || b.startsWith(a)); });
                el.querySelector('.s').textContent = items.length
                  ? items.length + (items.length >= 10 ? '+' : '') + ' tilkynningar · síðast: „' + (items[0].t || '').slice(0, 60) + '“ (' + (items[0].d || '').slice(0, 10) + ')'
                  : 'engar kauphallartilkynningar (félag ekki skráð á markað)';
                if (items.length) el.classList.add('on');
              }).catch(() => {});
              // ⚠ Vanskilastaða ársreikningaskila (LOTA 73) — opinber listi ársreikningaskrár RSK
              fetch('/api/vanskil?kt=' + encodeURIComponent(d.felag.kt || '')).then((r) => (r.ok ? r.json() : null)).then((v) => {
                const el = document.getElementById('fs-vanskil');
                if (!el || !v || !Array.isArray(v.ar)) return;
                el.hidden = false;
                el.innerHTML = v.ar.length
                  ? '<span class="fs-van bad">⚠ Í vanskilum með ársreikning: ' + v.ar.map((x) => escF(String(x.ar)) + ' (' + escF(x.vanskil) + ')').join(' · ') + '</span> <span class="fs-vansub">opinber listi ársreikningaskrár Skattsins</span>'
                  : '<span class="fs-van ok">✓ Engin vanskil á ársreikningaskilum</span> <span class="fs-vansub">rekstrarár ' + v.skodud.join(' og ') + ' · ársreikningaskrá Skattsins</span>';
              }).catch(() => {});
              // 🔔 Firmavakt (LOTA 73): breytinga- og vanskilavakt á félagið í tölvupósti
              const vb = document.getElementById('fs-vakta');
              if (vb) {
                const vkt = vb.dataset.kt, vnafn = vb.dataset.nafn;
                const paint = (on) => { vb.classList.toggle('on', on); vb.textContent = on ? '✓ Á vaktinni · 🔕 hætta' : '🔔 Vakta félagið'; };
                karpGet('/firmavakt').then((v) => { if (v && Array.isArray(v.felog)) paint(v.felog.some((x) => x.kt === vkt)); }).catch(() => {});
                vb.addEventListener('click', async () => {
                  vb.disabled = true;
                  try {
                    const cur = await karpGet('/firmavakt');
                    if (!cur || !Array.isArray(cur.felog)) throw new Error('auth');
                    const has = cur.felog.some((x) => x.kt === vkt);
                    const felog = has ? cur.felog.filter((x) => x.kt !== vkt) : cur.felog.concat([{ kt: vkt, nafn: vnafn }]);
                    const r = await karpPost('/firmavakt', { on: true, felog });
                    if (!r || r.ok !== true) throw new Error('save');
                    paint(!has);
                  } catch (e) {
                    const t0 = vb.textContent;
                    vb.textContent = '🔒 Innskráning þarf (Karp Pro)';
                    setTimeout(() => { vb.textContent = t0; }, 2600);
                  }
                  vb.disabled = false;
                });
              }
              // 🛒 kaupa skýrslu (0 kr. kynningarverð) → prentvæn PDF
              const bb = document.getElementById('fs-buy');
              if (bb) bb.addEventListener('click', async () => {
                bb.disabled = true; const t0 = bb.textContent; bb.textContent = '…';
                const doPrint = () => { bb.textContent = '✓ Keypt · útbý…'; setTimeout(() => { document.body.classList.add('fs-printing'); window.print(); setTimeout(() => { document.body.classList.remove('fs-printing'); bb.textContent = t0; bb.disabled = false; }, 600); }, 200); };
                // LOTA 82: reyna Teya-greiðslugátt fyrst; ókeypis/óuppsett → prentleið
                try {
                  const r = await fetch('/api/pay/checkout', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ kind: 'fyrirtaeki', ref: (d.felag.nafn || '') + ' ' + (d.felag.kt || '') }) });
                  const pd = await r.json().catch(() => null);
                  if (pd && pd.ok && pd.url) { location.href = pd.url; return; }
                } catch (e) {}
                doPrint();
              });
              return;
            }
            if (d.hits && d.hits.length) {
              skila('<div class="fs-hits">' + d.hits.map((h) => `<div class="fs-hit${h.afskrad ? ' af' : ''}" role="button" tabindex="0" data-kt="${escF(h.kt)}"><span class="kt">${escF(ktFmt(h.kt))}</span><span class="n">${escF(h.nafn)}${h.afskrad ? ' <span class="fs-badge">afskráð</span>' : ''}</span><span class="h">${escF(h.heimili || '')}</span></div>`).join('') + '</div>'
                + (d.alls ? `<div class="fs-more">Sýni fyrstu ${d.hits.length} af ${d.alls} — þrengdu leitina til að finna félagið beint.</div>` : ''));
              out.querySelectorAll('.fs-hit').forEach((el) => {
                const opna = () => leita(el.dataset.kt, true);
                el.onclick = opna;
                el.onkeydown = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opna(); } };
              });
              return;
            }
            skila(`<div class="fs-empty">Leit að „${escF(q)}“ skilaði engri niðurstöðu úr fyrirtækjaskrá.</div>`);
          })
          .catch(() => skila('<div class="fs-empty">Villa við uppflettingu — reyndu aftur.</div>'));
      }
      // Karp Pro-gátt (LOTA 63): leit + prófílkort læst innskráðum (ókeypis aðgangur)
      form.addEventListener('submit', (e) => { e.preventDefault(); if (!FS_USER || !FS_USER.loggedIn) { skila(fsTease()); return; } leita(inp.value); });
      loadUser().then((u) => {
        FS_USER = u;
        if (!u || !u.loggedIn) { form.style.display = 'none'; skila(fsTease()); return; }
        const q0 = new URLSearchParams(location.search).get('q');
        if (q0) { inp.value = q0; leita(q0); }
      }).catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="fyrirtaeki"]')) initFs(); });
  </script>
</Layout>
