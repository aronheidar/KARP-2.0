                  const rows = (st.styrkir || []).slice(0, 8).map((g) =>
                    `<div class="fs-st-row"><span class="fs-st-y">${escF(String(g.ar))}</span>`
                    + `<span class="fs-st-t"><b>${escF(g.sjodur)}</b>${g.vilyrdi ? '<span class="fs-st-vil" title="Vilyrði — samþykkt en óútgreitt">vilyrði</span>' : ''}${g.verkefni ? '<br><span class="fs-st-s">' + escF(g.verkefni) + '</span>' : ''}</span>`
                    + `<span class="fs-st-a">${kr(g.upphaed)}</span></div>`).join('');
                  el.innerHTML = `<div class="fs-sub">🏅 Opinberir styrkir — ${st.n} úthlutanir, samtals ${kr(st.total)}</div>`
                    + `<div class="fs-st-sum">${chips}</div>${rows}`
                    + `<div class="fs-kv-src">Opinberar úthlutanir sjóða (Kvikmynda-, Matvæla-, Orku-, Tækniþróunar- og uppbyggingarsjóða)`
                    + `${st.naemi === 'nafn' ? ' · tengt á nafni (áætluð samsvörun)' : ''}${st.n > 8 ? ' · sýni 8 af ' + st.n : ''}</div>`;
                }).catch(() => {});
              // 🔔 Firmavakt (LOTA 73): breytinga- og vanskilavakt á félagið í tölvupósti
              const vb = document.getElementById('fs-vakta');
              if (vb) {
                const vkt = vb.dataset.kt, vnafn = vb.dataset.nafn;
                const paint = (on) => { vb.classList.toggle('on', on); vb.textContent = on ? '✓ Á vaktinni · 🔕 hætta' : '🔔 Vakta félagið'; };
                karpGet('/firmavakt').then((v) => { if (v && Array.isArray(v.felog)) paint(v.felog.some((x) => x.kt === vkt)); }).catch(() => {});
                vb.addEventListener('click', async () => {
                  vb.disabled = true;
                  try {
                    const cur = await karpGet('/firmavakt');
                    if (!cur || !Array.isArray(cur.felog)) throw new Error('auth');
                    const has = cur.felog.some((x) => x.kt === vkt);
                    const felog = has ? cur.felog.filter((x) => x.kt !== vkt) : cur.felog.concat([{ kt: vkt, nafn: vnafn }]);
                    const r = await karpPost('/firmavakt', { on: true, felog });
                    if (!r || r.ok !== true) throw new Error('save');
                    paint(!has);
                  } catch (e) {
                    const t0 = vb.textContent;
                    vb.textContent = '🔒 Innskráning þarf (Karp+)';
                    setTimeout(() => { vb.textContent = t0; }, 2600);
                  }
                  vb.disabled = false;
                });
              }
              // 🛒 kaupa skýrslu (990 kr) — eigandi/admin → PDF strax; annars Teya-gátt (eða prentun fyrir launch)
              const bb = document.getElementById('fs-buy');
              if (bb) {
                const kt = bb.dataset.kt || '', rkey = 'fyrirtaeki:' + kt;
                const doPrint = () => { bb.textContent = '✓ Útbý PDF…'; setTimeout(() => { document.body.classList.add('fs-printing'); window.print(); setTimeout(() => { document.body.classList.remove('fs-printing'); paintBuy(); bb.disabled = false; }, 600); }, 200); };
                const paintBuy = () => { const owned = isAdmin() || hasReport(rkey); bb.dataset.owned = owned ? '1' : ''; bb.textContent = owned ? '🖨️ Sækja skýrslu (PDF)' : '🛒 Kaupa skýrslu — 990 kr'; };
                loadUser().then(paintBuy).catch(paintBuy);
                bb.addEventListener('click', async () => {
                  if (bb.dataset.owned) { bb.disabled = true; doPrint(); return; }
                  bb.disabled = true; const t0 = bb.textContent; bb.textContent = '…';
                  const res = await karpCheckout({ kind: 'fyrirtaeki', ref: (d.felag.nafn || '') + ' ' + kt, key: rkey });
                  if (res === 'redirected') return; // vafri á leið á hýstu greiðslusíðu Teya
                  bb.textContent = res === 'unconfigured' ? 'Greiðslur opna fljótlega' : 'Ekki tókst — reyndu aftur'; bb.disabled = false; setTimeout(paintBuy, 2800); // greiðsla fór ekki af stað → ENGIN ókeypis prentun
                });
              }
              return;
            }
            if (d.hits && d.hits.length) {
              skila('<div class="fs-hits">' + d.hits.map((h) => `<div class="fs-hit${h.afskrad ? ' af' : ''}" role="button" tabindex="0" data-kt="${escF(h.kt)}"><span class="kt">${escF(ktFmt(h.kt))}</span><span class="n">${escF(h.nafn)}${h.afskrad ? ' <span class="fs-badge">afskráð</span>' : ''}</span><span class="h">${escF(h.heimili || '')}</span></div>`).join('') + '</div>'
                + (d.alls ? `<div class="fs-more">Sýni fyrstu ${d.hits.length} af ${d.alls} — þrengdu leitina til að finna félagið beint.</div>` : ''));
              out.querySelectorAll('.fs-hit').forEach((el) => {
                const opna = () => leita(el.dataset.kt, true);
                el.onclick = opna;
                el.onkeydown = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opna(); } };
              });
              return;
            }
            skila(`<div class="fs-empty">Leit að „${escF(q)}“ skilaði engri niðurstöðu úr fyrirtækjaskrá.</div>`);
          })
          .catch(() => skila('<div class="fs-empty">Villa við uppflettingu — reyndu aftur.</div>'));
      }
      // Karp+-gátt (LOTA 63): leit + prófílkort læst innskráðum (ókeypis aðgangur)
      form.addEventListener('submit', (e) => { e.preventDefault(); if (!FS_USER || !FS_USER.loggedIn) { skila(fsTease()); return; } leita(inp.value); });
      // ?eigendur-syni=1 → opið UBO-sýnishorn (Gervifyrirtæki) — engin innskráning/kaup
      if (new URLSearchParams(location.search).get('eigendur-syni') === '1') {
        if (form) form.style.display = 'none';
        const host = document.createElement('div');
        host.className = 'fs-wrap eig-sample-wrap';
        const main = document.querySelector('main'); (main || document.body).appendChild(host);
        host.innerHTML = '<div class="fs-samplebar">👁️ Sýnishorn — gervifélag. Í raunskýrslu eru gögnin sótt lifandi úr opinberum skrám. <a href="/fyrirtaeki/">← Fletta upp raunfélagi</a></div><div id="fs-report"><div id="eig-host"></div></div>';
        renderUboSample(host.querySelector('#eig-host'), { navTo: (q) => { location.href = '/fyrirtaeki/?q=' + encodeURIComponent(q); } });
        return;
      }
      // ?syni=1 → sýnifyrirtæki (Norðurhaf) — opið öllum, engin innskráning, ekkert keypt
      if (new URLSearchParams(location.search).get('syni') === '1') {
        form.style.display = 'none';
        const demoF = demoFyrirtaeki();
        skila(fsKort(demoF));
        fsWireSector(demoF);   // 🏭 F2 í sýnishorni
        fsWireLanshaefi(demoF);   // 🎯 KARP lánshæfismat í sýnishorni
        const bk = out.querySelector('.fs-back'); if (bk) bk.onclick = () => { location.href = '/fyrirtaeki/'; };
        const br = out.querySelector('.fs-buyrow'); if (br) br.style.display = 'none';
        const rep = document.getElementById('fs-report');
        if (rep && !document.getElementById('fs-demo-note')) { const n = document.createElement('div'); n.id = 'fs-demo-note'; n.className = 'fs-demonote'; n.innerHTML = '👁️ <b>Sýnishorn</b> — Norðurhaf Sjávarfang hf. er EKKI raunverulegt félag. Sýnir allt sem fullbúin fyrirtækjaskýrsla getur innihaldið: fjárhagsmælaborð, kvóta, vörumerki, styrki og eftirlit.'; rep.insertBefore(n, rep.firstChild); }
        const setE = (id, html) => { const el = document.getElementById(id); if (el) { el.hidden = false; el.innerHTML = html; } };
        setE('fs-kvoti', '<div class="fs-sub">🐟 Aflamark (Fiskistofa)</div><div class="fs-chips"><span class="fs-chip"><b>Þorskur</b> 1.840 tonn</span><span class="fs-chip"><b>Ýsa</b> 720 tonn</span><span class="fs-chip"><b>Ufsi</b> 680 tonn</span><span class="fs-chip"><b>Samtals</b> 3.240 þorskígildistonn · 2025/26</span></div>');
        setE('fs-leyfi', '<div class="fs-sub">🎫 Leyfi &amp; réttindi <span class="fs-leyfi-af">🍷 vínveitingaleyfi</span></div><div class="fs-chips"><span class="fs-chip">Veitingaleyfi · A Veitingahús · fl. II <span class="fs-leyfi-loc">Hafnargata 12, 220 Hafnarfjörður</span></span></div><div class="fs-kv-src">Rekstrarleyfi (Sýslumenn) + ferðaþjónustuleyfi (Ferðamálastofa) — island.is</div>');
        setE('fs-loftfor', '<div class="fs-sub">✈️ Loftför — Loftfaraskrá (2)</div><div class="fs-chips"><span class="fs-chip"><b>TF-NHF</b> Beechcraft King Air 350 · 2019</span><span class="fs-chip"><b>TF-SEA</b> Airbus H145 þyrla · 2021</span></div><div class="fs-kv-src">Heimild: Loftfaraskrá Samgöngustofu (island.is)</div>');
        setE('fs-vorumerki', '<div class="fs-sub">™️ Skráð vörumerki (Hugverkastofa)</div><div class="fs-chips"><span class="fs-chip">Norðurhaf</span><span class="fs-chip">Bláa hafið</span><span class="fs-chip">SeaFresh</span><span class="fs-chip">Fjörukrydd</span></div>');
        setE('fs-styrkir', '<div class="fs-sub">🎁 Opinberir styrkir</div><div class="fs-chips"><span class="fs-chip"><b>Matvælasjóður</b> 18 m.kr · 2024 (vöruþróun)</span><span class="fs-chip"><b>AVS-sjóður</b> 9 m.kr · 2023</span></div>');
        setE('fs-eftirlit', '<div class="fs-sub">✅ Opinbert eftirlit</div><div class="fs-chips"><span class="fs-chip">Heilbrigðiseftirlit — engar athugasemdir (2025)</span><span class="fs-chip">MAST — grænt</span></div>');
        setE('fs-mast', '<div class="fs-sub">🏭 Starfsleyfi &amp; eftirlit — MAST (2)</div><div class="fs-ef-row"><span class="fs-ef-b r5">✓</span><span class="fs-ef-t"><b>Food · Section VIII</b><br><span class="fs-ef-l">Hafnargata 12, 220 Hafnarfjörður</span></span><span class="fs-ef-d">H472</span></div><div class="fs-ef-row"><span class="fs-ef-b r5">✓</span><span class="fs-ef-t"><b>MAT · Stóreldhús, smásalar</b><br><span class="fs-ef-l">Norðurgarður 3, 200 Kópavogur</span></span><span class="fs-ef-d">SF-8461</span></div><div class="fs-kv-src">Matvælastofnun + heilbrigðiseftirlit sveitarfélaga (landsdekkandi) · skyrslur.mast.is</div>');
        setE('fs-logbirting', '<div class="fs-sub">📜 Lögbirtingablaðið</div><div class="fs-chips"><span class="fs-chip">Aðalfundur boðaður 14.5.2026</span></div>');
        const setL = (id, txt) => { const el = document.getElementById(id); if (el) { const sp = el.querySelector('.s'); if (sp) sp.textContent = txt; el.classList.add('on'); } };
        setL('fs-umfj', '34 fyrirsagnir sl. 180 daga · viðhorf +12 (jákvætt)');
        setL('fs-birgir', '210 m.kr frá ríkinu sl. 12 mán — mest frá Hafrannsóknastofnun');
        setL('fs-utb', '3 útboð unnin · 145 m.kr samtals (TED/LV-vakt)');
        setL('fs-tilk', 'Skráð á Nasdaq First North · 4 tilkynningar 2026');
        setL('fs-lei', '5493001KJTIIGC8Y1R12 · gilt · á móðurfélag (GLEIF)');
        return;
      }
      loadUser().then((u) => {
        FS_USER = u;
        if (!u || !u.loggedIn) { form.style.display = 'none'; skila(fsTease()); return; }
        const q0 = new URLSearchParams(location.search).get('q');
        if (q0) { inp.value = q0; leita(q0); }
      }).catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="fyrirtaeki"]')) initFs(); });
  </script>
</Layout>
