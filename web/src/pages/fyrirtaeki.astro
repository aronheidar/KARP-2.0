          + '<div class="fs-media-list">' + fj.items.slice(0, 6).map((it) => '<a class="fs-media-i" href="' + escF(it.link) + '" target="_blank" rel="noopener"><span class="fs-media-t">' + escF(it.title) + '</span><span class="fs-media-m">' + escF(it.source || '') + (it.date ? ' · ' + escF(String(it.date).slice(0, 10)) : '') + '</span></a>').join('') + '</div>'
