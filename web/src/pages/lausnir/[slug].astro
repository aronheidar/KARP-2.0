---
// web/src/pages/lausnir/[slug].astro — býr til 7 landing-síður úr VORUR.
import Lausn from '../../components/Lausn.astro';
import { VORUR } from '../../data/lausnir.js';
export function getStaticPaths() {
  // fyrirtaekjaskyrsla = sérsniðin sameinuð síða (lausnir/fyrirtaekjaskyrsla.astro) → útilokuð hér (annars tvítekin).
  return VORUR.filter((v) => v.slug !== 'fyrirtaekjaskyrsla').map((v) => ({ params: { slug: v.slug }, props: { vara: v } }));
}
const { vara } = Astro.props;
---
<Lausn vara={vara} />
