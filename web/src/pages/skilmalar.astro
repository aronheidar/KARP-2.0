---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Skilmálar & persónuvernd: lögfræðitextinn portaður ÓBREYTTUR
// úr gamla mælaborðinu (skilmalar.json, dreginn vélrænt út). Statísk. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import SK from '../data/skilmalar.json';

const updated = '2026-07-02';
const desc = 'Skilmálar og persónuverndarstefna Karp (karp.is) — notkunarskilmálar, gagnaheimildir, kökur og réttindi notenda.';
---

<Layout title="Skilmálar & persónuvernd | Karp" description={desc} canonical="https://app.karp.is/skilmalar/" noindex={true}>
  <main>
    <p class="kicker">Karp</p>
    <h1>Skilmálar &amp; persónuvernd</h1>

    <h2>Notkunarskilmálar</h2>
    {SK.terms.map((s) => (
      <div class="sec">
        <h3>{s.n}. {s.t}</h3>
        <div set:html={s.b} />
      </div>
    ))}

    <h2>Persónuverndarstefna</h2>
    {SK.privacy.map((s) => (
      <div class="sec">
        <h3>{s.n}. {s.t}</h3>
        <div set:html={s.b} />
      </div>
    ))}

    <p class="foot">Síðast uppfært {updated}. Spurningar: sjá lið 1 í persónuverndarstefnu.</p>
  </main>

  <style>
    main { max-width: 720px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 30px; line-height: 1.15; margin: 0 0 14px; }
    h2 { font-size: 16px; color: #f6b13b; text-transform: uppercase; letter-spacing: .05em; margin: 28px 0 10px; }
    .sec h3 { font-size: 14.5px; color: #eaf1fb; margin: 14px 0 4px; }
    .sec :global(p) { font-size: 13.5px; color: #cdd6e6; line-height: 1.6; margin: 0 0 6px; }
    .sec :global(a) { color: #9fb0c8; }
    .sec :global(ul) { font-size: 13.5px; color: #cdd6e6; margin: 4px 0 8px; padding-left: 20px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 26px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
</Layout>
