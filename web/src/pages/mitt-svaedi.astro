                       : '<p class="dim sub-note">Sætin eru full — <a href="/karp-pro/#verd">fleiri aðgangar í stærra þrepi →</a></p>')
              + '<p class="dim sub-note">Meðlimur fær boðspóst og skráir sig inn — eða stofnar ókeypis aðgang — með þessu netfangi; þrep-aðgangurinn virkjast sjálfkrafa.</p>';
            box.querySelectorAll('.mem-x').forEach((b) => b.onclick = async () => { b.disabled = true; await A.teamSet(b.dataset.e, 'remove'); renderTeam(); });
            const go = $g('mem-go'); if (go) go.onclick = async () => { const i = $g('mem-email'), em = (i.value || '').trim(); if (!em) return; go.disabled = true; const r = await A.teamSet(em, 'add'); if (r && r.ok) renderTeam(); else { go.disabled = false; i.style.borderColor = 'var(--red)'; i.title = r && r.error === 'cap' ? 'Sætin eru full' : r && r.error === 'tier' ? 'Áskrift þarf til að bæta við aðgöngum' : 'Ógilt netfang'; } };
          });
        }
        function renderKtw() {
          const box = $g('ktw-box'); if (!box || !A.ktWatchList) return;
          A.ktWatchList().then((d) => {
            if (!d || (d.cap | 0) <= 0) { box.innerHTML = ''; return; }
            const rows = (d.kt || []).map((k) => '<div class="mem"><span>' + esc(k) + '</span><button data-k="' + esc(k) + '" class="mem-x" title="Fjarlægja">✕</button></div>').join('') || '<span class="dim">Engar kennitölur enn.</span>';
            box.innerHTML = seg('📇 Viðskiptamannavakt (kt)', (d.kt || []).length + '/' + d.cap + ' notaðar')
              + '<div class="mem-list">' + rows + '</div>'
              + ((d.kt || []).length < d.cap ? '<div class="mem-add"><input id="ktw-in" inputmode="numeric" placeholder="kennitala" maxlength="11" /><button id="ktw-go">Bæta við</button></div>'
                                             : '<p class="dim sub-note">Vaktin er full — <a href="/karp-pro/#verd">stærri vakt í Fyrirtæki+ →</a></p>');
            box.querySelectorAll('.mem-x').forEach((b) => b.onclick = async () => { b.disabled = true; await A.ktWatchSet(b.dataset.k, 'remove'); renderKtw(); });
            const go = $g('ktw-go'); if (go) go.onclick = async () => { const i = $g('ktw-in'), kt = (i.value || '').replace(/\D/g, ''); if (kt.length !== 10) { i.style.borderColor = 'var(--red)'; return; } go.disabled = true; const r = await A.ktWatchSet(kt, 'add'); if (r && r.ok) renderKtw(); else { go.disabled = false; i.style.borderColor = 'var(--red)'; } };
          });
