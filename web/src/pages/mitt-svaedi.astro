      }
      // 📬 Vikupóstur (og tölvupóst-yfirlit)
      function wireDigest(loggedIn) {
        const dg = $g('dg-on'), note = $g('dg-note'), more = $g('mail-more');
        if (more) more.innerHTML = loggedIn ? '<div class="mail-note">📨 Þú færð líka tölvupóst þegar leitarorð, fasteign eða félag á vaktinni þinni fær nýja niðurstöðu.</div>' : '';
        if (!dg) return;
        if (!loggedIn) { dg.disabled = true; if (note) { note.hidden = false; note.innerHTML = 'Vikuyfirlitið þarf innskráningu — <a href="' + loginHref() + '">skráðu þig inn</a> (ókeypis).'; } return; }
        karpGet('/digest').then((d) => { if (d && typeof d.on === 'boolean') dg.checked = d.on; }).catch(() => {});
        dg.onchange = async () => {
          try { const r = await karpPost('/digest', { on: dg.checked }); if (!r || r.ok !== true) throw new Error('no'); note.hidden = false; note.textContent = r.on ? '✓ Vikuyfirlitið er virkt — fyrsti pósturinn berst næsta mánudagsmorgun.' : 'Vikuyfirlitið er óvirkt.'; }
          catch (e) { dg.checked = false; note.hidden = false; note.textContent = 'Náði ekki að vista — reyndu aftur.'; }
