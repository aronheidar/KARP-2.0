  <!-- Eyja: flipar + widgets (fylgja/sveitarfélag/flokkamat/vaktir/aðgangur). #2 -->
  <script>
    import { loadUser, karpGet, karpPost, loginHref } from '../lib/auth.js';
    const $g = (id) => document.getElementById(id);
    const J = (id) => { try { return JSON.parse($g(id).textContent); } catch (e) { return null; } };
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    function initMitt() {
      if (!$g('p-dash') || $g('p-dash').dataset.done) return;
      $g('p-dash').dataset.done = '1';
      // Flipar
      document.querySelectorAll('.tab').forEach((t) => {
        t.onclick = () => {
          document.querySelectorAll('.tab').forEach((x) => x.classList.toggle('on', x === t));
          $g('p-dash').hidden = t.dataset.t !== 'dash';
          $g('p-still').hidden = t.dataset.t !== 'still';
        };
      });

      // 📊 Mælaborðs-rofar (localStorage) — kveikja/slökkva á spjöldum mælaborðsins
      const DASH_W = [['hagvisar', '📈 Hagvísar dagsins'], ['sveit', '🗺️ Mitt sveitarfélag'], ['loft', '🌬️ Loftgæði'], ['vaktir', '🔔 Vaktirnar — nýjast'], ['fylgja', '🔖 Að fylgja'], ['nylegt', '🕘 Nýlega skoðað'], ['skyrslur', '🛒 Keyptar skýrslur'], ['seats', '🏛️ Þingsæti-spá'], ['match', '🎯 Flokkamatið mitt']];
      const dhKey = 'karp-dash-hidden';
      const dhLoad = () => { try { return JSON.parse(localStorage.getItem(dhKey) || '[]'); } catch (e) { return []; } };
      const applyDash = () => { const hid = dhLoad(); DASH_W.forEach(([id]) => { const w = document.querySelector('.w[data-w="' + id + '"]'); if (w) w.hidden = hid.indexOf(id) !== -1; }); };
      applyDash();
      const tglBox = $g('dash-toggles');
      if (tglBox) {
        const hid0 = dhLoad();
        tglBox.innerHTML = DASH_W.map(([id, t]) => `<label class="tgl"><input type="checkbox" data-wid="${id}"${hid0.indexOf(id) === -1 ? ' checked' : ''} /><span class="tgl-sw"></span><span class="tgl-t"><b>${esc(t)}</b></span></label>`).join('');
        tglBox.querySelectorAll('input[data-wid]').forEach((inp) => {
          inp.onchange = () => { let h = dhLoad(); const id = inp.dataset.wid; h = inp.checked ? h.filter((x) => x !== id) : [...new Set([...h, id])]; localStorage.setItem(dhKey, JSON.stringify(h)); applyDash(); };
        });
      }

      // 🛒 Keyptar skýrslur (les /reports) — á mælaborði; vistast + aðgengilegar alltaf
      (function () {
        const el = $g('w-skyrslur'); if (!el) return;
        loadUser().then((u) => {
          if (!u || !u.loggedIn) { el.innerHTML = '<span class="dim">Skráðu þig inn til að sjá keyptar skýrslur — þær vistast hér og eru aðgengilegar alltaf.</span>'; return; }
          karpGet('/reports').then((d) => {
            const arr = (d && d.reports) || [];
            if (!arr.length) { el.innerHTML = '<span class="dim">Engar keyptar skýrslur enn. Kauptu fasteignamat eða fyrirtækjaskýrslu (990 kr) — þær vistast hér.</span>'; return; }
            // Flokka keyptar skýrslur eftir tegund (lykil-forskeyti). Nýir flokkar fyllast
            // sjálfkrafa þegar sölulyklar bætast við (t.d. eigendur:/areidanleiki:).
            const CATS = [
              { pfx: 'fyrirtaeki:', label: 'Fyrirtækjaskýrslur', ico: '📄', link: (id) => '/fyrirtaeki/?q=' + encodeURIComponent(id) },
              { pfx: 'eigendur:', label: 'Endanlegir eigendur', ico: '👤', link: (id) => '/eigendur/?q=' + encodeURIComponent(id) },
              { pfx: 'areidanleiki:', label: 'Áreiðanleikamat', ico: '🛡️', link: (id) => '/fyrirtaeki/?q=' + encodeURIComponent(id) + '&vidmot=areidanleiki' },
              { pfx: 'fjolmidlar:', label: 'Fjölmiðlavakt', ico: '📰', link: (id) => '/fyrirtaeki/?q=' + encodeURIComponent(id) },
              { pfx: 'fasteign:', label: 'Fasteignaskýrslur', ico: '🏠', link: (id) => '/fasteignavakt/?q=' + encodeURIComponent(id) },
              { pfx: 'thingmadur:', label: 'Þingmannaskýrslur', ico: '🏛️', link: (id) => '/althingi/' + encodeURIComponent(id) + '/skyrsla/' },
            ];
            const buckets = new Map(); const other = [];
            arr.forEach((r) => { const k = String(r.key || ''); const cat = CATS.find((c) => k.indexOf(c.pfx) === 0);
              if (cat) { if (!buckets.has(cat.label)) buckets.set(cat.label, []); buckets.get(cat.label).push({ r, id: k.slice(cat.pfx.length) }); }
              else other.push({ r }); });
            const rowH = (href, r) => `<a class="sk-row" href="${href}"><span class="sk-t">${esc(r.title || r.key || 'Skýrsla')}</span><span class="sk-o">Opna →</span></a>`;
            let html = '';
            CATS.forEach((c) => { const items = buckets.get(c.label); if (items && items.length) html += `<div class="sk-cat"><div class="sk-cat-h">${c.ico} ${c.label} <span class="sk-n">${items.length}</span></div><div class="sk-list">${items.map((it) => rowH(c.link(it.id), it.r)).join('')}</div></div>`; });
            if (other.length) html += `<div class="sk-cat"><div class="sk-cat-h">📁 Aðrar skýrslur <span class="sk-n">${other.length}</span></div><div class="sk-list">${other.map((it) => rowH('#', it.r)).join('')}</div></div>`;
            el.innerHTML = html;
          }).catch(() => { el.innerHTML = '<span class="dim">Náði ekki í keyptar skýrslur.</span>'; });
        });
      })();

      // 🕘 Nýlega skoðað (localStorage karp-recent) — skráð á fyrirtaeki.astro við hverja skoðun.
      (function () {
        const el = $g('w-nylegt'); if (!el) return;
        let arr = []; try { arr = JSON.parse(localStorage.getItem('karp-recent') || '[]'); } catch (e) {}
        if (!arr.length) return;   // heldur sjálfgefna „engin skoðuð" textanum
        const ago = (ts) => { const d = Math.floor((Date.now() - ts) / 86400000); return d <= 0 ? 'í dag' : d === 1 ? 'í gær' : 'fyrir ' + d + ' dögum'; };
        el.innerHTML = '<div class="sk-list">' + arr.slice(0, 8).map((r) => `<a class="sk-row" href="/fyrirtaeki/?q=${encodeURIComponent(r.kt)}"><span class="sk-t">${esc(r.nafn || r.kt)}</span><span class="sk-o">${ago(r.ts)} →</span></a>`).join('') + '</div>';
      })();

      // 🌗 Þema-rofi í Stillingum — samstillt við nav-rofann (window.karpSetTheme + karp-theme event).
      (function () {
        const seg = $g('theme-seg'); if (!seg) return;
        const cur = () => (window.karpGetTheme ? window.karpGetTheme() : (localStorage.getItem('karp-theme') === 'light' ? 'light' : 'dark'));
        const paint = () => seg.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b.dataset.th === cur()));
        paint();
        seg.querySelectorAll('button').forEach((b) => { b.onclick = () => { if (window.karpSetTheme) window.karpSetTheme(b.dataset.th); else { try { localStorage.setItem('karp-theme', b.dataset.th); } catch (e) {} document.documentElement.setAttribute('data-theme', b.dataset.th); } paint(); }; });
        window.addEventListener('karp-theme', paint);
      })();

      // ⭐ Áskrift, aðgangar (seats) & Viðskiptamannavakt (kt) — server-varið í karp-entitlement.php
      (function () {
        const el = $g('sub-body'); if (!el) return;
        const A = window.karpAuth || {};
        const seg = (t, h) => '<div class="sub-sub">' + t + (h ? ' <span class="dim">· ' + h + '</span>' : '') + '</div>';
        loadUser().then((u) => {
          if (!u || !u.loggedIn) { el.innerHTML = '<span class="dim">Skráðu þig inn til að sjá áskrift og aðganga.</span>'; return; }
          const lim = (A.limits && A.limits()) || {};
          const tierName = ({ grunnur: 'Grunnur', fyrirtaeki: 'Fyrirtæki', fyrirtaeki_plus: 'Fyrirtæki+' })[u.effectiveTier] || (u.isAdmin ? 'Stjórnandi' : 'Enginn þrep-aðgangur');
          const rem = (typeof u.reportsRemaining === 'number') ? u.reportsRemaining : 0;
          const remTxt = lim.reportsMonth === 0 ? 'stakar á 990 kr' : (rem < 0 ? 'ótakmarkað' : rem + ' af ' + lim.reportsMonth + ' eftir í mánuðinum · endurstillist um mánaðamót');
          // Upsell fyrir grunnur/fyrirtæki: „⬆ Uppfærðu í <næsta þrep> fyrir fleiri skýrslur" (Fyrirtæki+ er efst → ekkert).
          const nt = (A.nextTierUp && A.nextTierUp()) || null;
          const remUpsell = nt ? ' · <a href="/karp-pro/#verd">⬆ Uppfærðu í ' + esc(nt.heiti) + ' fyrir fleiri skýrslur →</a>' : '';
          const folCap = (lim.follows < 0) ? 'ótakmarkað' : lim.follows;
          const dags = (ts) => { try { return new Date(ts * 1000).toLocaleDateString('is-IS'); } catch (e) { return ''; } };
          // Sérlausnir (utbod/fasteign/frettir) — birtar með gildistíma + uppsagnar-hnappi
          const SVCN = { utbod: '📋 Útboðsvaktin', fasteign: '🏠 Fasteignavakt', frettir: '📰 Fjölmiðlavakt', thingskyrslur: '🏛️ Þingmannaskýrslur', kvoti: '⚓ Kvótavaktin' };
          const subsUntil = u.subsUntil || {};
          const svcRows = (u.subs || []).map((s) => {
            const sq = (u.svcQuota || {})[s];   // #22: fasteign/þingskyrslur = 20/mán → sýna „N eftir í mánuðinum"
            const qtxt = sq ? ' · <span class="dim">' + sq.remaining + ' af ' + sq.quota + ' eftir í mánuðinum</span>' : '';
            return '<div class="sub-row"><b>' + (SVCN[s] || s) + ':</b> virk' + (subsUntil[s] ? ' til ' + dags(subsUntil[s]) : '') + qtxt
              + ' · <button class="sub-cancel" data-svc="' + esc(s) + '" type="button">Segja upp</button></div>';
          }).join('');
          const tierUntil = u.tier_until ? ' · til ' + dags(u.tier_until) : '';
          const tierCancel = (u.tier && u.effectiveTier === u.tier) ? ' · <button class="sub-cancel" data-svc="" type="button">Segja upp</button>' : '';
          el.innerHTML =
            '<div class="sub-row"><b>Þrep:</b> ' + esc(tierName) + tierUntil + tierCancel
            + (u.effectiveTier || u.isAdmin ? ' · <a href="/karp-pro/#verd">breyta áskrift →</a>' : ' · <a href="/karp-pro/#verd">sjá áskrift →</a>') + '</div>'
            + svcRows
            + ((u.subs || []).length === 0 ? '<div class="sub-row dim">Engin sérlausn virk · <a href="/karp-pro/#verd">skoða sérlausnir →</a></div>' : '')
            + '<div class="sub-row"><b>Skýrslur:</b> ' + esc(remTxt) + remUpsell + '</div>'
            + '<div class="sub-row"><b>Fylgt félög:</b> ' + Number(u.followsCount || 0) + ' / ' + esc(String(folCap)) + '</div>'
            + '<div id="team-box"></div><div id="ktw-box"></div>';
          // Uppsögn: staðfesting → POST /api/sub/cancel → áskrift lifir út greitt tímabil
          el.querySelectorAll('.sub-cancel').forEach((b) => b.onclick = async () => {
            const nafn = b.dataset.svc ? (SVCN[b.dataset.svc] || b.dataset.svc) : 'þrep-áskriftinni';
            const untilTs = b.dataset.svc ? subsUntil[b.dataset.svc] : u.tier_until;   // sama dagsetning og Áskell-pósturinn sýnir
            const tilDags = untilTs ? dags(untilTs) : '';
            // Skýr staðfesting: aðgangur helst (til og með dags.), engin gjöld, endurnýjast ekki → sama og pósturinn segir.
            if (!confirm('Segja upp ' + nafn + '?\n\nÞú heldur fullum aðgangi' + (tilDags ? ' til og með ' + tilDags : ' út greitt tímabil') + '. Áskriftin endurnýjast ekki og engin frekari gjöld verða innheimt.')) return;
            b.disabled = true; b.textContent = 'Segi upp…';
            try {
              const r = await (await fetch('/api/sub/cancel', { method: 'POST', credentials: 'include', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ service: b.dataset.svc || undefined }) })).json();
              if (r && r.ok) { b.textContent = '✓ Uppsagt — virk' + (tilDags ? ' til ' + tilDags : ' út tímabilið'); }
