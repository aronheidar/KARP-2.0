---
// ─────────────────────────────────────────────────────────────
// „Mitt svæði" (LOTA 9) — widget-mælaborð EINS OG GAMLA + Stillingar-flipi:
// 📈 hagvísar · 🗺️ MITT SVEITARFÉLAG (val vistast) · 🔖 að fylgja ·
// 🏛️ þingsæti-spá · 🎯 flokkamatið (stefnupróf) — og Stillingar (sveitarfélag,
// vaktir, aðgangur). Allt bakað + localStorage; innskráð efni um auth.js. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import THINGMENN from '@gogn/althingi.json';
import ATV from '@gogn/atvinnuleysi.json';
import POLLS from '@gogn/polls.json';
import FRUMVORP from '@gogn/frumvorp.json';
import SVPOP from '@gogn/sveitarfelog_pop.json';
import SVCOORDS from '@gogn/sveitarfelog_coords.json';
import SVFIN from '@gogn/sveitarfelog_fin.json';
import SVMETA from '@gogn/sveitarfelog_meta.json';
import GLAEPIR from '@gogn/glaepir.json';
import FASTEIGNIR from '@gogn/fasteignir.json';
import REGIONGEO from '@gogn/landshlutar.json';
import JOFNUN from '@gogn/jofnun.json';
import SB from '@gogn/sedlabanki.json';
import { projectSeats } from '@lib/seats.mjs';
import { colorByName, partyName, partyColor } from '@lib/parties.mjs';
import { slugify } from '@lib/format.mjs';
import { computeMuniIndex } from '@lib/muniIndex.mjs';
import { makeMuniStats, svStab } from '@lib/muniStats.mjs';
import { makeRegionOf, makeLifsQ } from '@lib/geo.mjs';

// Þingmenn (fylgja-widget)
const MP = {};
THINGMENN.forEach((m) => { MP['mp:' + m.id] = { n: m.nafn, f: m.flokkur, c: colorByName(m.flokkur), s: slugify(m.nafn), img: m.mynd || '' }; });

// Hagvísa-strípa (bakað) — stýrivextir & verðbólga LIFANDI úr Seðlabanka-headline
const _sbv = (o) => (o && o.value != null ? String(o.value).replace('.', ',') + '%' : '–');
const _sbh = SB.headline || {};
const KPIS = [
  { l: '👷 Atvinnuleysi', v: (ATV.latest ?? 0).toFixed(1).replace('.', ',') + '%', href: '/vinnumarkadur/' },
  { l: '🏦 Stýrivextir', v: _sbv(_sbh.meginvextir), href: '/vextir/' },
  { l: '📉 Verðbólga', v: _sbv(_sbh.verdbolga), href: '/verdlag/' },
];

// Þingsæti-spá mini
const r = projectSeats(POLLS, THINGMENN);
const topParty = Object.keys(r.proj).sort((a, b) => r.proj[b] - r.proj[a])[0];
const SEATSW = { gov: r.govS, opp: r.oppS, maj: r.maj, top: topParty ? { n: partyName(topParty), c: partyColor(topParty), s: r.proj[topParty] } : null };

// Sveitarfélaga-val + FULLT SPJALD (LOTA 12): sama líkan og /sveitarfelog/[slug]
const idxMap = computeMuniIndex({ SVFIN, SVMETA, SVPOP, ATVINNULEYSI: ATV });
const regionOf = makeRegionOf({ SVCOORDS, REGIONGEO });
const muniStats = makeMuniStats({ ATVINNULEYSI: ATV, GLAEPIR, FASTEIGNIR });
const lifsQ = makeLifsQ({ SVMETA, regionOf, svUnemp: muniStats.svUnemp, svCrime: muniStats.svCrime });
const ranked = Object.keys(idxMap).filter((n) => idxMap[n].idx != null).sort((a, b) => idxMap[b].idx - idxMap[a].idx);
const r0 = (v) => (v == null ? null : Math.round(v));
const MUNIS = Object.keys(SVCOORDS).sort((a, b) => a.localeCompare(b, 'is')).map((n) => {
  const reg = regionOf(n), fin = SVFIN[n] || {}, ix = idxMap[n] || null;
  const crime = muniStats.svCrime(reg);
  const oryggi = crime && crime.hegn != null ? Math.max(0, Math.min(100, Math.round(100 - crime.hegn / 4.5))) : null;
  const house = muniStats.svHouse(n, reg);
  const jof = (JOFNUN.m || {})[n] || null;
  return {
    n, s: slugify(n), pop: SVPOP[n] || null,
    idx: ix ? r0(ix.idx) : null, rank: ranked.indexOf(n) + 1, rt: ranked.length,
    R: [ix ? r0(ix.fjar) : null, ix ? r0(ix.vox) : null, ix ? r0(ix.atv) : null, lifsQ(n), oryggi, svStab(fin)],
    u: fin.utsvar ?? null, sk: fin.skuldir_ibui ?? null, af: fin.afkoma_ibui ?? null,
    unemp: muniStats.svUnemp(n, reg), house: house ? house.v : null,
    jof: jof && jof.t && jof.ibuar ? Math.round(jof.t / jof.ibuar / 1000) : null,
  };
});

// Flokkamatið: sömu spurningar og stefnuprófið (afstaða = meirihluti flokks)
const pName = (k) => (k === 'U' ? 'Óháðir' : partyName(k) || k);
const SPQ = FRUMVORP
  .filter((b) => (b.hs === 'Frv.' || b.hs === 'Till.') && (b.ja || 0) > 0 && (b.nei || 0) > 5 && b.sam)
  .sort((a, b) => (b.d || '').localeCompare(a.d || '')).slice(0, 12)
  .map((b) => { const P = b.P || {}; const st = {}; Object.keys(P).forEach((k) => { const [ja, nei] = P[k]; if (k === 'U' || ja + nei === 0 || ja === nei) return; st[k] = ja > nei ? 1 : -1; }); return { id: 'q' + b.nr, stance: st }; })
  .filter((q) => Object.keys(q.stance).length >= 4);
const SPP = {};
[...new Set(SPQ.flatMap((q) => Object.keys(q.stance)))].forEach((k) => { SPP[k] = { n: pName(k), c: partyColor(k) }; });

const updated = '2026-07-02';
---

<Layout title="Mitt svæði | Karp" noindex={true}>
  <main data-pg="mitt-svaedi">
    <p class="kicker">Karp</p>
    <h1>Mitt svæði</h1>
    <div class="tabs"><button class="tab on" data-t="dash">📊 Mælaborð</button><button class="tab" data-t="still">⚙️ Stillingar</button></div>

    <!-- ── MÆLABORÐ ── -->
    <section id="p-dash">
      <div id="gate-note"></div>

      <!-- Umferðartölfræði — AÐEINS stjórnandi (Burst um worker /api/u/burst → CF-vefgreining). Falið sjálfgefið. -->
      <div class="w" id="w-traffic-box" hidden>
        <div class="w-h">📊 Umferð á Karp <span class="w-sub">Cloudflare · aðeins stjórnandi</span></div>
        <div id="w-traffic">Sæki tölfræði…</div>
      </div>

      <div class="w" data-w="hagvisar">
        <div class="w-h">📈 Hagvísar dagsins</div>
        <div class="kpis">{KPIS.map((k) => <a class="kpi" href={k.href}><span class="k-l">{k.l}</span><span class="k-v">{k.v}</span></a>)}</div>
      </div>

      <div class="w" data-w="sveit">
        <div class="w-h">🗺️ Mitt sveitarfélag</div>
        <div id="w-sveit"></div>
      </div>

      <div class="w" data-w="loft">
        <div class="w-h">🌬️ Loftgæði — lifandi <span class="w-sub">svifryk PM10 · Umhverfisstofnun</span></div>
        <div id="w-loft">Sæki mælingar…</div>
      </div>

      <div class="w" data-w="vaktir">
        <div class="w-h">🔔 Vaktirnar — nýjast <span class="w-sub">dómar · samráð · útboð · greiðslur</span> <a class="w-more" href="/vaktir/">Allar vaktir →</a></div>
        <div id="w-vaktir" class="wv-grid">Sæki vaktir…</div>
      </div>

      <div class="w" data-w="fylgja">
        <div class="w-h">🔖 Að fylgja <span id="fylgja-ny" class="fylgja-ny" hidden></span></div>
        <div id="mine">Hleð…</div>
      </div>

      <div class="w" data-w="nylegt">
        <div class="w-h">🕘 Nýlega skoðað</div>
        <div id="w-nylegt"><span class="dim">Engin félög skoðuð enn — opnaðu fyrirtækjaskýrslu og hún birtist hér.</span></div>
      </div>

      <div class="w" data-w="skyrslur">
        <div class="w-h">🛒 Keyptar skýrslur</div>
        <div id="w-skyrslur"><span class="dim">Hleð…</span></div>
      </div>

      <div class="w" data-w="seats">
        <div class="w-h">🏛️ Þingsæti-spá</div>
        <div class="seats">
          <span class={SEATSW.maj ? 'up' : 'dn'}><b>{SEATSW.gov}</b> ríkisstjórn</span>
          <span><b>{SEATSW.opp}</b> stjórnarandstaða</span>
          {SEATSW.top && <span style={`color:${SEATSW.top.c}`}><b>{SEATSW.top.s}</b> {SEATSW.top.n} (stærst)</span>}
          <a href="/althingi/">Sætaspáin →</a>
        </div>
      </div>

      <div class="w" data-w="match">
        <div class="w-h">🎯 Flokkamatið mitt</div>
        <div id="w-match"></div>
      </div>
    </section>

    <!-- ── STILLINGAR ── -->
    <section id="p-still" hidden>
      <div class="w">
        <div class="w-h">📊 Mælaborðið — hvað birtist</div>
        <p class="w-p">Kveiktu og slökktu á spjöldum mælaborðsins. Valið vistast í vafranum þínum.</p>
        <div id="dash-toggles" class="tgl-list"></div>
      </div>

      <div class="w">
        <div class="w-h">🌗 Þema</div>
        <p class="w-p">Ljóst eða dökkt útlit — valið vistast í vafranum og gildir um alla síðuna.</p>
        <div class="theme-seg" id="theme-seg"><button type="button" data-th="dark">🌙 Dökkt</button><button type="button" data-th="light">☀️ Ljóst</button></div>
      </div>

      <div class="w">
        <div class="w-h">🗺️ Sveitarfélagið mitt</div>
        <p class="w-p">Veldu sveitarfélagið þitt — spjaldið birtist á mælaborðinu og valið vistast í vafranum.</p>
        <select id="sv-sel"><option value="">— Velja sveitarfélag —</option>{MUNIS.map((m) => <option value={m.n}>{m.n}</option>)}</select>
      </div>

      <div class="w">
        <div class="w-h">📋 Vaktirnar mínar <a class="w-more" href="/vaktir/">Stjórna vöktum →</a></div>
        <p class="w-p">Yfirlit yfir allt sem þú vaktar. Virkar vaktir senda þér tölvupóst þegar eitthvað nýtt gerist.</p>
        <div id="vakt-yfirlit"><span class="dim">Sæki vaktirnar þínar…</span></div>
      </div>

      <div class="w">
        <div class="w-h">📬 Tölvupóstarnir mínir</div>
        <p class="w-p">Stýrðu hvaða tölvupóst þú færð frá Karp.</p>
        <label class="tgl"><input type="checkbox" id="dg-on" /><span class="tgl-sw"></span><span class="tgl-t"><b>📅 Vikuyfirlit</b><span class="tgl-d">Persónulegt yfirlit á mánudagsmorgnum — vaktir vikunnar, félög og þingmenn sem þú fylgist með, ný vörumerki, fasteignasölur og útboð.</span></span></label>
        <p id="dg-note" class="w-note" hidden></p>
        <div id="mail-more" class="mail-more"></div>
      </div>

      <div class="w" id="sub-card">
        <div class="w-h">⭐ Áskrift, aðgangar & vaktir</div>
        <div id="sub-body"><span class="dim">Hleð…</span></div>
      </div>

      <div class="w">
        <div class="w-h">👤 Aðgangurinn</div>
        <div id="acc" class="acc"></div>
        <div class="acc-links" id="acc-links" hidden>
          <button type="button" id="acc-edit" class="acc-lnk">Breyta prófíl</button>
          <a class="acc-lnk" href="/endurstilla/">Breyta lykilorði</a>
          <a class="acc-lnk" href="/hjalp/?fra=mitt-svaedi">Þarftu aðstoð?</a>
        </div>
        <form id="acc-form" class="acc-form" hidden autocomplete="on">
          <label class="acc-fld"><span>Nafn</span><input type="text" id="acc-name" autocomplete="name" maxlength="80" /></label>
          <label class="acc-fld"><span>Netfang</span><input type="email" id="acc-email" autocomplete="email" maxlength="120" /></label>
          <p class="acc-msg" id="acc-msg" hidden></p>
          <div class="acc-btns">
            <button type="submit" class="acc-save" id="acc-save">Vista</button>
            <button type="button" class="acc-cancel" id="acc-cancel">Hætta við</button>
          </div>
        </form>
      </div>
    </section>

    <p class="foot">Forþjónað (SSG) {updated} · persónulegt yfirlit — fylgja/vaktir um <code>auth.js</code>, sveitarfélagsval og flokkamat aðeins í þínum vafra. #2. · <a href="/hjalp/?fra=mitt-svaedi">🆘 Þarftu aðstoð?</a></p>
  </main>

  <script type="application/json" id="d-mp" set:html={JSON.stringify(MP)}></script>
  <script type="application/json" id="d-munis" set:html={JSON.stringify(MUNIS)}></script>
  <script type="application/json" id="d-spq" set:html={JSON.stringify({ q: SPQ, p: SPP })}></script>

  <style>
    main { max-width: 960px; margin: 0 auto; padding: 34px 20px 64px; container-type: inline-size; }
    /* Verk 8: mælaborð + stillingar í tvídálka til að minnka lóðrétt skrun.
       Container-query → nákvæmlega 2 dálkar þegar pláss ≥700px (les RAUNbreidd efnis,
       ekki gluggans → réttur á öllum fréttarásar-brotpunktum); 1 dálkur á síma/þröngu.
       dense-flæði pakkar spjöldum þétt; breiðu spjöldin (sveitarf./vaktir/bannerar) spanna báða. */
    #p-dash, #p-still { display: grid; grid-template-columns: 1fr; gap: 12px; align-items: start; grid-auto-flow: row dense; }
    @container (min-width: 700px) { #p-dash, #p-still { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    #gate-note, #w-traffic-box, .w[data-w="sveit"], .w[data-w="vaktir"] { grid-column: 1 / -1; }
    #gate-note:empty { display: none; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); margin: 0 0 4px; }
    h1 { font-size: 30px; margin: 0 0 12px; }
    .tabs { display: flex; gap: 6px; border-bottom: 1px solid var(--line); margin-bottom: 16px; }
    .tab { background: none; border: 0; color: var(--muted); font-size: 15px; font-weight: 700; padding: 10px 14px; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .tab.on { color: #f6b13b; border-bottom-color: #f6b13b; }
    .w { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 14px 16px; }
    .w-h { font-size: 13px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 10px; }
    .w-p { font-size: 13px; color: var(--muted); margin: 0 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; }
    .kpi { display: flex; flex-direction: column; gap: 2px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 10px 12px; text-decoration: none; }
    .kpi:hover { border-color: #f6b13b; }
    .k-l { font-size: 11px; color: var(--muted); }
    .k-v { font-size: 18px; font-weight: 800; color: var(--ink); }
    .seats { display: flex; flex-wrap: wrap; gap: 8px 18px; font-size: 13.5px; color: var(--muted); align-items: baseline; }
    .seats b { font-size: 18px; color: var(--ink); }
    .seats .up b { color: #46e08a; } .seats .dn b { color: #ff6d7a; }
    .seats a { color: #f6b13b; text-decoration: none; font-size: 12.5px; }
    select { width: 100%; max-width: 340px; background: var(--surface); border: 1px solid var(--line); color: var(--ink); border-radius: 9px; padding: 10px 12px; font-size: 14px; }
    .acc { font-size: 13.5px; color: var(--ink); margin-bottom: 8px; }
    .acc-links { display: flex; flex-wrap: wrap; gap: 14px; }
    .acc-links a, .acc-lnk { font-size: 12.5px; color: var(--muted); background: none; border: 0; padding: 0; font-family: inherit; cursor: pointer; text-decoration: none; }
    .acc-links a:hover, .acc-lnk:hover { color: #f6b13b; }
    .acc-form { margin-top: 10px; display: grid; gap: 9px; max-width: 340px; }
    .acc-fld { display: grid; gap: 3px; }
    .acc-fld span { font-size: 11.5px; color: var(--muted); }
    .acc-fld input { padding: 8px 10px; border: 1px solid var(--line); border-radius: 8px; font: inherit; background: var(--panel); color: #eef2f8; }
    .acc-fld input:focus { outline: none; border-color: #f6b13b; }
    .acc-btns { display: flex; gap: 8px; margin-top: 2px; }
    .acc-save { background: #f6b13b; color: #201400; border: 0; border-radius: 8px; padding: 8px 15px; font: inherit; font-weight: 700; cursor: pointer; }
    .acc-save:disabled { opacity: .55; cursor: default; }
    .acc-cancel { background: none; border: 1px solid var(--line); border-radius: 8px; padding: 8px 13px; font: inherit; color: var(--ink); cursor: pointer; }
    .acc-msg { font-size: 12.5px; margin: 0; }
    .acc-msg.ok { color: #6bd08b; }
    .acc-msg.err { color: #ff8a8a; }
    .dim { font-size: 13px; color: var(--faint); }
    .foot { font-size: 12px; color: var(--faint); margin-top: 20px; border-top: 1px solid var(--line); padding-top: 14px; }
  </style>

  <!-- is:global: klasar sem birtast (líka) í runtime-innerHTML → annars tréhristast (Astro-gildra) -->
  <style is:global>
    main[data-pg="mitt-svaedi"] .tgl-list { display: grid; gap: 10px; }
    main[data-pg="mitt-svaedi"] .tgl { display: flex; align-items: center; gap: 11px; cursor: pointer; }
    main[data-pg="mitt-svaedi"] .tgl > input { position: absolute; opacity: 0; width: 0; height: 0; }
    main[data-pg="mitt-svaedi"] .tgl-sw { flex: 0 0 38px; width: 38px; height: 22px; border-radius: 999px; background: var(--line); position: relative; transition: .18s; }
    main[data-pg="mitt-svaedi"] .tgl-sw::after { content: ''; position: absolute; top: 2px; left: 2px; width: 18px; height: 18px; border-radius: 50%; background: var(--ink); transition: .18s; }
    main[data-pg="mitt-svaedi"] .tgl > input:checked + .tgl-sw { background: #f6b13b; }
    main[data-pg="mitt-svaedi"] .tgl > input:checked + .tgl-sw::after { transform: translateX(16px); }
    main[data-pg="mitt-svaedi"] .tgl > input:disabled + .tgl-sw { opacity: .45; }
    main[data-pg="mitt-svaedi"] .tgl-t { display: flex; flex-direction: column; gap: 1px; }
    main[data-pg="mitt-svaedi"] .tgl-t b { font-size: 14px; color: var(--ink); font-weight: 600; }
    main[data-pg="mitt-svaedi"] .tgl-d { font-size: 12px; color: var(--muted); line-height: 1.4; }
    main[data-pg="mitt-svaedi"] .w-note { font-size: 12.5px; color: #46e08a; margin: 9px 0 0; }
    main[data-pg="mitt-svaedi"] .mail-more { margin-top: 10px; }
    main[data-pg="mitt-svaedi"] .mail-note { font-size: 12.5px; color: var(--muted); background: var(--panel); border: 1px solid var(--line); border-radius: 9px; padding: 9px 12px; line-height: 1.45; }
    main[data-pg="mitt-svaedi"] .vy-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 8px; }
    main[data-pg="mitt-svaedi"] .vy-row { display: flex; align-items: baseline; gap: 8px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 10px 12px; text-decoration: none; }
    main[data-pg="mitt-svaedi"] .vy-row:hover { border-color: #f6b13b; }
    main[data-pg="mitt-svaedi"] .vy-n { font-size: 20px; font-weight: 800; color: #f6b13b; font-variant-numeric: tabular-nums; }
    main[data-pg="mitt-svaedi"] .vy-l { font-size: 12.5px; color: var(--ink); }
    main[data-pg="mitt-svaedi"] .vy-out, main[data-pg="mitt-svaedi"] .vy-empty { font-size: 13px; color: var(--muted); line-height: 1.5; }
    main[data-pg="mitt-svaedi"] .vy-empty { margin-top: 8px; }
    main[data-pg="mitt-svaedi"] .vy-out a, main[data-pg="mitt-svaedi"] .vy-empty a { color: #f6b13b; }
    main[data-pg="mitt-svaedi"] .sk-list { display: grid; gap: 7px; }
    main[data-pg="mitt-svaedi"] .sk-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 10px 12px; text-decoration: none; }
    main[data-pg="mitt-svaedi"] .sk-row:hover { border-color: #f6b13b; }
    main[data-pg="mitt-svaedi"] .sk-cat { margin-top: 13px; }
    main[data-pg="mitt-svaedi"] .sk-cat:first-child { margin-top: 0; }
    main[data-pg="mitt-svaedi"] .sk-cat-h { font-size: 12px; font-weight: 700; color: var(--muted); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    main[data-pg="mitt-svaedi"] .sk-cat-h .sk-n { font-size: 11px; color: var(--faint); font-weight: 600; }
    main[data-pg="mitt-svaedi"] .fc-dot { color: var(--gold); font-size: 9px; vertical-align: middle; }
    main[data-pg="mitt-svaedi"] .fylgja-ny { font-size: 11px; font-weight: 700; color: var(--gold); background: rgba(246,177,59,.14); padding: 1px 8px; border-radius: 999px; margin-left: 6px; }
    main[data-pg="mitt-svaedi"] .theme-seg { display: inline-flex; border: 1px solid var(--line); border-radius: 9px; overflow: hidden; }
    main[data-pg="mitt-svaedi"] .theme-seg button { background: none; border: 0; padding: 8px 14px; color: var(--muted); cursor: pointer; font: inherit; font-size: 13px; }
