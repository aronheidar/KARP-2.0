            const mems = (d.members || []).map((m) => (typeof m === 'string' ? { email: m, skrad: null } : m));
            const rows = mems.map((m) => '<div class="mem"><span>' + esc(m.email) + (m.skrad === false ? ' <em class="dim" style="font-style:normal;font-size:10.5px">· óskráð — biðja um nýskráningu</em>' : m.skrad ? ' <em style="font-style:normal;font-size:10.5px;color:var(--green,#6ee7b7)">· virkur</em>' : '') + '</span><button data-e="' + esc(m.email) + '" class="mem-x" title="Fjarlægja">✕</button></div>').join('') || '<span class="dim">Engir meðlimir enn.</span>';
            const full = mems.length >= d.cap;
