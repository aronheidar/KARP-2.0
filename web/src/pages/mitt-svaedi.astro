      // 📋 Vakta-samantekt (öll vaktakerfi) — í Stillingum
      async function paintVaktYfirlit(loggedIn) {
        const el = $g('vakt-yfirlit'); if (!el) return;
        if (!loggedIn) { el.innerHTML = '<div class="vy-out">🔎 <a href="/vaktir/">Leitarorðavaktin</a> og fasteignavaktin virka án innskráningar (vistast í vafra). <a href="' + loginHref() + '">Skráðu þig inn</a> til að fá vaktir í tölvupóst og sjá þær á öllum tækjum.</div>'; return; }
        const [lv, fv, fm, hv] = await Promise.all([karpGet('/leitvakt').catch(() => null), karpGet('/fastvakt').catch(() => null), karpGet('/firmavakt').catch(() => null), karpGet('/vaktir').catch(() => null)]);
        const nOrd = ((lv && lv.ord) || []).length, nFast = ((fv && fv.vaktir) || []).length, nFelog = ((fm && fm.felog) || []).length;
        const nHag = (Array.isArray(hv) ? hv : ((hv && hv.vaktir) || [])).length;
