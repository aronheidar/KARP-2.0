---
// ─────────────────────────────────────────────────────────────
// „Mitt svæði" (LOTA 9) — widget-mælaborð EINS OG GAMLA + Stillingar-flipi:
// 📈 hagvísar · 🗺️ MITT SVEITARFÉLAG (val vistast) · 🔖 að fylgja ·
// 🏛️ þingsæti-spá · 🎯 flokkamatið (stefnupróf) — og Stillingar (sveitarfélag,
// vaktir, aðgangur). Allt bakað + localStorage; innskráð efni um auth.js. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import THINGMENN from '@gogn/althingi.json';
import ATV from '@gogn/atvinnuleysi.json';
import POLLS from '@gogn/polls.json';
import FRUMVORP from '@gogn/frumvorp.json';
import SVPOP from '@gogn/sveitarfelog_pop.json';
import SVCOORDS from '@gogn/sveitarfelog_coords.json';
import SVFIN from '@gogn/sveitarfelog_fin.json';
import SVMETA from '@gogn/sveitarfelog_meta.json';
import GLAEPIR from '@gogn/glaepir.json';
import FASTEIGNIR from '@gogn/fasteignir.json';
import REGIONGEO from '@gogn/landshlutar.json';
import JOFNUN from '@gogn/jofnun.json';
import { projectSeats } from '@lib/seats.mjs';
import { colorByName, partyName, partyColor } from '@lib/parties.mjs';
import { slugify } from '@lib/format.mjs';
import { computeMuniIndex } from '@lib/muniIndex.mjs';
import { makeMuniStats, svStab } from '@lib/muniStats.mjs';
import { makeRegionOf, makeLifsQ } from '@lib/geo.mjs';

// Þingmenn (fylgja-widget)
const MP = {};
THINGMENN.forEach((m) => { MP['mp:' + m.id] = { n: m.nafn, f: m.flokkur, c: colorByName(m.flokkur), s: slugify(m.nafn), img: m.mynd || '' }; });

// Hagvísa-strípa (bakað)
const KPIS = [
  { l: '👷 Atvinnuleysi', v: (ATV.latest ?? 0).toFixed(1).replace('.', ',') + '%', href: '/vinnumarkadur/' },
  { l: '🏦 Stýrivextir', v: '7,75%', href: '/verdlag/' },
  { l: '📉 Verðbólga', v: 'sjá Verðlag', href: '/verdlag/' },
];

// Þingsæti-spá mini
const r = projectSeats(POLLS, THINGMENN);
const topParty = Object.keys(r.proj).sort((a, b) => r.proj[b] - r.proj[a])[0];
const SEATSW = { gov: r.govS, opp: r.oppS, maj: r.maj, top: topParty ? { n: partyName(topParty), c: partyColor(topParty), s: r.proj[topParty] } : null };

// Sveitarfélaga-val + FULLT SPJALD (LOTA 12): sama líkan og /sveitarfelog/[slug]
const idxMap = computeMuniIndex({ SVFIN, SVMETA, SVPOP, ATVINNULEYSI: ATV });
const regionOf = makeRegionOf({ SVCOORDS, REGIONGEO });
const muniStats = makeMuniStats({ ATVINNULEYSI: ATV, GLAEPIR, FASTEIGNIR });
const lifsQ = makeLifsQ({ SVMETA, regionOf, svUnemp: muniStats.svUnemp, svCrime: muniStats.svCrime });
const ranked = Object.keys(idxMap).filter((n) => idxMap[n].idx != null).sort((a, b) => idxMap[b].idx - idxMap[a].idx);
const r0 = (v) => (v == null ? null : Math.round(v));
const MUNIS = Object.keys(SVCOORDS).sort((a, b) => a.localeCompare(b, 'is')).map((n) => {
  const reg = regionOf(n), fin = SVFIN[n] || {}, ix = idxMap[n] || null;
  const crime = muniStats.svCrime(reg);
  const oryggi = crime && crime.hegn != null ? Math.max(0, Math.min(100, Math.round(100 - crime.hegn / 4.5))) : null;
  const house = muniStats.svHouse(n, reg);
  const jof = (JOFNUN.m || {})[n] || null;
  return {
    n, s: slugify(n), pop: SVPOP[n] || null,
    idx: ix ? r0(ix.idx) : null, rank: ranked.indexOf(n) + 1, rt: ranked.length,
    R: [ix ? r0(ix.fjar) : null, ix ? r0(ix.vox) : null, ix ? r0(ix.atv) : null, lifsQ(n), oryggi, svStab(fin)],
    u: fin.utsvar ?? null, sk: fin.skuldir_ibui ?? null, af: fin.afkoma_ibui ?? null,
    unemp: muniStats.svUnemp(n, reg), house: house ? house.v : null,
    jof: jof && jof.t && jof.ibuar ? Math.round(jof.t / jof.ibuar / 1000) : null,
  };
});

// Flokkamatið: sömu spurningar og stefnuprófið (afstaða = meirihluti flokks)
const pName = (k) => (k === 'U' ? 'Óháðir' : partyName(k) || k);
const SPQ = FRUMVORP
  .filter((b) => (b.hs === 'Frv.' || b.hs === 'Till.') && (b.ja || 0) > 0 && (b.nei || 0) > 5 && b.sam)
  .sort((a, b) => (b.d || '').localeCompare(a.d || '')).slice(0, 12)
  .map((b) => { const P = b.P || {}; const st = {}; Object.keys(P).forEach((k) => { const [ja, nei] = P[k]; if (k === 'U' || ja + nei === 0 || ja === nei) return; st[k] = ja > nei ? 1 : -1; }); return { id: 'q' + b.nr, stance: st }; })
  .filter((q) => Object.keys(q.stance).length >= 4);
const SPP = {};
[...new Set(SPQ.flatMap((q) => Object.keys(q.stance)))].forEach((k) => { SPP[k] = { n: pName(k), c: partyColor(k) }; });

const updated = '2026-07-02';
---

<Layout title="Mitt svæði | Karp" noindex={true}>
  <main data-pg="mitt-svaedi">
    <p class="kicker">Karp</p>
    <h1>Mitt svæði</h1>
    <div class="tabs"><button class="tab on" data-t="dash">📊 Mælaborð</button><button class="tab" data-t="still">⚙️ Stillingar</button></div>

    <!-- ── MÆLABORÐ ── -->
    <section id="p-dash">
      <div id="gate-note"></div>

      <div class="w">
        <div class="w-h">📈 Hagvísar dagsins</div>
        <div class="kpis">{KPIS.map((k) => <a class="kpi" href={k.href}><span class="k-l">{k.l}</span><span class="k-v">{k.v}</span></a>)}</div>
      </div>

      <div class="w">
        <div class="w-h">🗺️ Mitt sveitarfélag</div>
        <div id="w-sveit"></div>
      </div>

      <div class="w">
        <div class="w-h">🌬️ Loftgæði — lifandi <span class="w-sub">svifryk PM10 · Umhverfisstofnun</span></div>
        <div id="w-loft">Sæki mælingar…</div>
      </div>

      <div class="w">
        <div class="w-h">🔔 Vaktirnar — nýjast <span class="w-sub">dómar · samráð · útboð · greiðslur</span> <a class="w-more" href="/vaktir/">Allar vaktir →</a></div>
        <div id="w-vaktir" class="wv-grid">Sæki vaktir…</div>
      </div>

      <div class="w">
        <div class="w-h">🔖 Að fylgja</div>
        <div id="mine">Hleð…</div>
      </div>

      <div class="w">
        <div class="w-h">🏛️ Þingsæti-spá</div>
        <div class="seats">
          <span class={SEATSW.maj ? 'up' : 'dn'}><b>{SEATSW.gov}</b> ríkisstjórn</span>
          <span><b>{SEATSW.opp}</b> stjórnarandstaða</span>
          {SEATSW.top && <span style={`color:${SEATSW.top.c}`}><b>{SEATSW.top.s}</b> {SEATSW.top.n} (stærst)</span>}
          <a href="/althingi/">Sætaspáin →</a>
        </div>
      </div>

      <div class="w">
        <div class="w-h">🎯 Flokkamatið mitt</div>
        <div id="w-match"></div>
      </div>
    </section>

    <!-- ── STILLINGAR ── -->
    <section id="p-still" hidden>
      <div class="w">
        <div class="w-h">🗺️ Sveitarfélagið mitt</div>
        <p class="w-p">Veldu sveitarfélagið þitt — spjaldið birtist á mælaborðinu og valið vistast í vafranum.</p>
        <select id="sv-sel"><option value="">— Velja sveitarfélag —</option>{MUNIS.map((m) => <option value={m.n}>{m.n}</option>)}</select>
      </div>
      <div class="w">
        <div class="w-h">🔔 Vaktir</div>
        <div id="vaktir"><span class="dim">Skráðu þig inn til að sjá vaktirnar þínar.</span></div>
      </div>
      <div class="w">
        <div class="w-h">👤 Aðgangurinn</div>
        <div id="acc" class="acc"></div>
        <div class="acc-links">
          <a href="https://karp.is/notandi/" target="_blank" rel="noopener">Breyta prófíl á karp.is ↗</a>
          <a href="https://wp.karp.is/login/?action=lostpassword" target="_blank" rel="noopener">Breyta lykilorði ↗</a>
        </div>
      </div>
    </section>

    <p class="foot">Forþjónað (SSG) {updated} · persónulegt yfirlit — fylgja/vaktir um <code>auth.js</code>, sveitarfélagsval og flokkamat aðeins í þínum vafra. #2.</p>
  </main>

  <script type="application/json" id="d-mp" set:html={JSON.stringify(MP)}></script>
  <script type="application/json" id="d-munis" set:html={JSON.stringify(MUNIS)}></script>
  <script type="application/json" id="d-spq" set:html={JSON.stringify({ q: SPQ, p: SPP })}></script>

  <style>
    main { max-width: 780px; margin: 0 auto; padding: 34px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 30px; margin: 0 0 12px; }
    .tabs { display: flex; gap: 6px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 16px; }
    .tab { background: none; border: 0; color: #9fb0c8; font-size: 15px; font-weight: 700; padding: 10px 14px; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .tab.on { color: #f6b13b; border-bottom-color: #f6b13b; }
    .w { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; }
    .w-h { font-size: 13px; font-weight: 700; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 10px; }
    .w-p { font-size: 13px; color: #9fb0c8; margin: 0 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; }
    .kpi { display: flex; flex-direction: column; gap: 2px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 10px 12px; text-decoration: none; }
    .kpi:hover { border-color: #f6b13b; }
    .k-l { font-size: 11px; color: #9fb0c8; }
    .k-v { font-size: 18px; font-weight: 800; color: #eaf1fb; }
    .seats { display: flex; flex-wrap: wrap; gap: 8px 18px; font-size: 13.5px; color: #9fb0c8; align-items: baseline; }
    .seats b { font-size: 18px; color: #eaf1fb; }
    .seats .up b { color: #46e08a; } .seats .dn b { color: #ff6d7a; }
    .seats a { color: #f6b13b; text-decoration: none; font-size: 12.5px; }
    select { width: 100%; max-width: 340px; background: #0e1626; border: 1px solid rgba(255,255,255,.15); color: #eaf1fb; border-radius: 9px; padding: 10px 12px; font-size: 14px; }
    .acc { font-size: 13.5px; color: #cdd6e6; margin-bottom: 8px; }
    .acc-links { display: flex; flex-wrap: wrap; gap: 14px; }
    .acc-links a { font-size: 12.5px; color: #9fb0c8; }
    .acc-links a:hover { color: #f6b13b; }
    .dim { font-size: 13px; color: #7e8ca6; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 20px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>
  <style is:global>
    /* Runtime-innihald widgeta → global. */
    .w-more { margin-left: auto; font-size: 12px; color: #f6b13b; text-decoration: none; }
    .wv-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(215px, 1fr)); gap: 10px; font-size: 13px; color: #9fb0c8; }
    .wv { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07); border-radius: 10px; padding: 8px 11px; }
    .wv-h { font-size: 11px; color: #7e8ca6; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 4px; }
    .wv-i { display: block; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.05); text-decoration: none; }
    .wv-i:last-child { border-bottom: 0; }
    .wv-t { display: block; font-size: 12.5px; color: #eaf1fb; line-height: 1.3; }
    .wv-i:hover .wv-t { color: #f6b13b; }
    .wv-s { display: block; font-size: 10.5px; color: #7e8ca6; margin-top: 1px; }
    #gate-note .gate { font-size: 14px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 12px 14px; border-radius: 0 8px 8px 0; margin-bottom: 12px; }
    #gate-note .gate a { color: #f6b13b; }
    #w-sveit .sv-empty { font-size: 13px; color: #7e8ca6; }
    #w-sveit .sv-empty button { background: none; border: 0; color: #f6b13b; cursor: pointer; font-size: 13px; padding: 0; }
    #w-sveit .sv-head { display: flex; flex-wrap: wrap; gap: 8px 16px; align-items: baseline; margin-bottom: 10px; }
    #w-sveit .sv-n { font-size: 17px; font-weight: 800; color: #f6b13b; }
    #w-sveit .sv-i { font-size: 13px; color: #9fb0c8; }
    #w-sveit .sv-badge { font-size: 11.5px; color: #eaf1fb; background: rgba(246,177,59,.14); border: 1px solid rgba(246,177,59,.35); border-radius: 999px; padding: 2px 10px; }
    #w-sveit a.sv-go { font-size: 12.5px; color: #f6b13b; text-decoration: none; margin-left: auto; }
    #w-sveit .sv-body { display: grid; grid-template-columns: minmax(0, 1fr) 230px; gap: 10px; align-items: center; }
    @media (max-width: 700px) { #w-sveit .sv-body { grid-template-columns: 1fr; } }
    #w-sveit .sv-tiles { display: grid; grid-template-columns: repeat(auto-fill, minmax(118px, 1fr)); gap: 7px; }
    #w-sveit .svt { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 9px; padding: 7px 9px; }
    #w-sveit .svt-l { font-size: 10.5px; color: #8fa0ba; white-space: nowrap; overflow: hidden; }
    #w-sveit .svt-v { font-size: 16.5px; font-weight: 800; color: #eaf1fb; font-variant-numeric: tabular-nums; margin-top: 1px; }
    #w-sveit .svt-s { font-size: 10px; color: #7e8ca6; }
    #w-sveit #sv-radar { width: 100%; height: 195px; }
    .w-sub { font-size: 11px; color: #7e8ca6; font-weight: 400; margin-left: 8px; text-transform: none; letter-spacing: 0; }
    .loft { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; }
    .lf { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 9px; padding: 8px 10px; }
    .lf-n { font-size: 10.5px; color: #8fa0ba; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .lf-v { font-size: 18px; font-weight: 800; font-variant-numeric: tabular-nums; margin-top: 2px; }
    .lf-v span { font-size: 10px; font-weight: 400; color: #7e8ca6; }
    .lf-s { font-size: 10.5px; font-weight: 700; }
    .lf-note { font-size: 11px; color: #7e8ca6; margin-top: 8px; }
    #mine .gate, #mine .empty { font-size: 14px; color: #9fb0c8; }
    #mine .empty a, #mine .gate a { color: #f6b13b; }
    #mine .flist { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
    #mine .fcard { display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-left: 3px solid var(--pc); border-radius: 10px; padding: 7px 9px; }
    #mine .fc-link { display: flex; align-items: center; gap: 9px; text-decoration: none; color: #eaf1fb; flex: 1; min-width: 0; }
    #mine .fc-link img, #mine .fc-ini { width: 34px; height: 42px; border-radius: 7px; object-fit: cover; flex: none; background: #0e1626; }
    #mine .fc-ini { display: inline-flex; align-items: center; justify-content: center; font-weight: 700; color: var(--pc); font-size: 16px; }
    #mine .fc-txt { display: flex; flex-direction: column; min-width: 0; }
    #mine .fc-n { font-weight: 600; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    #mine .fc-f { font-size: 11px; color: #9fb0c8; }
    #mine .fc-x { background: none; border: 0; color: #7e8ca6; font-size: 14px; cursor: pointer; padding: 3px 5px; flex: none; }
    #mine .fc-x:hover { color: #ff6d7a; }
    #w-match .m-row { display: grid; grid-template-columns: 120px 1fr 46px; gap: 10px; align-items: center; margin-top: 6px; }
    #w-match .m-n { font-size: 12.5px; font-weight: 700; color: var(--pc); }
    #w-match .m-bar { height: 10px; border-radius: 5px; background: rgba(255,255,255,.07); overflow: hidden; }
    #w-match .m-bar i { display: block; height: 100%; background: var(--pc); }
    #w-match .m-v { text-align: right; font-size: 12px; font-weight: 700; color: #eaf1fb; }
    #w-match .m-empty { font-size: 13px; color: #7e8ca6; }
    #w-match .m-empty a { color: #f6b13b; }
    #vaktir .vk { display: flex; justify-content: space-between; align-items: center; gap: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 9px 12px; margin-top: 6px; font-size: 13px; color: #cdd6e6; }
    #vaktir .vk b { color: #eaf1fb; }
    #vaktir .vk-x { background: none; border: 0; color: #7e8ca6; font-size: 15px; cursor: pointer; }
    #vaktir .vk-x:hover { color: #ff6d7a; }
    #vaktir .vk-note { font-size: 12px; color: #7e8ca6; margin-top: 8px; }
    #vaktir .vk-note a { color: #9fb0c8; }
  </style>

  <!-- Eyja: flipar + widgets (fylgja/sveitarfélag/flokkamat/vaktir/aðgangur). #2 -->
  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';
    const $g = (id) => document.getElementById(id);
    const J = (id) => { try { return JSON.parse($g(id).textContent); } catch (e) { return null; } };
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    function initMitt() {
      if (!$g('p-dash') || $g('p-dash').dataset.done) return;
      $g('p-dash').dataset.done = '1';
      // Flipar
      document.querySelectorAll('.tab').forEach((t) => {
        t.onclick = () => {
          document.querySelectorAll('.tab').forEach((x) => x.classList.toggle('on', x === t));
          $g('p-dash').hidden = t.dataset.t !== 'dash';
          $g('p-still').hidden = t.dataset.t !== 'still';
        };
      });

      // Mitt sveitarfélag (localStorage karp-sveit) — FULLT SPJALD: lykiltölur + radar (LOTA 12)
      const gt = (v) => String(v).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      const f1 = (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ','));
      const paintSveit = () => {
        const el = $g('w-sveit');
        const sv = localStorage.getItem('karp-sveit') || '';
        const MUNIS = J('d-munis') || [];
        const m = MUNIS.find((x) => x.n === sv);
        if (!m) { el.innerHTML = '<div class="sv-empty">Ekkert valið — <button id="go-still">veldu sveitarfélagið þitt í ⚙️ Stillingum</button>.</div>'; const b = el.querySelector('#go-still'); if (b) b.onclick = () => document.querySelector('.tab[data-t="still"]').click(); return; }
        const tile = (e, l, v, s) => `<div class="svt"><div class="svt-l">${e} ${l}</div><div class="svt-v">${v}</div><div class="svt-s">${s}</div></div>`;
        el.innerHTML = `
          <div class="sv-head">
            <span class="sv-n">${esc(m.n)}</span>
            ${m.pop ? `<span class="sv-i">${gt(m.pop)} íbúar</span>` : ''}
            ${m.idx != null ? `<span class="sv-badge">🏆 ${m.rank}. af ${m.rt}</span>` : ''}
            <a class="sv-go" href="/sveitarfelog/${esc(m.s)}/">Opna sveitarspjaldið →</a>
          </div>
          <div class="sv-body">
            <div class="sv-tiles">
              ${m.idx != null ? tile('🏆', 'Vísitala', String(m.idx), 'af 100') : ''}
              ${tile('👷', 'Atvinnuleysi', m.unemp != null ? f1(m.unemp) + '%' : '–', 'skráð')}
              ${tile('🏠', 'Húsnæði', m.house != null ? gt(m.house) + ' þ' : '–', 'kr/m²')}
              ${tile('💰', 'Útsvar', m.u != null ? f1(m.u) + '%' : '–', 'hám. 14,74%')}
              ${tile('💳', 'Skuldir/íbúa', m.sk != null ? gt(m.sk) + ' þ' : '–', 'þ.kr.')}
              ${tile('📊', 'Afkoma/íbúa', m.af != null ? (m.af >= 0 ? '+' : '') + gt(m.af) + ' þ' : '–', 'rekstur')}
              ${m.jof != null ? tile('⚖️', 'Jöfnunarsjóður', gt(m.jof) + ' þ', 'kr/íbúa á ári') : ''}
            </div>
            <div id="sv-radar"></div>
          </div>`;
        // Mini-Stellaris-radar (sömu 6 ásar og sveitarspjaldið)
        const hasR = (m.R || []).filter((v) => v != null).length >= 4;
        const rEl = $g('sv-radar');
        if (!hasR || !rEl) { if (rEl) rEl.remove(); return; }
        const draw = () => {
          if (window.echarts.getInstanceByDom(rEl)) return;
          const c = window.echarts.init(rEl);
          c.setOption({
            backgroundColor: 'transparent',
            radar: {
              indicator: ['Fjárhagur', 'Vöxtur', 'Atvinna', 'Lífsgæði', 'Öryggi', 'Stöðugl.'].map((l) => ({ name: l, max: 100 })),
              radius: '62%', center: ['50%', '54%'],
              axisName: { color: '#9fb0c8', fontSize: 10 },
              splitArea: { areaStyle: { color: ['rgba(255,255,255,.02)', 'rgba(255,255,255,.045)'] } },
              splitLine: { lineStyle: { color: 'rgba(255,255,255,.09)' } },
              axisLine: { lineStyle: { color: 'rgba(255,255,255,.09)' } },
            },
            tooltip: { show: false },
            series: [{ type: 'radar', silent: true, data: [{ value: m.R.map((v) => v ?? 0), lineStyle: { color: '#f6b13b', width: 2 }, itemStyle: { color: '#f6b13b' }, areaStyle: { color: '#f6b13b', opacity: 0.2 }, symbolSize: 3 }] }],
          });
        };
        if (window.echarts) { draw(); return; }
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', draw, { once: true });
      };
      paintSveit();
      const sel = $g('sv-sel');
      sel.value = localStorage.getItem('karp-sveit') || '';
      sel.onchange = () => { localStorage.setItem('karp-sveit', sel.value); paintSveit(); };

      // Loftgæði — LIFANDI frá Umhverfisstofnun (api.ust.is, opið CORS). LOTA 13.
      (() => {
        const el = $g('w-loft');
        if (!el || el.dataset.done) return;
        el.dataset.done = '1';
        const grade = (v) => (v == null ? ['—', '#7e8ca6'] : v < 20 ? ['gott', '#46e08a'] : v < 50 ? ['í lagi', '#f6b13b'] : ['slæmt', '#ff6d7a']);
        fetch('https://api.ust.is/aq/a/getLatest')
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            if (!d) { el.innerHTML = '<span class="dim">Náði ekki í loftgæðagögn.</span>'; return; }
            const rows = Object.values(d).map((s) => {
              const pm = s.parameters && (s.parameters.PM10 || s.parameters['PM2.5']);
              const latest = pm && pm['0'];
              const v = latest && latest.value != null ? Math.round(parseFloat(latest.value) * 10) / 10 : null;
              return { n: s.name || '', v, t: latest && (latest.endtime || latest.time) };
            }).filter((x) => x.n && x.v != null);
            if (!rows.length) { el.innerHTML = '<span class="dim">Engar nýjar mælingar í boði.</span>'; return; }
            // Valið sveitarfélag fyrst ef stöðvarnafn passar, annars stærstu stöðvarnar
            const sv = (localStorage.getItem('karp-sveit') || '').split(/bær|borg|kaupstaður|hreppur/)[0].trim();
            rows.sort((a, b) => {
              const am = sv && a.n.toLowerCase().includes(sv.toLowerCase()) ? 1 : 0;
              const bm = sv && b.n.toLowerCase().includes(sv.toLowerCase()) ? 1 : 0;
              return bm - am || b.v - a.v;
            });
            el.innerHTML = '<div class="loft">' + rows.slice(0, 6).map((x) => {
              const [lbl, col] = grade(x.v);
              return `<div class="lf"><div class="lf-n">${esc(x.n)}</div><div class="lf-v" style="color:${col}">${String(x.v).replace('.', ',')} <span>µg/m³</span></div><div class="lf-s" style="color:${col}">● ${lbl}</div></div>`;
            }).join('') + '</div><div class="lf-note">PM10-svifryk, nýjasta klukkustundarmæling. Viðmið: &lt;20 gott · 20–50 í lagi · &gt;50 slæmt. Heimild: api.ust.is.</div>';
          })
          .catch(() => { el.innerHTML = '<span class="dim">Náði ekki í loftgæðagögn.</span>'; });
      })();

      // 🔔 Vaktirnar — nýjast úr fjórum lifandi veitum (LOTA 18 #11b)
      (() => {
        const el = $g('w-vaktir');
        if (!el) return;
        const dIS2 = (d) => { const m = String(d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.` : ''; };
        const box = (t, rows, href) => `<div class="wv"><div class="wv-h">${t}</div>${rows.map((r) => `<a class="wv-i" href="${href}" ${href.startsWith('http') ? 'target="_blank" rel="noopener"' : ''}><span class="wv-t">${r[0]}</span><span class="wv-s">${r[1]}</span></a>`).join('') || '<span class="dim">—</span>'}</div>`;
        Promise.allSettled([
          fetch('/api/domar').then((r) => (r.ok ? r.json() : null)),
          fetch('/api/samrad').then((r) => (r.ok ? r.json() : null)),
          fetch('/api/utbod').then((r) => (r.ok ? r.json() : null)),
          fetch('/api/greidslur').then((r) => (r.ok ? r.json() : null)),
        ]).then(([dm, sm, ub, gr]) => {
          const out = [];
          const d = dm.value;
          if (d && (d.hr || []).length) out.push(box('⚖️ Nýjustu dómar', d.hr.slice(0, 2).map((v) => [esc('Mál ' + v.nr + ' · Hæstiréttur'), dIS2(v.dags) + esc((v.efnisord || [])[0] || '')]), '/vaktir/'));
          const cs = ((((sm.value || {}).data || {}).consultationPortalGetCases || {}).cases || []);
          if (cs.length) out.push(box('💬 Í samráði', cs.slice(0, 2).map((c) => [esc(String(c.name).slice(0, 54)), esc(c.institutionName || '') + ' · ' + esc(c.statusName || '')]), '/vaktir/'));
          const ps = ub.value;
          if (Array.isArray(ps) && ps.length) out.push(box('📋 Ný útboð', ps.slice(0, 2).map((p) => [esc(((p.title || {}).rendered || '').slice(0, 54)), dIS2(p.date)]), '/vaktir/'));
          const g = gr.value;
          if (g && (g.rows || []).length) out.push(box('💸 Greiðslur ríkisins', g.rows.slice(0, 2).map((r) => [esc(r.stofnun + ' → ' + r.birgir).slice(0, 60), dIS2(r.dags) + Math.round(r.upph / 1000).toLocaleString('de-DE') + ' þ.kr']), '/vaktir/'));
          el.innerHTML = out.length ? out.join('') : '<span class="dim">Vaktirnar svara ekki í augnablikinu — kíktu á <a href="/vaktir/">Vaktir</a>.</span>';
        });
      })();

      // Flokkamatið (úr stefnuprófs-svörum í localStorage)
      const mEl = $g('w-match');
      const D = J('d-spq');
      let ans = {};
      try { ans = JSON.parse(localStorage.getItem('karp-stefnuprof') || '{}'); } catch (e) {}
      const answered = Object.keys(ans).length;
      if (!answered || !D) {
        mEl.innerHTML = '<div class="m-empty">Taktu <a href="/stefnuprof/">stefnuprófið</a> — þá birtist flokkamatið þitt hér.</div>';
      } else {
        const score = {}, max = {};
        D.q.forEach((q) => { const a = ans[q.id]; if (!a) return; Object.keys(q.stance).forEach((k) => { max[k] = (max[k] || 0) + 1; if (q.stance[k] === a) score[k] = (score[k] || 0) + 1; }); });
        const rows = Object.keys(max).map((k) => ({ n: D.p[k].n, c: D.p[k].c, pct: Math.round(((score[k] || 0) / max[k]) * 100) })).sort((a, b) => b.pct - a.pct).slice(0, 5);
        mEl.innerHTML = rows.map((r) => `<div class="m-row" style="--pc:${r.c}"><span class="m-n">${esc(r.n)}</span><span class="m-bar"><i style="width:${r.pct}%"></i></span><span class="m-v">${r.pct}%</span></div>`).join('') + `<div class="m-empty" style="margin-top:8px"><a href="/stefnuprof/">Endurtaka prófið →</a></div>`;
      }

      // Innskráð efni — LOTA 19: enginn veggur; óinnskráð sést allt og fylgi les
      // líka localStorage-listann (karp-follows-local af þingmanna-/frétta-síðum).
      loadUser().then(async (u) => {
        const gate = $g('gate-note');
        if (!u || !u.loggedIn) {
          gate.innerHTML = '';
          $g('acc').innerHTML = `Ekki innskráð(ur) — allt hér vistast í vafranum þínum. <a href="${(u && u.loginUrl) || 'https://wp.karp.is/login/'}">Innskráning</a> geymir það milli tækja og opnar vaktir í tölvupósti.`;
          const MPL = J('d-mp') || {};
          let lf = [];
          try { lf = JSON.parse(localStorage.getItem('karp-follows-local') || '[]'); } catch (e) {}
          const mps = lf.filter((k) => k.indexOf('mp:') === 0 && MPL[k]);
          $g('mine').innerHTML = mps.length
            ? '<div class="flist">' + mps.map((k) => { const m = MPL[k]; return `<div class="fcard" style="--pc:${m.c}"><a class="fc-link" href="/althingi/${m.s}/"><span class="fc-txt"><span class="fc-n">${esc(m.n)}</span><span class="fc-f">${esc(m.f)}</span></span></a></div>`; }).join('') + '</div><div class="dim" style="margin-top:6px">Vistað á þessu tæki.</div>'
            : '<div class="empty">Þú fylgist ekki með neinum enn — farðu á <a href="/althingi/thingmenn/">Þingmenn</a> og ýttu „+ Fylgja" (vistast á tækinu án innskráningar).</div>';
          $g('vaktir').innerHTML = '<span class="dim">🔎 <a href="/vaktir/">Leitarorðavaktin</a> virkar án innskráningar — hagvísavaktir í tölvupósti þurfa innskráningu.</span>';
          return;
        }
        $g('acc').textContent = `Innskráð(ur) sem ${u.name || ''}${u.email ? ' · ' + u.email : ''}`;
        // Að fylgja
        const MP = J('d-mp') || {};
        const paintMine = () => {
          const el = $g('mine');
          const mps = (window.KARP_USER.follows || []).filter((k) => k.indexOf('mp:') === 0 && MP[k]);
          const cos = (window.KARP_USER.follows || []).filter((k) => k.indexOf('co:') === 0);
          if (!mps.length && !cos.length) { el.innerHTML = '<div class="empty">Þú fylgist ekki með neinum enn — farðu á <a href="/althingi/thingmenn/">Þingmenn</a> eða <a href="/frettir/">Umfjöllun</a> og ýttu „+ Fylgja".</div>'; return; }
          el.innerHTML = '<div class="flist">' + mps.map((k) => {
            const m = MP[k];
            const pic = m.img ? `<img src="${esc(m.img)}" alt="" loading="lazy" onerror="this.style.display='none'">` : `<span class="fc-ini">${esc(m.n.charAt(0))}</span>`;
            return `<div class="fcard" style="--pc:${m.c}"><a class="fc-link" href="/althingi/${m.s}/">${pic}<span class="fc-txt"><span class="fc-n">${esc(m.n)}</span><span class="fc-f">${esc(m.f)}</span></span></a><button class="fc-x" data-key="${esc(k)}">✕</button></div>`;
          }).join('') + cos.map((k) => { const n = k.slice(3); return `<div class="fcard" style="--pc:#19d3c5"><a class="fc-link" href="/frettir/"><span class="fc-ini">🏢</span><span class="fc-txt"><span class="fc-n">${esc(n)}</span><span class="fc-f">umfjöllun vöktuð</span></span></a><button class="fc-x" data-key="${esc(k)}">✕</button></div>`; }).join('') + '</div>';
          el.querySelectorAll('.fc-x').forEach((b) => {
            b.onclick = async () => { b.disabled = true; const next = (window.KARP_USER.follows || []).filter((x) => x !== b.dataset.key); const res = await karpPost('/follows', { follows: next }); window.KARP_USER.follows = (res && res.follows) ? res.follows : next; paintMine(); };
          });
        };
        paintMine();
        // Vaktir
        const vd = await karpGet('/vaktir');
        const vb = $g('vaktir');
        if (vd) {
          const arr = Array.isArray(vd) ? vd : (vd && vd.vaktir) || [];
          const paintV = (list) => {
            vb.innerHTML = (list.length
              ? list.map((v, i) => `<div class="vk"><span><b>${esc(v.metric || v.m || '')}</b> ${esc(v.area || v.svaedi || '')} ${esc(v.dir === 'under' || v.dir === 'undir' ? 'fer undir' : 'fer yfir')} <b>${esc(v.threshold ?? v.vidmid ?? '')}</b></span><button class="vk-x" data-i="${v.id ?? i}">✕</button></div>`).join('')
              : '<div class="vk">Engin vakt skráð.</div>')
              + '<div class="vk-note">Vaktir senda tölvupóst þegar hagvísir nær viðmiði — stofnaðar á <a href="https://karp.is">karp.is</a> (Stillingar → Vaktir) að sinni.</div>';
            vb.querySelectorAll('.vk-x').forEach((b) => { b.onclick = async () => { b.disabled = true; const res = await karpPost('/vaktirdelete', { id: b.dataset.i }); paintV(Array.isArray(res) ? res : (res && res.vaktir) || []); }; });
          };
          paintV(arr);
        } else {
          vb.innerHTML = '<span class="dim">Vaktir birtast á karp.is.</span>';
        }
      });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="mitt-svaedi"]')) initMitt(); });
  </script>
</Layout>
