      }

      // Mitt sveitarfélag (localStorage karp-sveit) — FULLT SPJALD: lykiltölur + radar (LOTA 12)
      const gt = (v) => String(v).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      const f1 = (v) => (v == null ? '–' : String(Math.round(v * 10) / 10).replace('.', ','));
      const paintSveit = () => {
        const el = $g('w-sveit');
