            } catch (e) { b.textContent = 'Ekki tókst — reyndu aftur'; b.disabled = false; }
          });
          renderTeam(); renderKtw();
        });
        function renderTeam() {
          const box = $g('team-box'); if (!box || !A.teamList) return;
          A.teamList().then((d) => {
            if (!d || (d.cap | 0) <= 0) { box.innerHTML = ''; return; }
