---
import Layout from '../layouts/Layout.astro';
// Forsíða (hub) fyrir karp.is — nú í app-skel (nav vinstra + fréttir hægra). #2 Á3/Á6.
const pages = [
  { href: '/kort/', emoji: '🗺️', title: 'Íslandskortið', desc: 'Gagnvirkt kort — öll sveitarfélög lituð eftir 14 mælikvörðum, þysjun í landshluta.' },
  { href: '/verdlag/', emoji: '📉', title: 'Verðlag', desc: 'Verðbólga og uppruni hennar, neyslukarfan, gengi og stýrivextir — lifandi lykiltölur.' },
  { href: '/sveitarfelog/', emoji: '🏘️', title: 'Sveitarfélaga-vísitala', desc: 'Samsett vísitala 36 sveitarfélaga: fjárhagur, vöxtur og atvinna vegin saman.' },
  { href: '/althingi/', emoji: '🏛️', title: 'Sætaspá Alþingis', desc: "D'Hondt-sætaspá úr nýjustu könnunum — ríkisstjórn vs. stjórnarandstaða." },
  { href: '/thingmal/', emoji: '📜', title: 'Þingmál', desc: 'Nýjustu frumvörp og tillögur með atkvæðagreiðslu — kjóstu þína eigin skoðun.' },
  { href: '/kannanir/', emoji: '📊', title: 'Fylgi flokka', desc: 'Fylgi flokka í skoðanakönnunum frá kosningum 2024 — þróun yfir tíma.' },
  { href: '/markadir/', emoji: '📈', title: 'Markaðir', desc: 'Úrvalsvísitala, skráð félög og ávöxtunarferill ríkisbréfa.' },
  { href: '/rikisfjarmal/', emoji: '🏦', title: 'Ríkisfjármál', desc: 'Tekjur og útgjöld ríkissjóðs — fjárlög eftir málefnasviðum.' },
  { href: '/fasteignir/', emoji: '🏠', title: 'Fasteignaverð', desc: 'Verð á fermetra höfuðborg vs landsbyggð — þróun úr þinglýstum kaupum.' },
  { href: '/orka/', emoji: '⚡', title: 'Orka', desc: 'Raforkuframleiðsla og hlutfall endurnýjanlegrar orku frá 1969.' },
  { href: '/vinnumarkadur/', emoji: '👷', title: 'Vinnumarkaður', desc: 'Skráð atvinnuleysi — mánaðarþróun, landshlutar, kyn og ríkisfang.' },
  { href: '/afbrot/', emoji: '🚓', title: 'Afbrot', desc: 'Hegningarlagabrot á 10.000 íbúa — þróun, landshlutar og brotaflokkar.' },
  { href: '/nato/', emoji: '🌍', title: 'NATO & sendiráð', desc: 'Varnarútgjöld NATO-ríkja og sendiráðanet Íslands.' },
  { href: '/hagvoxtur/', emoji: '🚀', title: 'Hagvöxtur', desc: 'VLF ársfjórðungslega, samsetning landsframleiðslunnar og Norðurlanda-samanburður.' },
  { href: '/vidskipti/', emoji: '🚢', title: 'Utanríkisverslun', desc: 'Út- og innflutningur eftir vöruflokkum, jöfnuður og mánaðarleg þróun.' },
  { href: '/mannfjoldi/', emoji: '👥', title: 'Mannfjöldi', desc: 'Íbúafjöldi, þættir fólksfjölgunar og hlutfall innflytjenda.' },
  { href: '/menntun/', emoji: '🎓', title: 'Menntun', desc: 'Menntunarstaða 25–64 ára eftir ISCED-stigum og kyni.' },
  { href: '/rafbilar/', emoji: '🔌', title: 'Rafbílar', desc: 'Bílaflotinn eftir orkugjafa og rafvæðingar-hlutfallið.' },
  { href: '/umferd/', emoji: '✈️', title: 'Umferð', desc: 'Farþegar um Keflavíkurflugvöll og lifandi vegaumferð.' },
  { href: '/topplistar/', emoji: '🏆', title: 'Topplistar', desc: 'Raðanir sveitarfélaga eftir 12 mælikvörðum — hver stendur best?' },
  { href: '/jofnunarsjodur/', emoji: '⚖️', title: 'Jöfnunarsjóður', desc: 'Hvert fara 54 milljarðar sjóðsins — eftir flokkum og sveitarfélögum.' },
  { href: '/ees/', emoji: '💶', title: 'EES / EFTA', desc: 'Innri markaðurinn, tveggja stoða kerfið og nýjustu ESB-tilskipanir.' },
  { href: '/samtok/', emoji: '🤝', title: 'Alþjóðasamstarf', desc: 'Samtökin og samningarnir sem Ísland á aðild að — frá SÞ til Parísarsamnings.' },
  { href: '/reiknivelar/', emoji: '🧮', title: 'Reiknivélar', desc: 'Laun, húsnæðislán, lífeyrir og verðmat — reiknað í vafra.' },
];
// 🗞️ VIKAN Í GÖGNUNUM (LOTA 16, liður 2) — regludrifin gagnaskrif: setningar
// samdar VÉLRÆNT úr nýjustu tölum safnsins (engin gervigreind, hrein regluvirkni).
import POLLS from '@gogn/polls.json';
import FRUMVORP from '@gogn/frumvorp.json';
import LEIGA from '@gogn/leiga.json';
import ATVL from '@gogn/atvinnuleysi.json';
import MARKADIR from '@gogn/markadir.json';
import { partyName } from '@lib/parties.mjs';

const VIKAN = [];
try {
  const p = POLLS.polls || [];
  if (p.length >= 2) {
    const a = p[p.length - 1], b = p[p.length - 2];
    const top = Object.keys(a.v || {}).sort((x, y) => (a.v[y] || 0) - (a.v[x] || 0))[0];
    const d = top && b.v && b.v[top] != null ? Math.round(((a.v[top] || 0) - b.v[top]) * 10) / 10 : null;
    if (top) VIKAN.push(`📊 Í nýjustu könnun (${a.pollster}, ${a.date}) mælist ${partyName(top)} stærstur með ${String(a.v[top]).replace('.', ',')}%${d != null && d !== 0 ? ` — ${d > 0 ? 'hækkar' : 'lækkar'} um ${String(Math.abs(d)).replace('.', ',')} prósentustig milli kannana` : ''}.`);
  }
  const done = FRUMVORP.filter((b) => /^Samþykkt/.test(b.stada || '')).sort((x, y) => (y.d || '').localeCompare(x.d || ''))[0];
  if (done) VIKAN.push(`🏛️ Nýjast samþykkt á Alþingi: ${done.titill.charAt(0).toUpperCase() + done.titill.slice(1)} (${done.ja}–${done.nei}).`);
  if (ATVL.latest != null) VIKAN.push(`👷 Skráð atvinnuleysi stendur í ${String(ATVL.latest).replace('.', ',')}%.`);
  const lq = (LEIGA.quarters || []).filter((x) => x.n >= 100);
  if (lq.length >= 5) {
    const now = lq[lq.length - 1], ago = lq[lq.length - 5];
    VIKAN.push(`🔑 Leiguverð (miðgildi) var ${String(now.medM2).replace('.', ',')} kr/m² í ${now.q} — ${Math.round(((now.medM2 / ago.medM2) - 1) * 100)}% hærra en ári fyrr.`);
  }
  const ix = (MARKADIR.indices || [])[0];
  if (ix && ix.chgPct != null) VIKAN.push(`📈 ${ix.name.split('—')[0].trim()} ${ix.chgPct >= 0 ? 'hækkaði' : 'lækkaði'} um ${String(Math.abs(ix.chgPct)).replace('.', ',')}% síðasta viðskiptadag.`);
} catch (e) {}

const updated = '2026-07-01';
---

<Layout
  title="Hagvísir Íslands — Karp"
  description="Lifandi hagvísar, sveitarfélaga-vísitala og sætaspá Alþingis — borgaralegt mælaborð fyrir Ísland, byggt á opinberum gögnum."
  canonical="https://karp.is/"
>
  <main class="pg">
    <p class="kicker">Karp</p>
    <h1>Hagvísir Íslands</h1>
    <p class="lead">Borgaralegt mælaborð — opinber gögn, forþjónuð fyrir hraða og sýnileika.</p>

    <section class="b2b-hero">
      <div class="bh-top">
        <div class="bh-txt">
          <div class="bh-kick">⭐ Fyrir fyrirtæki</div>
          <h2>Fyrirtækjaskýrslur, endanlegir eigendur & áreiðanleikamat</h2>
          <p>Öll opinber fyrirtækjagögn á einum stað — ársreikningar, eigendanet, KYC-skimun og vaktir. Frá 990 kr. Prófaðu fría uppflettingu:</p>
        </div>
      </div>
      <form class="bh-search" action="/fyrirtaeki/" method="get" role="search">
        <input name="q" placeholder="Fletta upp félagi eða kt…" aria-label="Leita að félagi" autocomplete="off" />
        <button type="submit">🔎 Leita</button>
      </form>
      <div class="bh-links"><a href="/karp-pro/">Karp+ &amp; verð →</a><a href="/lausnir/fyrirtaekjaskyrsla/">Um fyrirtækjaskýrsluna →</a></div>
    </section>

    {VIKAN.length > 0 && (
      <section class="vikan">
        <div class="v-h">🗞️ Staðan í gögnunum <i class="tip" tabindex="0" data-tip="Setningarnar eru samdar VÉLRÆNT úr nýjustu tölum gagnasafnsins við hverja byggingu — regludrifin gagnaskrif, engin gervigreind og engin ritstjórn.">ⓘ</i></div>
        <ul>{VIKAN.map((v) => <li>{v}</li>)}</ul>
      </section>
    )}

    <div class="grid">
      {pages.map((p) => (
        <a class="card" href={p.href}>
          <div class="c-emoji">{p.emoji}</div>
          <div class="c-title">{p.title}</div>
          <div class="c-desc">{p.desc}</div>
          <div class="c-go">Skoða →</div>
        </a>
      ))}
    </div>

    <p class="foot">
      Forþjónað (SSG) {updated} · gögn sótt á byggingartíma úr opinberum veitum
    </p>
  </main>

  <style>
    .vikan { background: rgba(246,177,59,.05); border: 1px solid rgba(246,177,59,.22); border-radius: 13px; padding: 14px 18px; margin: 16px 0 6px; }
    .v-h { font-size: 13px; font-weight: 800; color: #f6b13b; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
    .vikan ul { margin: 0; padding-left: 4px; list-style: none; }
    .vikan li { font-size: 14px; color: #dfe7f4; line-height: 1.6; padding: 3px 0; }
    .kicker { font-size: 13px; letter-spacing: .22em; text-transform: uppercase; color: #f6b13b; font-weight: 700; margin: 0 0 6px; }
    h1 { font-size: 38px; line-height: 1.1; margin: 0 0 10px; }
    .lead { color: #cdd6e6; font-size: 18px; max-width: 620px; }
    .b2b-hero { background: linear-gradient(180deg,rgba(246,177,59,.10),rgba(246,177,59,.04)); border: 1px solid rgba(246,177,59,.30); border-radius: 16px; padding: 20px 22px; margin: 20px 0 8px; }
    .bh-kick { font-size: 11.5px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: #f6b13b; margin-bottom: 6px; }
    .b2b-hero h2 { font-size: 23px; margin: 0 0 6px; color: #eaf1fb; line-height: 1.2; }
    .bh-txt p { color: #cdd6e6; font-size: 14.5px; line-height: 1.55; margin: 0; max-width: 60ch; }
    .bh-search { display: flex; gap: 8px; margin: 14px 0 0; max-width: 520px; }
    .bh-search input { flex: 1; font: inherit; font-size: 16px; padding: 11px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,.14); background: rgba(0,0,0,.25); color: #eaf1fb; }
    .bh-search button { font: inherit; font-weight: 700; font-size: 15px; border: 0; border-radius: 10px; padding: 11px 18px; background: #f6b13b; color: #131a29; cursor: pointer; white-space: nowrap; }
    .bh-links { display: flex; gap: 18px; margin-top: 12px; flex-wrap: wrap; }
    .bh-links a { color: #f6b13b; text-decoration: none; font-weight: 600; font-size: 13.5px; }
    @media (max-width: 560px) { .bh-search { flex-direction: column; } .bh-search button { width: 100%; } }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin: 32px 0 8px; }
    .card { display: block; text-decoration: none; color: inherit; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 16px; padding: 22px; transition: border-color .15s, transform .15s, background .15s; }
    .card:hover { border-color: #f6b13b; transform: translateY(-2px); background: rgba(246,177,59,.06); }
    .c-emoji { font-size: 30px; }
    .c-title { font-size: 19px; font-weight: 700; margin: 10px 0 4px; }
    .c-desc { font-size: 14px; color: #9fb0c8; }
    .c-go { font-size: 13px; color: #f6b13b; font-weight: 600; margin-top: 12px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 34px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .foot a { color: #9fb0c8; }
  </style>
</Layout>
