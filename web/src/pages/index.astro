---
import Layout from '../layouts/Layout.astro';
// Forsíða (hub) fyrir app.karp.is — nú í app-skel (nav vinstra + fréttir hægra). #2 Á3/Á6.
const pages = [
  { href: '/efnahagur/', emoji: '📉', title: 'Efnahagur', desc: 'Verðbólga, stýrivextir, gengi og atvinnuleysi — lifandi lykiltölur frá Hagstofu, Seðlabanka og ECB.' },
  { href: '/sveitarfelog/', emoji: '🏘️', title: 'Sveitarfélaga-vísitala', desc: 'Samsett vísitala 36 sveitarfélaga: fjárhagur, vöxtur og atvinna vegin saman.' },
  { href: '/althingi/', emoji: '🏛️', title: 'Sætaspá Alþingis', desc: "D'Hondt-sætaspá úr nýjustu könnunum — ríkisstjórn vs. stjórnarandstaða." },
  { href: '/thingmal/', emoji: '📜', title: 'Þingmál', desc: 'Nýjustu frumvörp og tillögur með atkvæðagreiðslu — kjóstu þína eigin skoðun.' },
  { href: '/kannanir/', emoji: '📊', title: 'Kannanir', desc: 'Fylgi flokka í skoðanakönnunum frá kosningum 2024 — þróun yfir tíma.' },
];
const updated = '2026-07-01';
---

<Layout
  title="Hagvísir Íslands — Karp"
  description="Lifandi hagvísar, sveitarfélaga-vísitala og sætaspá Alþingis — borgaralegt mælaborð fyrir Ísland, byggt á opinberum gögnum."
  canonical="https://app.karp.is/"
>
  <main class="pg">
    <p class="kicker">Karp</p>
    <h1>Hagvísir Íslands</h1>
    <p class="lead">Borgaralegt mælaborð — opinber gögn, forþjónuð fyrir hraða og sýnileika.</p>

    <div class="grid">
      {pages.map((p) => (
        <a class="card" href={p.href}>
          <div class="c-emoji">{p.emoji}</div>
          <div class="c-title">{p.title}</div>
          <div class="c-desc">{p.desc}</div>
          <div class="c-go">Skoða →</div>
        </a>
      ))}
    </div>

    <p class="foot">
      Forþjónað (SSG) {updated} · gögn sótt á byggingartíma · fullt mælaborð á <a href="https://www.karp.is">karp.is</a>
    </p>
  </main>

  <style>
    .kicker { font-size: 13px; letter-spacing: .22em; text-transform: uppercase; color: #f6b13b; font-weight: 700; margin: 0 0 6px; }
    h1 { font-size: 38px; line-height: 1.1; margin: 0 0 10px; }
    .lead { color: #cdd6e6; font-size: 18px; max-width: 620px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 16px; margin: 32px 0 8px; }
    .card { display: block; text-decoration: none; color: inherit; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); border-radius: 16px; padding: 22px; transition: border-color .15s, transform .15s, background .15s; }
    .card:hover { border-color: #f6b13b; transform: translateY(-2px); background: rgba(246,177,59,.06); }
    .c-emoji { font-size: 30px; }
    .c-title { font-size: 19px; font-weight: 700; margin: 10px 0 4px; }
    .c-desc { font-size: 14px; color: #9fb0c8; }
    .c-go { font-size: 13px; color: #f6b13b; font-weight: 600; margin-top: 12px; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 34px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
    .foot a { color: #9fb0c8; }
  </style>
</Layout>
