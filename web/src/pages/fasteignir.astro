---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Fasteignaverð: miðgildi verð/m² höfuðborgarsvæði vs
// landsbyggð yfir tíma (fasteignir.json months, HMS kaupskrá). Í Layout. #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands, slugify } from '@lib/format.mjs';
import FASTEIGNIR from '@gogn/fasteignir.json';
import LEIGARAW from '@gogn/leiga.json';

// Leigumarkaðurinn (LOTA 13i): fjórðungar með 100+ samningum + muni-tafla
const lq = (LEIGARAW.quarters || []).filter((x) => x.n >= 100);
const LEIGA = lq.length > 8 ? {
  quarters: lq, first: lq[0], last: lq[lq.length - 1],
  q0: lq[0].q, q1: lq[lq.length - 1].q,
  rise: Math.round(((lq[lq.length - 1].medM2 / lq[0].medM2) - 1) * 100),
  total: LEIGARAW.total, muniYear: LEIGARAW.muniYear,
  munis: Object.entries(LEIGARAW.byMuni).map(([n, v]) => ({ n, ...v })).sort((a, b) => b.medM2 - a.medM2),
} : null;

const months = FASTEIGNIR.months || [];
const latest = months[months.length - 1] || {};
const prev12 = months[months.length - 13] || {};
const hb = latest.hbsv || {}, land = latest.land || {};
const yoyHb = prev12.hbsv && prev12.hbsv.m2 ? ((hb.m2 - prev12.hbsv.m2) / prev12.hbsv.m2) * 100 : null;
const yoyLand = prev12.land && prev12.land.m2 ? ((land.m2 - prev12.land.m2) / prev12.land.m2) * 100 : null;

const chartMonths = months.map((m) => m.m);
const hbSeries = months.map((m) => (m.hbsv ? m.hbsv.m2 : null));
const landSeries = months.map((m) => (m.land ? m.land.m2 : null));

// ── Leigu/kaup-vísir (LOTA 66): verð/m² ÷ árleg leiga/m² = hve mörg ár af leigu jafngilda kaupverði ──
const qToMonths = (q) => { const y = q.slice(0, 4), f = +q.slice(5); return [1, 2, 3].map((k) => y + '-' + String((f - 1) * 3 + k).padStart(2, '0')); };
const natSaleM2 = (q) => { const ms = qToMonths(q).map((mm) => months.find((x) => x.m === mm)).filter(Boolean); let num = 0, den = 0; ms.forEach((x) => { if (x.hbsv) { num += x.hbsv.m2 * x.hbsv.n; den += x.hbsv.n; } if (x.land) { num += x.land.m2 * x.land.n; den += x.land.n; } }); return den ? num / den : null; };
const PR = (LEIGARAW.quarters || []).filter((x) => x.n >= 100).map((x) => { const s = natSaleM2(x.q); return (s && x.medM2) ? { q: x.q, pr: Math.round((s * 1000) / (x.medM2 * 12) * 10) / 10 } : null; }).filter(Boolean);
const prNow = PR.length ? PR[PR.length - 1] : null;
const prAvg = PR.length ? Math.round((PR.reduce((a, b) => a + b.pr, 0) / PR.length) * 10) / 10 : null;
const prVerdict = (prNow && prAvg) ? (prNow.pr > prAvg * 1.08 ? { t: 'Hallar á leigu', c: 'dn', d: 'kaupverð er hátt miðað við leigu í sögulegu samhengi' } : prNow.pr < prAvg * 0.92 ? { t: 'Hallar á kaup', c: 'up', d: 'kaupverð er lágt miðað við leigu í sögulegu samhengi' } : { t: 'Í jafnvægi', c: '', d: 'nálægt sögulegu meðaltali' }) : null;

// Choropleth-kort: miðgildi verð/m² per sveitarfélag (byMuni). Slug (m/nafnaleiðréttingar
// þar sem fasteignaskrár-nafn víkur frá sveitarfélaga-síðu) fyrir smell → undirsíðu.
const SUBPAGE_ALIAS = { 'Hafnarfjarðarkaupstaður': 'Hafnarfjörður', 'Seltjarnarnesbær': 'Seltjarnarnes' };
const BM = FASTEIGNIR.byMuni || {};
const mapValues = {}, mapDetail = {};
Object.keys(BM).forEach((n) => {
  const b = BM[n];
  if (b && b.m2) { mapValues[n] = b.m2; mapDetail[n] = { p25: b.p25, p75: b.p75, n: b.n, slug: slugify(SUBPAGE_ALIAS[n] || n) }; }
});
const mapWindow = FASTEIGNIR.byMuniWindow || '';

const updated = '2026-07-01';
const yoyTxt = (v) => (v == null ? '' : (v > 0 ? '+' : '') + fmtNum(v, 1) + '%');
const desc = `Fasteignaverð á Íslandi — miðgildi ${groupThousands(hb.m2)} þús.kr/m² á höfuðborgarsvæðinu (${yoyTxt(yoyHb)} á ári) og ${groupThousands(land.m2)} þús.kr/m² á landsbyggðinni. Þróun úr þinglýstum kaupum.`;
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Dataset', name: 'Fasteignaverð á Íslandi',
  description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Verð á fermetra (þús.kr)',
};
---

<Layout title="Fasteignaverð — verð á fermetra | Karp" description={desc} canonical="https://karp.is/fasteignir/" jsonLd={jsonLd} ogTitle="Fasteignaverð á Íslandi">
  <main data-pg="fasteignir">
    <p class="kicker">Hagvísir Íslands · Fasteignaverð</p>
    <h1>Fasteignaverð</h1>
    <p>Miðgildi kaupverðs á fermetra úr þinglýstum kaupum (HMS kaupskrá). Vilt þú <a href="/reiknivelar/">verðmeta íbúð</a>? Notaðu verðmats-reiknivélina.</p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Fasteignagögn: kaupskrá og leiguskrá HMS (opin gagnasöfn) og íbúðaverðsvísitala Hagstofunnar. Miðgildi og fermetraverð reiknar Karp úr þinglýstum samningum; leiguskráin nær aðeins til þinglýstra leigusamninga.">ⓘ</i> Um gögnin á síðunni</p>

    <div class="kpis">
      <div class="kpi"><div class="k-l">🏙️ Höfuðborgarsvæði</div><div class="k-v">{groupThousands(hb.m2)}</div><div class="k-s">þús/m² · <span class={yoyHb >= 0 ? 'up' : 'dn'}>{yoyTxt(yoyHb)}</span> á ári</div></div>
      <div class="kpi"><div class="k-l">🌄 Landsbyggð</div><div class="k-v">{groupThousands(land.m2)}</div><div class="k-s">þús/m² · <span class={yoyLand >= 0 ? 'up' : 'dn'}>{yoyTxt(yoyLand)}</span> á ári</div></div>
      <div class="kpi"><div class="k-l">🧾 Meðalverð (höfuðb.)</div><div class="k-v">{fmtNum(hb.vp, 1)}</div><div class="k-s">m.kr · {groupThousands(hb.n)} kaup/mán</div></div>
    </div>

    <h2>Verð á fermetra — þróun</h2>
    <div id="chart"></div>

    <h2>Kort — verð á fermetra eftir sveitarfélagi</h2>
    <div id="fast-map" class="chl-mapbox"></div>
    <p class="mapcap">Miðgildi verð/m² (þús.kr) eftir sveitarfélagi, {mapWindow}. Smelltu á sveitarfélag fyrir nánari síðu.</p>

    <p class="note">ⓘ Miðgildi (robust gegn útlögum) verð/m² úr þinglýstum kaupum íbúðarhúsnæðis. Höfuðborgarsvæði = 7 sveitarfélög; landsbyggð = önnur. Per-sveitarfélag verðmat er í <a href="/reiknivelar/">Reiknivélum</a>.</p>

    {LEIGA && (
      <>
        <h2>Leigumarkaðurinn — þróun leiguverðs {LEIGA.q0} til {LEIGA.q1}</h2>
        <div class="kpis">
          <div class="kpi"><div class="k-l">🔑 Miðgildi leiguverðs</div><div class="k-v">{groupThousands(LEIGA.last.medM2)}</div><div class="k-s">kr/m² á mán · {LEIGA.last.q}</div></div>
          <div class="kpi"><div class="k-l">📈 Hækkun frá {LEIGA.first.q.slice(0, 4)}</div><div class="k-v">{LEIGA.rise}%</div><div class="k-s">miðgildi kr/m²</div></div>
          <div class="kpi"><div class="k-l">🧾 Samningar alls</div><div class="k-v">{groupThousands(LEIGA.total)}</div><div class="k-s">þinglýstir 2011–2024</div></div>
        </div>
        <div id="chart-leiga"></div>
        <h2>Leiguverð eftir sveitarfélögum ({LEIGA.muniYear})</h2>
        <div class="tw">
          <table>
            <thead><tr><th class="l">Sveitarfélag</th><th>Miðgildi kr/m²</th><th>Miðgildi leigu</th><th>Samningar</th></tr></thead>
            <tbody>
              {LEIGA.munis.map((m) => (
                <tr>
                  <td class="l">{m.n}</td>
                  <td class="num">{groupThousands(m.medM2)}</td>
                  <td class="num">{groupThousands(m.medRent)} kr</td>
                  <td class="num">{groupThousands(m.n12)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="note">ⓘ Leiguskrá HMS byggir á <strong>þinglýstum</strong> leigusamningum — þinglýsingarskyldan féll niður með nýju húsaleigulögunum og skráin nær því fram í ársbyrjun 2024. Sveitarfélagatölur miða við {LEIGA.muniYear} (síðasta heila árið). Nýja rafræna leiguskráin verður tengd þegar opin gögn hennar birtast.</p>
      </>
    )}

    {PR.length > 4 && (
      <>
        <h2>Kaupa eða leigja? — verð/leigu-hlutfall yfir tíma</h2>
        <div class="kpis">
          <div class="kpi"><div class="k-l">⚖️ Verð/leigu-hlutfall</div><div class="k-v">{fmtNum(prNow.pr, 1)}</div><div class="k-s">ár af leigu = kaupverð · {prNow.q.slice(0, 4)}</div></div>
          <div class="kpi"><div class="k-l">📊 Sögulegt meðaltal</div><div class="k-v">{fmtNum(prAvg, 1)}</div><div class="k-s">ár · {PR[0].q.slice(0, 4)}–{prNow.q.slice(0, 4)}</div></div>
          {prVerdict && (<div class="kpi"><div class="k-l">🧭 Staðan núna</div><div class={'k-v sm ' + prVerdict.c}>{prVerdict.t}</div><div class="k-s">{prVerdict.d}</div></div>)}
        </div>
        <div id="chart-pr"></div>
        <p class="note">ⓘ Verð/leigu-hlutfallið sýnir hve <strong>mörg ár af leigu jafngilda kaupverði</strong> sömu íbúðar (miðgildi kaupverðs/m² ÷ árleg miðgildisleiga/m²). <strong>Hátt</strong> hlutfall → kaup dýr miðað við leigu (leiga tiltölulega hagstæð); <strong>lágt</strong> → kaup tiltölulega hagstæð. Þetta er vísbending, ekki ráðgjöf — vextir, eiginfjármyndun og leiguþróun vega líka þungt. Leiguskrá HMS nær fram á {prNow.q.slice(0, 4)} (þinglýsingarskyldan féll niður), svo nýjasta hlutfallið endurspeglar það tímabil.</p>
      </>
    )}

    <p class="foot">Forþjónað (SSG) {updated}. Heimild: HMS kaupskrá (þinglýst kaup) + Leiguskrá HMS. #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; } p a { color: #f6b13b; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0; }
    .note a { color: #f6b13b; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 26px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-v.sm { font-size: 18px; line-height: 1.2; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    .up { color: #46e08a; } .dn { color: #ff6d7a; }
    #chart { width: 100%; height: 340px; }
    #chart-leiga { width: 100%; height: 300px; }
    #chart-pr { width: 100%; height: 300px; }
    .tw { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    th, td { text-align: right; padding: 7px 10px; border-bottom: 1px solid rgba(255,255,255,.07); white-space: nowrap; }
    th { color: #7e8ca6; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
    td.l, th.l { text-align: left; }
    .num { font-variant-numeric: tabular-nums; }
    .mapcap { font-size: 12px; color: #7e8ca6; margin: 8px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: verð/m² þróun (2 línur), astro:page-load. #2 -->
  <script define:vars={{ chartMonths, hbSeries, landSeries, LEIGAQ: LEIGA ? LEIGA.quarters : null, PR, prAvg }}>
    function initChart() {
      const el = document.getElementById('chart');
      if (!el) return;
      if (!window.echarts) {
        let s = document.getElementById('echarts-cdn');
        if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
        s.addEventListener('load', initChart, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const c = window.echarts.init(el);
      c.setOption({
        backgroundColor: 'transparent',
        legend: { data: ['Höfuðborgarsvæði', 'Landsbyggð'], textStyle: { color: '#9fb0c8' }, top: 0 },
        grid: { left: 50, right: 16, top: 34, bottom: 26 },
        xAxis: { type: 'category', data: chartMonths, axisLabel: { color: '#7e8ca6', interval: 35 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : Math.round(v) + ' þús/m²') },
        series: [
          { name: 'Höfuðborgarsvæði', type: 'line', data: hbSeries, smooth: true, symbol: 'none', connectNulls: true, lineStyle: { width: 3, color: '#f6b13b' } },
          { name: 'Landsbyggð', type: 'line', data: landSeries, smooth: true, symbol: 'none', connectNulls: true, lineStyle: { width: 3, color: '#3a8dff' } },
        ],
      });
      window.addEventListener('resize', () => c.resize());
    }
    function initLeiga() {
      const el = document.getElementById('chart-leiga');
      if (!el || !LEIGAQ) return;
      if (!window.echarts) {
        let sc = document.getElementById('echarts-cdn');
        if (!sc) { sc = document.createElement('script'); sc.id = 'echarts-cdn'; sc.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(sc); }
        sc.addEventListener('load', initLeiga, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const c = window.echarts.init(el);
      c.setOption({
        backgroundColor: 'transparent',
        grid: { left: 52, right: 46, top: 30, bottom: 26 },
        legend: { data: ['Miðgildi kr/m²', 'Fjöldi samninga'], textStyle: { color: '#9fb0c8' }, top: 0 },
        tooltip: { trigger: 'axis' },
        xAxis: { type: 'category', data: LEIGAQ.map((x) => x.q), axisLabel: { color: '#7e8ca6', fontSize: 10, formatter: (v) => (v.endsWith('F1') ? v.slice(0, 4) : '') }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: [
          { type: 'value', scale: true, axisLabel: { color: '#7e8ca6', fontSize: 10 }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
          { type: 'value', axisLabel: { color: '7e8ca6', show: false }, splitLine: { show: false } },
        ],
        series: [
          { name: 'Fjöldi samninga', type: 'bar', yAxisIndex: 1, data: LEIGAQ.map((x) => x.n), itemStyle: { color: 'rgba(58,141,255,.25)' }, barMaxWidth: 10 },
          { name: 'Miðgildi kr/m²', type: 'line', data: LEIGAQ.map((x) => x.medM2), smooth: true, symbol: 'none', lineStyle: { color: '#19d3c5', width: 3 }, itemStyle: { color: '#19d3c5' } },
        ],
      });
      window.addEventListener('resize', () => c.resize());
    }
    function initPr() {
      const el = document.getElementById('chart-pr');
      if (!el || !PR || !PR.length) return;
      if (!window.echarts) {
        let sp = document.getElementById('echarts-cdn');
        if (!sp) { sp = document.createElement('script'); sp.id = 'echarts-cdn'; sp.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(sp); }
        sp.addEventListener('load', initPr, { once: true });
        return;
      }
      if (window.echarts.getInstanceByDom(el)) return;
      const c = window.echarts.init(el);
      c.setOption({
        backgroundColor: 'transparent',
        grid: { left: 44, right: 16, top: 30, bottom: 26 },
        legend: { data: ['Verð/leigu-hlutfall', 'Sögulegt meðaltal'], textStyle: { color: '#9fb0c8' }, top: 0 },
        tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : (Math.round(v * 10) / 10).toString().replace('.', ',') + ' ár') },
        xAxis: { type: 'category', data: PR.map((x) => x.q), axisLabel: { color: '#7e8ca6', fontSize: 10, formatter: (v) => (v.endsWith('F1') ? v.slice(0, 4) : '') }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
        yAxis: { type: 'value', scale: true, axisLabel: { color: '#7e8ca6', fontSize: 10, formatter: '{value}' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
        series: [
          { name: 'Verð/leigu-hlutfall', type: 'line', data: PR.map((x) => x.pr), smooth: true, symbol: 'none', lineStyle: { color: '#c792ff', width: 3 }, itemStyle: { color: '#c792ff' }, areaStyle: { color: 'rgba(199,146,255,.10)' } },
          { name: 'Sögulegt meðaltal', type: 'line', data: PR.map(() => prAvg), symbol: 'none', lineStyle: { color: '#7e8ca6', width: 1.5, type: 'dashed' } },
        ],
      });
      window.addEventListener('resize', () => c.resize());
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="fasteignir"]')) { initChart(); initLeiga(); initPr(); } });
  </script>

  <!-- Choropleth-kort (Leaflet) — sér eyja sem importar sameiginlega hjálparann. #2 -->
  <script type="application/json" id="fast-mapcfg" set:html={JSON.stringify({ values: mapValues, detail: mapDetail })}></script>
  <script>
    import { renderChoropleth } from '../lib/choropleth.mjs';
    function initFastMap() {
      const el = document.getElementById('fast-map');
      if (!el || !document.querySelector('main[data-pg="fasteignir"]')) return;
      let cfg; try { cfg = JSON.parse(document.getElementById('fast-mapcfg').textContent); } catch (e) { return; }
      const th = (n) => String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      renderChoropleth(el, {
        geojsonUrl: '/gogn/sveitarfelog_adm2.json',
        values: cfg.values, detail: cfg.detail,
        ramp: 'gold', bins: 6, binMode: 'quantile', format: th,
        label: 'Verð/m²', legendTitle: 'þús.kr/m²',
        tooltip: (name, v, d) => `<b>${name}</b><br>Verð/m²: <b>${v == null ? '—' : th(v) + ' þús'}</b>`
          + (d ? `<br><span style="color:#9fb0c8;font-size:12px">Bil ${th(d.p25)}–${th(d.p75)} · ${d.n} kaup</span>` : ''),
        onClick: (name, v, d) => { if (d && d.slug) window.location.href = '/sveitarfelog/' + d.slug + '/'; },
        attribution: 'Mörk: geoBoundaries · Gögn: HMS kaupskrá',
      });
    }
    document.addEventListener('astro:page-load', initFastMap);
  </script>
</Layout>
