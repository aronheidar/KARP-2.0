---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Mannfjöldi: heildarfjöldi (ársfjórðungslega), þættir
// fólksfjölgunar (aðfluttir umfram brottflutta + fæddir umfram dána) og
// hlutfall innflytjenda. Byggingartíma-PxWeb (þolir bilun). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import { fmtNum, groupThousands } from '@lib/format.mjs';

const px = async (path, query) => (await fetch('https://px.hagstofa.is/pxis/api/v1/is/' + path, { method: 'POST', body: JSON.stringify({ query, response: { format: 'json' } }) })).json();
const sel = (code, filter, values) => ({ code, selection: { filter, values } });
const num = (v) => { const n = parseFloat(String(v).replace(',', '.')); return isNaN(n) ? null : n; };

// Heildarmannfjöldi, ársfjórðungslega (16 ár).
let POP = null;
try {
  const j = await px('Ibuar/mannfjoldi/1_yfirlit/arsfjordungstolur/MAN10001.px', [sel('Sveitarfélag', 'item', ['IS']), sel('Kyn og ríkisfang', 'item', ['0']), sel('Ársfjórðungur', 'top', ['64'])]);
  const m = {};
  j.data.forEach((d) => { const t = d.key.find((k) => /\d{4}/.test(k)); const v = num(d.values[0]); if (t && v != null) m[t] = v; });
  const ts = Object.keys(m).sort();
  if (ts.length) {
    const last = m[ts[ts.length - 1]], y4 = m[ts[ts.length - 5]];
    POP = { labels: ts.map((t) => t.replace(/(\d{4}).*?([1-4])$/, '$1 F$2')), vals: ts.map((t) => m[t]), now: last, yoy: y4 ? Math.round(((last - y4) / y4) * 1000) / 10 : null };
  }
} catch (e) { POP = null; }

// Þættir fólksfjölgunar: 2=heildarfjölgun, 3=aðfl. umfram brottfl., 4=fæddir umfram dána.
// Ár sem vantar sundurliðun (3&4) eru síuð út.
let COMP = null;
try {
  const j = await px('Ibuar/mannfjoldi/1_yfirlit/Yfirlit_mannfjolda/MAN00000.px', [sel('Eining', 'item', ['3', '4', '2'])]);
  const by = { 2: {}, 3: {}, 4: {} };
  j.data.forEach((d) => {
    const t = d.key.find((k) => /^\d{4}$/.test(k));
    const e = d.key.find((k) => k === '2' || k === '3' || k === '4');
    const v = num(d.values[0]);
    if (t && e && v != null) by[e][t] = v;
  });
  const years = Object.keys(by[2]).filter((y) => by[3][y] != null && by[4][y] != null).sort().slice(-25);
  if (years.length) COMP = { years, netmig: years.map((y) => by[3][y]), natural: years.map((y) => by[4][y]), total: years.map((y) => by[2][y]) };
} catch (e) { COMP = null; }

// Innflytjendur: hlutfall af mannfjölda (124 = innflytjendur, -1 = alls).
let IMM = null;
try {
  // ATH: taflan hefur líka KYN-vídd — án Kyn=0 yfirskrifa kynjaraðir hver aðra!
  const j = await px('Ibuar/mannfjoldi/3_bakgrunnur/Uppruni/MAN43000.px', [sel('Aldur', 'item', ['-1']), sel('Bakgrunnur', 'item', ['-1', '124']), sel('Kyn', 'item', ['0'])]);
  const all = {}, imm = {};
  j.data.forEach((d) => {
    const t = d.key.find((k) => /^\d{4}$/.test(k));
    const b = d.key.includes('124') ? '124' : '-1'; // Bakgrunnur (Aldur er líka -1 en 124-raðir þekkjast)
    const v = num(d.values[0]);
    if (t && v != null) (b === '124' ? imm : all)[t] = v;
  });
  const years = Object.keys(imm).filter((y) => all[y]).sort().slice(-20);
  if (years.length) {
    const share = years.map((y) => Math.round((imm[y] / all[y]) * 1000) / 10);
    IMM = { years, share, now: share[share.length - 1] };
  }
} catch (e) { IMM = null; }

const updated = '2026-07-02';
const desc = `Mannfjöldi á Íslandi${POP ? ' — ' + groupThousands(POP.now) + ' íbúar' : ''}, þættir fólksfjölgunar (aðfluttir vs náttúruleg fjölgun) og hlutfall innflytjenda${IMM ? ' (' + fmtNum(IMM.now, 1) + '%)' : ''}.`;
const jsonLd = { '@context': 'https://schema.org', '@type': 'Dataset', name: 'Mannfjöldi á Íslandi', description: desc, creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' }, dateModified: updated, spatialCoverage: 'Ísland', variableMeasured: 'Mannfjöldi' };
---

<Layout title="Mannfjöldi — íbúar & fólksfjölgun | Karp" description={desc} canonical="https://app.karp.is/mannfjoldi/" jsonLd={jsonLd} ogTitle="Mannfjöldi á Íslandi">
  <main data-pg="mannfjoldi">
    <p class="kicker">Hagvísir Íslands · Samfélag</p>
    <h1>Mannfjöldi</h1>
    <p>Íbúafjöldi, hvað knýr fólksfjölgunina — aðfluttir umfram brottflutta eða fæddir umfram dána — og hlutfall innflytjenda. Heimild: Hagstofa Íslands.</p>

    <div class="kpis">
      {POP && <div class="kpi"><div class="k-l">👥 Íbúar</div><div class="k-v">{groupThousands(POP.now)}</div><div class="k-s">nýjasti ársfjórðungur</div></div>}
      {POP && POP.yoy != null && <div class="kpi"><div class="k-l">📈 Fjölgun</div><div class="k-v">{POP.yoy > 0 ? '+' : ''}{fmtNum(POP.yoy, 1)}%</div><div class="k-s">frá fyrra ári</div></div>}
      {IMM && <div class="kpi"><div class="k-l">🌍 Innflytjendur</div><div class="k-v">{fmtNum(IMM.now, 1)}%</div><div class="k-s">af mannfjölda</div></div>}
    </div>

    <div class="ppair">
      {POP && (
        <div>
          <h2>Íbúafjöldi — 16 ár</h2>
          <div id="chart-pop"></div>
        </div>
      )}
      {IMM && (
        <div>
          <h2>Hlutfall innflytjenda</h2>
          <div id="chart-imm"></div>
        </div>
      )}
    </div>

    {COMP && (
      <>
        <h2>Hvað knýr fjölgunina?</h2>
        <div id="chart-comp"></div>
        <p class="src">Stöflaðar súlur: aðfluttir umfram brottflutta (blátt) + fæddir umfram dána (grænt). Lína = heildarfjölgun ársins.</p>
      </>
    )}

    <p class="foot">Forþjónað (SSG) {updated}. Heimild: Hagstofa (MAN10001, MAN00000, MAN43000). #2.</p>
  </main>

  <style>
    main { max-width: 860px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    h2 { font-size: 15px; color: #9fb0c8; text-transform: uppercase; letter-spacing: .05em; margin: 30px 0 8px; }
    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 18px 0 6px; }
    .kpi { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 12px 14px; }
    .k-l { font-size: 12px; color: #9fb0c8; }
    .k-v { font-size: 25px; font-weight: 800; color: #f6b13b; margin-top: 2px; font-variant-numeric: tabular-nums; }
    .k-s { font-size: 11px; color: #7e8ca6; }
    #chart-pop { width: 100%; height: 290px; }
    .ppair { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 760px) { .ppair { grid-template-columns: 1fr; } }

    #chart-comp { width: 100%; height: 310px; }
    #chart-imm { width: 100%; height: 250px; }
    .src { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
    .foot { font-size: 12px; color: #6f7b8d; margin-top: 28px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 14px; }
  </style>

  <!-- Eyja: 3 gröf. astro:page-load. #2 -->
  <script define:vars={{ POP, COMP, IMM }}>
    function initCharts() {
      if (!document.getElementById('chart-pop') && !document.getElementById('chart-comp') && !document.getElementById('chart-imm')) return;
      const go = () => {
        const cp = document.getElementById('chart-pop');
        if (cp && POP && !window.echarts.getInstanceByDom(cp)) {
          const c = window.echarts.init(cp);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 58, right: 14, top: 14, bottom: 24 },
            xAxis: { type: 'category', data: POP.labels, axisLabel: { color: '#7e8ca6', fontSize: 10, interval: 7 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', scale: true, axisLabel: { color: '#7e8ca6', formatter: (v) => Math.round(v / 1000) + 'þ' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.') },
            series: [{ type: 'line', data: POP.vals, smooth: true, symbol: 'none', lineStyle: { width: 3, color: '#f6b13b' }, areaStyle: { opacity: 0.12, color: '#f6b13b' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const cc = document.getElementById('chart-comp');
        if (cc && COMP && !window.echarts.getInstanceByDom(cc)) {
          const c = window.echarts.init(cc);
          c.setOption({
            backgroundColor: 'transparent',
            legend: { data: ['Aðfluttir umfram brottflutta', 'Fæddir umfram dána', 'Heildarfjölgun'], textStyle: { color: '#9fb0c8', fontSize: 10.5 }, top: 0 },
            grid: { left: 54, right: 14, top: 32, bottom: 24 },
            xAxis: { type: 'category', data: COMP.years, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: (v) => (Math.abs(v) >= 1000 ? v / 1000 + 'þ' : v) }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => (v == null ? '–' : String(Math.round(v)).replace(/\B(?=(\d{3})+(?!\d))/g, '.')) },
            series: [
              { name: 'Aðfluttir umfram brottflutta', type: 'bar', stack: 'f', data: COMP.netmig, itemStyle: { color: '#3a8dff' }, barWidth: 12 },
              { name: 'Fæddir umfram dána', type: 'bar', stack: 'f', data: COMP.natural, itemStyle: { color: '#46e08a' } },
              { name: 'Heildarfjölgun', type: 'line', data: COMP.total, smooth: true, symbol: 'none', lineStyle: { width: 2, color: '#eaf1fb', type: 'dashed' }, itemStyle: { color: '#eaf1fb' } },
            ],
          });
          window.addEventListener('resize', () => c.resize());
        }
        const ci = document.getElementById('chart-imm');
        if (ci && IMM && !window.echarts.getInstanceByDom(ci)) {
          const c = window.echarts.init(ci);
          c.setOption({
            backgroundColor: 'transparent', grid: { left: 42, right: 14, top: 14, bottom: 24 },
            xAxis: { type: 'category', data: IMM.years, axisLabel: { color: '#7e8ca6', fontSize: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,.14)' } } },
            yAxis: { type: 'value', axisLabel: { color: '#7e8ca6', formatter: '{value}%' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,.06)' } } },
            tooltip: { trigger: 'axis', valueFormatter: (v) => v.toFixed(1).replace('.', ',') + '%' },
            series: [{ type: 'line', data: IMM.share, smooth: true, symbol: 'circle', symbolSize: 4, lineStyle: { width: 2.5, color: '#c95cf7' }, itemStyle: { color: '#c95cf7' }, areaStyle: { opacity: 0.1, color: '#c95cf7' } }],
          });
          window.addEventListener('resize', () => c.resize());
        }
      };
      if (window.echarts) { go(); return; }
      let s = document.getElementById('echarts-cdn');
      if (!s) { s = document.createElement('script'); s.id = 'echarts-cdn'; s.src = 'https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js'; document.head.appendChild(s); }
      s.addEventListener('load', go, { once: true });
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="mannfjoldi"]')) initCharts(); });
  </script>
</Layout>
