---
// ─────────────────────────────────────────────────────────────
// SSG-síða (#2) — Þingmál: nýjustu efnismál (frumvörp + tillögur) úr
// frumvorp.json með Alþingis-úrslitum + samantekt + „kjóstu þína skoðun"-eyju
// (karpGet/karpPost /vote gegnum auth.js; lazy-hydrað með IntersectionObserver).
// Í app-skelinni (Layout). #2.
// ─────────────────────────────────────────────────────────────
import Layout from '../layouts/Layout.astro';
import ThingTabs from '../components/ThingTabs.astro';
import { partyName } from '@lib/parties.mjs';
import FRUMVORP from '@gogn/frumvorp.json';

const pName = (k) => (k === 'U' ? 'Óháðir' : partyName(k) || k);

const LIMIT = 40;
const bills = FRUMVORP
  .filter((b) => b.hs === 'Frv.' || b.hs === 'Till.')
  .sort((a, b) => (b.d || '').localeCompare(a.d || '') || b.nr - a.nr)
  .slice(0, LIMIT)
  .map((b) => {
    const P = b.P || {};
    const dissent = Object.keys(P).filter((k) => (P[k][1] || 0) > 0).map(pName);
    return {
      key: 'mal_' + b.nr,
      titill: b.titill,
      type: b.hs === 'Frv.' ? 'Frumvarp' : 'Tillaga',
      isFrv: b.hs === 'Frv.',
      d: b.d,
      ja: b.ja || 0, nei: b.nei || 0, fj: b.fj || 0,
      stada: b.stada || '',
      sam: b.sam || '',
      passed: (b.stada || '').startsWith('Samþykkt'),
      dissent,
      parties: Object.keys(P).map((k) => ({ n: pName(k), ja: P[k][0] || 0, nei: P[k][1] || 0 })).sort((a, b2) => b2.ja + b2.nei - (a.ja + a.nei)),
    };
  });

// Gluggagögn (frumvarpa-modal): key → full lýsing + flokka-atkvæði.
const BILLS = {};
bills.forEach((b) => { BILLS[b.key] = { t: b.titill, type: b.type, d: b.d, sam: b.sam, stada: b.stada, ja: b.ja, nei: b.nei, fj: b.fj, passed: b.passed, parties: b.parties }; });

const updated = '2026-07-01';
const nPassed = bills.filter((b) => b.passed).length;
const desc = `Nýjustu ${bills.length} þingmál á Alþingi — frumvörp og þingsályktunartillögur með atkvæðagreiðslu, niðurstöðu og samantekt. Kjóstu þína eigin skoðun á hverju máli.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Þingmál á Alþingi',
  description: 'Nýjustu frumvörp og þingsályktunartillögur á Alþingi með atkvæðagreiðslu og niðurstöðu.',
  creator: { '@type': 'Organization', name: 'Karp', url: 'https://www.karp.is' },
  dateModified: updated,
  spatialCoverage: 'Ísland',
};
---

<Layout
  title="Þingmál — nýjustu frumvörp & tillögur | Karp"
  description={desc}
  canonical="https://app.karp.is/thingmal/"
  jsonLd={jsonLd}
  ogTitle="Þingmál á Alþingi"
>
  <main data-pg="thingmal">
    <p class="kicker">Hagvísir Íslands · Alþingi</p>
    <ThingTabs active="mal" />
    <h1>Þingmál</h1>
    <p>
      {bills.length} nýjustu efnismál á Alþingi — frumvörp og þingsályktunartillögur með niðurstöðu
      atkvæðagreiðslu. {nPassed} þeirra voru samþykkt. <strong>Kjóstu þína eigin skoðun</strong> á hverju máli
      og sjáðu hvernig aðrir lesendur Karp greiða atkvæði.
    </p>
    <p class="datainfo"><i class="tip" tabindex="0" data-tip="Þingmál: opin XML-gögn Alþingis, lifandi listi uppfærður á ~10 mín fresti um veitu Karp. Staða máls fylgir flokkun Alþingis.">ⓘ</i> Um gögnin á síðunni</p>
    <p class="note">
      ⓘ „Alþingi" sýnir raunatkvæði þingmanna (með–á móti · fjarvist). „Þín skoðun" er óformleg könnun meðal
      innskráðra lesenda Karp — ekki þingatkvæði. Gögn frá althingi.is.
    </p>

    <div id="live-mal" hidden>
      <h2 class="lm-h">🔴 Lifandi frá Alþingi <span class="lm-sub">nýjustu mál þingsins 157 — beint úr XML-veitu Alþingis (10 mín cache)</span></h2>
      <div id="lm-list" class="lm-grid"></div>
    </div>

    <div class="bills">
      {bills.map((b) => (
        <article class="bill">
          <div class="b-top">
            <span class={`badge ${b.isFrv ? 'frv' : 'till'}`}>{b.type}</span>
            <span class="b-date">{b.d}</span>
          </div>
          <h2 class="b-title" data-bkey={b.key} role="button" tabindex="0" title="Smelltu fyrir nánari upplýsingar">{b.titill}</h2>
          {b.sam && <p class="b-sam">{b.sam}</p>}
          <div class="b-result">
            {b.stada && <span class={`r-tag ${b.passed ? 'r-yes' : 'r-neu'}`}>{b.stada}</span>}
            <span class="r-count">Alþingi: {b.ja}–{b.nei}{b.fj ? ` · ${b.fj} fjarv.` : ''}</span>
            {b.dissent.length > 0 && <span class="r-dissent">Á móti: {b.dissent.join(', ')}</span>}
          </div>
          <div class="vote" data-bill={b.key}><div class="v-load">…</div></div>
        </article>
      ))}
    </div>

    <p class="foot">
      Forþjónað (SSG) {updated}. Þingmál + atkvæðagreiðslur frá Alþingi (althingi.is); notendakannanir vistaðar
      um <code>/vote</code> gegnum sameiginlega <code>src/lib/auth</code>. #2.
    </p>

    <!-- Frumvarpa-glugginn (smellt á titil) — eins og gamla mælaborðið. #2 LOTA 7 -->
    <div id="bill-modal" hidden>
      <div class="bm-back"></div>
      <div class="bm-box"><button class="bm-x" aria-label="Loka">×</button><div id="bm-body"></div></div>
    </div>
    <script type="application/json" id="d-bills" set:html={JSON.stringify(BILLS)}></script>
  </main>

  <style is:global>
    /* LIVE-málin verða til í runtime (innerHTML) → verða að vera global,
       annars tree-shake-ar Astro reglurnar úr scoped-blokkinni. */
    .lm-it { display: block; background: rgba(255,109,122,.05); border: 1px solid rgba(255,109,122,.2); border-radius: 10px; padding: 9px 12px; text-decoration: none; }
    .lm-it:hover { border-color: rgba(255,109,122,.5); }
    .lm-t { display: block; font-size: 13px; font-weight: 600; color: #eaf1fb; line-height: 1.3; }
    .lm-m { display: block; font-size: 11px; color: #9fb0c8; margin-top: 3px; }
    .lm-v { margin-left: 8px; background: rgba(66,208,134,.12); border: 1px solid rgba(66,208,134,.35); color: #42d086; border-radius: 8px; padding: 1px 8px; font-size: 10.5px; cursor: pointer; }
    .lm-v:hover { background: rgba(66,208,134,.22); }
  </style>
  <style>
    main { max-width: 1020px; margin: 0 auto; padding: 44px 20px 64px; }
    .kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: #7e8ca6; margin: 0 0 4px; }
    h1 { font-size: 32px; line-height: 1.15; margin: 0 0 10px; }
    p { color: #cdd6e6; }
    .note { font-size: 13px; color: #9fb0c8; background: rgba(255,255,255,.04); border-left: 3px solid #f6b13b; padding: 10px 14px; border-radius: 0 8px 8px 0; margin: 16px 0 22px; }
    .lm-h { font-size: 15px; color: #ff6d7a; text-transform: uppercase; letter-spacing: .05em; margin: 4px 0 8px; }
    .lm-sub { font-size: 11px; color: #7e8ca6; text-transform: none; letter-spacing: 0; font-weight: 400; margin-left: 8px; }
    .lm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 20px; }
    @media (max-width: 860px) { .lm-grid { grid-template-columns: 1fr; } }
    .bills { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
    @media (max-width: 860px) { .bills { grid-template-columns: 1fr; } }
    .bill { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 16px 18px; }
    .b-top { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
    .badge { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; padding: 2px 8px; border-radius: 6px; }
    .badge.frv { background: rgba(246,177,59,.16); color: #f6b13b; }
    .badge.till { background: rgba(124,92,247,.16); color: #b9a6ff; }
    .b-date { font-size: 12px; color: #7e8ca6; }
    .b-title { font-size: 17px; font-weight: 700; margin: 0 0 6px; line-height: 1.25; color: #eaf1fb; cursor: pointer; }
    .b-title:hover { color: #f6b13b; }
    .b-sam { font-size: 14px; color: #9fb0c8; margin: 0 0 10px; }
    .b-result { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 12px; font-size: 13px; margin-bottom: 12px; }
    .r-tag { font-weight: 700; padding: 2px 9px; border-radius: 6px; }
    .r-yes { background: rgba(70,224,138,.15); color: #46e08a; }
    .r-neu { background: rgba(255,255,255,.07); color: #9fb0c8; }
    .r-count { color: #9fb0c8; font-variant-numeric: tabular-nums; }
    .r-dissent { color: #ff8e98; }
  </style>
  <style is:global>
    /* Kjósa-eyjan er búin til á keyrslutíma → global. */
    .vote { border-top: 1px solid rgba(255,255,255,.08); padding-top: 12px; }
    .v-load { color: #7e8ca6; font-size: 13px; }
    .v-q { font-size: 13px; font-weight: 600; color: #cdd6e6; margin-bottom: 8px; }
    .v-btns { display: flex; gap: 8px; margin-bottom: 8px; }
    .v-b { flex: 1; background: #0e1626; border: 1px solid rgba(255,255,255,.15); color: #eaf1fb; border-radius: 8px; padding: 8px 10px; font-weight: 700; font-size: 14px; cursor: pointer; }
    .v-b:hover { border-color: rgba(255,255,255,.35); }
    .v-b.v-ja.on { background: rgba(70,224,138,.18); border-color: #46e08a; color: #46e08a; }
    .v-b.v-nei.on { background: rgba(255,109,122,.16); border-color: #ff6d7a; color: #ff6d7a; }
    .v-b:disabled { opacity: .6; cursor: default; }
    .v-gate { font-size: 13px; color: #9fb0c8; margin-bottom: 8px; }
    .v-gate a { color: #f6b13b; }
    .v-bar { height: 8px; border-radius: 5px; background: rgba(255,109,122,.35); overflow: hidden; }
    .v-bar-ja { height: 100%; background: #46e08a; }
    .v-tally { font-size: 12px; color: #7e8ca6; margin-top: 5px; font-variant-numeric: tabular-nums; }
    /* Frumvarpa-glugginn (fyllt á keyrslutíma). */
    #bill-modal { position: fixed; inset: 0; z-index: 70; display: flex; align-items: center; justify-content: center; }
    #bill-modal[hidden] { display: none; }
    .bm-back { position: absolute; inset: 0; background: rgba(3,6,12,.72); backdrop-filter: blur(2px); }
    .bm-box { position: relative; width: min(600px, calc(100vw - 28px)); max-height: calc(100vh - 40px); overflow: auto; background: #0b1220; border: 1px solid rgba(255,255,255,.14); border-radius: 16px; padding: 20px 22px; box-shadow: 0 18px 60px rgba(0,0,0,.55); }
    .bm-x { position: absolute; top: 10px; right: 12px; background: none; border: 0; color: #7e8ca6; font-size: 24px; cursor: pointer; z-index: 2; }
    .bm-x:hover { color: #eaf1fb; }
    .bm-type { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #f6b13b; }
    .bm-t { font-size: 18px; font-weight: 800; color: #eaf1fb; margin: 4px 0 8px; line-height: 1.3; padding-right: 20px; }
    .bm-sam { font-size: 13.5px; color: #cdd6e6; line-height: 1.55; margin-bottom: 12px; }
    .bm-res { font-size: 13px; margin-bottom: 12px; }
    .bm-res .yes { color: #46e08a; font-weight: 700; } .bm-res .neu { color: #9fb0c8; font-weight: 700; }
    .bm-ph { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #7e8ca6; margin: 10px 0 6px; }
    .bm-p { display: grid; grid-template-columns: 1fr 70px 70px; gap: 4px 10px; font-size: 12.5px; color: #cdd6e6; }
    .bm-p .h { color: #7e8ca6; font-size: 10.5px; text-transform: uppercase; }
    .bm-p .ja { color: #46e08a; text-align: right; font-variant-numeric: tabular-nums; }
    .bm-p .nei { color: #ff6d7a; text-align: right; font-variant-numeric: tabular-nums; }
  </style>

  <!-- Eyja: kjósa um þingmál (auth.js /vote), lazy-hydrað með IntersectionObserver. #2 -->
  <script>
    import { loadUser, karpGet, karpPost } from '../lib/auth.js';

    function render(el, bill, d) {
      const u = window.KARP_USER || { loggedIn: false };
      const ja = d.ja || 0, nei = d.nei || 0, total = ja + nei, mine = d.mine || '';
      const pct = total ? Math.round((ja / total) * 100) : 0;
      let h = '<div class="v-q">Hvernig myndir þú kjósa?</div>';
      if (u.loggedIn) {
        h += `<div class="v-btns"><button class="v-b v-ja${mine === 'ja' ? ' on' : ''}" data-c="ja">✓ Með</button><button class="v-b v-nei${mine === 'nei' ? ' on' : ''}" data-c="nei">✗ Á móti</button></div>`;
      } else {
        h += `<div class="v-gate">🔒 <a href="${u.loginUrl || 'https://karp.is/login/'}">Skráðu þig inn</a> til að kjósa</div>`;
      }
      if (total) {
        h += `<div class="v-bar"><div class="v-bar-ja" style="width:${pct}%"></div></div><div class="v-tally">${ja} með · ${nei} á móti · ${pct}% með</div>`;
      } else {
        h += '<div class="v-tally">Engin atkvæði lesenda enn — vertu fyrst(ur).</div>';
      }
      el.innerHTML = h;
      el.querySelectorAll('.v-b').forEach((btn) => {
        btn.onclick = async () => {
          el.querySelectorAll('.v-b').forEach((b) => (b.disabled = true));
          const res = (await karpPost('/vote', { bill, choice: btn.dataset.c })) || {};
          render(el, bill, res);
        };
      });
    }

    async function hydrate(el) {
      const bill = el.dataset.bill;
      const d = (await karpGet('/vote?bill=' + encodeURIComponent(bill))) || {};
      render(el, bill, d);
    }

    function initVotes() {
      const boxes = document.querySelectorAll('.vote[data-bill]');
      if (!boxes.length) return;
      loadUser().then(() => {
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { obs.unobserve(e.target); hydrate(e.target); }
          });
        }, { rootMargin: '250px' });
        boxes.forEach((b) => io.observe(b));
      });
    }

    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="thingmal"]')) initVotes(); });
  </script>

  <!-- Eyja: frumvarpa-glugginn. #2 LOTA 7 -->
  <script>
    function bmClose() { const m = document.getElementById('bill-modal'); if (m) m.hidden = true; }
    function bmOpen(key) {
      const dataEl = document.getElementById('d-bills');
      const m = document.getElementById('bill-modal');
      if (!dataEl || !m) return;
      let B = {};
      try { B = JSON.parse(dataEl.textContent || '{}'); } catch (e) { return; }
      const d = B[key];
      if (!d) return;
      const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      let h = `<div class="bm-type">${esc(d.type)} · ${esc(d.d || '')}</div><div class="bm-t">${esc(d.t)}</div>`;
      if (d.sam) h += `<div class="bm-sam">${esc(d.sam)}</div>`;
      h += `<div class="bm-res"><span class="${d.passed ? 'yes' : 'neu'}">${esc(d.stada || 'Niðurstaða liggur ekki fyrir')}</span> · Alþingi: ${d.ja}–${d.nei}${d.fj ? ` · ${d.fj} fjarvistir` : ''}</div>`;
      if (d.parties && d.parties.length) {
        h += '<div class="bm-ph">Atkvæði eftir flokkum</div><div class="bm-p"><span class="h">Flokkur</span><span class="h ja">Með</span><span class="h nei">Á móti</span>';
        h += d.parties.map((p) => `<span>${esc(p.n)}</span><span class="ja">${p.ja}</span><span class="nei">${p.nei}</span>`).join('');
        h += '</div>';
      }
      document.getElementById('bm-body').innerHTML = h;
      m.hidden = false;
    }
    function initBillModal() {
      const m = document.getElementById('bill-modal');
      if (!m) return;
      m.querySelector('.bm-x').onclick = bmClose;
      m.querySelector('.bm-back').onclick = bmClose;
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') bmClose(); });
      document.querySelectorAll('[data-bkey]').forEach((el) => {
        const go = () => bmOpen(el.dataset.bkey);
        el.onclick = go;
        el.onkeydown = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); } };
      });
      // Djúptengill af þingsals-síðunni (LOTA 13): /thingmal/?nr=X → atkvæða-glugginn opnast
      const nr = new URLSearchParams(location.search).get('nr');
      if (nr && /^\d+$/.test(nr)) {
        bmOpen('mal_' + nr);
        try { history.replaceState(null, '', location.pathname); } catch (e) {}
      }
    }
    // 🔴 LIVE-mál af Alþingi um worker-proxy (LOTA 15b). Felur sig ef proxy vantar.
    function initLiveMal() {
      const wrap = document.getElementById('live-mal');
      if (!wrap || wrap.dataset.done) return;
      wrap.dataset.done = '1';
      const esc2 = (t) => String(t ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      fetch('/api/thingmal')
        .then((r) => (r.ok ? r.text() : null))
        .then((xml) => {
          if (!xml || xml[0] === '{') return; // proxy ekki til / villusvar
          const doc = new DOMParser().parseFromString(xml, 'text/xml');
          const items = [...doc.querySelectorAll('mál')].map((m) => ({
            nr: +(m.getAttribute('málsnúmer') || 0),
            heiti: (m.querySelector('málsheiti') || {}).textContent || '',
            teg: (m.querySelector('málstegund heiti, málstegund') || {}).textContent || '',
            html: (m.querySelector('html') || {}).textContent || '',
          })).filter((x) => x.nr && x.heiti);
          if (!items.length) return;
          items.sort((a, b) => b.nr - a.nr);
          // LOTA 18 #9: sé LIVE-málið líka í bökuðu skránni (atkvæði til) → „Atkvæði ↓"-flaga
          // sem skrunar á spjald málsins hér á síðunni í stað þess að opna althingi.is.
          document.getElementById('lm-list').innerHTML = items.slice(0, 10).map((x) => {
            const local = document.querySelector('[data-bkey="mal_' + x.nr + '"]');
            const votes = local ? '<button class="lm-v" data-nr="' + x.nr + '">🗳️ Atkvæði ↓</button>' : '';
            return '<a class="lm-it" href="' + (x.html && /^https?:/.test(x.html) ? esc2(x.html) : 'https://www.althingi.is/thingstorf/thingmalalistar-eftir-thingum/ferill/?ltg=157&mnr=' + x.nr) + '" target="_blank" rel="noopener"><span class="lm-t">' + esc2(x.heiti) + '</span><span class="lm-m">Mál nr. ' + x.nr + (x.teg ? ' · ' + esc2(x.teg.trim()) : '') + votes + '</span></a>';
          }).join('');
          document.querySelectorAll('.lm-v').forEach((b) => b.addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            const t = document.querySelector('[data-bkey="mal_' + b.dataset.nr + '"]');
            if (t) { t.scrollIntoView({ behavior: 'smooth', block: 'center' }); t.click(); }
          }));
          wrap.hidden = false;
        })
        .catch(() => {});
    }
    document.addEventListener('astro:page-load', () => { if (document.querySelector('main[data-pg="thingmal"]')) { initBillModal(); initLiveMal(); } });
  </script>
</Layout>
