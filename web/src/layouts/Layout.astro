---
// Layout.astro — app-skel (nav vinstra · efni í miðju · fréttir hægra), eins og gamla karp.is.
// #2. Engin React — hrein Astro + vanilla-eyjur + View Transitions (mjúk skipti án endurhleðslu).
import { ClientRouter } from 'astro:transitions';
import KarpFish from '../components/KarpFish.astro';
const { title, description = '', canonical = '', jsonLd = null, noindex = false, ogTitle = '', ogType = 'website', ogImage = '' } = Astro.props;
// NAV — NÁKVÆM eftirmynd gamla mælaborðsins (röð, hópar, undirflokkar, heiti).
// Hópar opnast/lokast (accordion); hópur virku síðunnar er sjálfkrafa opinn.
const NAV = [
  { label: 'Karp+', emoji: '⭐', icon: 'pro', items: [
    { href: '/mitt-svaedi/', label: 'Mitt svæði' },
    { href: '/frettir/', label: 'Vöktun & umfjöllun' },
    { href: '/utbod/', label: 'Útboðsvaktin' },
    { href: '/vaktir/', label: 'Leitarorðavaktin' },
    { href: '/fasteignavakt/', label: 'Fasteignavaktin' },
    { href: '/eftirlit/', label: 'Eftirlitsvaktin' },
    { href: '/fyrirtaeki/', label: 'Fyrirtækjaskrá' },
    { href: '/okutaeki-skip/', label: 'Ökutæki & skip' },
  ] },
  { href: '/kort/', label: 'Ísland', emoji: '🗺️' },
  { href: '/markadir/', label: 'Markaðir', emoji: '📈' },
  { label: 'Alþingi', emoji: '🏛️', items: [
    { href: '/althingi/', label: 'Þingsalur', exact: true },
    { href: '/ivilnanir/', label: 'Ívilnanir & styrkir' },
    { href: '/thingmal/', label: 'Frumvörp & atkvæði' },
    { href: '/althingi/nefndir/', label: 'Nefndir' },
    { href: '/althingi/flokkar/', label: 'Flokkar' },
    { href: '/althingi/thingmenn/', label: 'Þingmenn' },
    { sub: 'Kosningar & kannanir' },
    { href: '/stefnuprof/', label: 'Stefnupróf' },
    { href: '/kannanir/', label: 'Fylgi flokka' },
    { href: '/karp-kannanir/', label: 'Karp-kannanir' },
    { sub: 'Alþjóðasamstarf' },
    { href: '/samtok/', label: 'Samtök & samningar' },
    { href: '/nato/', label: 'NATO' },
    { href: '/ees/', label: 'EES / EFTA' },
    { href: '/sendirad/', label: 'Sendiráð' },
  ] },
  { label: 'Ríkisstjórn', emoji: '🏦', items: [
    { href: '/rikisfjarmal/', label: 'Ríkisfjármál' },
    { href: '/birgjar/', label: 'Birgjar ríkisins' },
    { href: '/skattar/', label: 'Skattar' },
    { href: '/utgjold/', label: 'Útgjöld' },
    { href: '/langtima/', label: 'Langtímastefna' },
    { href: '/vidskipti/', label: 'Utanríkisverslun' },
  ] },
  { label: 'Sveitarstjórnir', emoji: '🏘️', items: [
    { href: '/sveitarfelog/', label: 'Yfirlit', exact: true },
    { href: '/topplistar/', label: 'Topplistar' },
    { href: '/sveitarfelog/reykjavikurborg/', label: 'Sveitarfélag' },
    { href: '/jofnunarsjodur/', label: 'Jöfnunarsjóður' },
  ] },
  { label: 'Efnahagur', emoji: '📉', items: [
    { href: '/verdlag/', label: 'Verðlag' },
    { href: '/lyf/', label: 'Lyf & lyfjaverð' },
    { href: '/vextir/', label: 'Vextir & gengi' },
    { href: '/fasteignir/', label: 'Fasteignaverð' },
    { href: '/samanburdur/', label: 'Ísland í samanburði' },
    { href: '/hagvoxtur/', label: 'Hagvöxtur' },
    { href: '/vinnumarkadur/', label: 'Vinnumarkaður' },
    { href: '/hagspar/', label: 'Hagspár' },
    { href: '/hermir/', label: 'Hagkerfis-hermir' },
    { href: '/furduhagfraedi/', label: 'Furðuhagfræði' },
    { sub: 'Reiknivélar' },
    { href: '/reiknivelar/', label: 'Launareiknivél', exact: true },
    { href: '/reiknivelar/?t=hus', label: 'Húsnæðislán' },
    { href: '/reiknivelar/?t=vm', label: 'Verðmat fasteignar' },
    { href: '/reiknivelar/?t=lif', label: 'Lífeyrir' },
  ] },
  { label: 'Atvinnuvegir', emoji: '🏭', items: [
    { href: '/atvinnuvegir/sjavarutvegur/', label: 'Sjávarútvegur' },
    { href: '/atvinnuvegir/ferdathjonusta/', label: 'Ferðaþjónusta' },
    { href: '/atvinnuvegir/landbunadur/', label: 'Landbúnaður' },
    { href: '/atvinnuvegir/storidja/', label: 'Stóriðja & orka' },
    { href: '/orka/', label: 'Raforka' },
    { href: '/atvinnuvegir/hugverk/', label: 'Hugverk & tækni' },
    { href: '/audlindir/', label: 'Auðlindir' },
  ] },
  { label: 'Samfélag', emoji: '👥', icon: 'torfa', items: [
    { href: '/mannfjoldi/', label: 'Mannfjöldi' },
    { href: '/menntun/', label: 'Menntun' },
    { href: '/afbrot/', label: 'Afbrot og öryggi' },
    { href: '/rafbilar/', label: 'Rafbílar & floti' },
    { href: '/umferd/', label: 'Umferð' },
  ] },
];
const path = Astro.url.pathname;
const active = (it) => {
  if (!it.href) return false;
  const clean = it.href.split('?')[0];
  if (it.exact || clean === '/') return path === clean;
  return path.startsWith(clean);
};
const groupOpen = (grp) => (grp.items || []).some((it) => active(it));
---
<!doctype html>
<html lang="is">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="is_IS" />
    {(ogTitle || title) && <meta property="og:title" content={ogTitle || title} />}
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage || 'https://karp.is/og-karp.png'} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Karp — Hagvísir Íslands" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        { '@type': 'WebSite', name: 'Karp — Hagvísir Íslands', url: 'https://karp.is/', inLanguage: 'is', description: 'Opinber gögn um íslenskt efnahagslíf, Alþingi, sveitarfélög og markaði — á mannamáli.' },
        { '@type': 'Organization', name: 'Karp', url: 'https://karp.is/', logo: 'https://karp.is/og-karp.png', email: 'aron@sgdal.is', parentOrganization: { '@type': 'Organization', name: 'Steinsson Greykdal ehf.' } },
      ],
    })} />
    <ClientRouter />
    <style is:global>
      :root { color-scheme: dark; --bg:#070b16; --panel:rgba(255,255,255,.04); --line:rgba(255,255,255,.08); --ink:#eaf1fb; --muted:#9fb0c8; --faint:#7e8ca6; --gold:#f6b13b; }
      * { box-sizing: border-box; }
      body { margin:0; background:var(--bg); color:var(--ink); font:16px/1.6 system-ui,-apple-system,sans-serif; }
      .shell { display:grid; grid-template-columns:212px minmax(0,1fr) 300px; min-height:100vh; }

      /* NAV (vinstra) */
      .nav { border-right:1px solid var(--line); padding:20px 14px; display:flex; flex-direction:column; gap:3px; position:sticky; top:0; height:100vh; overflow-y:auto; scrollbar-width:thin; }
      .brand { font-weight:800; letter-spacing:.2em; color:var(--gold); text-decoration:none; font-size:16px; padding:2px 10px 18px; }
      .nav-a { display:flex; align-items:center; gap:11px; padding:9px 12px; border-radius:9px; text-decoration:none; color:var(--muted); font-weight:600; font-size:14px; }
      .nav-a:hover { background:var(--panel); color:var(--ink); }
      .nav-a.on { background:rgba(246,177,59,.12); color:var(--gold); }
      /* Accordion-hópar (eins og gamla): summary = hópahaus, ▸ snýst þegar opið */
      .ng { margin:0; }
      .ng-s { list-style:none; cursor:pointer; user-select:none; position:relative; }
      .ng-s::-webkit-details-marker { display:none; }
      .ng-c { margin-left:auto; font-size:10px; color:#5a6678; transition:transform .15s; }
      .ng[open] > .ng-s .ng-c { transform:rotate(90deg); }
      .ng-i { padding:1px 0 5px; }
      .nav-b { display:block; padding:6px 12px 6px 26px; border-radius:8px; text-decoration:none; color:#8fa0b8; color:#8b9cb5; font-size:13px; }
      .nav-b:hover { background:var(--panel); color:var(--ink); }
      .nav-b.on { background:rgba(246,177,59,.12); color:var(--gold); font-weight:600; }
      .ng-sub { font-size:10px; text-transform:uppercase; letter-spacing:.09em; color:#5a6678; font-weight:700; padding:10px 12px 3px 43px; }
      .nav-foot { margin-top:auto; padding-top:14px; border-top:1px solid var(--line); }
      .nav-legal { display:block; margin-top:8px; font-size:10.5px; color:#5a6678; text-decoration:none; }
      .nav-legal:hover { color:#9fb0c8; }

      /* EFNI (miðja) */
      .content { min-width:0; }
      .pg { max-width:860px; margin:0 auto; padding:34px 28px 64px; }

      /* View Transitions: aðeins efnið hreyfist — skelin (nav+fréttir) er föst. */
      ::view-transition-old(root), ::view-transition-new(root) { animation: none; }
      /* ATH: aðeins opacity — transform á main gerir position:fixed afkomendur
         (modalar!) fasta við main í stað gluggans (fill-mode heldur gildinu). */
      .content > main { animation: pageIn .22s ease both; }
      @keyframes pageIn { from { opacity: 0; } to { opacity: 1; } }
      @media (prefers-reduced-motion: reduce) { .content > main { animation: none; } }

      /* FRÉTTIR (hægra) */
      .news { border-left:1px solid var(--line); padding:20px 16px; position:sticky; top:0; height:100vh; overflow-y:auto; }
      .news-h { font-size:12px; text-transform:uppercase; letter-spacing:.08em; color:var(--faint); font-weight:700; margin-bottom:10px; }
      .news-item { display:block; padding:9px 0; border-bottom:1px solid var(--line); text-decoration:none; }
      .news-item:hover .news-t { color:var(--gold); }
      .news-t { display:block; font-size:13px; color:var(--ink); line-height:1.35; }
      .news-s { display:block; font-size:11px; color:var(--faint); margin-top:3px; }
      .news-empty { font-size:13px; color:var(--faint); }
      .news-cats { display:flex; gap:4px; margin-bottom:8px; flex-wrap:wrap; }
      .nc { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:var(--muted); border-radius:7px; padding:3px 8px; font-size:12px; cursor:pointer; }
      .nc:hover { color:var(--gold); border-color:var(--gold); }
      .nc.on { background:rgba(246,177,59,.14); border-color:var(--gold); color:var(--gold); }

      /* CHIP (auth) — stílar sprautast úr auth.js */
      .chip { display:flex; align-items:center; gap:8px; font-size:13px; flex-wrap:wrap; }

      @media (max-width:1000px){ .shell{grid-template-columns:180px minmax(0,1fr);} .news{display:none;} }
      @media (max-width:640px){
        .shell{grid-template-columns:1fr;}
        .nav{position:static;height:auto;flex-direction:column;border-right:0;border-bottom:1px solid var(--line);padding:12px;gap:2px;}
        .nav-a{padding:7px 10px;font-size:13px;}
        .brand{padding:2px 8px;}
        .nav-foot{margin:0 0 0 auto;padding:0;border:0;order:-1;}
        .pg{padding:22px 18px 48px;}
      }
    </style>
    <style is:global>
      /* ⓘ-tooltip (LOTA 13j): data-tip á hvaða element sem er — útskýrir tölu/uppruna */
      .tip { display: inline-flex; align-items: center; justify-content: center; width: 15px; height: 15px; border-radius: 50%; background: rgba(255,255,255,.1); color: #9fb0c8; font-size: 10px; font-style: normal; cursor: help; margin-left: 5px; vertical-align: middle; position: relative; }
      [data-tip] { position: relative; }
      [data-tip]:hover::after, [data-tip]:focus::after { content: attr(data-tip); position: absolute; bottom: calc(100% + 7px); left: 50%; transform: translateX(-50%); z-index: 90; width: max-content; max-width: 260px; background: rgba(9,14,26,.97); border: 1px solid rgba(255,255,255,.16); border-radius: 9px; padding: 8px 11px; font-size: 11.5px; font-weight: 400; line-height: 1.45; color: #dfe7f4; text-align: left; white-space: normal; box-shadow: 0 8px 24px rgba(0,0,0,.4); pointer-events: none; }
      [data-tip]:hover::before, [data-tip]:focus::before { content: ''; position: absolute; bottom: calc(100% + 2px); left: 50%; transform: translateX(-50%); border: 5px solid transparent; border-top-color: rgba(255,255,255,.16); z-index: 90; }
      main p.datainfo, p.datainfo { font-size: 12px; color: #7e8ca6; margin: 2px 0 0; }
      /* hidden-attributið á ALLTAF að fela — display-reglur á klösum mega ekki
         yfirskrifa það (t.d. .cos{display:grid} á Vöktun braut sýnileikastýringu). */
      [hidden] { display: none !important; }
      /* LOTA 23 (mobile-úttekt): breiðar töflur skruna innan síns ramma á síma
         í stað þess að sprengja síðuna (fannst á /althingi/ og /verdlag/). */
      @media (max-width: 760px) { main table { display: block; overflow-x: auto; } }
      /* 🐟 Fljótandi Spyrðu-Karp hnappurinn (LOTA 19; animation-safnið
         flutti HEIM í KarpFish.astro í LOTU 50 — hér aðeins staðsetning + hover-hraði) */
      #karp-fab { position: fixed; right: 18px; bottom: 18px; z-index: 60; display: flex; align-items: center; gap: 2px; background: none; border: 0; padding: 0; cursor: pointer; filter: drop-shadow(0 6px 18px rgba(0,0,0,.45)); }
      /* 💬 Spyrðu-Karp spjallglugginn (LOTA 94) — ofan fisksins í hægra horni, á öllum síðum */
      .kc { position: fixed; right: 18px; bottom: 96px; z-index: 61; width: 350px; max-width: calc(100vw - 24px); max-height: min(72vh, 560px); display: flex; flex-direction: column; background: linear-gradient(#141f37, #0e1626); border: 1px solid rgba(124,92,255,.35); border-radius: 16px; box-shadow: 0 18px 50px rgba(0,0,0,.55); overflow: hidden; }
      .kc[hidden] { display: none; }
      .kc-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,.08); }
      .kc-t { font-weight: 800; font-size: 14px; color: #eaf1fb; }
      .kc-x { background: none; border: 0; color: #9fb0c8; font-size: 15px; cursor: pointer; padding: 2px 6px; border-radius: 6px; }
      .kc-x:hover { color: #f6b13b; }
      .kc-body { flex: 1 1 auto; overflow-y: auto; padding: 12px 14px; display: flex; flex-direction: column; gap: 10px; min-height: 90px; }
      .kc-msg { font-size: 13.5px; line-height: 1.55; border-radius: 12px; padding: 9px 12px; max-width: 88%; white-space: pre-wrap; word-wrap: break-word; }
      .kc-msg.u { align-self: flex-end; background: #f6b13b; color: #131a29; font-weight: 600; }
      .kc-msg.a { align-self: flex-start; background: rgba(124,92,255,.12); border: 1px solid rgba(124,92,255,.28); color: #dfe7f4; }
      .kc-msg.a a { color: #f6b13b; }
      .kc-msg.err { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; align-self: flex-start; }
      .kc-hint { font-size: 12.5px; color: #9fb0c8; line-height: 1.5; padding: 2px; }
      .kc-hint a { color: #f6b13b; font-weight: 700; }
      .kc-chips { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 14px 10px; }
      .kc-ch { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: #9fb0c8; border-radius: 999px; padding: 5px 11px; font-size: 11.5px; cursor: pointer; }
      .kc-ch:hover { color: #f6b13b; border-color: rgba(246,177,59,.4); }
      .kc-ask { display: flex; gap: 7px; padding: 10px 12px 12px; border-top: 1px solid rgba(255,255,255,.08); }
      #kc-q { flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14); border-radius: 10px; padding: 9px 12px; color: #eaf1fb; font-size: 13.5px; }
      #kc-q:focus { outline: none; border-color: rgba(246,177,59,.55); }
      #kc-go { background: #f6b13b; color: #131a29; border: 0; border-radius: 10px; padding: 0 14px; font-weight: 800; font-size: 14px; cursor: pointer; }
      #kc-go:disabled { opacity: .55; cursor: wait; }
      @media (max-width: 760px) { .kc { right: 10px; bottom: 78px; width: calc(100vw - 20px); } }
      .kfab-bub { background: #f6b13b; color: #131a29; font-size: 12.5px; font-weight: 800; padding: 7px 12px; border-radius: 999px 999px 4px 999px; opacity: 0; transform: translateY(6px); transition: opacity .25s, transform .25s; pointer-events: none; white-space: nowrap; }
      #karp-fab:hover .kfab-bub, #karp-fab:focus-visible .kfab-bub { opacity: 1; transform: translateY(0); }
      #karp-fab:hover .karpfish { animation-duration: 1.6s; }
      #karp-fab:hover .kf-tail { animation-duration: .8s; }
      @media (max-width: 760px) { #karp-fab { right: 10px; bottom: 12px; } #karp-fab .karpfish { width: 52px; height: 52px; } }
      .datainfo .tip::after, .datainfo .tip::before { bottom: auto; top: calc(100% + 7px); }
      .datainfo .tip:hover::before, .datainfo .tip:focus::before { top: calc(100% + 2px); border-top-color: transparent; border-bottom-color: rgba(255,255,255,.16); }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="nav" transition:persist>
        <a class="brand" href="/"><span>KARP</span></a>
        <nav>
          {NAV.map((n) => n.items ? (
            <details class="ng" open={groupOpen(n)}>
              <summary class="nav-a ng-s">{n.label}<span class="ng-c">▸</span></summary>
              <div class="ng-i">
                {n.items.map((it) => it.sub
                  ? <div class="ng-sub">{it.sub}</div>
                  : <a class={`nav-b${active(it) ? ' on' : ''}`} href={it.href}>{it.label}</a>
                )}
              </div>
            </details>
          ) : (
            <a class={`nav-a${active(n) ? ' on' : ''}`} href={n.href}>{n.label}</a>
          ))}
        </nav>
        <div class="nav-foot"><div id="chip" class="chip"></div><a class="nav-legal" href="/um-karp/">Um Karp</a><a class="nav-legal" href="/skilmalar/">Skilmálar</a></div>
      </aside>

      <div class="content"><slot /></div>

      <section id="karp-chat" class="kc" hidden transition:persist>
        <div class="kc-head"><span class="kc-t">🐟 Spyrðu Karp</span><button type="button" class="kc-x" id="kc-x" aria-label="Loka spjalli">✕</button></div>
        <div class="kc-body" id="kc-body"></div>
        <div class="kc-chips" id="kc-chips">
          <button class="kc-ch" data-q="Hverjir eru stýrivextirnir núna?">Stýrivextirnir?</button>
          <button class="kc-ch" data-q="Hvert er fylgi flokkanna í nýjustu könnun?">Fylgi flokkanna?</button>
          <button class="kc-ch" data-q="Hvaða fyrirtæki fær mest greitt frá ríkinu?">Stærsti birgir ríkisins?</button>
          <button class="kc-ch" data-q="Hvað kostar fermetrinn í leigu?">Leiguverð?</button>
        </div>
        <form class="kc-ask" id="kc-ask" autocomplete="off">
          <input id="kc-q" type="text" maxlength="300" placeholder="Spurðu karpann…" aria-label="Spurning" />
          <button type="submit" id="kc-go" aria-label="Senda">➤</button>
        </form>
      </section>
      <button type="button" id="karp-fab" class="kf-anim" aria-label="Spyrðu Karp — opna spjall" aria-expanded="false" transition:persist>
        <span class="kfab-bub">Spyrðu Karp!</span>
        <KarpFish size={68} />
      </button>

      <aside class="news" transition:persist>
        <div class="news-h">📰 Fréttir</div>
        <div class="news-cats" id="news-cats">
          <button class="nc on" data-e="">Allt</button>
          <button class="nc" data-e="__karp" title="Karp-fréttir — skrifaðar sjálfvirkt úr gögnunum">🐟</button>
          <button class="nc" data-e="efnahagur">💹</button>
          <button class="nc" data-e="stjornmal">🏛️</button>
          <button class="nc" data-e="sveitarfelog">🏘️</button>
          <button class="nc" data-e="althjoda">🌍</button>
          <button class="nc" data-e="samfelag">👥</button>
          <button class="nc" data-e="__erlent" title="Ísland í erlendum miðlum">🗺️</button>
        </div>
        <div id="news-list">Hleð…</div>
      </aside>
    </div>

    <script>
      // Keyrir á astro:page-load → bæði við fyrstu hleðslu OG eftir hverja View-Transition
      // navígasjón (því module-skriftir keyra annars aðeins einu sinni). Fréttir cache-ast í
      // module-breytu → engin endur-sókn milli síðna, aðeins endur-teikning.
      import { mountChip, loadUser, loginHref } from '../lib/auth.js';
      const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      // Öryggi: aðeins http(s)-slóðir úr ytri veitum (javascript:/data: URI blokkað).
      const safeHref = (u) => (/^https?:\/\//i.test(String(u || '')) ? String(u) : '#');
      // Fréttir cache-ast PER FLOKK (LOTA 14: flokka-pillur á stikunni eins og gamla).
      const newsCache = {};
      let newsEfni = '';
      try { newsEfni = localStorage.getItem('karp-rail-efni') || ''; } catch (e) {}

      // Innri slóðir (Karp-fréttir) opnast í sama glugga; ytri veitur í nýjum.
      const railHref = (u) => (/^\/[a-z0-9\-_/#?=.%]*$/i.test(String(u || '')) ? String(u) : safeHref(u));
      const renderNews = (arr) =>
        arr.length
          ? arr.slice(0, 14).map((it) => { const h = railHref(it.link); const ext = /^https?:/i.test(h); return `<a class="news-item" href="${esc(h)}"${ext ? ' target="_blank" rel="noopener"' : ''}><span class="news-t">${esc(it.title)}</span><span class="news-s">${esc(it.source || '')}</span></a>`; }).join('')
          : '<div class="news-empty">Engar fréttir í flokknum í augnablikinu.</div>';

      function paintNews() {
        const nl = document.getElementById('news-list');
        if (!nl) return;
        document.querySelectorAll('#news-cats .nc').forEach((b) => b.classList.toggle('on', (b.dataset.e || '') === newsEfni));
        if (newsCache[newsEfni]) { nl.innerHTML = renderNews(newsCache[newsEfni]); return; }
        if (newsEfni === '__karp') {
          // 🐟 Karp-fréttir — skrifaðar sjálfvirkt úr gögnunum (LOTA 29)
          fetch('/gogn/frettavel.json')
            .then((r) => (r.ok ? r.json() : null))
            .then((d) => {
              const dIS = (x) => { const m = String(x || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? `${+m[3]}.${+m[2]}.${m[1]}` : ''; };
              const items = ((d && d.items) || []).slice(0, 13).map((it) => ({ title: it.title, link: '/frettavel/#' + it.id, source: '🐟 Karp · ' + dIS(it.date) }));
              items.push({ title: '🗞️ Allar Karp-fréttirnar — og hvernig þær verða til', link: '/frettavel/', source: 'Fréttavél Karp' });
              newsCache[newsEfni] = items;
              nl.innerHTML = renderNews(items);
            })
            .catch(() => { nl.innerHTML = '<div class="news-empty">Karp-fréttirnar svara ekki í augnablikinu.</div>'; });
          return;
        }
        if (newsEfni === '__erlent') {
          // 🌍 Ísland í erlendum miðlum — RSS um worker-proxy (LOTA 21)
          fetch('/api/erlent')
            .then((r) => (r.ok ? r.text() : ''))
            .then((xml) => {
              let items = [];
              if (xml && xml[0] !== '{') {
                const doc = new DOMParser().parseFromString(xml, 'text/xml');
                items = [...doc.querySelectorAll('item')].slice(0, 14).map((it) => ({
                  title: (it.querySelector('title') || {}).textContent || '',
                  link: (it.querySelector('link') || {}).textContent || '',
                  source: (it.querySelector('source') || {}).textContent || (((it.querySelector('link') || {}).textContent || '').split('//')[1] || '').split('/')[0].replace('www.', ''),
                })).filter((x) => x.title);
              }
              newsCache[newsEfni] = items;
              nl.innerHTML = renderNews(items);
            })
            .catch(() => { nl.innerHTML = '<div class="news-empty">Erlendi straumurinn svarar ekki í augnablikinu.</div>'; });
          return;
        }
        fetch('https://wp.karp.is/wp-json/karp/v1/frettir' + (newsEfni ? '?efni=' + encodeURIComponent(newsEfni) : ''))
          .then((r) => (r.ok ? r.json() : []))
          // Endapunkturinn skilar {efni, cached, items:[...]} — EKKI beinu fylki.
          .then((d) => { newsCache[newsEfni] = Array.isArray(d) ? d : (d && d.items) || []; nl.innerHTML = renderNews(newsCache[newsEfni]); })
          .catch(() => { nl.innerHTML = '<div class="news-empty">Fréttir ekki tiltækar hér (birtast á karp.is).</div>'; });
      }

      // LOTA 21: stikan fylgir samhenginu — síður og Vöktunar-val stýra flokknum
      // (eins og gamla kerfið). Pillusmellur = handval sem heldur þar til næsta síða
      // með skýrt samhengi opnast. window.karpSetRailEfni er kallað úr Vöktun.
      window.karpSetRailEfni = (e, persist) => {
        newsEfni = e || '';
        if (persist) { try { localStorage.setItem('karp-rail-efni', newsEfni); } catch (er) {} }
        const nl = document.getElementById('news-list');
        if (nl && !newsCache[newsEfni]) nl.innerHTML = 'Hleð…';
        paintNews();
      };
      const PATH_EFNI = [
        [/^\/frettavel/, '__karp'],
        [/^\/(althingi|thingmal|rikisstjorn|stefnuprof|kannanir|karp-kannanir|kosningar)/, 'stjornmal'],
        [/^\/(sveitarfelog|kort|jofnunarsjodur)/, 'sveitarfelog'],
        [/^\/(verdlag|lyf|vextir|vinnumarkadur|markadir|fasteignir|fasteignavakt|eftirlit|okutaeki|skip|rikisfjarmal|skattar|utgjold|birgjar|hagvoxtur|hagspar|vidskipti|langtima|reiknivelar|hermir|furduhagfraedi|fyrirtaeki)/, 'efnahagur'],
        [/^\/(utanrikis|nato|sendirad|ees|samanburdur)/, 'althjoda'],
        [/^\/(afbrot|menntun|mannfjoldi|umferd|orka|audlindir|rafbilar|samtok|topplistar|atvinnuvegir)/, 'samfelag'],
      ];
      function railFollowPath() {
        const hit = PATH_EFNI.find(([rx]) => rx.test(location.pathname));
        if (hit && newsEfni !== hit[1]) window.karpSetRailEfni(hit[1], false);
      }

      function mountNewsCats() {
        const row = document.getElementById('news-cats');
        if (!row || row.dataset.mounted) return;
        row.dataset.mounted = '1';
        row.querySelectorAll('.nc').forEach((b) => {
          b.addEventListener('click', () => window.karpSetRailEfni(b.dataset.e || '', true));
        });
      }

      // Fasta nav-ið (transition:persist) heldur virku stöðunni frá FYRSTU síðu → uppfæra með JS.
      // Stakir hlekkir = .nav-a[href]; undirhlekkir = .nav-b; virki hópurinn opnast sjálfkrafa.
      function updateActiveNav() {
        const p = location.pathname;
        const isOn = (a, exactRoots) => {
          const href = (a.getAttribute('href') || '').split('?')[0];
          if (!href) return false;
          if (href === '/' || exactRoots.includes(href)) return p === href;
          return p.startsWith(href);
        };
        const EXACT = ['/althingi/', '/sveitarfelog/', '/atvinnuvegir/', '/reiknivelar/'];
        document.querySelectorAll('a.nav-a').forEach((a) => a.classList.toggle('on', isOn(a, EXACT)));
        let activeGrp = null;
        document.querySelectorAll('a.nav-b').forEach((a) => {
          const on = isOn(a, EXACT);
          a.classList.toggle('on', on);
          if (on) activeGrp = a.closest('details.ng');
        });
        if (activeGrp && !activeGrp.open) activeGrp.open = true;
      }

      // Sjálfslækning grafa (LOTA 12): ECharts sem init-ast á 0-breidd element (VT-tímasetning,
      // falinn flipi, þröngt view) verður ósýnilegt að eilífu — resize() lagar. Keyrt eftir hverja síðu.
      function fixZeroCharts() {
        if (!window.echarts) return;
        document.querySelectorAll('[_echarts_instance_]').forEach((el) => {
          const c = window.echarts.getInstanceByDom(el);
          if (c && el.clientWidth > 0 && c.getWidth() === 0) c.resize();
        });
      }

      function mountShell() {
        // Chip + fréttir eru í föstu skelinni → festa aðeins einu sinni (dataset lifir persist).
        const chipEl = document.getElementById('chip');
        if (chipEl && !chipEl.dataset.mounted) { chipEl.dataset.mounted = '1'; mountChip(chipEl); }
        updateActiveNav();
        mountNewsCats();
        railFollowPath();
        paintNews();
        setTimeout(fixZeroCharts, 400);
        setTimeout(fixZeroCharts, 1500);
      }

      document.addEventListener('astro:page-load', mountShell);

      // 💬 Spyrðu-Karp spjallglugginn (LOTA 94) — fljótandi, á öllum síðum; fab+chat eru persist → init EINU SINNI.
      function mountChat() {
        const fab = document.getElementById('karp-fab'), chat = document.getElementById('karp-chat');
        if (!fab || !chat || fab.dataset.chat) return;
        fab.dataset.chat = '1';
        const body = document.getElementById('kc-body'), q = document.getElementById('kc-q'), go = document.getElementById('kc-go'), form = document.getElementById('kc-ask'), chips = document.getElementById('kc-chips');
        const MSG = { unconfigured: 'Aðstoðarmaðurinn er í gangsetningu — kíktu aftur fljótlega.', kvoti: 'Dagskvótinn þinn er búinn (20 spurningar) — reyndu aftur á morgun.', lengd: 'Spurningin þarf að vera 3–300 stafir.', ai: 'Svarvélin svaraði ekki — reyndu aftur eftir smástund.' };
        let HIST = [], gated = null, greeted = false;
        const add = (cls, html) => { const d = document.createElement('div'); d.className = 'kc-msg ' + cls; d.innerHTML = html; body.appendChild(d); body.scrollTop = body.scrollHeight; return d; };
        const linkify = (s) => esc(s).replace(/(^|[\s(])(\/[a-z0-9-]+\/)/g, '$1<a href="$2">$2</a>');
        const showGate = () => { form.style.display = 'none'; chips.style.display = 'none'; if (!body.querySelector('.kc-hint')) { const h = document.createElement('div'); h.className = 'kc-hint'; h.innerHTML = '⭐ Spyrðu Karp er hluti af <a href="/karp-pro/">Karp+</a> — ókeypis aðgangur sem tekur mínútu. <a href="' + loginHref() + '">Skráðu þig inn</a> og karpinn svarar.'; body.appendChild(h); } };
        const openChat = () => {
          chat.hidden = false; fab.setAttribute('aria-expanded', 'true');
          if (!greeted) { greeted = true; add('a', 'Hæ! 🐟 Ég er Karpinn. Spurðu mig um hagkerfið, þingið, sveitarfélögin eða gögnin á Karp — ég svara út frá tölum vefjarins.'); }
          if (gated === null) loadUser().then((u) => { gated = !(u && u.loggedIn); if (gated) showGate(); }).catch(() => {});
          else if (gated) showGate();
          if (gated === false) setTimeout(() => q && q.focus(), 60);
        };
        const closeChat = () => { chat.hidden = true; fab.setAttribute('aria-expanded', 'false'); };
        const ask = async (text) => {
          text = (text || '').trim(); if (text.length < 3 || go.disabled) return;
          if (chips) chips.style.display = 'none';
          add('u', esc(text)); q.value = ''; go.disabled = true;
          const t = add('a', 'Hugsa…');
          try {
            const r = await fetch('/api/spyrdu', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ q: text.slice(0, 300), hist: HIST.length ? HIST : undefined }) });
            const d = await r.json();
            if (d && d.svar) { t.innerHTML = linkify(d.svar); HIST.push({ q: text.slice(0, 300), a: d.svar.slice(0, 1200) }); HIST = HIST.slice(-3); }
            else { t.className = 'kc-msg err'; t.textContent = MSG[(d || {}).error] || MSG.ai; }
          } catch (e) { t.className = 'kc-msg err'; t.textContent = MSG.ai; }
          go.disabled = false; q.focus();
        };
        fab.addEventListener('click', () => chat.hidden ? openChat() : closeChat());
        document.getElementById('kc-x').addEventListener('click', closeChat);
        form.addEventListener('submit', (e) => { e.preventDefault(); ask(q.value); });
        chips.querySelectorAll('.kc-ch').forEach((c) => c.addEventListener('click', () => ask(c.dataset.q)));
      }
      document.addEventListener('astro:page-load', mountChat);

      // 🩺 Villu-beacon (LOTA 23): sendir client-villur á /api/villa (worker → CF-logs).
      // Hver einstök villuskilaboð aðeins einu sinni per heimsókn; sendBeacon truflar ekkert.
      const villaSent = new Set();
      const beacon = (m) => {
        const key = String(m).slice(0, 120);
        if (villaSent.has(key) || villaSent.size > 8) return;
        villaSent.add(key);
        try { navigator.sendBeacon('/api/villa', JSON.stringify({ m: String(m).slice(0, 300), u: location.pathname })); } catch (e) {}
      };
      window.addEventListener('error', (e) => beacon(e.message || 'error'));
      window.addEventListener('unhandledrejection', (e) => beacon((e.reason && (e.reason.message || e.reason)) || 'rejection'));
    </script>
  </body>
</html>
